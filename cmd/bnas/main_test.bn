package "main"

import "pkg/buf"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func TestDefaultOutputS() testing.TestResult {
	var input @[]char = buf.CopyStr("test.s")
	var result @[]char = defaultOutput(input)
	var raw []char = result
	if !charsEqual(raw, "test.o") {
		return fail("expected test.o")
	}
	return ""
}

func TestDefaultOutputNoExt() testing.TestResult {
	var input @[]char = buf.CopyStr("test.asm")
	var result @[]char = defaultOutput(input)
	var raw []char = result
	if !charsEqual(raw, "test.asm.o") {
		return fail("expected test.asm.o")
	}
	return ""
}

func TestDefaultOutputPath() testing.TestResult {
	var input @[]char = buf.CopyStr("/tmp/foo.s")
	var result @[]char = defaultOutput(input)
	var raw []char = result
	if !charsEqual(raw, "/tmp/foo.o") {
		return fail("expected /tmp/foo.o")
	}
	return ""
}
