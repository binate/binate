func TestParseArgsRoot() testing.TestResult {
	var args @[][]char = make_slice([]char, 3)
	args[0] = "--root"
	args[1] = "/my/root"
	args[2] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if !seq(cli.RootFlag, "/my/root") { return fail("wrong root") }
	return ""
}

func TestParseArgsRuntime() testing.TestResult {
	var args @[][]char = make_slice([]char, 3)
	args[0] = "--runtime"
	args[1] = "/path/to/rt.c"
	args[2] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if !seq(cli.RuntimePath, "/path/to/rt.c") { return fail("wrong runtime") }
	return ""
}

func TestParseArgsPkg() testing.TestResult {
	var args @[][]char = make_slice([]char, 4)
	args[0] = "--pkg"
	args[1] = "pkg/foo"
	args[2] = "--root"
	args[3] = "/proj"
	var cli CLIArgs = parseArgs(args)
	if !seq(cli.PkgFlag, "pkg/foo") { return fail("wrong pkg") }
	if !seq(cli.RootFlag, "/proj") { return fail("wrong root") }
	return ""
}

func TestParseArgsMultipleFiles() testing.TestResult {
	var args @[][]char = make_slice([]char, 3)
	args[0] = "a.bn"
	args[1] = "b.bn"
	args[2] = "c.bn"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 3 { return fail("expected 3 filenames") }
	return ""
}

func TestParseArgsEmpty() testing.TestResult {
	var args [][]char
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 0 { return fail("expected 0 filenames") }
	if cli.Debug { return fail("debug should be false") }
	if cli.EmitLLVM { return fail("emit-llvm should be false") }
	return ""
}
