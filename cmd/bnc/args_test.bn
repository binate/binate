package "main"

import "pkg/builtin/testing"

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func fail(msg []char) testing.TestResult {
	return msg
}

// ============================================================
// parseArgs tests
// ============================================================

func TestParseArgsSimple() testing.TestResult {
	var args [][]char
	args = append(args, "foo.bn")
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 1 { return fail("expected 1 filename") }
	if !seq(cli.Filenames[0], "foo.bn") { return fail("wrong filename") }
	return ""
}

func TestParseArgsOutput() testing.TestResult {
	var args [][]char
	args = append(args, "-o")
	args = append(args, "mybin")
	args = append(args, "foo.bn")
	var cli CLIArgs = parseArgs(args)
	if !seq(cli.Output, "mybin") { return fail("wrong output") }
	if len(cli.Filenames) != 1 { return fail("expected 1 filename") }
	return ""
}

func TestParseArgsEmitLLVM() testing.TestResult {
	var args [][]char
	args = append(args, "--emit-llvm")
	args = append(args, "foo.bn")
	var cli CLIArgs = parseArgs(args)
	if !cli.EmitLLVM { return fail("expected emit-llvm") }
	return ""
}

func TestParseArgsCompileOnly() testing.TestResult {
	var args [][]char
	args = append(args, "-c")
	args = append(args, "foo.bn")
	var cli CLIArgs = parseArgs(args)
	if !cli.CompileOnly { return fail("expected compile-only") }
	return ""
}

