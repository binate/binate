package "main"

import "pkg/builtin/testing"

// Tests for compile.bn pure functions.

func TestResolveRootWithFlag() testing.TestResult {
	var r []char = resolveRoot("/my/root", "src/main.bn")
	if !seq(r, "/my/root") { return fail("should use root flag") }
	return ""
}

func TestResolveRootFromFile() testing.TestResult {
	var r []char = resolveRoot(nil, "/proj/src/main.bn")
	if !seq(r, "/proj/src") { return fail("should derive from file") }
	return ""
}

func TestResolveRootBareFile() testing.TestResult {
	var r []char = resolveRoot(nil, "main.bn")
	if !seq(r, ".") { return fail("should default to dot") }
	return ""
}
