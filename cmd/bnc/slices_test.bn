package "main"

import "pkg/ast"
import "pkg/buf"
import "pkg/builtin/testing"

func TestAppendCharSlice() testing.TestResult {
	var s @[]@[]char
	s = appendCharSlice(s, buf.CopyStr("one"))
	s = appendCharSlice(s, buf.CopyStr("two"))
	if len(s) != 2 { return fail("expected len 2") }
	return ""
}

func TestAppendRawCharSlice() testing.TestResult {
	var s @[]@[]char
	s = appendRawCharSlice(s, "hello")
	s = appendRawCharSlice(s, "world")
	if len(s) != 2 { return fail("expected len 2") }
	return ""
}

func TestAppendFilePtr() testing.TestResult {
	var s @[]@ast.File
	var f @ast.File = make(ast.File)
	s = appendFilePtr(s, f)
	if len(s) != 1 { return fail("expected len 1") }
	return ""
}

func TestAppendImportSpecPtr() testing.TestResult {
	var s @[]@ast.ImportSpec
	var imp @ast.ImportSpec = make(ast.ImportSpec)
	s = appendImportSpecPtr(s, imp)
	s = appendImportSpecPtr(s, imp)
	if len(s) != 2 { return fail("expected len 2") }
	return ""
}
