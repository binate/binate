package "main"

import "pkg/builtin/testing"
import "pkg/ast"
import "pkg/buf"

// ============================================================
// lastSegment tests
// ============================================================

func TestLastSegmentSimple() testing.TestResult {
	var s []char = lastSegment("main")
	if !seq(s, "main") { return fail("expected main") }
	return ""
}

func TestLastSegmentOneSlash() testing.TestResult {
	var s []char = lastSegment("pkg/parser")
	if !seq(s, "parser") { return fail("expected parser") }
	return ""
}

func TestLastSegmentDeep() testing.TestResult {
	var s []char = lastSegment("pkg/asm/aarch64")
	if !seq(s, "aarch64") { return fail("expected aarch64") }
	return ""
}

// ============================================================
// hasPrefix tests
// ============================================================

func TestHasPrefixTrue() testing.TestResult {
	if !hasPrefix("TestFoo", "Test") {
		return fail("TestFoo should have prefix Test")
	}
	return ""
}

func TestHasPrefixFalse() testing.TestResult {
	if hasPrefix("foo", "Test") {
		return fail("foo should not have prefix Test")
	}
	return ""
}

func TestHasPrefixExact() testing.TestResult {
	if !hasPrefix("Test", "Test") {
		return fail("exact match should be prefix")
	}
	return ""
}

func TestHasPrefixTooShort() testing.TestResult {
	if hasPrefix("Te", "Test") {
		return fail("shorter string should not match")
	}
	return ""
}

// ============================================================
// isTestPkg tests
// ============================================================

func TestIsTestPkgFound() testing.TestResult {
	var pkgs @[]@[]char = make_slice(@[]char, 2)
	pkgs[0] = "pkg/ir"
	pkgs[1] = "pkg/types"
	if !isTestPkg("pkg/ir", pkgs) {
		return fail("pkg/ir should be found")
	}
	return ""
}

func TestIsTestPkgNotFound() testing.TestResult {
	var pkgs @[]@[]char = make_slice(@[]char, 1)
	pkgs[0] = "pkg/ir"
	if isTestPkg("pkg/types", pkgs) {
		return fail("pkg/types should not be found")
	}
	return ""
}

func TestIsTestPkgEmpty() testing.TestResult {
	var pkgs @[]@[]char
	if isTestPkg("pkg/ir", pkgs) {
		return fail("empty list should not match")
	}
	return ""
}

// ============================================================
// appendTestFunc tests
// ============================================================

func TestAppendTestFuncToNil() testing.TestResult {
	var list @[]TestFunc
	var tf TestFunc
	tf.PkgPath = "pkg/ir"
	tf.FuncName = "TestFoo"
	list = appendTestFunc(list, tf)
	if len(list) != 1 { return fail("expected len 1") }
	if !seq(list[0].FuncName, "TestFoo") {
		return fail("wrong func name")
	}
	return ""
}

func TestAppendTestFuncMultiple() testing.TestResult {
	var list @[]TestFunc
	var tf1 TestFunc
	tf1.PkgPath = "pkg/ir"
	tf1.FuncName = "TestA"
	list = appendTestFunc(list, tf1)
	var tf2 TestFunc
	tf2.PkgPath = "pkg/ir"
	tf2.FuncName = "TestB"
	list = appendTestFunc(list, tf2)
	if len(list) != 2 { return fail("expected len 2") }
	if !seq(list[1].FuncName, "TestB") {
		return fail("wrong second func name")
	}
	return ""
}

// ============================================================
// toBytes tests
// ============================================================

func TestToBytesEmpty() testing.TestResult {
	var b @[]uint8 = toBytes("")
	if len(b) != 0 { return fail("expected empty") }
	return ""
}

func TestToBytesContent() testing.TestResult {
	var b @[]uint8 = toBytes("AB")
	if len(b) != 2 { return fail("expected len 2") }
	if b[0] != 65 { return fail("expected 65 for A") }
	if b[1] != 66 { return fail("expected 66 for B") }
	return ""
}

// ============================================================
// genTestRunner tests
// ============================================================

func TestGenTestRunnerEmpty() testing.TestResult {
	var pkgs @[]@[]char = make_slice(@[]char, 1)
	pkgs[0] = "pkg/ir"
	var tests @[]TestFunc
	var src []char = genTestRunner(pkgs, tests)
	// Should contain package declaration and import
	if !hasPrefix(src, "package \"main\"") {
		return fail("should start with package main")
	}
	return ""
}

func TestGenTestRunnerWithTest() testing.TestResult {
	var pkgs @[]@[]char = make_slice(@[]char, 1)
	pkgs[0] = "pkg/ir"
	var tests @[]TestFunc
	var tf TestFunc
	tf.PkgPath = "pkg/ir"
	tf.FuncName = "TestFoo"
	tests = appendTestFunc(tests, tf)
	var src []char = genTestRunner(pkgs, tests)
	// Should contain the test function call
	if !containsStr(src, "ir.TestFoo()") {
		return fail("should contain ir.TestFoo()")
	}
	return ""
}

func TestGenTestRunnerSummary() testing.TestResult {
	var pkgs @[]@[]char = make_slice(@[]char, 1)
	pkgs[0] = "pkg/ir"
	var tests @[]TestFunc
	var src []char = genTestRunner(pkgs, tests)
	// Should contain pass/fail summary
	if !containsStr(src, "passed") {
		return fail("should contain passed in summary")
	}
	return ""
}

// ============================================================
// isTestResultReturn tests
// ============================================================

func TestIsTestResultReturnValid() testing.TestResult {
	// Build a Decl with Results = [testing.TestResult]
	var d @ast.Decl = make(ast.Decl)
	d.Kind = ast.DECL_FUNC
	d.Name = "TestFoo"
	var r @ast.TypeExpr = make(ast.TypeExpr)
	r.Kind = ast.TEXPR_NAMED
	r.Pkg = "testing"
	r.Name = "TestResult"
	d.Results = make_slice(@ast.TypeExpr, 1)
	d.Results[0] = r
	if !isTestResultReturn(d) {
		return fail("testing.TestResult should be valid")
	}
	return ""
}

func TestIsTestResultReturnManagedCharSlice() testing.TestResult {
	// Build a Decl with Results = [@[]char]
	var d @ast.Decl = make(ast.Decl)
	d.Kind = ast.DECL_FUNC
	d.Name = "TestBar"
	var base @ast.TypeExpr = make(ast.TypeExpr)
	base.Kind = ast.TEXPR_NAMED
	base.Name = "char"
	var r @ast.TypeExpr = make(ast.TypeExpr)
	r.Kind = ast.TEXPR_MANAGED_SLICE
	r.Base = base
	d.Results = make_slice(@ast.TypeExpr, 1)
	d.Results[0] = r
	if !isTestResultReturn(d) {
		return fail("@[]char should be valid test result")
	}
	return ""
}

func TestIsTestResultReturnNoResults() testing.TestResult {
	var d @ast.Decl = make(ast.Decl)
	d.Kind = ast.DECL_FUNC
	d.Name = "TestBaz"
	if isTestResultReturn(d) {
		return fail("no results should not be valid")
	}
	return ""
}

func TestIsTestResultReturnWrongType() testing.TestResult {
	var d @ast.Decl = make(ast.Decl)
	d.Kind = ast.DECL_FUNC
	d.Name = "TestQux"
	var r @ast.TypeExpr = make(ast.TypeExpr)
	r.Kind = ast.TEXPR_NAMED
	r.Name = "int"
	d.Results = make_slice(@ast.TypeExpr, 1)
	d.Results[0] = r
	if isTestResultReturn(d) {
		return fail("int return should not be valid")
	}
	return ""
}

// ============================================================
// Helpers
// ============================================================

func containsStr(hay []char, needle []char) bool {
	if len(needle) == 0 { return true }
	if len(hay) < len(needle) { return false }
	for i := 0; i <= len(hay) - len(needle); i++ {
		var match bool = true
		for j := 0; j < len(needle); j++ {
			if hay[i + j] != needle[j] {
				match = false
				break
			}
		}
		if match { return true }
	}
	return false
}
