package "main"

import "pkg/builtin/testing"

// ============================================================
// Test helpers
// ============================================================

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func fail(msg @[]char) testing.TestResult {
	return msg
}

// ============================================================
// streq tests
// ============================================================

func TestStreqEqual() testing.TestResult {
	if !streq("hello", "hello") { return fail("same strings should be equal") }
	return ""
}

func TestStreqDifferent() testing.TestResult {
	if streq("hello", "world") { return fail("different strings should not be equal") }
	return ""
}

func TestStreqDifferentLength() testing.TestResult {
	if streq("abc", "ab") { return fail("different lengths should not be equal") }
	return ""
}

func TestStreqEmpty() testing.TestResult {
	if !streq("", "") { return fail("empty strings should be equal") }
	return ""
}

// ============================================================
// hasSuffix tests
// ============================================================

func TestHasSuffixTrue() testing.TestResult {
	if !hasSuffix("hello.bn", ".bn") { return fail("should have suffix .bn") }
	return ""
}

func TestHasSuffixFalse() testing.TestResult {
	if hasSuffix("hello.go", ".bn") { return fail("should not have suffix .bn") }
	return ""
}

func TestHasSuffixTestBn() testing.TestResult {
	if !hasSuffix("foo_test.bn", "_test.bn") { return fail("should have suffix _test.bn") }
	return ""
}

func TestHasSuffixTooShort() testing.TestResult {
	if hasSuffix(".b", ".bn") { return fail("shorter than suffix should return false") }
	return ""
}

func TestHasSuffixExact() testing.TestResult {
	if !hasSuffix(".bn", ".bn") { return fail("exact match should return true") }
	return ""
}

// ============================================================
// dirOf tests
// ============================================================

func TestDirOfSimple() testing.TestResult {
	var d []char = dirOf("/foo/bar/baz.bn")
	if !seq(d, "/foo/bar") { return fail("expected /foo/bar") }
	return ""
}

func TestDirOfNoSlash() testing.TestResult {
	var d []char = dirOf("baz.bn")
	if d != nil { return fail("expected nil for no directory") }
	return ""
}

func TestDirOfTrailingSlash() testing.TestResult {
	var d []char = dirOf("/foo/bar/")
	if !seq(d, "/foo/bar") { return fail("expected /foo/bar") }
	return ""
}

func TestDirOfRoot() testing.TestResult {
	var d []char = dirOf("/foo")
	if !seq(d, "") { return fail("expected empty string") }
	return ""
}

// ============================================================
// stripExt tests
// ============================================================

func TestStripExtSimple() testing.TestResult {
	var r []char = stripExt("hello.bn")
	if !seq(r, "hello") { return fail("expected hello") }
	return ""
}

func TestStripExtWithPath() testing.TestResult {
	var r []char = stripExt("/foo/bar/hello.bn")
	if !seq(r, "/foo/bar/hello") { return fail("expected /foo/bar/hello") }
	return ""
}

func TestStripExtNoExt() testing.TestResult {
	var r []char = stripExt("hello")
	if !seq(r, "hello") { return fail("expected hello unchanged") }
	return ""
}

func TestStripExtMultipleDots() testing.TestResult {
	var r []char = stripExt("archive.tar.gz")
	// stripExt finds the last dot after the last slash
	if !seq(r, "archive.tar") { return fail("expected archive.tar") }
	return ""
}

// ============================================================
// shortName tests
// ============================================================

func TestShortNameSimple() testing.TestResult {
	var r []char = shortName("/foo/bar/baz.bn")
	if !seq(r, "baz.bn") { return fail("expected baz.bn") }
	return ""
}

func TestShortNameNoSlash() testing.TestResult {
	var r []char = shortName("baz.bn")
	if !seq(r, "baz.bn") { return fail("expected baz.bn unchanged") }
	return ""
}

// ============================================================
// quotePath tests
// ============================================================

func TestQuotePathSimple() testing.TestResult {
	var r []char = quotePath("pkg/foo")
	if !seq(r, "\"pkg/foo\"") { return fail("expected quoted path") }
	return ""
}

func TestQuotePathEmpty() testing.TestResult {
	var r []char = quotePath("")
	if !seq(r, "\"\"") { return fail("expected empty quotes") }
	return ""
}

// ============================================================
// unquote tests
// ============================================================

func TestUnquoteQuoted() testing.TestResult {
	var r []char = unquote("\"hello\"")
	if !seq(r, "hello") { return fail("expected hello") }
	return ""
}

func TestUnquoteUnquoted() testing.TestResult {
	var r []char = unquote("hello")
	if !seq(r, "hello") { return fail("expected hello unchanged") }
	return ""
}

func TestUnquoteEmpty() testing.TestResult {
	var r []char = unquote("\"\"")
	if !seq(r, "") { return fail("expected empty string") }
	return ""
}

func TestUnquoteSingleChar() testing.TestResult {
	var r []char = unquote("x")
	if !seq(r, "x") { return fail("expected x unchanged") }
	return ""
}

// ============================================================
// discoverBinateRoot tests
// ============================================================

func TestDiscoverBinateRootNil() testing.TestResult {
	var r []char = discoverBinateRoot(nil)
	if r != nil { return fail("expected nil") }
	return ""
}

func TestDiscoverBinateRootValid() testing.TestResult {
	var r []char = discoverBinateRoot("/home/user/binate/runtime/binate_runtime.c")
	if !seq(r, "/home/user/binate") { return fail("expected /home/user/binate") }
	return ""
}
