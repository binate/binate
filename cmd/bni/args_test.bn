package "main"

import "pkg/builtin/testing"

func fail(msg []char) testing.TestResult {
	return msg
}

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

// ============================================================
// parseArgs tests
// ============================================================

func TestParseArgsSimple() testing.TestResult {
	var args @[][]char = make_slice([]char, 1)
	args[0] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 1 { return fail("expected 1 filename") }
	if !seq(cli.Filenames[0], "foo.bn") { return fail("wrong filename") }
	return ""
}

func TestParseArgsMultipleFiles() testing.TestResult {
	var args @[][]char = make_slice([]char, 2)
	args[0] = "a.bn"
	args[1] = "b.bn"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 2 { return fail("expected 2 filenames") }
	return ""
}

func TestParseArgsWithDash() testing.TestResult {
	var args @[][]char = make_slice([]char, 4)
	args[0] = "foo.bn"
	args[1] = "--"
	args[2] = "arg1"
	args[3] = "arg2"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 1 { return fail("expected 1 filename") }
	if len(cli.ProgArgs) != 2 { return fail("expected 2 prog args") }
	if !seq(cli.ProgArgs[0], "arg1") { return fail("wrong prog arg 0") }
	return ""
}

func TestParseArgsRoot() testing.TestResult {
	var args @[][]char = make_slice([]char, 3)
	args[0] = "-root"
	args[1] = "/my/root"
	args[2] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if !seq(cli.RootOverride, "/my/root") { return fail("wrong root") }
	if len(cli.Filenames) != 1 { return fail("expected 1 filename") }
	return ""
}

func TestParseArgsAddRoot() testing.TestResult {
	var args @[][]char = make_slice([]char, 3)
	args[0] = "-add-root"
	args[1] = "/extra"
	args[2] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if len(cli.AddRoots) != 1 { return fail("expected 1 add-root") }
	if !seq(cli.AddRoots[0], "/extra") { return fail("wrong add-root") }
	return ""
}

func TestParseArgsVerbose() testing.TestResult {
	var args @[][]char = make_slice([]char, 2)
	args[0] = "-v"
	args[1] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if !cli.Verbose { return fail("expected verbose") }
	return ""
}

func TestParseArgsVerboseLong() testing.TestResult {
	var args @[][]char = make_slice([]char, 2)
	args[0] = "-verbose"
	args[1] = "foo.bn"
	var cli CLIArgs = parseArgs(args)
	if !cli.Verbose { return fail("expected verbose") }
	return ""
}

func TestParseArgsEmpty() testing.TestResult {
	var args [][]char
	var cli CLIArgs = parseArgs(args)
	if len(cli.Filenames) != 0 { return fail("expected 0 filenames") }
	if len(cli.ProgArgs) != 0 { return fail("expected 0 prog args") }
	return ""
}

// ============================================================
// hasSuffix tests
// ============================================================

func TestHasSuffixTrue() testing.TestResult {
	if !hasSuffix("hello.bn", ".bn") { return fail("should match .bn") }
	return ""
}

func TestHasSuffixFalse() testing.TestResult {
	if hasSuffix("hello.go", ".bn") { return fail("should not match .bn") }
	return ""
}

func TestHasSuffixTestBn() testing.TestResult {
	if !hasSuffix("foo_test.bn", "_test.bn") { return fail("should match _test.bn") }
	return ""
}

func TestHasSuffixTooShort() testing.TestResult {
	if hasSuffix("x", ".bn") { return fail("shorter than suffix") }
	return ""
}

func TestHasSuffixExact() testing.TestResult {
	if !hasSuffix(".bn", ".bn") { return fail("exact match should work") }
	return ""
}
