package "main"

import "pkg/builtin/testing"

// main.bn has main() and parseSourceFiles — both require filesystem access
// and are tested through conformance tests. This file exists for completeness
// and to test resolveRoot which is defined in main.bn.

func TestResolveRootEmptyOverride() testing.TestResult {
	// Empty override with a path that has a directory
	var r []char = resolveRoot("", "pkg/foo/bar.bn")
	if !seq(r, "pkg/foo") { return fail("expected pkg/foo") }
	return ""
}
