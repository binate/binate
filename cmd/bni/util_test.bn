package "main"

import "pkg/builtin/testing"

// ============================================================
// streq tests
// ============================================================

func TestStreqEqual() testing.TestResult {
	if !streq("hello", "hello") { return fail("same strings") }
	return ""
}

func TestStreqDifferent() testing.TestResult {
	if streq("hello", "world") { return fail("different strings") }
	return ""
}

func TestStreqDifferentLength() testing.TestResult {
	if streq("abc", "ab") { return fail("different lengths") }
	return ""
}

func TestStreqEmpty() testing.TestResult {
	if !streq("", "") { return fail("empty strings") }
	return ""
}

// ============================================================
// dirOf tests
// ============================================================

func TestDirOfSimple() testing.TestResult {
	var d []char = dirOf("/foo/bar/baz.bn")
	if !seq(d, "/foo/bar") { return fail("expected /foo/bar") }
	return ""
}

func TestDirOfNoSlash() testing.TestResult {
	var d []char = dirOf("baz.bn")
	if !seq(d, "") { return fail("expected empty for no slash") }
	return ""
}

func TestDirOfTrailingSlash() testing.TestResult {
	var d []char = dirOf("/foo/bar/")
	if !seq(d, "/foo/bar") { return fail("expected /foo/bar") }
	return ""
}

// ============================================================
// resolveRoot tests
// ============================================================

func TestResolveRootWithOverride() testing.TestResult {
	var r []char = resolveRoot("/my/root", "src/main.bn")
	if !seq(r, "/my/root") { return fail("should use override") }
	return ""
}

func TestResolveRootFromFile() testing.TestResult {
	var r []char = resolveRoot("", "/proj/src/main.bn")
	if !seq(r, "/proj/src") { return fail("should derive from file path") }
	return ""
}

func TestResolveRootBareFile() testing.TestResult {
	var r []char = resolveRoot("", "main.bn")
	if !seq(r, ".") { return fail("should default to .") }
	return ""
}
