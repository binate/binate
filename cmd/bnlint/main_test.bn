package "main"

import "pkg/bootstrap"
import "pkg/buf"
import "pkg/lint"
import "pkg/token"
import "pkg/builtin/testing"

// ============================================================
// parseArgs tests
// ============================================================

func TestParseArgsBasic() testing.TestResult {
	var args @[]@[]char = make_slice(@[]char, 3)
	args[0] = "--root"
	args[1] = "/some/dir"
	args[2] = "pkg/foo"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Error) > 0 { return cli.Error }
	if !streq(cli.Root, "/some/dir") { return "wrong root" }
	if len(cli.Pkgs) != 1 { return "expected 1 pkg" }
	if !streq(cli.Pkgs[0], "pkg/foo") { return "wrong pkg" }
	return ""
}

func TestParseArgsMultiplePkgs() testing.TestResult {
	var args @[]@[]char = make_slice(@[]char, 4)
	args[0] = "--root"
	args[1] = "/dir"
	args[2] = "pkg/a"
	args[3] = "pkg/b"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Error) > 0 { return cli.Error }
	if len(cli.Pkgs) != 2 { return "expected 2 pkgs" }
	if !streq(cli.Pkgs[0], "pkg/a") { return "wrong pkg 0" }
	if !streq(cli.Pkgs[1], "pkg/b") { return "wrong pkg 1" }
	return ""
}

func TestParseArgsEmpty() testing.TestResult {
	var args @[]@[]char = make_slice(@[]char, 0)
	var cli CLIArgs = parseArgs(args)
	if len(cli.Error) == 0 { return "expected error for empty args" }
	return ""
}

func TestParseArgsMissingRoot() testing.TestResult {
	var args @[]@[]char = make_slice(@[]char, 1)
	args[0] = "pkg/foo"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Error) == 0 { return "expected error for missing --root" }
	return ""
}

func TestParseArgsMissingRootValue() testing.TestResult {
	var args @[]@[]char = make_slice(@[]char, 1)
	args[0] = "--root"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Error) == 0 { return "expected error for --root without value" }
	return ""
}

func TestParseArgsMissingPkgs() testing.TestResult {
	var args @[]@[]char = make_slice(@[]char, 2)
	args[0] = "--root"
	args[1] = "/dir"
	var cli CLIArgs = parseArgs(args)
	if len(cli.Error) == 0 { return "expected error for no packages" }
	return ""
}

// ============================================================
// formatDiag tests
// ============================================================

func TestFormatDiag() testing.TestResult {
	var d lint.Diagnostic
	d.Pos.File = "pkg/foo/bar.bn"
	d.Pos.Line = 42
	d.Pos.Col = 10
	d.Rule = "test-rule"
	d.Message = "something bad"
	var msg @[]char = formatDiag("pkg/foo", d, "")
	var expected []char = "pkg/foo/bar.bn:42:10: [test-rule] something bad"
	if !streq(msg, expected) {
		var cb buf.CharBuf = buf.New()
		cb = buf.WriteStr(cb, "expected '")
		cb = buf.WriteStr(cb, expected)
		cb = buf.WriteStr(cb, "', got '")
		cb = buf.WriteStr(cb, msg)
		cb = buf.WriteByte(cb, '\'')
		return buf.Bytes(cb)
	}
	return ""
}

func TestFormatDiagFallback() testing.TestResult {
	// When Pos.File is empty, falls back to pkgPath
	var d lint.Diagnostic
	d.Rule = "r"
	d.Message = "m"
	var msg @[]char = formatDiag("pkg/x", d, "")
	if !streq(msg, "pkg/x:0:0: [r] m") {
		return bootstrap.Concat("unexpected: ", msg)
	}
	return ""
}

func TestFormatDiagUsesFile() testing.TestResult {
	// When Pos.File is set, uses it instead of pkgPath
	var d lint.Diagnostic
	d.Pos.File = "src/thing.bn"
	d.Pos.Line = 5
	d.Pos.Col = 3
	d.Rule = "r"
	d.Message = "m"
	var msg @[]char = formatDiag("pkg/x", d, "")
	if !streq(msg, "src/thing.bn:5:3: [r] m") {
		return bootstrap.Concat("unexpected: ", msg)
	}
	return ""
}

func TestFormatDiagStripsRoot() testing.TestResult {
	var d lint.Diagnostic
	d.Pos.File = "/home/user/proj/pkg/foo/bar.bn"
	d.Pos.Line = 10
	d.Pos.Col = 5
	d.Rule = "r"
	d.Message = "m"
	var msg @[]char = formatDiag("pkg/foo", d, "/home/user/proj/")
	if !streq(msg, "pkg/foo/bar.bn:10:5: [r] m") {
		return bootstrap.Concat("unexpected: ", msg)
	}
	return ""
}

// ============================================================
// stripPrefix tests
// ============================================================

func TestStripPrefix() testing.TestResult {
	var result []char = stripPrefix("/a/b/c.bn", "/a/b/")
	if !streq(result, "c.bn") { return bootstrap.Concat("unexpected: ", result) }
	return ""
}

func TestStripPrefixNoMatch() testing.TestResult {
	var result []char = stripPrefix("other/path.bn", "/a/b/")
	if !streq(result, "other/path.bn") { return bootstrap.Concat("unexpected: ", result) }
	return ""
}

func TestStripPrefixEmpty() testing.TestResult {
	var result []char = stripPrefix("path.bn", "")
	if !streq(result, "path.bn") { return bootstrap.Concat("unexpected: ", result) }
	return ""
}

// ============================================================
// quotePath tests
// ============================================================

func TestQuotePath() testing.TestResult {
	var q @[]char = quotePath("pkg/foo")
	if !streq(q, "\"pkg/foo\"") {
		return bootstrap.Concat("unexpected: ", q)
	}
	return ""
}

func TestQuotePathEmpty() testing.TestResult {
	var q @[]char = quotePath("")
	if !streq(q, "\"\"") {
		return bootstrap.Concat("unexpected: ", q)
	}
	return ""
}

// ============================================================
// streq tests
// ============================================================

func TestStreqEqual() testing.TestResult {
	if !streq("hello", "hello") { return "equal strings should match" }
	return ""
}

func TestStreqDifferent() testing.TestResult {
	if streq("hello", "world") { return "different strings should not match" }
	return ""
}

func TestStreqDifferentLen() testing.TestResult {
	if streq("hi", "hello") { return "different length strings should not match" }
	return ""
}

func TestStreqEmpty() testing.TestResult {
	if !streq("", "") { return "empty strings should match" }
	return ""
}

// ============================================================
// appendStr / appendMsg tests
// ============================================================

func TestAppendStr() testing.TestResult {
	var s @[]@[]char
	s = appendStr(s, "a")
	s = appendStr(s, "b")
	if len(s) != 2 { return "expected len 2" }
	if !streq(s[0], "a") { return "wrong [0]" }
	if !streq(s[1], "b") { return "wrong [1]" }
	return ""
}

func TestAppendMsgGrowth() testing.TestResult {
	var s @[]@[]char = make_slice(@[]char, 2)
	var n int = 0
	s = appendMsg(s, n, "a")
	n = n + 1
	s = appendMsg(s, n, "b")
	n = n + 1
	// Should trigger growth
	s = appendMsg(s, n, "c")
	n = n + 1
	if n != 3 { return "expected 3 items" }
	if !streq(s[0], "a") { return "wrong [0]" }
	if !streq(s[1], "b") { return "wrong [1]" }
	if !streq(s[2], "c") { return "wrong [2]" }
	return ""
}

// ============================================================
// lintPackages integration test
// ============================================================

func TestLintPackagesClean() testing.TestResult {
	// Lint pkg/ast — should have no lint diagnostics (it's just type defs)
	var root @[]char = findRoot()
	if len(root) == 0 { return "" }  // skip if can't determine root
	var pkgs @[]@[]char = make_slice(@[]char, 1)
	pkgs[0] = "pkg/ast"
	var result LintResult = lintPackages(root, pkgs)
	if len(result.Error) > 0 { return result.Error }
	if result.NumDiags != 0 {
		return bootstrap.Concat("expected 0 diags for pkg/ast, got ", bootstrap.Itoa(result.NumDiags))
	}
	return ""
}

func TestLintPackagesBadPkg() testing.TestResult {
	var root @[]char = findRoot()
	if len(root) == 0 { return "" }
	var pkgs @[]@[]char = make_slice(@[]char, 1)
	pkgs[0] = "pkg/nonexistent"
	var result LintResult = lintPackages(root, pkgs)
	// Should get a loader error
	if len(result.Error) == 0 {
		return "expected error for nonexistent package"
	}
	return ""
}

// findRoot attempts to locate the binate source root by looking for
// pkg/ast.bni relative to the bootstrap's --root flag.
func findRoot() @[]char {
	var args [][]char = bootstrap.Args()
	for i := 0; i < len(args); i++ {
		if streq(args[i], "--root") && i + 1 < len(args) {
			return buf.CopyStr(args[i + 1])
		}
	}
	return buf.CopyStr("")
}
