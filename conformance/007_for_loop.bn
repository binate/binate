package "main"

func main() {
	sum := 0
	for i := 0; i < 5; i++ {
		sum = sum + i
	}
	println(sum)

	n := 1
	for n < 100 {
		n = n * 2
	}
	println(n)

	total := 0
	for i := 0; i < 10; i++ {
		if i == 5 {
			break
		}
		total = total + i
	}
	println(total)

	odd := 0
	for i := 0; i < 10; i++ {
		if i % 2 == 0 {
			continue
		}
		odd = odd + i
	}
	println(odd)
}
