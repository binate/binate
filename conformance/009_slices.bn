package "main"

func main() {
	s := make_raw_deprecated([]int, 3)
	s[0] = 10
	s[1] = 20
	s[2] = 30
	println(len(s))
	println(s[0])
	println(s[2])

	// Managed slice with 4 elements
	var t @[]int = make_slice(int, 4)
	t[0] = 10
	t[1] = 20
	t[2] = 30
	t[3] = 40
	println(len(t))
	println(t[3])

	// Single-element managed slice
	var u @[]int = make_slice(int, 1)
	u[0] = 99
	println(len(u))
	println(u[0])
}
