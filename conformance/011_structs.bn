package "main"

type Point struct {
	x int
	y int
}

type Rect struct {
	min Point
	max Point
}

func main() {
	p := Point{x: 3, y: 4}
	println(p.x)
	println(p.y)
	p.x = 10
	println(p.x)

	r := Rect{
		min: Point{x: 1, y: 2},
		max: Point{x: 4, y: 6},
	}
	println((r.max.x - r.min.x) * (r.max.y - r.min.y))
}
