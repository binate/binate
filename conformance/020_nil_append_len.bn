package "main"

func main() {
	// Nil slice has len 0
	var s []int
	println(len(s))

	// make_slice with 1 element
	var t @[]int = make_slice(int, 1)
	t[0] = 42
	println(len(t))
	println(t[0])

	// make_slice with 2 elements
	var u @[]int = make_slice(int, 2)
	u[0] = 42
	u[1] = 99
	println(len(u))
	println(u[1])
}
