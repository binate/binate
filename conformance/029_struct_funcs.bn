package "main"

type Point struct {
	x int
	y int
}

func makePoint(x int, y int) Point {
	return Point{x: x, y: y}
}

func addPoints(a Point, b Point) Point {
	return Point{x: a.x + b.x, y: a.y + b.y}
}

func dot(a Point, b Point) int {
	return a.x * b.x + a.y * b.y
}

func main() {
	p := makePoint(3, 4)
	println(p.x, p.y)

	q := makePoint(1, 2)
	r := addPoints(p, q)
	println(r.x, r.y)

	println(dot(p, q))
}
