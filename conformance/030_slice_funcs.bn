package "main"

func sum(s []int) int {
	total := 0
	for v in s {
		total = total + v
	}
	return total
}

func maxVal(s []int) int {
	m := s[0]
	for i := 1; i < len(s); i++ {
		if s[i] > m {
			m = s[i]
		}
	}
	return m
}

func main() {
	var s []int
	s = append(s, 10)
	s = append(s, 20)
	s = append(s, 30)
	println(sum(s))
	println(maxVal(s))

	s = append(s, 5)
	s = append(s, 50)
	println(sum(s))
	println(maxVal(s))
}
