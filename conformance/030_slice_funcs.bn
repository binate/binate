package "main"

func sum(s []int) int {
	total := 0
	for v in s {
		total = total + v
	}
	return total
}

func maxVal(s []int) int {
	m := s[0]
	for i := 1; i < len(s); i++ {
		if s[i] > m {
			m = s[i]
		}
	}
	return m
}

func main() {
	var s @[]int = make_slice(int, 3)
	s[0] = 10
	s[1] = 20
	s[2] = 30
	println(sum(s))
	println(maxVal(s))

	var s2 @[]int = make_slice(int, 5)
	s2[0] = 10
	s2[1] = 20
	s2[2] = 30
	s2[3] = 5
	s2[4] = 50
	println(sum(s2))
	println(maxVal(s2))
}
