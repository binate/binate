package "main"

func main() {
	// Multiplication table corners
	for i := 1; i <= 3; i++ {
		for j := 1; j <= 3; j++ {
			println(i * j)
		}
	}

	// Nested break only breaks inner loop
	count := 0
	for i := 0; i < 5; i++ {
		for j := 0; j < 5; j++ {
			if j >= 2 {
				break
			}
			count++
		}
	}
	println(count)
}
