package "main"

func findFirst(s []int, target int) int {
	for i := 0; i < len(s); i++ {
		if s[i] == target {
			return i
		}
	}
	return -1
}

func isEven(n int) bool {
	if n % 2 == 0 {
		return true
	}
	return false
}

func main() {
	var s @[]int = make_slice(int, 4)
	s[0] = 10
	s[1] = 20
	s[2] = 30
	s[3] = 40
	println(findFirst(s, 30))
	println(findFirst(s, 99))
	println(isEven(4))
	println(isEven(7))
}
