package "main"

func main() {
	// Short-circuit: second operand should not matter when first decides
	x := 5
	if x > 0 && x < 10 {
		println(1)
	}
	if x > 10 || x == 5 {
		println(2)
	}
	if !(x == 3) {
		println(3)
	}

	// Complex boolean expressions
	a := true
	b := false
	if a && !b {
		println(4)
	}
	if !a || b {
		println(999)
	} else {
		println(5)
	}
}
