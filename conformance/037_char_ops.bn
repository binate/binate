package "main"

func isUpper(c char) bool {
	return c >= 'A' && c <= 'Z'
}

func toLower(c char) char {
	if isUpper(c) {
		return cast(char, cast(int, c) + 32)
	}
	return c
}

func main() {
	println(isUpper('A'))
	println(isUpper('z'))
	println(cast(int, toLower('H')))
	println(cast(int, toLower('x')))

	var s []char = "Hello"
	println(cast(int, s[0]))
	println(cast(int, toLower(s[0])))
}
