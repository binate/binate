package "main"

func factorial(n int) int {
	if n <= 1 {
		return 1
	}
	return n * factorial(n - 1)
}

func power(base int, exp int) int {
	if exp == 0 {
		return 1
	}
	return base * power(base, exp - 1)
}

func main() {
	println(factorial(5))
	println(factorial(10))
	println(power(2, 10))
	println(power(3, 4))
}
