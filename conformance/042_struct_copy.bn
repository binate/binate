package "main"

type Point struct {
	x int
	y int
}

func newPoint(x int, y int) Point {
	return Point{x: x, y: y}
}

func modifyPoint(p Point) {
	p.x = 99
}

func main() {
	// Struct assignment should copy
	var a Point = Point{x: 1, y: 2}
	var b Point = a
	b.x = 10
	println(a.x)
	println(b.x)

	// Struct as function arg should copy
	var c Point = Point{x: 5, y: 6}
	modifyPoint(c)
	println(c.x)

	// Struct return
	var d Point = newPoint(7, 8)
	println(d.x)
	println(d.y)
}
