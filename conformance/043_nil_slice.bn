package "main"

func main() {
	// Nil slice has len 0
	var s []int
	println(len(s))

	// Managed slice with 3 elements
	var ms @[]int = make_slice(int, 3)
	ms[0] = 10
	ms[1] = 20
	ms[2] = 30
	println(len(ms))
	println(ms[0])
	println(ms[1])
	println(ms[2])

	// Nil char slice has len 0
	var c []char
	println(len(c))

	// Managed char slice with 2 elements
	var mc @[]char = make_slice(char, 2)
	mc[0] = 'a'
	mc[1] = 'b'
	println(len(mc))
}
