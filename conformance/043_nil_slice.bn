package "main"

func main() {
	// Nil slice has len 0
	var s []int
	println(len(s))

	// Append to nil slice
	s = append(s, 10)
	s = append(s, 20)
	s = append(s, 30)
	println(len(s))
	println(s[0])
	println(s[1])
	println(s[2])

	// Nil char slice
	var c []char
	println(len(c))
	c = append(c, 'a')
	c = append(c, 'b')
	println(len(c))
}
