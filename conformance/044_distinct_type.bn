package "main"

type Celsius int
type Meters int

func toFahrenheit(c Celsius) int {
	return cast(int, c) * 9 / 5 + 32
}

func main() {
	var temp Celsius = 100
	println(toFahrenheit(temp))

	var dist Meters = 42
	println(cast(int, dist))

	// Arithmetic on distinct types
	var a Celsius = 10
	var b Celsius = 20
	var c Celsius = a + b
	println(cast(int, c))
}
