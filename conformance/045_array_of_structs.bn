package "main"

type Point struct {
	x int
	y int
}

func main() {
	var pts [3]Point
	pts[0] = Point{x: 1, y: 2}
	pts[1] = Point{x: 3, y: 4}
	pts[2] = Point{x: 5, y: 6}

	var sum int = 0
	for i := 0; i < 3; i++ {
		sum = sum + pts[i].x + pts[i].y
	}
	println(sum)

	// Access individual fields
	println(pts[1].x)
	println(pts[2].y)
}
