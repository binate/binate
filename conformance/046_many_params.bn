package "main"

func add6(a int, b int, c int, d int, e int, f int) int {
	return a + b + c + d + e + f
}

func add8(a int, b int, c int, d int, e int, f int, g int, h int) int {
	return a + b + c + d + e + f + g + h
}

func main() {
	println(add6(1, 2, 3, 4, 5, 6))
	println(add8(1, 2, 3, 4, 5, 6, 7, 8))
}
