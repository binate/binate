package "main"

type Point struct {
	x int
	y int
}

type Rect struct {
	min Point
	max Point
}

func area(r Rect) int {
	var w int = r.max.x - r.min.x
	var h int = r.max.y - r.min.y
	return w * h
}

func main() {
	var r Rect
	r.min = Point{x: 1, y: 2}
	r.max = Point{x: 5, y: 7}

	println(r.min.x)
	println(r.max.y)
	println(area(r))

	// Struct with managed pointer field
	var p @Point = box(Point{x: 10, y: 20})
	println(p.x + p.y)
}
