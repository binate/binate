package "main"

func greet(name []char) []char {
	return name
}

func strLen(s []char) int {
	return len(s)
}

func main() {
	var name []char = "world"
	println(greet(name))
	println(strLen(name))
	println(strLen("hello"))

	// Char arithmetic
	var ch char = 'A'
	var next char = ch + 1
	println(cast(int, next))

	// Char comparison
	if ch < 'Z' {
		println(true)
	}
}
