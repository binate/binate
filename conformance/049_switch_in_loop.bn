package "main"

func classify(n int) int {
	if n < 0 {
		return -1
	}
	if n == 0 {
		return 0
	}
	return 1
}

func main() {
	// Switch with tag inside loop
	for i := 0; i < 5; i++ {
		switch i {
		case 0:
			println(10)
		case 1:
			println(20)
		case 2:
			println(30)
		default:
			println(99)
		}
	}

	// Function call from switch inside loop
	var sum int = 0
	for i := -3; i <= 3; i++ {
		sum = sum + classify(i)
	}
	println(sum)
}
