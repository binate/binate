package "main"

type Point struct {
	x int
	y int
}

func divmod(a int, b int) (int, int) {
	return a / b, a % b
}

func minmax(a int, b int, c int) (int, int) {
	var lo int = a
	var hi int = a
	if b < lo { lo = b }
	if c < lo { lo = c }
	if b > hi { hi = b }
	if c > hi { hi = c }
	return lo, hi
}

func main() {
	var q int
	var r int
	q, r = divmod(17, 5)
	println(q)
	println(r)

	var lo int
	var hi int
	lo, hi = minmax(3, 1, 7)
	println(lo)
	println(hi)
}
