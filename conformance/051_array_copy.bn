package "main"

func modifyArray(a [3]int) {
	a[0] = 99
}

func main() {
	// Array assignment should copy
	var a [3]int = [3]int{1, 2, 3}
	var b [3]int = a
	b[0] = 10
	println(a[0])
	println(b[0])

	// Array as function arg should copy
	var c [3]int = [3]int{4, 5, 6}
	modifyArray(c)
	println(c[0])
}
