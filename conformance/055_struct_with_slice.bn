package "main"

type Buffer struct {
    data []int
    name []char
}

func main() {
    var b Buffer
    b.name = "test"
    b.data = append(b.data, 1)
    b.data = append(b.data, 2)
    b.data = append(b.data, 3)
    println(len(b.data))
    println(b.data[0])
    println(b.data[2])
    println(b.name)
}
