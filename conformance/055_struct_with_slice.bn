package "main"

type Buffer struct {
    data []int
    name []char
}

func main() {
    var b Buffer
    b.name = "test"
    b.data = make_slice(int, 3)
    b.data[0] = 1
    b.data[1] = 2
    b.data[2] = 3
    println(len(b.data))
    println(b.data[0])
    println(b.data[2])
    println(b.name)
}
