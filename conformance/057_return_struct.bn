package "main"

type Vec2 struct {
    x int
    y int
}

func add(a Vec2, b Vec2) Vec2 {
    return Vec2{x: a.x + b.x, y: a.y + b.y}
}

func scale(v Vec2, s int) Vec2 {
    return Vec2{x: v.x * s, y: v.y * s}
}

func main() {
    var a Vec2 = Vec2{x: 1, y: 2}
    var b Vec2 = Vec2{x: 3, y: 4}
    var c Vec2 = add(a, b)
    println(c.x)
    println(c.y)

    var d Vec2 = scale(c, 3)
    println(d.x)
    println(d.y)
}
