package "main"

type Node struct {
    val  int
    next @Node
}

func buildList(n int) @Node {
    if n <= 0 {
        return nil
    }
    var node @Node = make(Node)
    node.val = n
    node.next = buildList(n - 1)
    return node
}

func sumList(node @Node) int {
    if node == nil {
        return 0
    }
    return node.val + sumList(node.next)
}

func main() {
    var list @Node = buildList(5)
    println(sumList(list))
    println(list.val)
    println(list.next.val)
}
