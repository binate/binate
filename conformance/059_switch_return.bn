package "main"

func classify(n int) int {
    switch n {
    case 0:
        return -1
    case 1:
        return 0
    case 2:
        return 1
    }
    return 99
}

func findFirst(target int) int {
    for i := 0; i < 10; i++ {
        switch classify(i) {
        case 1:
            return i
        }
    }
    return -1
}

func main() {
    println(classify(0))
    println(classify(1))
    println(classify(2))
    println(classify(5))
    println(findFirst(1))
}
