package "main"

type Mixed struct {
    A int8
    B int
    C int8
}

func main() {
    var m Mixed
    m.A = cast(int8, 10)
    m.B = 42
    m.C = cast(int8, 99)
    println(cast(int, m.A))
    println(m.B)
    println(cast(int, m.C))

    // Via managed pointer
    var p @Mixed = make(Mixed)
    p.A = cast(int8, 1)
    p.B = 200
    p.C = cast(int8, 3)
    println(cast(int, p.A))
    println(p.B)
    println(cast(int, p.C))
}
