package "main"

import "pkg/geom"

func main() {
	// Create point via package function
	var p @geom.Point = geom.NewPoint(10, 20)
	println(geom.Sum(p))

	// Access fields
	println(p.X)
	println(p.Y)

	// Modify fields
	p.X = 100
	println(geom.Sum(p))

	// Constants
	println(geom.ORIGIN_X)
	println(geom.ORIGIN_Y)
}
