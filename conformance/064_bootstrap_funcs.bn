package "main"

import "pkg/bootstrap"

func main() {
	// Concat
	var s @[]char = bootstrap.Concat("hello", " world")
	println(s)

	// Itoa
	var n @[]char = bootstrap.Itoa(42)
	println(n)

	// Itoa negative
	var neg @[]char = bootstrap.Itoa(-7)
	println(neg)

	// Concat with Itoa
	var msg @[]char = bootstrap.Concat("value=", bootstrap.Itoa(100))
	println(msg)
}
