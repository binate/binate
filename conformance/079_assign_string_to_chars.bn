package "main"

// Regression: assigning a string literal to an existing []char variable
// stored the raw pointer without converting to a slice, corrupting the length.

func pick(n int) []char {
	var s []char
	if n == 0 {
		s = "zero"
	} else if n == 1 {
		s = "one"
	} else {
		s = "other"
	}
	return s
}

func main() {
	println(pick(0))
	println(pick(1))
	println(pick(2))
	println(len(pick(0)))
	println(len(pick(1)))
	println(len(pick(2)))
	println("done")
}
