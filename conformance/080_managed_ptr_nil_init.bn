package "main"

type Node struct {
	Value int
}

func pick(n int) @Node {
	var result @Node
	if n > 0 {
		result = make(Node)
		result.Value = n
	}
	return result
}

func main() {
	var a @Node = pick(0)
	if a == nil {
		println("nil")
	} else {
		println(a.Value)
	}
	var b @Node = pick(42)
	if b == nil {
		println("nil")
	} else {
		println(b.Value)
	}
	println("done")
}
