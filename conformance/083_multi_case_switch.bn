package "main"

func classify(n int) []char {
	switch n {
	case 1, 2, 3:
		return "low"
	case 4, 5:
		return "mid"
	case 10:
		return "ten"
	default:
		return "other"
	}
}

func main() {
	println(classify(1))
	println(classify(2))
	println(classify(3))
	println(classify(4))
	println(classify(5))
	println(classify(10))
	println(classify(99))
}
