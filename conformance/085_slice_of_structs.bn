package "main"

type Point struct {
	X int
	Y int
}

func main() {
	var pts []Point

	// Build via append with composite literals
	pts = append(pts, Point{1, 2})
	pts = append(pts, Point{3, 4})
	pts = append(pts, Point{5, 6})

	// Read fields
	println(pts[0].X)
	println(pts[0].Y)
	println(pts[1].X)
	println(pts[2].Y)

	// Write fields in-place
	pts[1].X = 30
	pts[1].Y = 40
	println(pts[1].X)
	println(pts[1].Y)

	// Length
	println(len(pts))
}
