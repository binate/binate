package "main"

var items []int

func addItem(x int) {
	items = append(items, x)
}

func resetItems() {
	items = nil
}

func main() {
	// Global slice starts as nil
	println(len(items))

	addItem(10)
	addItem(20)
	addItem(30)
	println(len(items))
	println(items[0])
	println(items[2])

	// Reset to nil
	resetItems()
	println(len(items))

	// Re-use after nil reset
	addItem(99)
	println(len(items))
	println(items[0])
}
