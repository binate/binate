package "main"

var items @[]int

func setItems() {
	items = make_slice(int, 3)
	items[0] = 10
	items[1] = 20
	items[2] = 30
}

func resetItems() {
	var zero @[]int
	items = zero
}

func main() {
	// Global slice starts as zero value
	println(len(items))

	setItems()
	println(len(items))
	println(items[0])
	println(items[2])

	// Reset to zero value
	resetItems()
	println(len(items))

	// Re-use after reset
	items = make_slice(int, 1)
	items[0] = 99
	println(len(items))
	println(items[0])
}
