package "main"

func printChars(s []char) {
	for i := 0; i < len(s); i++ {
		println(cast(int, s[i]))
	}
}

func main() {
	// String literal to []char
	var s []char = "Hi"
	println(len(s))
	printChars(s)

	// Reassign string to []char variable
	s = "AB"
	println(len(s))
	printChars(s)

	// Empty string
	var e []char = ""
	println(len(e))

	// []char from function return used as string
	println(s)
}
