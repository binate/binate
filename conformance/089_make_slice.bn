package "main"

func main() {
	// make_slice returns @[]T (managed-slice)
	var s @[]int = make_slice(int, 3)
	s[0] = 10
	s[1] = 20
	s[2] = 30
	println(len(s))
	println(s[0])
	println(s[1])
	println(s[2])

	// Zero-initialized
	var z @[]int = make_slice(int, 2)
	println(z[0])
	println(z[1])
	println(len(z))

	// Char slice
	var c @[]char = make_slice(char, 4)
	c[0] = 'H'
	c[1] = 'i'
	c[2] = '!'
	c[3] = '\n'
	println(len(c))
}
