package "main"

func main() {
	// Get a pointer to an array, index through the pointer
	var arr [4]int
	arr[0] = 10
	arr[1] = 20
	arr[2] = 30
	arr[3] = 99

	var p *int = &arr[0]
	println(p[0])
	println(p[1])
	println(p[2])

	// Write through pointer
	p[3] = 42
	println(arr[3])

	// Offset pointer and index
	var q *int = &arr[2]
	println(q[0])
	println(q[1])
}
