package "main"

// Test for-in loop over managed slice (@[]T).
// Regression: emitManagedToRaw emitted duplicate SSA names when
// slice_len and slice_get both converted the same managed slice.

func main() {
	var s @[]int = make_slice(int, 3)
	s[0] = 10
	s[1] = 20
	s[2] = 30

	// for-value
	var total int = 0
	for v in s {
		total = total + v
	}
	println(total)

	// for-index-value
	for i, v in s {
		println(i, v)
	}
}
