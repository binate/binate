package "main"

// Test @[]T → []T conversion when assigning make_slice result to a
// raw slice struct field. Regression: managed slice (24 bytes) was
// stored into raw slice field (16 bytes), corrupting adjacent fields.

type Container struct {
	Data []int
	Name []char
}

func main() {
	var c Container
	c.Name = "hello"
	c.Data = make_slice(int, 3)
	c.Data[0] = 10
	c.Data[1] = 20
	c.Data[2] = 30
	println(len(c.Data))
	println(c.Data[1])
	println(c.Name)
}
