package "main"

import "pkg/buf"

func buildStr() @[]char {
	var b buf.CharBuf = buf.New()
	b = buf.WriteStr(b, "hello")
	return buf.Bytes(b)
}

func main() {
	// println with @[]char argument (managed char slice)
	var s @[]char = buildStr()
	println(s)

	// println with @[]char from make_slice
	var t @[]char = make_slice(char, 3)
	t[0] = 'a'
	t[1] = 'b'
	t[2] = 'c'
	println(t)

	// print with @[]char
	print(s)
	print(" ")
	println(t)
}
