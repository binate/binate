package "main"

type Named struct {
	Name @[]char
	Val  int
}

func makeNamed(name @[]char, val int) @Named {
	var n @Named = make(Named)
	n.Name = name
	n.Val = val
	return n
}

func main() {
	// String literal passed to function expecting @[]char
	var a @Named = makeNamed("hello", 42)
	println(a.Name)
	println(a.Val)

	// Multiple calls with string literals
	var b @Named = makeNamed("world", 99)
	println(b.Name)
	println(b.Val)
}
