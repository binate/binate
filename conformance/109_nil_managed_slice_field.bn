package "main"

type Container struct {
	Items @[]int
	Name  @[]char
}

func main() {
	var c @Container = make(Container)
	c.Items = make_slice(int, 3)
	c.Items[0] = 10
	c.Items[1] = 20
	c.Items[2] = 30
	c.Name = "hello"

	println(len(c.Items))
	println(c.Items[1])
	println(c.Name)

	// Zero the managed slice field — this must produce a proper zeroinitializer
	var zeroItems @[]int
	c.Items = zeroItems
	if len(c.Items) == 0 {
		println("empty")
	} else {
		println("FAIL: Items not empty")
	}

	// Name should still be valid
	println(c.Name)

	// Re-assign
	c.Items = make_slice(int, 2)
	c.Items[0] = 99
	println(c.Items[0])
	println(len(c.Items))
}
