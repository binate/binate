package "main"

import "pkg/mylib"

func check() mylib.Result {
	return mylib.MakeResult("hello")
}

func main() {
	var r mylib.Result = check()
	println(len(r))
	println(r)
	if mylib.IsEmpty(r) {
		println("empty")
	} else {
		println("not empty")
	}

	var empty mylib.Result = mylib.MakeResult("")
	if mylib.IsEmpty(empty) {
		println("empty ok")
	}
}
