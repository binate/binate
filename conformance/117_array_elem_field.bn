package "main"

// Access a field on a managed pointer stored in an array.
// arr[i] loads @Node, then .Val accesses the field.

type Node struct {
	Val int
}

func main() {
	var a @Node = make(Node)
	a.Val = 42
	var b @Node = make(Node)
	b.Val = 99

	var arr [2]@Node
	arr[0] = a
	arr[1] = b

	println(arr[0].Val)
	println(arr[1].Val)
}
