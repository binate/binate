package "main"

// Assignment to array elements through struct selectors:
// cont.Items[i] = v

type Node struct {
	Val int
}

type Container struct {
	Items [3]@Node
}

func main() {
	var a @Node = make(Node)
	a.Val = 10
	var b @Node = make(Node)
	b.Val = 20
	var c @Node = make(Node)
	c.Val = 30

	var cont @Container = make(Container)
	cont.Items[0] = a
	cont.Items[1] = b
	cont.Items[2] = c

	println(cont.Items[0].Val)
	println(cont.Items[1].Val)
	println(cont.Items[2].Val)
}
