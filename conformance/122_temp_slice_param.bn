package "main"

// Test that managed-slice to raw slice conversion works in function params.

func sumSlice(s []int) int {
	var total int = 0
	for i := 0; i < len(s); i++ {
		total = total + s[i]
	}
	return total
}

func main() {
	var ms @[]int = make_slice(int, 3)
	ms[0] = 10
	ms[1] = 20
	ms[2] = 30
	println(sumSlice(ms))
}
