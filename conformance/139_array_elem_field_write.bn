package "main"

type Node struct {
	Val int
}

func main() {
	// Store managed pointer in array, then write field through index
	var arr [2]@Node
	arr[0] = make(Node)
	arr[0].Val = 42
	arr[1] = make(Node)
	arr[1].Val = 99

	println(arr[0].Val)
	println(arr[1].Val)

	// Overwrite through index
	arr[0].Val = 77
	println(arr[0].Val)
}
