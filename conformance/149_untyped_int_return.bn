package "main"

// Untyped integer literals in return statements should adopt the
// function's return type.

func zero32() uint32 {
	return 0
}

func fortytwo8() int8 {
	return 42
}

func hundred16() uint16 {
	return 100
}

func main() {
	println(zero32())
	println(fortytwo8())
	println(hundred16())
}
