package "main"

// Multi-return where one target is a slice element.

func compute() (int, int) {
	return 42, 99
}

func main() {
	var arr @[]int = make_slice(int, 3)
	var x int
	x, arr[0] = compute()
	println(x)      // 42
	println(arr[0])  // 99

	arr[1], arr[2] = compute()
	println(arr[1])  // 42
	println(arr[2])  // 99
}
