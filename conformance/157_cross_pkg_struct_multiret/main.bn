package "main"

import "pkg/strtab"

func main() {
	// Exported struct type in multi-return
	var t strtab.Tab = strtab.New()
	var off1 int
	t, off1 = strtab.Add(t, "hello")
	println(off1)  // 1

	var off2 int
	t, off2 = strtab.Add(t, "world")
	println(off2)  // 7

	println(strtab.Len(t))  // 13

	// Internal struct type (not in .bni) used by package function
	var off3 int = strtab.InternalAdd("test")
	println(off3)  // 1
}
