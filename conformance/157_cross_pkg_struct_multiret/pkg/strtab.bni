package "pkg/strtab"

import "pkg/buf"

// Tab is exported in .bni so it can be used by callers.
type Tab struct {
	Buf buf.CharBuf
}

func New() Tab
func Add(t Tab, s []char) (Tab, int)
func Len(t Tab) int

// InternalAdd uses an internal struct (not in .bni) for its work.
// This tests whether internal struct types are correctly compiled.
func InternalAdd(s []char) int
