package "main"

import "pkg/rt"

// Regression: assigning untyped integer literals via pointer indexing
// to sub-word types must narrow the value before storing.

func main() {
	// Allocate raw memory for uint8 elements
	var p *uint8 = cast(*uint8, rt.Alloc(4))
	p[0] = 11
	p[1] = 22
	p[2] = 33
	p[3] = 44
	println(cast(int, p[0]))
	println(cast(int, p[1]))
	println(cast(int, p[2]))
	println(cast(int, p[3]))
	rt.Free(cast(*uint8, p))
}
