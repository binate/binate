package "main"

import "pkg/rt"

type Node struct {
	Val int
}

func doWork(n @Node) int {
	var local @Node = n
	return local.Val
}

func main() {
	var n @Node = make(Node)
	n.Val = 42
	var ptr *uint8 = bit_cast(*uint8, n)
	println(rt.Refcount(ptr))
	var v int = doWork(n)
	println(v)
	println(rt.Refcount(ptr))
}
