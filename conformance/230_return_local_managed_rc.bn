package "main"

import "pkg/rt"

// Test: returning a local @T transfers one reference to the caller.
// The local's scope cleanup is skipped (move), so rc should not
// temporarily spike to 2.

type Node struct {
	Val int
}

func makeNode(v int) @Node {
	var n @Node = make(Node)
	n.Val = v
	return n
}

func main() {
	var n @Node = makeNode(42)
	var ptr *uint8 = bit_cast(*uint8, n)
	println(n.Val)
	print("rc=")
	println(rt.Refcount(ptr))
}
