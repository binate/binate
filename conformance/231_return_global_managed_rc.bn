package "main"

import "pkg/rt"

// Test: returning a global @T creates a new reference for the caller.
// The global keeps its reference, so rc should be 2 after the call.

type Node struct {
	Val int
}

var g @Node

func getGlobal() @Node {
	return g
}

func main() {
	g = make(Node)
	g.Val = 99
	var ptr *uint8 = bit_cast(*uint8, g)
	print("before call rc=")
	println(rt.Refcount(ptr))

	var n @Node = getGlobal()
	println(n.Val)
	print("after call rc=")
	println(rt.Refcount(ptr))
}
