package "main"

import "pkg/rt"

// Test: returning make(T) — fresh allocation returned directly.
// make creates rc=1. Return transfers that ref to caller. rc=1.

type Node struct {
	Val int
}

func fresh() @Node {
	return make(Node)
}

func main() {
	var n @Node = fresh()
	n.Val = 77
	var ptr *uint8 = bit_cast(*uint8, n)
	println(n.Val)
	print("rc=")
	println(rt.Refcount(ptr))
}
