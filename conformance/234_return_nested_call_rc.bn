package "main"

import "pkg/rt"

// Test: returning the result of another function call.
// Inner call transfers one ref. Outer return transfers one ref.
// Net: one ref to caller.

type Node struct {
	Val int
}

func inner() @Node {
	var n @Node = make(Node)
	n.Val = 33
	return n
}

func outer() @Node {
	return inner()
}

func main() {
	var n @Node = outer()
	var ptr *uint8 = bit_cast(*uint8, n)
	println(n.Val)
	print("rc=")
	println(rt.Refcount(ptr))
}
