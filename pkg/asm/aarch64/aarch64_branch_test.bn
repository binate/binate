// --- Extend tests ---

func TestSxtb() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SXTB W0, W1 = SBFM W0, W1, #0, #7
	// 0|00|100110|0|000000|000111|00001|00000
	// = 0x13001C20
	Sxtb(a, false, X0, X1)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x13001C20 {
		return fail("SXTB W0, W1 encoding wrong")
	}
	return ""
}

func TestSxtw() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SXTW X0, W1 = SBFM X0, X1, #0, #31
	// 1|00|100110|1|000000|011111|00001|00000
	// = 0x93407C20
	Sxtw(a, X0, X1)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x93407C20 {
		return fail("SXTW X0, W1 encoding wrong")
	}
	return ""
}

func TestUxtb() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// UXTB W0, W1 = UBFM W0, W1, #0, #7
