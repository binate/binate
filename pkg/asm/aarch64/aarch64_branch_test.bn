package "pkg/asm/aarch64"

import "pkg/asm"
import "pkg/builtin/testing"

// --- Shift tests ---

func TestLslImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LSL W0, W1, #3 = UBFM W0, W1, #29, #28
	// 0|10|100110|0|011101|011100|00001|00000
	// = 0x53037020 ... let me just compute:
	// sf=0, opc=10, N=0, immr=29(0x1D), imms=28(0x1C)
	// 0x53000000 | (29<<16) | (28<<10) | (1<<5) | 0
	// = 0x53000000 | 0x001D0000 | 0x00007000 | 0x00000020
	// = 0x531D7020
	Lsl(a, false, X0, X1, Imm(3))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x531D7020 {
		return fail("LSL W0, W1, #3 encoding wrong")
	}
	return ""
}

func TestLslReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LSL X0, X1, X2 = LSLV X0, X1, X2
	// 1|00|11010110|00010|001000|00001|00000
	// = 0x9AC22020
	Lsl(a, true, X0, X1, Reg(X2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x9AC22020 {
		return fail("LSL X0, X1, X2 encoding wrong")
	}
	return ""
}

func TestLsrImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LSR W0, W1, #4 = UBFM W0, W1, #4, #31
	// sf=0, N=0, immr=4, imms=31
	// 0x53000000 | (4<<16) | (31<<10) | (1<<5) | 0
	// = 0x53047C20
	Lsr(a, false, X0, X1, Imm(4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x53047C20 {
		return fail("LSR W0, W1, #4 encoding wrong")
	}
	return ""
}

func TestAsrImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ASR X0, X1, #4 = SBFM X0, X1, #4, #63
	// sf=1, N=1, immr=4, imms=63
	// 0x93400000 | (4<<16) | (63<<10) | (1<<5) | 0
	// = 0x9344FC20
	Asr(a, true, X0, X1, Imm(4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x9344FC20 {
		return fail("ASR X0, X1, #4 encoding wrong")
	}
	return ""
}

func TestRorReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ROR X0, X1, X2 = RORV X0, X1, X2
	// 1|00|11010110|00010|001011|00001|00000
	// = 0x9AC22C20
	Ror(a, true, X0, X1, X2)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x9AC22C20 {
		return fail("ROR X0, X1, X2 encoding wrong")
	}
	return ""
}

// --- Multiply / Divide tests ---

func TestMul() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MUL X0, X1, X2 = MADD X0, X1, X2, XZR
	// 1|00|11011|000|00010|0|11111|00001|00000
	// = 0x9B027C20
	Mul(a, true, X0, X1, X2)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x9B027C20 {
		return fail("MUL X0, X1, X2 encoding wrong")
	}
	return ""
}

func TestSdiv() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SDIV W0, W1, W2
	// 0|00|11010|110|00010|00001|1|00001|00000
	// = 0x1AC20C20
	Sdiv(a, false, X0, X1, X2)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x1AC20C20 {
		return fail("SDIV W0, W1, W2 encoding wrong")
	}
	return ""
}

func TestUdiv() testing.TestResult {
