	var a @asm.Assembler = newAsm()
	// CSINC X0, X1, X2, NE
	// 1|00|11010100|00010|0001|0|1|00001|00000
	// = 0x9A821420
	Csinc(a, true, X0, X1, X2, COND_NE)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x9A821420 {
