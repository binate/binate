// --- Move tests ---

func TestMovReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV X0, X1 = ORR X0, XZR, X1
	// = 1|01|01010|00|0|00001|000000|11111|00000
	// = 0xAA0103E0
	Mov(a, true, X0, Reg(X1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xAA0103E0 {
		return fail("MOV X0, X1 encoding wrong")
	}
	return ""
}

func TestMovRegSP() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV X29, SP = ADD X29, SP, #0
	// = 1|00|100010|0|000000000000|11111|11101
	// = 0x910003FD
	Mov(a, true, FP, Reg(SP))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x910003FD {
		return fail("MOV X29, SP encoding wrong")
	}
	return ""
}

func TestMovSPReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV SP, X29 = ADD SP, X29, #0
	// = 1|00|100010|0|000000000000|11101|11111
	// = 0x910003BF
	Mov(a, true, SP, Reg(FP))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x910003BF {
		return fail("MOV SP, X29 encoding wrong")
	}
	return ""
}

func TestMovz() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOVZ X0, #0x1234 = 1|10|100101|00|0001001000110100|00000
	// = 0xD2824680
	Movz(a, true, X0, 0x1234, 0)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xD2824680 {
		return fail("MOVZ X0, #0x1234 encoding wrong")
	}
	return ""
}

