// --- Test and branch ---

func TestTbz() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// TBZ W0, #3, skip — bit 3, forward 8 bytes → imm14 = 2
	Tbz(a, X0, 3, "skip")
	Nop(a)
	asm.DefineLabel(a, "skip")
	Nop(a)

	ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("unexpected error") }
	// TBZ: b5=0, 011011|0|b40=00011|imm14=2|Rt=0
	// = 0x36180040
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x36180040 {
		return fail("TBZ fixup encoding wrong")
	}
	return ""
}

// --- Branch fixup tests ---

func TestBranchForward() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// B target at offset 0, target at offset 8 → PC-relative = +8, imm26 = 2
	B(a, "target")                // offset 0: B target (placeholder)
	Nop(a)                         // offset 4: NOP
	asm.DefineLabel(a, "target")   // offset 8
	Nop(a)                         // offset 8: NOP

	ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("unexpected error") }
	if a.NumRelocs != 0 { return fail("expected 0 relocations (branch should be resolved)") }

	// B instruction at offset 0 should now have imm26 = 2 (offset +8, /4 = 2)
	// B opcode = 0x14000000, imm26 = 2 → 0x14000002
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x14000002 {
		return fail("B forward encoding wrong after fixup")
	}
	return ""
}

func TestBranchBackward() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// target at offset 0, B target at offset 8 → PC-relative = -8, imm26 = -2
	asm.DefineLabel(a, "loop")
	Nop(a)                         // offset 0: NOP
	Nop(a)                         // offset 4: NOP
	B(a, "loop")                   // offset 8: B loop

	ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("unexpected error") }
	if a.NumRelocs != 0 { return fail("expected 0 relocations") }

	// B at offset 8, target at offset 0 → PC-relative = -8, imm26 = -2
	// -2 in 26-bit = 0x03FFFFFE, OR'd with B opcode 0x14000000
	// = 0x17FFFFFE
	var inst uint32 = readInst(a.Sections[0], 8)
	if inst != 0x17FFFFFE {
		return fail("B backward encoding wrong after fixup")
	}
	return ""
}

func TestBcondFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// B.EQ to forward label, offset 0 → 8, PC-relative = +8, imm19 = 2
	Bcond(a, COND_EQ, "skip")     // offset 0
	Nop(a)                         // offset 4
	asm.DefineLabel(a, "skip")     // offset 8
	Nop(a)                         // offset 8

	ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("unexpected error") }
	if a.NumRelocs != 0 { return fail("expected 0 relocations") }

	// B.EQ opcode = 0x54000000 | cond(0), imm19 = 2 → bits [23:5] = 2
	// = 0x54000040
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x54000040 {
		return fail("B.EQ fixup encoding wrong")
	}
	return ""
}

func TestCbzFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CBZ X0, skip: offset 0 → 8, imm19 = 2
	Cbz(a, true, X0, "skip")      // offset 0
	Nop(a)                          // offset 4
	asm.DefineLabel(a, "skip")      // offset 8
	Nop(a)                          // offset 8

	ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("unexpected error") }

	// CBZ X0 = sf(1)|0110100|imm19|Rt(0) = 0xB4000000 | (2 << 5) = 0xB4000040
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xB4000040 {
		return fail("CBZ fixup encoding wrong")
	}
	return ""
}

func TestExternalSymbolReloc() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// Branch to an undefined (external) symbol — should become a relocation
	asm.SetGlobal(a, "external_func")
	Bl(a, "external_func")

	ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("unexpected error") }
	if a.NumRelocs != 1 { return fail("expected 1 relocation for external branch") }
	return ""
}

// --- Sequence test: simple function prologue/epilogue ---

func TestPrologueEpilogue() testing.TestResult {
	var a @asm.Assembler = newAsm()

	// Function prologue
	Stp(a, true, FP, LR, MemPre(SP, -16))  // stp x29, x30, [sp, #-16]!
	Mov(a, true, FP, Reg(SP))               // mov x29, sp

	// Function body: just a NOP
	Nop(a)

	// Function epilogue
	Ldp(a, true, FP, LR, MemPost(SP, 16))   // ldp x29, x30, [sp], #16
	Ret(a)                                    // ret

	var s @asm.Section = a.Sections[0]
	if s.Len != 20 { return fail("expected 20 bytes (5 instructions)") }

	// Verify each instruction
	if readInst(s, 0) != 0xA9BF7BFD { return fail("stp wrong") }
	// MOV X29, SP = ADD X29, SP, #0 (because reg 31 in ORR Rm is XZR, not SP)
	// ADD X29, SP, #0 = 1|00|100010|0|000000000000|11111|11101 = 0x910003FD
	var movInst uint32 = readInst(s, 4)
	if movInst != 0x910003FD { return fail("mov x29, sp encoding wrong") }

	if readInst(s, 8) != 0xD503201F { return fail("nop wrong") }
	if readInst(s, 12) != 0xA8C17BFD { return fail("ldp wrong") }
	if readInst(s, 16) != 0xD65F03C0 { return fail("ret wrong") }

	return ""
}
