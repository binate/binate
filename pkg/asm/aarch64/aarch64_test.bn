package "pkg/asm/aarch64"

import "pkg/asm"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

// Read a little-endian uint32 from section data at offset
func readInst(s @asm.Section, off int) uint32 {
	return cast(uint32, s.Data[off]) |
		(cast(uint32, s.Data[off + 1]) << 8) |
		(cast(uint32, s.Data[off + 2]) << 16) |
		(cast(uint32, s.Data[off + 3]) << 24)
}

func newAsm() @asm.Assembler {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	return a
}

// --- Logical immediate tests ---

func TestAndImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// AND X0, X1, #0xFF (8 ones, no rotation)
	// element size = 8 (0xFF repeats at 8-bit period)
	// ones = 8, but wait — 0xFF in an 8-bit element is all-ones.
	// So the smallest non-trivial period is 16: 0x00FF repeats at 16-bit.
	// Actually: 0xFF = 0x00000000000000FF. Replicate: no period < 64 works
	// because upper bytes are 0. So element size = 64, N=1, ones=8, immr=0.
	// AND X imm: 1|00|100100|1|000000|000111|00001|00000
	// = 0x92401C20
	And(a, true, X0, X1, Imm(0xFF))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x92401C20 {
		return fail("AND X0, X1, #0xFF encoding wrong")
	}
	return ""
}

func TestOrrImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ORR X0, X1, #0x00FF00FF00FF00FF
	// Pattern: 0000000011111111 repeating at 16-bit element size
	// element=16, ones=8, start=0, immr=0
	// N=0, imms = ((~31) & 0x3f) | 7 = 0x20 | 7 = 0x27
	// ORR X imm: 1|01|100100|0|000000|100111|00001|00000
	// = 0xB2009C20
	var v int = 0x00FF00FF
	v = v | (v << 32)
	Orr(a, true, X0, X1, Imm(v))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xB2009C20 {
		return fail("ORR X0, X1, #0x00FF00FF00FF00FF encoding wrong")
	}
	return ""
}

func TestEorImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// EOR X0, X1, #1 (just bit 0)
	// element size=64 (no smaller period), ones=1, start=0, immr=0
	// N=1, imms=0
	// EOR X imm: 1|10|100100|1|000000|000000|00001|00000
	// = 0xD2400020
	Eor(a, true, X0, X1, Imm(1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xD2400020 {
		return fail("EOR X0, X1, #1 encoding wrong")
	}
	return ""
}

func TestAndImmMask() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// AND W0, W1, #0x7FFF (15 ones starting at bit 0)
	// element=32 (32-bit op), ones=15, start=0, immr=0
	// N=0, imms = (~63 & 0x3f) | 14 = 0 | 14 = 14
	// AND W imm: 0|00|100100|0|000000|001110|00001|00000
	// = 0x12003820
	And(a, false, X0, X1, Imm(0x7FFF))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x12003820 {
		return fail("AND W0, W1, #0x7FFF encoding wrong")
	}
	return ""
}

func TestTstImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// TST X0, #1 = ANDS XZR, X0, #1
	// N=1, immr=0, imms=0
	// ANDS X imm: 1|11|100100|1|000000|000000|00000|11111
	// = 0xF240001F
	Tst(a, true, X0, Imm(1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xF240001F {
		return fail("TST X0, #1 encoding wrong")
	}
	return ""
}

