// --- MOV / MVN ---

func TestMovReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV R0, R1 (opcode=1101, Rn=0)
	// = 0xE1A00001
	Mov(a, COND_AL, false, R0, Reg(R1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1A00001 {
		return fail("MOV R0, R1 encoding wrong")
	}
	return ""
}

func TestMovImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV R0, #0
	// = 0xE3A00000
	Mov(a, COND_AL, false, R0, Imm(0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE3A00000 {
		return fail("MOV R0, #0 encoding wrong")
	}
	return ""
}

func TestMvnReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MVN R0, R1 (opcode=1111)
	// = 0xE1E00001
	Mvn(a, COND_AL, false, R0, Reg(R1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1E00001 {
		return fail("MVN R0, R1 encoding wrong")
	}
	return ""
}

// --- CMP / CMN / TST / TEQ ---

func TestCmpReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CMP R0, R1 (opcode=1010, S=1 always, Rd=0)
	// = 0xE1500001
	Cmp(a, COND_AL, R0, Reg(R1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1500001 {
		return fail("CMP R0, R1 encoding wrong")
	}
	return ""
}

func TestCmpImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CMP R0, #10
	// = 0xE350000A
	Cmp(a, COND_AL, R0, Imm(10))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE350000A {
		return fail("CMP R0, #10 encoding wrong")
	}
	return ""
}

func TestTstReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// TST R0, R1 (opcode=1000, S=1)
	// = 0xE1100001
	Tst(a, COND_AL, R0, Reg(R1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1100001 {
		return fail("TST R0, R1 encoding wrong")
	}
	return ""
}

func TestTeqReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// TEQ R0, R1 (opcode=1001, S=1)
	// = 0xE1300001
	Teq(a, COND_AL, R0, Reg(R1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1300001 {
		return fail("TEQ R0, R1 encoding wrong")
	}
	return ""
}

// --- MOVW / MOVT ---

func TestMovwImm16() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOVW R0, #0x1234
	// cond=1110 | 0011 0000 | imm4=0001 | Rd=0000 | imm12=001000110100
	// = 0xE3010234
	Movw(a, COND_AL, R0, 0x1234)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE3010234 {
		return fail("MOVW R0, #0x1234 encoding wrong")
	}
	return ""
}

func TestMovtImm16() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOVT R0, #0xABCD
	// cond=1110 | 0011 0100 | imm4=1010 | Rd=0000 | imm12=101111001101
	// = 0xE34A0BCD
	Movt(a, COND_AL, R0, 0xABCD)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE34A0BCD {
		return fail("MOVT R0, #0xABCD encoding wrong")
	}
	return ""
}

// --- RSB / ADC / SBC ---

func TestRsbImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// RSB R0, R1, #0 (negate: R0 = 0 - R1)
	// opcode=0011
	// = 0xE2610000
	Rsb(a, COND_AL, false, R0, R1, Imm(0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE2610000 {
		return fail("RSB R0, R1, #0 encoding wrong")
	}
	return ""
}

func TestAdcReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADC R0, R1, R2 (opcode=0101)
	// = 0xE0A10002
	Adc(a, COND_AL, false, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0A10002 {
		return fail("ADC R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestSbcReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SBC R0, R1, R2 (opcode=0110)
	// = 0xE0C10002
	Sbc(a, COND_AL, false, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0C10002 {
		return fail("SBC R0, R1, R2 encoding wrong")
	}
	return ""
}
