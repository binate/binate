package "pkg/asm/arm32"

import "pkg/asm"
import "pkg/builtin/testing"

// --- ADD ---

func TestAddRegSimple() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADD R0, R1, R2 (AL, no S)
	// cond=1110 | 00 | I=0 | opcode=0100 | S=0 | Rn=0001 | Rd=0000
	//   | 00000 | 00 | 0 | Rm=0010
	// = 0xE0810002
	Add(a, COND_AL, false, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0810002 {
		return fail("ADD R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestAddImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADD R0, R1, #42 (AL, no S)
	// cond=1110 | 00 | I=1 | 0100 | S=0 | 0001 | 0000 | rot=0000 | imm8=00101010
	// = 0xE281002A
	Add(a, COND_AL, false, R0, R1, Imm(42))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE281002A {
		return fail("ADD R0, R1, #42 encoding wrong")
	}
	return ""
}

func TestAddsReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADDS R0, R1, R2 (set flags)
	// Same as ADD but S=1 (bit 20)
	// = 0xE0910002
	Add(a, COND_AL, true, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0910002 {
		return fail("ADDS R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestAddConditional() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADDEQ R0, R1, R2 (cond=EQ=0)
	// = 0x00810002
	Add(a, COND_EQ, false, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x00810002 {
		return fail("ADDEQ R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestAddRegShifted() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADD R0, R1, R2, LSL #3
	// operand2: shamt=00011 | type=00(LSL) | 0 | Rm=0010 = 0x182
	// = 0xE0810182
	Add(a, COND_AL, false, R0, R1, RegShift(R2, LSL, 3))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0810182 {
		return fail("ADD R0, R1, R2 LSL #3 encoding wrong")
	}
	return ""
}

// --- SUB ---

func TestSubRegSimple() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SUB R0, R1, R2
	// opcode=0010
	// = 0xE0410002
	Sub(a, COND_AL, false, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0410002 {
		return fail("SUB R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestSubImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SUB R3, R4, #16
	// = 0xE2443010
	Sub(a, COND_AL, false, R3, R4, Imm(16))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE2443010 {
		return fail("SUB R3, R4, #16 encoding wrong")
	}
	return ""
}

// --- AND / ORR / EOR / BIC ---

func TestAndReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// AND R0, R1, R2 (opcode=0000)
	// = 0xE0010002
	And(a, COND_AL, false, R0, R1, Reg(R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0010002 {
		return fail("AND R0, R1, R2 encoding wrong")
	}
	return ""
}

