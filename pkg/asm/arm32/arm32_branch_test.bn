package "pkg/asm/arm32"

import "pkg/asm"
import "pkg/builtin/testing"

// --- B / BL ---

func TestBLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// B label (AL) — emits placeholder with fixup
	// cond=1110 | 1010 | imm24=0
	// = 0xEA000000
	B(a, COND_AL, "target")
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xEA000000 {
		return fail("B target placeholder wrong")
	}
	return ""
}

func TestBlLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BL label (AL)
	// cond=1110 | 1011 | imm24=0
	// = 0xEB000000
	Bl(a, COND_AL, "target")
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xEB000000 {
		return fail("BL target placeholder wrong")
	}
	return ""
}

func TestBCondLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BEQ label (cond=0000)
	// = 0x0A000000
	B(a, COND_EQ, "target")
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0x0A000000 {
		return fail("BEQ target placeholder wrong")
	}
	return ""
}

// --- BX / BLX ---

func TestBxReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BX LR (return from function)
	// cond=1110 | 0001 0010 1111 1111 1111 0001 | Rm=1110(LR)
	// = 0xE12FFF1E
	Bx(a, COND_AL, LR)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE12FFF1E {
		return fail("BX LR encoding wrong")
	}
	return ""
}

func TestBlxReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BLX R3
	// = 0xE12FFF33
	Blx(a, COND_AL, R3)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE12FFF33 {
		return fail("BLX R3 encoding wrong")
	}
	return ""
}

// --- Branch fixup resolution ---

func TestBranchForwardFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// B .target ; offset = target - fixup - 8, then /4
	// fixup at 0, target at 12 -> offset = 12 - 0 - 8 = 4 -> 4/4 = 1
	B(a, COND_AL, "target")
	Nop(a)  // offset 4
	Nop(a)  // offset 8
	asm.DefineLabel(a, "target")
	Nop(a)  // offset 12

	var ok bool = ResolveFixups(a)
	if !ok {
		return fail("forward fixup resolution failed")
	}
	var inst uint32 = readInst(a.Sections[0], 0)
	// Expected: 0xEA000001 (branch forward 1 word past PC+8)
	if inst != 0xEA000001 {
		return fail("B forward fixup encoding wrong")
	}
	return ""
}

func TestBranchBackwardFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// target:
	//   NOP          ; offset 0
	//   B target     ; offset 4, target at 0
	// offset = 0 - 4 - 8 = -12 -> -12/4 = -3
	asm.DefineLabel(a, "target")
	Nop(a)  // offset 0
	B(a, COND_AL, "target")  // offset 4

	var ok bool = ResolveFixups(a)
	if !ok {
		return fail("backward fixup resolution failed")
	}
	var inst uint32 = readInst(a.Sections[0], 4)
	// Expected: 0xEAFFFFFD (-3 in 24-bit signed = 0xFFFFFD)
	if inst != 0xEAFFFFFD {
		return fail("B backward fixup encoding wrong")
	}
	return ""
}

func TestBlForwardFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BL target ; fixup at 0, target at 8
	// offset = 8 - 0 - 8 = 0 -> 0/4 = 0
	Bl(a, COND_AL, "target")
	Nop(a)
	asm.DefineLabel(a, "target")
	Nop(a)

	var ok bool = ResolveFixups(a)
	if !ok {
		return fail("BL forward fixup failed")
	}
	var inst uint32 = readInst(a.Sections[0], 0)
	// Expected: 0xEB000000 (offset 0 — target is exactly at PC+8)
	if inst != 0xEB000000 {
		return fail("BL forward fixup encoding wrong")
	}
	return ""
}

// --- MUL / MLA ---

func TestMulReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MUL R0, R1, R2 (no S)
	// cond=1110 | 0000000 | S=0 | Rd=0000 | 0000 | Rm=0010
	//   | 1001 | Rn=0001
	// = 0xE0000291
	Mul(a, COND_AL, false, R0, R1, R2)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0000291 {
		return fail("MUL R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestMlaReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MLA R0, R1, R2, R3
	// cond=1110 | 0000001 | S=0 | Rd=0000 | Ra=0011 | Rm=0010
	//   | 1001 | Rn=0001
	// = 0xE0203291
	Mla(a, COND_AL, false, R0, R1, R2, R3)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0203291 {
		return fail("MLA R0, R1, R2, R3 encoding wrong")
	}
	return ""
}

// --- UMULL / SMULL ---

func TestUmull() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// UMULL R0, R1, R2, R3
	// cond=1110 | 0000100 | S=0 | RdHi=0001 | RdLo=0000
	//   | Rm=0011 | 1001 | Rn=0010
	// = 0xE0810392
	Umull(a, COND_AL, false, R0, R1, R2, R3)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0810392 {
		return fail("UMULL encoding wrong")
	}
	return ""
}

func TestSmull() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SMULL R0, R1, R2, R3
	// cond=1110 | 0000110 | S=0 | RdHi=0001 | RdLo=0000
	//   | Rm=0011 | 1001 | Rn=0010
	// = 0xE0C10392
	Smull(a, COND_AL, false, R0, R1, R2, R3)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE0C10392 {
		return fail("SMULL encoding wrong")
	}
	return ""
}

// --- SDIV / UDIV ---

func TestSdiv() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SDIV R0, R1, R2
	// cond=1110 | 0111 0001 | Rd=0000 | 1111 | Rm=0010 | 0001 | Rn=0001
	// = 0xE710F211
	Sdiv(a, COND_AL, R0, R1, R2)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE710F211 {
		return fail("SDIV R0, R1, R2 encoding wrong")
	}
	return ""
}

func TestUdiv() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// UDIV R0, R1, R2
	// cond=1110 | 0111 0011 | Rd=0000 | 1111 | Rm=0010 | 0001 | Rn=0001
	// = 0xE730F211
	Udiv(a, COND_AL, R0, R1, R2)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE730F211 {
		return fail("UDIV R0, R1, R2 encoding wrong")
	}
	return ""
}

// --- CLZ ---

func TestClz() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CLZ R0, R1
	// cond=1110 | 0001 0110 | 1111 | Rd=0000 | 1111 | 0001 | Rm=0001
	// = 0xE16F0F11
	Clz(a, COND_AL, R0, R1)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE16F0F11 {
		return fail("CLZ R0, R1 encoding wrong")
	}
	return ""
}
