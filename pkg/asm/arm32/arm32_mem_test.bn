package "pkg/asm/arm32"

import "pkg/asm"
import "pkg/builtin/testing"

// --- LDR / STR ---

func TestLdrImmOffset() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1, #8]
	// cond=1110 | 01 | I=0 | P=1 | U=1 | B=0 | W=0 | L=1
	//   | Rn=0001 | Rt=0000 | imm12=000000001000
	// = 0xE5910008
	Ldr(a, COND_AL, R0, MemImm(R1, 8))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5910008 {
		return fail("LDR R0, [R1, #8] encoding wrong")
	}
	return ""
}

func TestLdrImmNegOffset() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1, #-4]
	// U=0 (subtract), offset=4
	// = 0xE5110004
	Ldr(a, COND_AL, R0, MemImm(R1, -4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5110004 {
		return fail("LDR R0, [R1, #-4] encoding wrong")
	}
	return ""
}

func TestLdrImmZero() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1] = LDR R0, [R1, #0]
	// = 0xE5910000
	Ldr(a, COND_AL, R0, MemImm(R1, 0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5910000 {
		return fail("LDR R0, [R1] encoding wrong")
	}
	return ""
}

func TestStrImmOffset() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// STR R0, [R1, #4]
	// L=0
	// = 0xE5810004
	Str(a, COND_AL, R0, MemImm(R1, 4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5810004 {
		return fail("STR R0, [R1, #4] encoding wrong")
	}
	return ""
}

func TestLdrRegOffset() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1, R2]
	// I=1, P=1, U=1, L=1
	// = 0xE7910002
	Ldr(a, COND_AL, R0, MemReg(R1, R2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE7910002 {
		return fail("LDR R0, [R1, R2] encoding wrong")
	}
	return ""
}

func TestLdrPreIndex() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1, #4]!
	// P=1, W=1 (pre-index writeback)
	// = 0xE5B10004
	Ldr(a, COND_AL, R0, MemPre(R1, 4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5B10004 {
		return fail("LDR R0, [R1, #4]! encoding wrong")
	}
	return ""
}

func TestLdrPostIndex() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1], #4
	// P=0, W=0 (post-index)
	// = 0xE4910004
	Ldr(a, COND_AL, R0, MemPost(R1, 4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE4910004 {
		return fail("LDR R0, [R1], #4 encoding wrong")
	}
	return ""
}

// --- LDRB / STRB ---

func TestLdrbImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDRB R0, [R1, #0]
	// B=1 (bit 22)
	// = 0xE5D10000
	Ldrb(a, COND_AL, R0, MemImm(R1, 0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5D10000 {
		return fail("LDRB R0, [R1] encoding wrong")
	}
	return ""
}

func TestStrbImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// STRB R0, [R1, #1]
	// = 0xE5C10001
	Strb(a, COND_AL, R0, MemImm(R1, 1))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE5C10001 {
		return fail("STRB R0, [R1, #1] encoding wrong")
	}
	return ""
}

// --- LDRH / STRH ---

func TestLdrhImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDRH R0, [R1, #0]
	// Extra load/store: 000 | P=1 | U=1 | I=1 | W=0 | L=1
	//   | Rn=0001 | Rt=0000 | immH=0000 | 1 | SH=01 | 1 | immL=0000
	// = 0xE1D100B0
	Ldrh(a, COND_AL, R0, MemImm(R1, 0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1D100B0 {
		return fail("LDRH R0, [R1] encoding wrong")
	}
	return ""
}

func TestStrhImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// STRH R0, [R1, #4]
	// L=0, I=1, offset=4 (immH=0, immL=4)
	// = 0xE1C100B4
	Strh(a, COND_AL, R0, MemImm(R1, 4))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1C100B4 {
		return fail("STRH R0, [R1, #4] encoding wrong")
	}
	return ""
}

func TestLdrsbImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDRSB R0, [R1, #0]
	// SH=10 (signed byte)
	// = 0xE1D100D0
	Ldrsb(a, COND_AL, R0, MemImm(R1, 0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1D100D0 {
		return fail("LDRSB R0, [R1] encoding wrong")
	}
	return ""
}

func TestLdrshImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDRSH R0, [R1, #0]
	// SH=11 (signed halfword)
	// = 0xE1D100F0
	Ldrsh(a, COND_AL, R0, MemImm(R1, 0))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1D100F0 {
		return fail("LDRSH R0, [R1] encoding wrong")
	}
	return ""
}

// --- LDM / STM / PUSH / POP ---

func TestPush() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// PUSH {R4, LR} = STMDB SP!, {R4, LR}
	// regmask = (1<<4) | (1<<14) = 0x4010
	// STM: cond=1110 | 100 | P=1 | U=0 | S=0 | W=1 | L=0
	//   | Rn=1101(SP) | regmask
	// = 0xE92D4010
	var mask int = (1 << 4) | (1 << 14)
	Push(a, COND_AL, mask)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE92D4010 {
		return fail("PUSH {R4, LR} encoding wrong")
	}
	return ""
}

func TestPop() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// POP {R4, PC} = LDM SP!, {R4, PC}
	// regmask = (1<<4) | (1<<15) = 0x8010
	// LDM: cond=1110 | 100 | P=0 | U=1 | S=0 | W=1 | L=1
	//   | Rn=1101(SP) | regmask
	// = 0xE8BD8010
	var mask int = (1 << 4) | (1 << 15)
	Pop(a, COND_AL, mask)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE8BD8010 {
		return fail("POP {R4, PC} encoding wrong")
	}
	return ""
}

func TestStmdb() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// STMDB R0!, {R1, R2, R3}
	// regmask = (1<<1)|(1<<2)|(1<<3) = 0x000E
	// = 0xE920000E
	var mask int = (1 << 1) | (1 << 2) | (1 << 3)
	Stmdb(a, COND_AL, R0, true, mask)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE920000E {
		return fail("STMDB R0!, {R1-R3} encoding wrong")
	}
	return ""
}

func TestLdm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDM R0, {R1, R2} (no writeback)
	// P=0, U=1, W=0, L=1
	// regmask = (1<<1)|(1<<2) = 0x0006
	// = 0xE8900006
	var mask int = (1 << 1) | (1 << 2)
	Ldm(a, COND_AL, R0, false, mask)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE8900006 {
		return fail("LDM R0, {R1, R2} encoding wrong")
	}
	return ""
}

// --- Scaled register offset ---

func TestLdrSregOffset() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LDR R0, [R1, R2, LSL #2]
	// I=1, P=1, U=1, shift=LSL=00, shamt=2
	// operand: 00010 | 00 | 0 | 0010 = 0x00000102
	// = 0xE7910102
	Ldr(a, COND_AL, R0, MemSReg(R1, R2, LSL, 2))
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE7910102 {
		return fail("LDR R0, [R1, R2, LSL #2] encoding wrong")
	}
	return ""
}
