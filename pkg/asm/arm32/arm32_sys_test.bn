package "pkg/asm/arm32"

import "pkg/asm"
import "pkg/builtin/testing"

// --- NOP ---

func TestNop() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// NOP = MOV R0, R0
	// = 0xE1A00000
	Nop(a)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1A00000 {
		return fail("NOP encoding wrong")
	}
	return ""
}

// --- SVC ---

func TestSvc() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SVC #0 (AL)
	// cond=1110 | 1111 | imm24=0
	// = 0xEF000000
	Svc(a, COND_AL, 0)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xEF000000 {
		return fail("SVC #0 encoding wrong")
	}
	return ""
}

func TestSvcImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SVC #1
	// = 0xEF000001
	Svc(a, COND_AL, 1)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xEF000001 {
		return fail("SVC #1 encoding wrong")
	}
	return ""
}

// --- BKPT ---

func TestBkpt() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BKPT #0
	// 1110 | 0001 0010 | 000000000000 | 0111 | 0000
	// = 0xE1200070
	Bkpt(a, 0)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1200070 {
		return fail("BKPT #0 encoding wrong")
	}
	return ""
}

func TestBkptImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// BKPT #0x1234
	// imm12 = 0x123 (bits [19:8]), imm4 = 0x4 (bits [3:0])
	// 0xE1200070 | (0x123 << 8) | 0x4 = 0xE1212374
	Bkpt(a, 0x1234)
	var inst uint32 = readInst(a.Sections[0], 0)
	if inst != 0xE1212374 {
		return fail("BKPT #0x1234 encoding wrong")
	}
	return ""
}
