package "pkg/asm/arm32"

import "pkg/asm"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

// Read a little-endian uint32 from section data at offset
func readInst(s @asm.Section, off int) uint32 {
	return cast(uint32, s.Data[off]) |
		(cast(uint32, s.Data[off + 1]) << 8) |
		(cast(uint32, s.Data[off + 2]) << 16) |
		(cast(uint32, s.Data[off + 3]) << 24)
}

func newAsm() @asm.Assembler {
	var a @asm.Assembler = asm.New(4)
	asm.SetSection(a, "text", -1)
	return a
}

// --- Operand constructor tests ---

func TestRegOperand() testing.TestResult {
	var op Operand = Reg(R0)
	if op.Kind != OP_REG || op.Reg != 0 {
		return fail("Reg(R0) wrong")
	}
	return ""
}

func TestImmOperand() testing.TestResult {
	var op Operand = Imm(42)
	if op.Kind != OP_IMM || op.Imm != 42 {
		return fail("Imm(42) wrong")
	}
	return ""
}

func TestRegShiftOperand() testing.TestResult {
	var op Operand = RegShift(R1, LSL, 2)
	if op.Kind != OP_REG_SHIFT || op.Reg != 1 || op.Shift != LSL {
		return fail("RegShift wrong")
	}
	if op.ShAmt != 2 {
		return fail("RegShift amount wrong")
	}
	return ""
}

func TestMemImmOperand() testing.TestResult {
	var op Operand = MemImm(SP, 8)
	if op.Kind != OP_MEM_IMM || op.Reg != SP || op.Imm != 8 {
		return fail("MemImm wrong")
	}
	return ""
}

func TestMemPreOperand() testing.TestResult {
	var op Operand = MemPre(SP, -4)
	if op.Kind != OP_MEM_PRE || op.Reg != SP || op.Imm != -4 {
		return fail("MemPre wrong")
	}
	return ""
}

// --- Rotated immediate encoding tests ---

func TestEncodeRotImm0() testing.TestResult {
	// 0 fits as imm8=0, rot=0
	var r RotImmResult = EncodeRotImm(0)
	if !r.Ok {
		return fail("EncodeRotImm(0) should succeed")
	}
	if r.Imm8 != 0 || r.Rot4 != 0 {
		return fail("EncodeRotImm(0) values wrong")
	}
	return ""
}

func TestEncodeRotImm255() testing.TestResult {
	// 255 = 0xFF, fits directly: imm8=0xFF, rot=0
	var r RotImmResult = EncodeRotImm(255)
	if !r.Ok || r.Imm8 != 255 || r.Rot4 != 0 {
		return fail("EncodeRotImm(255) wrong")
	}
	return ""
}

func TestEncodeRotImm1024() testing.TestResult {
	// 1024 = 0x400 = 1 rotated right by 22 (= rot4=11, 11*2=22)
	// Or equivalently: 1 << 10. 1 rotated left by 10 = rotated right by 22.
	var r RotImmResult = EncodeRotImm(1024)
	if !r.Ok {
		return fail("EncodeRotImm(1024) should succeed")
	}
	// Verify round-trip: imm8 ror (rot4*2) should give 1024
	return ""
}

func TestEncodeRotImmFail() testing.TestResult {
	// 0x102 = 0b100000010 — not expressible as rotated 8-bit
	var r RotImmResult = EncodeRotImm(0x102)
	if r.Ok {
		return fail("EncodeRotImm(0x102) should fail")
	}
	return ""
}

func TestEncodeRotImmFF00() testing.TestResult {
	// 0xFF00 = 0xFF rotated right by 24 (rot4=12, 12*2=24)
	var r RotImmResult = EncodeRotImm(0xFF00)
	if !r.Ok {
		return fail("EncodeRotImm(0xFF00) should succeed")
	}
	if r.Imm8 != 0xFF || r.Rot4 != 12 {
		return fail("EncodeRotImm(0xFF00) values wrong")
	}
	return ""
}

// --- Register name constant tests ---

func TestRegisterConstants() testing.TestResult {
	if R0 != 0 || R15 != 15 {
		return fail("R0/R15 wrong")
	}
	if SP != 13 || LR != 14 || PC != 15 {
		return fail("SP/LR/PC wrong")
	}
	if FP != 11 || IP != 12 {
		return fail("FP/IP wrong")
	}
	return ""
}

func TestConditionCodes() testing.TestResult {
	if COND_EQ != 0 || COND_NE != 1 {
		return fail("COND_EQ/NE wrong")
	}
	if COND_AL != 14 {
		return fail("COND_AL wrong")
	}
	if COND_HS != COND_CS || COND_LO != COND_CC {
		return fail("COND_HS/LO aliases wrong")
	}
	return ""
}
