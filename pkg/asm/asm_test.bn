package "pkg/asm"

import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func TestNew() testing.TestResult {
	var a @Assembler = New(8)
	if a.WordSize != 8 { return fail("expected word size 8") }
	if a.NumSections != 0 { return fail("expected 0 sections") }
	if a.NumSymbols != 0 { return fail("expected 0 symbols") }
	if a.Current != -1 { return fail("expected current = -1") }
	if a.HasError { return fail("expected no error") }
	return ""
}

func TestSetSection() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	if a.NumSections != 1 { return fail("expected 1 section") }
	if a.Current != 0 { return fail("expected current = 0") }
	if a.Sections[0].Flags != (SF_READ | SF_EXEC) {
		return fail("expected text section flags = read|exec")
	}

	// Switching to same section doesn't create a new one
	SetSection(a, "text", -1)
	if a.NumSections != 1 { return fail("expected still 1 section") }

	// Create data section
	SetSection(a, "data", -1)
	if a.NumSections != 2 { return fail("expected 2 sections") }
	if a.Current != 1 { return fail("expected current = 1") }
	if a.Sections[1].Flags != (SF_READ | SF_WRITE) {
		return fail("expected data section flags = read|write")
	}
	return ""
}

func TestEmitBytes() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	EmitUint8(a, 0x90)
	EmitUint8(a, 0x91)
	var s @Section = a.Sections[0]
	if s.Len != 2 { return fail("expected len 2") }
	if s.Data[0] != 0x90 { return fail("expected 0x90") }
	if s.Data[1] != 0x91 { return fail("expected 0x91") }
	return ""
}

func TestEmitUint32() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	EmitUint32(a, 0xDEADBEEF)
	var s @Section = a.Sections[0]
	if s.Len != 4 { return fail("expected len 4") }
	// Little-endian: EF BE AD DE
	if s.Data[0] != 0xEF { return fail("expected byte 0 = 0xEF") }
	if s.Data[1] != 0xBE { return fail("expected byte 1 = 0xBE") }
	if s.Data[2] != 0xAD { return fail("expected byte 2 = 0xAD") }
	if s.Data[3] != 0xDE { return fail("expected byte 3 = 0xDE") }
	return ""
}

func TestDefineLabel() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	EmitUint32(a, 0)  // 4 bytes of padding
	DefineLabel(a, "my_label")
	if a.NumSymbols != 1 { return fail("expected 1 symbol") }
	if a.Symbols[0].Section != 0 { return fail("expected section 0") }
	if a.Symbols[0].Offset != 4 { return fail("expected offset 4") }
	if a.Symbols[0].Binding != BIND_LOCAL { return fail("expected local binding") }
	return ""
}

func TestSetGlobal() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	DefineLabel(a, "my_func")
	SetGlobal(a, "my_func")
	if a.Symbols[0].Binding != BIND_GLOBAL { return fail("expected global binding") }

	// SetGlobal on undefined symbol creates it
	SetGlobal(a, "external")
	if a.NumSymbols != 2 { return fail("expected 2 symbols") }
	if a.Symbols[1].Section != -1 { return fail("expected section -1 for external") }
	if a.Symbols[1].Binding != BIND_GLOBAL { return fail("expected global binding") }
	return ""
}

func TestAlign() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	EmitUint8(a, 0x01)
	Align(a, 4)
	var s @Section = a.Sections[0]
	if s.Len != 4 { return fail("expected len 4 after align") }
	// Padding bytes should be zero
	if s.Data[1] != 0 { return fail("expected zero padding") }
	if s.Data[2] != 0 { return fail("expected zero padding") }
	if s.Data[3] != 0 { return fail("expected zero padding") }

	// Already aligned — no change
	Align(a, 4)
	if s.Len != 4 { return fail("expected still len 4") }
	return ""
}

func TestZeroAndFill() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "data", -1)
	Zero(a, 4)
	Fill(a, 3, 0xCC)
	var s @Section = a.Sections[0]
	if s.Len != 7 { return fail("expected len 7") }
	if s.Data[0] != 0 { return fail("expected zero") }
	if s.Data[3] != 0 { return fail("expected zero") }
	if s.Data[4] != 0xCC { return fail("expected 0xCC") }
	if s.Data[6] != 0xCC { return fail("expected 0xCC") }
	return ""
}

func TestEmitAsciz() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "rodata", -1)
	EmitAsciz(a, "hi")
	var s @Section = a.Sections[0]
	if s.Len != 3 { return fail("expected len 3 (hi + null)") }
	if s.Data[0] != 'h' { return fail("expected 'h'") }
	if s.Data[1] != 'i' { return fail("expected 'i'") }
	if s.Data[2] != 0 { return fail("expected null terminator") }
	return ""
}

func TestCurrentOffset() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	if CurrentOffset(a) != 0 { return fail("expected offset 0") }
	EmitUint32(a, 0)
	if CurrentOffset(a) != 4 { return fail("expected offset 4") }
	EmitUint32(a, 0)
	if CurrentOffset(a) != 8 { return fail("expected offset 8") }
	return ""
}

func TestNoSectionError() testing.TestResult {
	var a @Assembler = New(8)
	EmitUint8(a, 0)
	if !a.HasError { return fail("expected error when no section set") }
	return ""
}

func TestDuplicateLabel() testing.TestResult {
	var a @Assembler = New(8)
	SetSection(a, "text", -1)
	DefineLabel(a, "dup")
	DefineLabel(a, "dup")
	if !a.HasError { return fail("expected error on duplicate label") }
	return ""
}
