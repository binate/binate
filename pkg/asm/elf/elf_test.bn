package "pkg/asm/elf"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/asm/arm32"
import "pkg/bootstrap"
import "pkg/buf"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

// Test writing a simple AArch64 ELF object file and verify the header.
func TestWriteSimpleElf() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")
	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(42))
	aarch64.Ret(a)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("assembler error") }

	var path []char = "/tmp/binate_elf_test.o"
	var ok bool = WriteAArch64(a, path)
	if !ok { return fail("failed to write ELF") }

	// Read the file back and verify ELF magic
	var fd int = bootstrap.Open(path, bootstrap.O_RDONLY)
	if fd < 0 { return fail("cannot open ELF file") }
	var hdr @[]uint8 = make_slice(uint8, 64)
	var raw []uint8 = hdr
	var n int = bootstrap.Read(fd, raw, 64)
	bootstrap.Close(fd)
	if n < 64 { return fail("ELF file too small") }

	// ELF magic: 7f 45 4c 46
	if hdr[0] != 0x7f { return fail("bad magic[0]") }
	if hdr[1] != 0x45 { return fail("bad magic[1]") }
	if hdr[2] != 0x4c { return fail("bad magic[2]") }
	if hdr[3] != 0x46 { return fail("bad magic[3]") }

	// Class: 64-bit
	if hdr[4] != 2 { return fail("expected ELFCLASS64") }
	// Data: little-endian
	if hdr[5] != 1 { return fail("expected ELFDATA2LSB") }
	// Type: ET_REL = 1 (at offset 16, little-endian uint16)
	if hdr[16] != 1 || hdr[17] != 0 { return fail("expected ET_REL") }
	// Machine: EM_AARCH64 = 183 = 0xB7 (at offset 18)
	if hdr[18] != 0xB7 || hdr[19] != 0 { return fail("expected EM_AARCH64") }

	return ""
}

// Test ELF with multiple sections.
func TestWriteMultiSection() testing.TestResult {
	var a @asm.Assembler = asm.New(8)

	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "func1")
	asm.SetGlobal(a, "func1")
	aarch64.Nop(a)
	aarch64.Ret(a)

	asm.SetSection(a, "data", -1)
	asm.EmitUint32(a, 0xDEADBEEF)

	asm.SetSection(a, "rodata", -1)
	asm.EmitAsciz(a, "hello")

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	var path []char = "/tmp/binate_elf_multi.o"
	var ok bool = WriteAArch64(a, path)
	if !ok { return fail("failed to write ELF") }

	// Verify file exists and has reasonable size
	if bootstrap.Stat(path) != 1 { return fail("ELF file not found") }
	return ""
}

// Test ELF with relocations.
func TestWriteElfReloc() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "caller")
	asm.SetGlobal(a, "caller")
	asm.SetGlobal(a, "external")
	aarch64.Bl(a, "external")
	aarch64.Ret(a)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("assembler error") }
	if a.NumRelocs != 1 { return fail("expected 1 relocation") }

	var path []char = "/tmp/binate_elf_reloc.o"
	var ok bool = WriteAArch64(a, path)
	if !ok { return fail("failed to write ELF") }

	if bootstrap.Stat(path) != 1 { return fail("ELF file not found") }
	return ""
}

// Test x86-64 ELF header.
func TestWriteX86Elf() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	// Just emit some bytes (no real x86 instructions, just testing the header)
	asm.EmitUint8(a, 0xC3)  // ret
	asm.Finalize(a)

	var path []char = "/tmp/binate_elf_x86.o"
	var ok bool = WriteX86_64(a, path)
	if !ok { return fail("failed to write ELF") }

	var fd int = bootstrap.Open(path, bootstrap.O_RDONLY)
	if fd < 0 { return fail("cannot open ELF file") }
	var hdr @[]uint8 = make_slice(uint8, 64)
	var raw []uint8 = hdr
	bootstrap.Read(fd, raw, 64)
	bootstrap.Close(fd)

	// Machine: EM_X86_64 = 62 = 0x3E
	if hdr[18] != 0x3E || hdr[19] != 0 { return fail("expected EM_X86_64") }
	return ""
}

// Test ARM32 ELF32 header.
func TestWriteArm32Elf() testing.TestResult {
	var a @asm.Assembler = asm.New(4)
	asm.SetSection(a, "text", -1)
	// Emit a NOP (MOV R0, R0 = 0xE1A00000)
	asm.EmitUint32(a, 0xE1A00000)
	asm.Finalize(a)

	var path []char = "/tmp/binate_elf_arm32.o"
	var ok bool = WriteARM32(a, path)
	if !ok { return fail("failed to write ARM32 ELF") }

	var fd int = bootstrap.Open(path, bootstrap.O_RDONLY)
	if fd < 0 { return fail("cannot open ELF file") }
	var hdr @[]uint8 = make_slice(uint8, 52)
	var raw []uint8 = hdr
	bootstrap.Read(fd, raw, 52)
	bootstrap.Close(fd)

	// Magic
	if hdr[0] != 0x7f || hdr[1] != 0x45 {
		return fail("bad magic")
	}
	// Class: 32-bit (ELFCLASS32 = 1)
	if hdr[4] != 1 { return fail("expected ELFCLASS32") }
	// Data: little-endian
	if hdr[5] != 1 { return fail("expected ELFDATA2LSB") }
	// Type: ET_REL = 1
	if hdr[16] != 1 || hdr[17] != 0 { return fail("expected ET_REL") }
	// Machine: EM_ARM = 40 = 0x28
	if hdr[18] != 0x28 || hdr[19] != 0 {
		return fail("expected EM_ARM")
	}
	// e_ehsize at offset 40 (ELF32) should be 52
	if hdr[40] != 52 || hdr[41] != 0 {
		return fail("expected e_ehsize=52")
	}
	// e_shentsize at offset 46 should be 40
	if hdr[46] != 40 || hdr[47] != 0 {
		return fail("expected e_shentsize=40")
	}
	return ""
}

// --- ARM32 semihosting end-to-end tests ---
// These assemble ARM32 code, link as bare-metal ELF32, and run under
// qemu-system-arm with semihosting. The semihosting ABI lets us exit
// with a specific code (SYS_EXIT_EXTENDED) without needing a Linux
// userspace or syscall forwarding.

func canRunArm32Semihosting() bool {
	// Check for qemu-system-arm
	var args @[]@[]char = make_slice(@[]char, 1)
	args[0] = bootstrap.Concat("--version", "")
	var exit int = bootstrap.Exec("qemu-system-arm", args)
	if exit != 0 { return false }
	// Check for arm-none-eabi-ld
	var args2 @[]@[]char = make_slice(@[]char, 1)
	args2[0] = bootstrap.Concat("--version", "")
	var exit2 int = bootstrap.Exec("arm-none-eabi-ld", args2)
	return exit2 == 0
}

// writeLinkerScript writes a minimal bare-metal linker script for the
// ARM virt machine (RAM at 0x40000000).
func writeLinkerScript(path []char) bool {
	var fd int = bootstrap.Open(path,
		bootstrap.O_WRONLY | bootstrap.O_CREATE | bootstrap.O_TRUNC)
	if fd < 0 { return false }
	var cb buf.CharBuf = buf.New()
	cb = buf.WriteStr(cb, "ENTRY(_start)\n")
	cb = buf.WriteStr(cb, "SECTIONS {\n")
	cb = buf.WriteStr(cb, "    . = 0x40000000;\n")
	cb = buf.WriteStr(cb, "    .text : { *(.text) }\n")
	cb = buf.WriteStr(cb, "    .data : { *(.data) }\n")
	cb = buf.WriteStr(cb, "}\n")
	var data []char = buf.Bytes(cb)
	bootstrap.Write(fd, data, len(data))
	bootstrap.Close(fd)
	return true
}

// linkArm32 links an ARM32 ELF object into a bare-metal executable.
func linkArm32(objPath []char, elfPath []char, ldScript []char) bool {
	var args @[]@[]char = make_slice(@[]char, 5)
	args[0] = bootstrap.Concat("-T", "")
	args[1] = bootstrap.Concat(ldScript, "")
	args[2] = bootstrap.Concat("-o", "")
	args[3] = bootstrap.Concat(elfPath, "")
	args[4] = bootstrap.Concat(objPath, "")
	var exit int = bootstrap.Exec("arm-none-eabi-ld", args)
	return exit == 0
}

// runArm32Semihosting runs a bare-metal ELF under QEMU with semihosting.
func runArm32Semihosting(elfPath []char) int {
	var args @[]@[]char = make_slice(@[]char, 8)
	args[0] = bootstrap.Concat("-M", "")
	args[1] = bootstrap.Concat("virt", "")
	args[2] = bootstrap.Concat("-cpu", "")
	args[3] = bootstrap.Concat("cortex-a15", "")
	args[4] = bootstrap.Concat("-semihosting", "")
	args[5] = bootstrap.Concat("-nographic", "")
	args[6] = bootstrap.Concat("-kernel", "")
	args[7] = bootstrap.Concat(elfPath, "")
	return bootstrap.Exec("qemu-system-arm", args)
}

// semiExit emits ARM32 semihosting SYS_EXIT_EXTENDED with a given
// exit code. Uses movw/movt to build the address of the exit block
// in the data section. The caller must define "exit_block" as a label
// in the data section containing {0x20026, exitCode}.
func semiExit(a @asm.Assembler, exitBlockLabel []char) {
	// mov r0, #0x20 (SYS_EXIT_EXTENDED)
	arm32.Mov(a, arm32.COND_AL, false, arm32.R0, arm32.Imm(0x20))
	// Load exit_block address via label fixup
	// For now, use a simple approach: emit the address in a literal
	// after the svc and load it PC-relative.
	// Actually: we can use the label mechanism with LDR.
	arm32.Ldr(a, arm32.COND_AL, arm32.R1, arm32.Label(exitBlockLabel))
	// svc #0x123456
	arm32.Svc(a, arm32.COND_AL, 0x123456)
}

// emitExitBlock emits a semihosting exit block in the data section:
// {ADP_Stopped_ApplicationExit (0x20026), exitCode}.
func emitExitBlock(a @asm.Assembler, label []char, exitCode int) {
	asm.DefineLabel(a, label)
	// 0x20026 = ADP_Stopped_ApplicationExit
	asm.EmitUint32(a, 0x00020026)
	asm.EmitUint32(a, cast(uint32, exitCode))
}

// Test: exit with code 42 via semihosting.
func TestArm32SemihostingExit() testing.TestResult {
	if !canRunArm32Semihosting() { return "" }

	var a @asm.Assembler = asm.New(4)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")

	// mov r0, #0x20 (SYS_EXIT_EXTENDED)
	arm32.Mov(a, arm32.COND_AL, false, arm32.R0, arm32.Imm(0x20))
	// movw r1, #low16(exit_block)  — filled by linker via relocation
	// movt r1, #high16(exit_block) — filled by linker via relocation
	// For now, build the address manually with known data layout.
	// Data section follows text. text = _start + 3 instrs + literal
	// This is fragile; instead use movw/movt with known address.
	// The virt machine loads at 0x40000000. Our text is small, data
	// follows immediately. Let's place the exit block right after the
	// code using .data section and use movw/movt with the address.
	// Actually, the simplest approach: put the exit block in .text
	// right after the svc, and use a PC-relative offset.
	// Simplest: use inline data after a branch-to-self.

	// Let's just build a flat binary with data after code:
	// _start:
	//   mov r0, #0x20
	//   ldr r1, [pc, #4]    ; load address from literal pool
	//   svc #0x123456
	//   b .                  ; halt
	//   .word exit_block     ; literal pool
	// exit_block:
	//   .word 0x20026
	//   .word 42
	//
	// PC-relative: at the ldr, PC = addr+8, offset=4, loads from addr+12
	// That's right after the b instruction at addr+12.

	// Emit ldr r1, [pc, #4]
	arm32.Ldr(a, arm32.COND_AL, arm32.R1, arm32.MemImm(arm32.PC, 4))
	arm32.Svc(a, arm32.COND_AL, 0x123456)
	// b . (infinite loop as safety)
	asm.DefineLabel(a, "halt")
	arm32.B(a, arm32.COND_AL, "halt")
	// Literal pool: address of exit_block (filled at link time)
	asm.EmitAddr(a, "exit_block")

	// Exit block (in same section for simplicity)
	asm.DefineLabel(a, "exit_block")
	asm.EmitUint32(a, 0x00020026)
	asm.EmitUint32(a, 42)

	arm32.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail(a.ErrorMsg) }

	var objPath []char = "/tmp/binate_arm32_semi.o"
	if !WriteARM32(a, objPath) { return fail("write ELF failed") }

	var ldScript []char = "/tmp/binate_arm32.ld"
	if !writeLinkerScript(ldScript) { return fail("write ld script failed") }

	var elfPath []char = "/tmp/binate_arm32_semi.elf"
	if !linkArm32(objPath, elfPath, ldScript) {
		return fail("link failed")
	}

	var exitCode int = runArm32Semihosting(elfPath)
	if exitCode != 42 { return fail("expected exit code 42") }
	return ""
}

// emitSemiExit emits the semihosting exit sequence. The exit block
// must immediately follow this code (label + 2 words of data).
// blockLabel is the label for the exit block.
func emitSemiExit(a @asm.Assembler, blockLabel []char) {
	// mov r0, #0x20 (SYS_EXIT_EXTENDED)
	arm32.Mov(a, arm32.COND_AL, false, arm32.R0, arm32.Imm(0x20))
	// ldr r1, [pc, #4] — load exit_block address from literal pool
	arm32.Ldr(a, arm32.COND_AL, arm32.R1, arm32.MemImm(arm32.PC, 4))
	// svc #0x123456
	arm32.Svc(a, arm32.COND_AL, 0x123456)
	// b . (safety halt)
	asm.DefineLabel(a, "halt_safety")
	arm32.B(a, arm32.COND_AL, "halt_safety")
	// Literal pool: address of exit_block (resolved by linker)
	asm.EmitAddr(a, blockLabel)
}

// emitSemiExitDynamic emits the semihosting exit sequence where r0
// already contains the exit code. Writes r0 into the exit block and
// exits. blockLabel is the label for the exit block. Uses r3 as
// scratch.
func emitSemiExitDynamic(a @asm.Assembler, blockLabel []char, haltLabel []char) {
	// ldr r3, [pc, #16] — load exit_block address
	// str r0, [r3, #4]  — store exit code into block
	// mov r0, #0x20
	// mov r1, r3
	// svc #0x123456
	// b .
	// .word exit_block
	arm32.Ldr(a, arm32.COND_AL, arm32.R3, arm32.MemImm(arm32.PC, 16))
	arm32.Str(a, arm32.COND_AL, arm32.R0, arm32.MemImm(arm32.R3, 4))
	arm32.Mov(a, arm32.COND_AL, false, arm32.R0, arm32.Imm(0x20))
	arm32.Mov(a, arm32.COND_AL, false, arm32.R1, arm32.Reg(arm32.R3))
	arm32.Svc(a, arm32.COND_AL, 0x123456)
	asm.DefineLabel(a, haltLabel)
	arm32.B(a, arm32.COND_AL, haltLabel)
	asm.EmitAddr(a, blockLabel)
}

// Test: loop summing 1..9, exit with result (45).
func TestArm32SemihostingLoop() testing.TestResult {
	if !canRunArm32Semihosting() { return "" }

	var a @asm.Assembler = asm.New(4)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")

	// r0 = sum = 0, r1 = i = 1, r2 = limit = 10
	arm32.Mov(a, arm32.COND_AL, false, arm32.R0, arm32.Imm(0))
	arm32.Mov(a, arm32.COND_AL, false, arm32.R1, arm32.Imm(1))
	arm32.Mov(a, arm32.COND_AL, false, arm32.R2, arm32.Imm(10))

	// loop: sum += i; i++; if i != limit goto loop
	asm.DefineLabel(a, "loop")
	arm32.Add(a, arm32.COND_AL, false, arm32.R0, arm32.R0, arm32.Reg(arm32.R1))
	arm32.Add(a, arm32.COND_AL, false, arm32.R1, arm32.R1, arm32.Imm(1))
	arm32.Cmp(a, arm32.COND_AL, arm32.R1, arm32.Reg(arm32.R2))
	arm32.B(a, arm32.COND_NE, "loop")

	// Exit with sum in r0
	emitSemiExitDynamic(a, "exit_block2", "halt2")

	asm.DefineLabel(a, "exit_block2")
	asm.EmitUint32(a, 0x00020026)
	asm.EmitUint32(a, 0)  // placeholder, overwritten by str

	arm32.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail(a.ErrorMsg) }

	var objPath []char = "/tmp/binate_arm32_loop.o"
	if !WriteARM32(a, objPath) { return fail("write failed") }

	var ldScript []char = "/tmp/binate_arm32.ld"
	writeLinkerScript(ldScript)

	var elfPath []char = "/tmp/binate_arm32_loop.elf"
	if !linkArm32(objPath, elfPath, ldScript) {
		return fail("link failed")
	}

	var exitCode int = runArm32Semihosting(elfPath)
	if exitCode != 45 { return fail("expected exit code 45 (sum 1..9)") }
	return ""
}

// Test: function call with PUSH/POP prologue/epilogue.
func TestArm32SemihostingCall() testing.TestResult {
	if !canRunArm32Semihosting() { return "" }

	var a @asm.Assembler = asm.New(4)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")

	// Set up stack pointer (virt machine RAM at 0x40000000, use top of 1MB)
	arm32.Movw(a, arm32.COND_AL, arm32.SP, 0x0000)
	arm32.Movt(a, arm32.COND_AL, arm32.SP, 0x4010)

	// Call add_five(37) -> should return 42 in r0
	arm32.Mov(a, arm32.COND_AL, false, arm32.R0, arm32.Imm(37))
	arm32.Bl(a, arm32.COND_AL, "add_five")

	// Exit with result in r0
	emitSemiExitDynamic(a, "exit_block3", "halt3")

	// add_five: push {lr}; add r0, r0, #5; pop {pc}
	asm.DefineLabel(a, "add_five")
	var lrMask int = 1 << 14
	var pcMask int = 1 << 15
	arm32.Push(a, arm32.COND_AL, lrMask)
	arm32.Add(a, arm32.COND_AL, false, arm32.R0, arm32.R0, arm32.Imm(5))
	arm32.Pop(a, arm32.COND_AL, pcMask)

	// Exit block
	asm.DefineLabel(a, "exit_block3")
	asm.EmitUint32(a, 0x00020026)
	asm.EmitUint32(a, 0)

	arm32.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail(a.ErrorMsg) }

	var objPath []char = "/tmp/binate_arm32_call.o"
	if !WriteARM32(a, objPath) { return fail("write failed") }

	var ldScript []char = "/tmp/binate_arm32.ld"
	writeLinkerScript(ldScript)

	var elfPath []char = "/tmp/binate_arm32_call.elf"
	if !linkArm32(objPath, elfPath, ldScript) {
		return fail("link failed")
	}

	var exitCode int = runArm32Semihosting(elfPath)
	if exitCode != 42 {
		return fail("expected exit code 42 (37+5)")
	}
	return ""
}

// If on Linux, test linking and running an ELF binary.
func canLinkElf() bool {
	// Check if we're on Linux by trying to run 'readelf'
	var args @[]@[]char = make_slice(@[]char, 1)
	args[0] = bootstrap.Concat("--version", "")
	var exit int = bootstrap.Exec("readelf", args)
	if exit != 0 { return false }
	// Check we're on AArch64 (the test uses AArch64 syscalls)
	var args2 @[]@[]char = make_slice(@[]char, 1)
	args2[0] = bootstrap.Concat("-m", "")
	var exit2 int = bootstrap.Exec("uname", args2)
	// uname -m always succeeds on Linux, but we can't easily read its output.
	// Instead, try a test link: assemble a minimal AArch64 object and link it.
	// If we're on x86-64, the linker will reject the AArch64 object.
	return canLinkAArch64Elf()
}

func canLinkAArch64Elf() bool {
	// Write a minimal AArch64 ELF object and try to link it
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")
	aarch64.Movz(a, true, aarch64.X0, 0, 0)
	aarch64.Svc(a, 0)
	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	var objPath []char = "/tmp/binate_elf_probe.o"
	if !WriteAArch64(a, objPath) { return false }

	var args @[]@[]char = make_slice(@[]char, 5)
	args[0] = bootstrap.Concat("-nostdlib", "")
	args[1] = bootstrap.Concat("-static", "")
	args[2] = bootstrap.Concat("-o", "")
	args[3] = bootstrap.Concat("/tmp/binate_elf_probe", "")
	args[4] = bootstrap.Concat(objPath, "")
	var exit int = bootstrap.Exec("cc", args)
	return exit == 0
}

func TestElfLinkAndRun() testing.TestResult {
	if !canLinkElf() { return "" }  // skip on non-Linux

	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")
	// exit(42) via syscall on Linux/AArch64:
	// mov x8, #93   (SYS_exit)
	// mov x0, #42
	// svc #0
	aarch64.Movz(a, true, aarch64.X8, 93, 0)
	aarch64.Movz(a, true, aarch64.X0, 42, 0)
	aarch64.Svc(a, 0)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	var objPath []char = "/tmp/binate_elf_run.o"
	if !WriteAArch64(a, objPath) { return fail("write failed") }

	// Link as static executable
	var exePath []char = "/tmp/binate_elf_run"
	var args @[]@[]char = make_slice(@[]char, 5)
	args[0] = bootstrap.Concat("-nostdlib", "")
	args[1] = bootstrap.Concat("-static", "")
	args[2] = bootstrap.Concat("-o", "")
	args[3] = bootstrap.Concat(exePath, "")
	args[4] = bootstrap.Concat(objPath, "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 { return fail("linking failed") }

	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != 42 { return fail("expected exit code 42") }
	return ""
}
