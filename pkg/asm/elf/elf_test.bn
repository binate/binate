package "pkg/asm/elf"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/bootstrap"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

// Test writing a simple AArch64 ELF object file and verify the header.
func TestWriteSimpleElf() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")
	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(42))
	aarch64.Ret(a)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("assembler error") }

	var path []char = "/tmp/binate_elf_test.o"
	var ok bool = WriteAArch64(a, path)
	if !ok { return fail("failed to write ELF") }

	// Read the file back and verify ELF magic
	var fd int = bootstrap.Open(path, bootstrap.O_RDONLY)
	if fd < 0 { return fail("cannot open ELF file") }
	var hdr @[]uint8 = make_slice(uint8, 64)
	var raw []uint8 = hdr
	var n int = bootstrap.Read(fd, raw, 64)
	bootstrap.Close(fd)
	if n < 64 { return fail("ELF file too small") }

	// ELF magic: 7f 45 4c 46
	if hdr[0] != 0x7f { return fail("bad magic[0]") }
	if hdr[1] != 0x45 { return fail("bad magic[1]") }
	if hdr[2] != 0x4c { return fail("bad magic[2]") }
	if hdr[3] != 0x46 { return fail("bad magic[3]") }

	// Class: 64-bit
	if hdr[4] != 2 { return fail("expected ELFCLASS64") }
	// Data: little-endian
	if hdr[5] != 1 { return fail("expected ELFDATA2LSB") }
	// Type: ET_REL = 1 (at offset 16, little-endian uint16)
	if hdr[16] != 1 || hdr[17] != 0 { return fail("expected ET_REL") }
	// Machine: EM_AARCH64 = 183 = 0xB7 (at offset 18)
	if hdr[18] != 0xB7 || hdr[19] != 0 { return fail("expected EM_AARCH64") }

	return ""
}

// Test ELF with multiple sections.
func TestWriteMultiSection() testing.TestResult {
	var a @asm.Assembler = asm.New(8)

	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "func1")
	asm.SetGlobal(a, "func1")
	aarch64.Nop(a)
	aarch64.Ret(a)

	asm.SetSection(a, "data", -1)
	asm.EmitUint32(a, 0xDEADBEEF)

	asm.SetSection(a, "rodata", -1)
	asm.EmitAsciz(a, "hello")

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	var path []char = "/tmp/binate_elf_multi.o"
	var ok bool = WriteAArch64(a, path)
	if !ok { return fail("failed to write ELF") }

	// Verify file exists and has reasonable size
	if bootstrap.Stat(path) != 1 { return fail("ELF file not found") }
	return ""
}

// Test ELF with relocations.
func TestWriteElfReloc() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "caller")
	asm.SetGlobal(a, "caller")
	asm.SetGlobal(a, "external")
	aarch64.Bl(a, "external")
	aarch64.Ret(a)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("assembler error") }
	if a.NumRelocs != 1 { return fail("expected 1 relocation") }

	var path []char = "/tmp/binate_elf_reloc.o"
	var ok bool = WriteAArch64(a, path)
	if !ok { return fail("failed to write ELF") }

	if bootstrap.Stat(path) != 1 { return fail("ELF file not found") }
	return ""
}

// Test x86-64 ELF header.
func TestWriteX86Elf() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	// Just emit some bytes (no real x86 instructions, just testing the header)
	asm.EmitUint8(a, 0xC3)  // ret
	asm.Finalize(a)

	var path []char = "/tmp/binate_elf_x86.o"
	var ok bool = WriteX86_64(a, path)
	if !ok { return fail("failed to write ELF") }

	var fd int = bootstrap.Open(path, bootstrap.O_RDONLY)
	if fd < 0 { return fail("cannot open ELF file") }
	var hdr @[]uint8 = make_slice(uint8, 64)
	var raw []uint8 = hdr
	bootstrap.Read(fd, raw, 64)
	bootstrap.Close(fd)

	// Machine: EM_X86_64 = 62 = 0x3E
	if hdr[18] != 0x3E || hdr[19] != 0 { return fail("expected EM_X86_64") }
	return ""
}

// If on Linux, test linking and running an ELF binary.
func canLinkElf() bool {
	// Check if we're on Linux by trying to run 'readelf'
	var args @[]@[]char = make_slice(@[]char, 1)
	args[0] = bootstrap.Concat("--version", "")
	var exit int = bootstrap.Exec("readelf", args)
	return exit == 0
}

func TestElfLinkAndRun() testing.TestResult {
	if !canLinkElf() { return "" }  // skip on non-Linux

	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "_start")
	asm.SetGlobal(a, "_start")
	// exit(42) via syscall on Linux/AArch64:
	// mov x8, #93   (SYS_exit)
	// mov x0, #42
	// svc #0
	aarch64.Movz(a, true, aarch64.X8, 93, 0)
	aarch64.Movz(a, true, aarch64.X0, 42, 0)
	aarch64.Svc(a, 0)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	var objPath []char = "/tmp/binate_elf_run.o"
	if !WriteAArch64(a, objPath) { return fail("write failed") }

	// Link as static executable
	var exePath []char = "/tmp/binate_elf_run"
	var args @[]@[]char = make_slice(@[]char, 5)
	args[0] = bootstrap.Concat("-nostdlib", "")
	args[1] = bootstrap.Concat("-static", "")
	args[2] = bootstrap.Concat("-o", "")
	args[3] = bootstrap.Concat(exePath, "")
	args[4] = bootstrap.Concat(objPath, "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 { return fail("linking failed") }

	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != 42 { return fail("expected exit code 42") }
	return ""
}
