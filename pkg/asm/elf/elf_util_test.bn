package "pkg/asm/elf"

import "pkg/builtin/testing"

// Test helper fail() is in elf_test.bn

// --- BinBuf tests ---

func TestBbU8() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbU8(b, 0x42)
	if b.Len != 1 || b.Data[0] != 0x42 {
		return fail("bbU8 wrong")
	}
	return ""
}

func TestBbU16() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbU16(b, 0x1234)
	if b.Len != 2 { return fail("bbU16 length wrong") }
	// Little-endian: 0x34, 0x12
	if b.Data[0] != 0x34 || b.Data[1] != 0x12 {
		return fail("bbU16 encoding wrong")
	}
	return ""
}

func TestBbU32() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbU32(b, 0xDEADBEEF)
	if b.Len != 4 { return fail("bbU32 length wrong") }
	if b.Data[0] != 0xEF || b.Data[1] != 0xBE {
		return fail("bbU32 low bytes wrong")
	}
	if b.Data[2] != 0xAD || b.Data[3] != 0xDE {
		return fail("bbU32 high bytes wrong")
	}
	return ""
}

func TestBbZeros() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbZeros(b, 4)
	if b.Len != 4 { return fail("bbZeros length wrong") }
	for i := 0; i < 4; i++ {
		if b.Data[i] != 0 { return fail("bbZeros not zero") }
	}
	return ""
}

func TestBbAlign() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbU8(b, 1)  // 1 byte
	b = bbAlign(b, 4)  // align to 4 -> should pad 3 bytes
	if b.Len != 4 { return fail("bbAlign length wrong") }
	return ""
}

// --- String table tests ---

func TestStrTab() testing.TestResult {
	var st StrTab = newStrTab()
	var off1 int = strTabAdd(&st, "hello")
	var off2 int = strTabAdd(&st, "world")
	// First byte is null (0), then "hello\0" at offset 1, "world\0" after
	if off1 != 1 { return fail("first string offset wrong") }
	if off2 != 7 { return fail("second string offset wrong") }
	return ""
}

// --- Section mapping tests ---

func TestElfSectFlags() testing.TestResult {
	var textFlags uint64 = elfSectFlags("text")
	if textFlags != (SHF_ALLOC | SHF_EXECINSTR) {
		return fail("text flags wrong")
	}
	var dataFlags uint64 = elfSectFlags("data")
	if dataFlags != (SHF_ALLOC | SHF_WRITE) {
		return fail("data flags wrong")
	}
	var roFlags uint64 = elfSectFlags("rodata")
	if roFlags != SHF_ALLOC {
		return fail("rodata flags wrong")
	}
	return ""
}

func TestElfSectType() testing.TestResult {
	if elfSectType("text") != SHT_PROGBITS {
		return fail("text type wrong")
	}
	if elfSectType("bss") != SHT_NOBITS {
		return fail("bss type wrong")
	}
	return ""
}

// --- bbAddr tests ---

func TestBbAddr64() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbAddr(b, 0x100, true)
	if b.Len != 8 { return fail("bbAddr 64-bit should be 8 bytes") }
	if b.Data[0] != 0x00 || b.Data[1] != 0x01 {
		return fail("bbAddr 64-bit value wrong")
	}
	return ""
}

func TestBbAddr32() testing.TestResult {
	var b BinBuf = newBinBuf()
	b = bbAddr(b, 0x100, false)
	if b.Len != 4 { return fail("bbAddr 32-bit should be 4 bytes") }
	if b.Data[0] != 0x00 || b.Data[1] != 0x01 {
		return fail("bbAddr 32-bit value wrong")
	}
	return ""
}
