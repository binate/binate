package "pkg/asm/macho"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/bootstrap"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

// Test that we can assemble a simple function and write a valid Mach-O object file.
func TestWriteSimpleObj() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	// A function that returns 42: mov w0, #42; ret
	asm.DefineLabel(a, "_answer")
	asm.SetGlobal(a, "_answer")
	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(42))
	aarch64.Ret(a)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("assembler error") }

	var path []char = "/tmp/binate_asm_test.o"
	var ok bool = WriteARM64(a, path)
	if !ok { return fail("failed to write object file") }

	// Verify the file exists and has reasonable size
	if bootstrap.Stat(path) != 1 {
		return fail("object file not found")
	}

	// Verify with otool -h (check Mach-O header)
	var args @[]@[]char = make_slice(@[]char, 2)
	args[0] = bootstrap.Concat("-h", "")
	args[1] = bootstrap.Concat(path, "")
	var exit int = bootstrap.Exec("otool", args)
	if exit != 0 {
		return fail("otool -h failed")
	}

	// Verify disassembly with otool -tv
	var args2 @[]@[]char = make_slice(@[]char, 2)
	args2[0] = bootstrap.Concat("-tv", "")
	args2[1] = bootstrap.Concat(path, "")
	var exit2 int = bootstrap.Exec("otool", args2)
	if exit2 != 0 {
		return fail("otool -tv failed")
	}

	return ""
}

// Test linking the object file into an executable and running it.
func TestLinkAndRun() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	// _main: mov w0, #42; ret
	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")
	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(42))
	aarch64.Ret(a)

	aarch64.ResolveFixups(a)
	asm.Finalize(a)

	if a.HasError { return fail("assembler error") }

	var objPath []char = "/tmp/binate_asm_link_test.o"
	var ok bool = WriteARM64(a, objPath)
	if !ok { return fail("failed to write object file") }

	// Link with system linker: ld -o <exe> <obj> -lSystem -syslibroot <sdk> -e _main -arch arm64
	var exePath []char = "/tmp/binate_asm_link_test"

	// Use ld via cc for simpler invocation
	var args @[]@[]char = make_slice(@[]char, 4)
	args[0] = bootstrap.Concat("-o", "")
	args[1] = bootstrap.Concat(exePath, "")
	args[2] = bootstrap.Concat(objPath, "")
	args[3] = bootstrap.Concat("-Wl,-e,_main", "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 {
		return fail("linking failed")
	}

	// Run the executable — should exit with code 42
	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != 42 {
		return fail("expected exit code 42")
	}

	return ""
}

// Helper to assemble, link, run, and check exit code
func assembleAndRun(a @asm.Assembler, expected int) testing.TestResult {
	aarch64.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail("assembler error") }

	var objPath []char = "/tmp/binate_asm_e2e.o"
	var ok bool = WriteARM64(a, objPath)
	if !ok { return fail("failed to write object file") }

	var exePath []char = "/tmp/binate_asm_e2e"
	var args @[]@[]char = make_slice(@[]char, 4)
	args[0] = bootstrap.Concat("-o", "")
	args[1] = bootstrap.Concat(exePath, "")
	args[2] = bootstrap.Concat(objPath, "")
	args[3] = bootstrap.Concat("-Wl,-e,_main", "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 { return fail("linking failed") }

	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != expected {
		return fail("wrong exit code")
	}
	return ""
}

// Sum 1..9 using a loop: result = 45, exit code = 45
// Tests: backward branch, forward conditional branch, compare, add
//
//   _main:
//     mov w0, #0        // sum = 0
//     mov w1, #1        // i = 1
//   .loop:
//     add w0, w0, w1    // sum += i
//     add w1, w1, #1    // i++
//     cmp w1, #10
//     b.lt .loop        // if i < 10, loop
//     ret
func TestLoopSum() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(0))   // sum = 0
	aarch64.Mov(a, false, aarch64.X1, aarch64.Imm(1))   // i = 1

	asm.DefineLabel(a, "_main.loop")
	aarch64.Add(a, false, aarch64.X0, aarch64.X0, aarch64.Reg(aarch64.X1))  // sum += i
	aarch64.Add(a, false, aarch64.X1, aarch64.X1, aarch64.Imm(1))           // i++
	aarch64.Cmp(a, false, aarch64.X1, aarch64.Imm(10))                      // cmp i, 10
	aarch64.Bcond(a, aarch64.COND_LT, "_main.loop")                         // b.lt .loop
	aarch64.Ret(a)

	// 1+2+3+...+9 = 45
	return assembleAndRun(a, 45)
}

// Conditional: return 10 if arg would be 0 (it is), else 20.
// Tests: CBZ forward branch
//
//   _main:
//     mov w1, #0
//     cbnz w1, .nonzero
//     mov w0, #10
//     ret
//   .nonzero:
//     mov w0, #20
//     ret
func TestConditionalCbz() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	aarch64.Mov(a, false, aarch64.X1, aarch64.Imm(0))
	aarch64.Cbnz(a, false, aarch64.X1, "_main.nonzero")
	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(10))
	aarch64.Ret(a)

	asm.DefineLabel(a, "_main.nonzero")
	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(20))
	aarch64.Ret(a)

	return assembleAndRun(a, 10)
}

// Function call: _main calls _add5 via BL, tests function call + return
//
//   _add5:
//     add w0, w0, #5
//     ret
//   _main:
//     mov w0, #7
//     bl _add5
//     ret              // exit with 12
func TestFunctionCall() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)

	// _add5
	asm.DefineLabel(a, "_add5")
	aarch64.Add(a, false, aarch64.X0, aarch64.X0, aarch64.Imm(5))
	aarch64.Ret(a)

	// _main
	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	// Save LR (BL overwrites it)
	aarch64.Stp(a, true, aarch64.FP, aarch64.LR, aarch64.MemPre(aarch64.SP, -16))

	aarch64.Mov(a, false, aarch64.X0, aarch64.Imm(7))
	aarch64.Bl(a, "_add5")

	// Restore LR and return
	aarch64.Ldp(a, true, aarch64.FP, aarch64.LR, aarch64.MemPost(aarch64.SP, 16))
	aarch64.Ret(a)

	// 7 + 5 = 12
	return assembleAndRun(a, 12)
}
