package "pkg/asm/macho"

import "pkg/asm"
import "pkg/asm/x64"
import "pkg/bootstrap"
import "pkg/builtin/testing"

// canLinkAndRunX64 checks if we can compile and run x86-64 Mach-O
// binaries. Requires macOS with Rosetta (Apple Silicon) or native
// x86-64.
func canLinkAndRunX64() bool {
	if !canLinkAndRun() { return false }
	// Check that cc can target x86-64
	var args @[]@[]char = make_slice(@[]char, 5)
	args[0] = bootstrap.Concat("-arch", "")
	args[1] = bootstrap.Concat("x86_64", "")
	args[2] = bootstrap.Concat("-x", "")
	args[3] = bootstrap.Concat("c", "")
	args[4] = bootstrap.Concat("-E", "/dev/null")
	var exit int = bootstrap.Exec("cc", args)
	return exit == 0
}

// assembleAndRunX64 is a helper that assembles x86-64, writes Mach-O,
// links with cc -arch x86_64, and checks the exit code.
func assembleAndRunX64(a @asm.Assembler, expected int) testing.TestResult {
	x64.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail(a.ErrorMsg) }

	var objPath []char = "/tmp/binate_x64_e2e.o"
	var ok bool = WriteX86_64(a, objPath)
	if !ok { return fail("failed to write x86-64 Mach-O") }

	var exePath []char = "/tmp/binate_x64_e2e"
	var args @[]@[]char = make_slice(@[]char, 6)
	args[0] = bootstrap.Concat("-arch", "")
	args[1] = bootstrap.Concat("x86_64", "")
	args[2] = bootstrap.Concat("-o", "")
	args[3] = bootstrap.Concat(exePath, "")
	args[4] = bootstrap.Concat(objPath, "")
	args[5] = bootstrap.Concat("-Wl,-e,_main", "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 { return fail("linking failed") }

	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != expected {
		return fail("wrong exit code")
	}
	return ""
}

// macOS x86-64 syscall convention:
// RAX = 0x2000000 | unix_syscall_number
// SYS_exit = 1, so RAX = 0x2000001
// RDI = first argument (exit code)

// Test: exit with code 42 via syscall.
func TestX64MachoExit() testing.TestResult {
	if !canLinkAndRunX64() { return "" }

	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	// mov eax, 0x2000001 (SYS_exit)
	x64.Mov(a, x64.Reg(x64.RAX, x64.SZ32), x64.Imm(0x2000001))
	// mov edi, 42
	x64.Mov(a, x64.Reg(x64.RDI, x64.SZ32), x64.Imm(42))
	// syscall
	x64.Syscall(a)

	return assembleAndRunX64(a, 42)
}

// Test: loop summing 1..9, exit with result (45).
func TestX64MachoLoop() testing.TestResult {
	if !canLinkAndRunX64() { return "" }

	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	// xor eax, eax   (sum = 0)
	x64.Xor(a, x64.Reg(x64.RAX, x64.SZ32), x64.Reg(x64.RAX, x64.SZ32))
	// mov ecx, 1     (i = 1)
	x64.Mov(a, x64.Reg(x64.RCX, x64.SZ32), x64.Imm(1))

	// loop: add eax, ecx; inc ecx; cmp ecx, 10; jne loop
	asm.DefineLabel(a, "loop")
	x64.Add(a, x64.Reg(x64.RAX, x64.SZ32), x64.Reg(x64.RCX, x64.SZ32))
	x64.Inc(a, x64.Reg(x64.RCX, x64.SZ32))
	x64.Cmp(a, x64.Reg(x64.RCX, x64.SZ32), x64.Imm(10))
	x64.Jcc(a, x64.CC_NE, "loop")

	// mov edi, eax (exit code = sum)
	x64.Mov(a, x64.Reg(x64.RDI, x64.SZ32), x64.Reg(x64.RAX, x64.SZ32))
	// mov eax, 0x2000001
	x64.Mov(a, x64.Reg(x64.RAX, x64.SZ32), x64.Imm(0x2000001))
	// syscall
	x64.Syscall(a)

	return assembleAndRunX64(a, 45)
}

// Test: function call with push/pop prologue/epilogue.
func TestX64MachoCall() testing.TestResult {
	if !canLinkAndRunX64() { return "" }

	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	// mov edi, 37
	x64.Mov(a, x64.Reg(x64.RDI, x64.SZ32), x64.Imm(37))
	// call add_five
	x64.Call(a, "add_five")
	// eax = 42, use as exit code
	// mov edi, eax
	x64.Mov(a, x64.Reg(x64.RDI, x64.SZ32), x64.Reg(x64.RAX, x64.SZ32))
	// mov eax, 0x2000001
	x64.Mov(a, x64.Reg(x64.RAX, x64.SZ32), x64.Imm(0x2000001))
	x64.Syscall(a)

	// add_five: returns arg + 5 in eax
	asm.DefineLabel(a, "add_five")
	// lea eax, [rdi + 5]
	x64.Lea(a, x64.Reg(x64.RAX, x64.SZ32), x64.Mem(x64.RDI, 5, x64.SZ32))
	x64.Ret(a)

	return assembleAndRunX64(a, 42)
}

// Test: multiply and conditional.
func TestX64MachoMul() testing.TestResult {
	if !canLinkAndRunX64() { return "" }

	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	asm.DefineLabel(a, "_main")
	asm.SetGlobal(a, "_main")

	// 6 * 7 = 42
	x64.Mov(a, x64.Reg(x64.RAX, x64.SZ32), x64.Imm(6))
	x64.Imul3(a, x64.Reg(x64.RAX, x64.SZ32), x64.Reg(x64.RAX, x64.SZ32), 7)

	// exit(eax)
	x64.Mov(a, x64.Reg(x64.RDI, x64.SZ32), x64.Reg(x64.RAX, x64.SZ32))
	x64.Mov(a, x64.Reg(x64.RAX, x64.SZ32), x64.Imm(0x2000001))
	x64.Syscall(a)

	return assembleAndRunX64(a, 42)
}
