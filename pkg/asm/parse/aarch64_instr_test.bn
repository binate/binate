package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/asm/macho"
import "pkg/bootstrap"
import "pkg/builtin/testing"

// --- Additional instruction parsing tests ---

func TestParseMov() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "mov x0, x1")
	if p.HasError { return fail(p.ErrorMsg) }
	// MOV X0, X1 = ORR X0, XZR, X1 = 0xAA0103E0
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xAA0103E0 { return fail("MOV X0, X1 wrong") }
	return ""
}

func TestParseMovImm() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "mov w0, #42")
	if p.HasError { return fail(p.ErrorMsg) }
	// MOV W0, #42 = MOVZ W0, #42 = 0x52800540
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0x52800540 { return fail("MOV W0, #42 wrong") }
	return ""
}

