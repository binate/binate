// --- End-to-end: parse text, write Mach-O, link, run ---

// canLinkAndRun checks if we're on macOS/AArch64 where Mach-O linking works.
func canLinkAndRun() bool {
	var args @[]@[]char = make_slice(@[]char, 1)
	args[0] = bootstrap.Concat("--version", "")
	var exit int = bootstrap.Exec("otool", args)
	return exit == 0
}

func TestParseAndRun() testing.TestResult {
	if !canLinkAndRun() { return "" }
	var a @asm.Assembler = asm.New(8)
	var p @Parser = NewParser(a, "test.s")
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, ".global _main")
	ParseLine(p, "_main:")
	ParseLine(p, "sub w0, w0, w0")   // w0 = 0
	ParseLine(p, "add w0, w0, #33") // w0 = 33
	ParseLine(p, "  ret")
	if p.HasError { return fail(p.ErrorMsg) }

	aarch64.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail("finalize error") }

	var objPath []char = "/tmp/binate_parse_test.o"
	if !macho.WriteARM64(a, objPath) { return fail("write failed") }

	var exePath []char = "/tmp/binate_parse_test"
	var args @[]@[]char = make_slice(@[]char, 4)
	args[0] = bootstrap.Concat("-o", "")
	args[1] = bootstrap.Concat(exePath, "")
	args[2] = bootstrap.Concat(objPath, "")
	args[3] = bootstrap.Concat("-Wl,-e,_main", "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 { return fail("linking failed") }

	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != 33 { return fail("expected exit code 33") }
	return ""
}

func TestParseMvn() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "mvn x0, x1")
	if p.HasError { return fail(p.ErrorMsg) }
	// MVN X0, X1 = ORN X0, XZR, X1 = 0xAA2103E0
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xAA2103E0 {
		return fail("mvn x0, x1 parse wrong")
	}
	return ""
}
