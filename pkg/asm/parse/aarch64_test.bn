package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/builtin/testing"

// --- Instruction parsing tests ---

func TestParseNop() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "nop")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xD503201F { return fail("NOP encoding wrong") }
	return ""
}

func TestParseRet() testing.TestResult {
	var p @Parser = newTestParser()
