func TestParseSvc() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "svc #0x80")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xD4001001 { return fail("SVC #0x80 encoding wrong") }
	return ""
}

func TestParseBranch() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "b target")
	ParseLine(p, "nop")
	ParseLine(p, "target:")
	ParseLine(p, "nop")
	if p.HasError { return fail(p.ErrorMsg) }
	aarch64.ResolveFixups(p.Asm)
	asm.Finalize(p.Asm)
	// B at offset 0 → target at offset 8, imm26 = 2
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0x14000002 { return fail("B encoding wrong after fixup") }
	return ""
}
