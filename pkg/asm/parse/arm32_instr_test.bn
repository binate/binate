	return ""
}

func TestParseArm32PopRange() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	// POP {r4-r7, pc}
	ParseLine(p, "pop {r4-r7, pc}")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	// regmask = (1<<4)|(1<<5)|(1<<6)|(1<<7)|(1<<15) = 0x80F0
	// POP = LDM SP!, regmask
	// = 0xE8BD80F0
	if inst != 0xE8BD80F0 {
		return fail("POP {r4-r7, pc} parse wrong")
	}
	return ""
}

func TestParseArm32BkptImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "bkpt #0")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE1200070 {
		return fail("BKPT #0 parse wrong")
	}
	return ""
}

func TestParseArm32CondMov() testing.TestResult {
	// "moveq r0, r1" -> MOV with cond=EQ
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "moveq r0, r1")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	// MOV EQ: cond=0000 | opcode=1101 | Rd=0000 | Rm=0001
	// = 0x01A00001
	if inst != 0x01A00001 {
		return fail("MOVEQ R0, R1 parse wrong")
	}
	return ""
}

func TestParseArm32AndImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "and r0, r1, #0xFF")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE20100FF {
		return fail("AND R0, R1, #0xFF parse wrong")
	}
	return ""
}
