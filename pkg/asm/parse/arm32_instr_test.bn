package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/arm32"
import "pkg/builtin/testing"

// Instruction dispatch tests (tests for arm32_instr.bn).
// Helper functions newArm32Parser and readWord are in arm32_test.bn.

func TestParseArm32MovwImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "movw r0, #0x1234")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE3010234 {
		return fail("MOVW R0, #0x1234 parse wrong")
	}
	return ""
}

