package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/arm32"
import "pkg/builtin/testing"

// Helper: create a parser for ARM32
func newArm32Parser() (@Parser, @asm.Assembler) {
	var a @asm.Assembler = asm.New(4)
	asm.SetSection(a, "text", -1)
	var p @Parser = NewParser(a, "test.s")
	p.Arch = ARCH_ARM32
	return p, a
}

// Helper: read instruction at offset
func readWord(s @asm.Section, off int) uint32 {
	return cast(uint32, s.Data[off]) |
		(cast(uint32, s.Data[off + 1]) << 8) |
		(cast(uint32, s.Data[off + 2]) << 16) |
		(cast(uint32, s.Data[off + 3]) << 24)
}

// --- Register parsing tests ---

func TestArm32ParseRegR0() testing.TestResult {
	if parseArm32Reg("r0") != 0 { return fail("r0") }
	if parseArm32Reg("r15") != 15 { return fail("r15") }
	if parseArm32Reg("R7") != 7 { return fail("R7") }
	return ""
}

func TestArm32ParseRegNamed() testing.TestResult {
	if parseArm32Reg("sp") != arm32.SP { return fail("sp") }
	if parseArm32Reg("lr") != arm32.LR { return fail("lr") }
	if parseArm32Reg("pc") != arm32.PC { return fail("pc") }
	if parseArm32Reg("fp") != arm32.FP { return fail("fp") }
	return ""
}

func TestArm32ParseRegInvalid() testing.TestResult {
	if parseArm32Reg("r16") != -1 { return fail("r16 should be invalid") }
	if parseArm32Reg("x0") != -1 { return fail("x0 should be invalid") }
	if parseArm32Reg("") != -1 { return fail("empty should be invalid") }
	return ""
}

// --- Condition code parsing ---

func TestArm32ParseCondCode() testing.TestResult {
	if parseArm32CondCode("eq") != arm32.COND_EQ { return fail("eq") }
	if parseArm32CondCode("ne") != arm32.COND_NE { return fail("ne") }
	if parseArm32CondCode("al") != arm32.COND_AL { return fail("al") }
	if parseArm32CondCode("xx") != -1 { return fail("xx should be -1") }
	return ""
}

// --- Mnemonic splitting ---

func TestSplitMnemSimple() testing.TestResult {
	var base []char
	var cond int = 0
	var s bool = false
	base, cond, s = splitMnem("add")
	if !mnemIs(base, "add") || cond != arm32.COND_AL || s {
		return fail("add split wrong")
	}
	return ""
}

func TestSplitMnemCond() testing.TestResult {
	var base []char
	var cond int = 0
	var s bool = false
	base, cond, s = splitMnem("addeq")
	if !mnemIs(base, "add") || cond != arm32.COND_EQ || s {
		return fail("addeq split wrong")
	}
	return ""
}

func TestSplitMnemS() testing.TestResult {
	var base []char
	var cond int = 0
	var s bool = false
	base, cond, s = splitMnem("adds")
	if !mnemIs(base, "add") || cond != arm32.COND_AL || !s {
		return fail("adds split wrong")
	}
	return ""
}

func TestSplitMnemSCond() testing.TestResult {
	var base []char
	var cond int = 0
	var s bool = false
	base, cond, s = splitMnem("addseq")
	if !mnemIs(base, "add") || cond != arm32.COND_EQ || !s {
		return fail("addseq split wrong")
	}
	return ""
}

// --- Instruction parsing tests ---

func TestParseArm32AddRegImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "add r0, r1, #42")
	if p.HasError { return fail(p.ErrorMsg) }
	// ADD R0, R1, #42 = 0xE281002A
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE281002A {
		return fail("ADD R0, R1, #42 parse wrong")
	}
	return ""
}

func TestParseArm32SubReg() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "sub r0, r1, r2")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE0410002 {
		return fail("SUB R0, R1, R2 parse wrong")
	}
	return ""
}

func TestParseArm32MovImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "mov r0, #0")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE3A00000 {
		return fail("MOV R0, #0 parse wrong")
