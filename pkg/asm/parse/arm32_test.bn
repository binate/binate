func TestParseArm32LdrImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "ldr r0, [r1, #8]")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE5910008 {
		return fail("LDR R0, [R1, #8] parse wrong")
	}
	return ""
