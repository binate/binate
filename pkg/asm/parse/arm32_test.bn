func TestParseArm32BxLr() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "bx lr")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE12FFF1E {
		return fail("BX LR parse wrong")
	}
	return ""
}

func TestParseArm32Nop() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "nop")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE1A00000 {
		return fail("NOP parse wrong")
	}
	return ""
}

func TestParseArm32CondBranch() testing.TestResult {
	// "bne" should split into base="b", cond=NE
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "bne target")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	// BNE: cond=0001 | 1010 | imm24=0
	if inst != 0x1A000000 {
		return fail("BNE parse wrong")
	}
	return ""
}

func TestParseArm32AddsCond() testing.TestResult {
	// "addseq r0, r1, r2" -> base="add", cond=EQ, S=true
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "addseq r0, r1, r2")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	// ADDSEQ: cond=0000 | 00|I=0|0100|S=1 | Rn=0001 | Rd=0000 | Rm=0010
	// = 0x00910002
	if inst != 0x00910002 {
		return fail("ADDSEQ R0, R1, R2 parse wrong")
	}
	return ""
}

func TestParseArm32PushPop() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "push {r4, lr}")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	// PUSH {R4, LR} = 0xE92D4010
	if inst != 0xE92D4010 {
		return fail("PUSH {r4, lr} parse wrong")
	}
	return ""
}

func TestParseArm32Svc() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "svc #0")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xEF000000 {
		return fail("SVC #0 parse wrong")
	}
	return ""
}

func TestParseArm32ShiftedReg() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	ParseLine(p, "add r0, r1, r2, lsl #3")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readWord(a.Sections[0], 0)
	if inst != 0xE0810182 {
		return fail("ADD R0, R1, R2 LSL #3 parse wrong")
	}
	return ""
}

func TestParseArm32ArchDirective() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newArm32Parser()
	p.Arch = ARCH_UNKNOWN  // reset
	ParseLine(p, ".arch arm32")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Arch != ARCH_ARM32 {
		return fail("arch not set to ARM32")
	}
	return ""
}
