package "pkg/asm/parse"

import "pkg/builtin/testing"

// --- Expression tests ---

func TestExprSimple() testing.TestResult {
	var l Lexer = NewLexer("42", 1)
	var tok Token
	l, tok = LexNext(l)
	var result ExprResult
	l, tok, result = ParseExpr(l, tok)
	if !result.Ok || result.Val != 42 { return fail("expected 42") }
	return ""
}

func TestExprArith() testing.TestResult {
	var l Lexer = NewLexer("3 + 4 * 2", 1)
	var tok Token
	l, tok = LexNext(l)
	var result ExprResult
	l, tok, result = ParseExpr(l, tok)
	// 3 + (4*2) = 11 (multiplication has higher precedence)
	if !result.Ok || result.Val != 11 { return fail("expected 11") }
	return ""
}

func TestExprBitwise() testing.TestResult {
	var l Lexer = NewLexer("(1 << 3) | 1", 1)
	var tok Token
	l, tok = LexNext(l)
	var result ExprResult
	l, tok, result = ParseExpr(l, tok)
	if !result.Ok || result.Val != 9 { return fail("expected 9") }
	return ""
}
