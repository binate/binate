package "pkg/asm/parse"

import "pkg/builtin/testing"

// --- Lexer tests ---

func TestLexIdent() testing.TestResult {
	var l Lexer = NewLexer("add x0", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected IDENT") }
	if !charsEqual(tok.Text, "add") { return fail("expected 'add'") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected IDENT for x0") }
	if !charsEqual(tok.Text, "x0") { return fail("expected 'x0'") }
	return ""
}

func TestLexInt() testing.TestResult {
	var l Lexer = NewLexer("42 0xFF 0b1010", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT || tok.Ival != 42 { return fail("expected 42") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT || tok.Ival != 255 { return fail("expected 255") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT || tok.Ival != 10 { return fail("expected 10") }
	return ""
}

func TestLexString() testing.TestResult {
	var l Lexer = NewLexer("\"hello\"", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_STRING { return fail("expected STRING") }
	if !charsEqual(tok.Text, "hello") { return fail("expected 'hello'") }
	return ""
}

func TestLexPunctuation() testing.TestResult {
	var l Lexer = NewLexer("[x0, #8]!", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_LBRACKET { return fail("expected [") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected x0") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_COMMA { return fail("expected ,") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_HASH { return fail("expected #") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT { return fail("expected 8") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_RBRACKET { return fail("expected ]") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_BANG { return fail("expected !") }
	return ""
}

func TestLexComment() testing.TestResult {
	var l Lexer = NewLexer("add x0 // comment", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected add") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected x0") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_EOF { return fail("expected EOF after comment") }
	return ""
}
