package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/asm/macho"
import "pkg/bootstrap"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func readInst(s @asm.Section, off int) uint32 {
	return cast(uint32, s.Data[off]) |
		(cast(uint32, s.Data[off + 1]) << 8) |
		(cast(uint32, s.Data[off + 2]) << 16) |
		(cast(uint32, s.Data[off + 3]) << 24)
}

func newTestParser() @Parser {
	var a @asm.Assembler = asm.New(8)
	return NewParser(a, "test.s")
}

// --- Lexer tests ---

func TestLexIdent() testing.TestResult {
	var l Lexer = NewLexer("add x0", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected IDENT") }
	if !charsEqual(tok.Text, "add") { return fail("expected 'add'") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected IDENT for x0") }
	if !charsEqual(tok.Text, "x0") { return fail("expected 'x0'") }
	return ""
}

func TestLexInt() testing.TestResult {
	var l Lexer = NewLexer("42 0xFF 0b1010", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT || tok.Ival != 42 { return fail("expected 42") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT || tok.Ival != 255 { return fail("expected 255") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT || tok.Ival != 10 { return fail("expected 10") }
	return ""
}

func TestLexString() testing.TestResult {
	var l Lexer = NewLexer("\"hello\"", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_STRING { return fail("expected STRING") }
	if !charsEqual(tok.Text, "hello") { return fail("expected 'hello'") }
	return ""
}

func TestLexPunctuation() testing.TestResult {
	var l Lexer = NewLexer("[x0, #8]!", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_LBRACKET { return fail("expected [") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected x0") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_COMMA { return fail("expected ,") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_HASH { return fail("expected #") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_INT { return fail("expected 8") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_RBRACKET { return fail("expected ]") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_BANG { return fail("expected !") }
	return ""
}

func TestLexComment() testing.TestResult {
	var l Lexer = NewLexer("add x0 // comment", 1)
	var tok Token
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected add") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_IDENT { return fail("expected x0") }
	l, tok = LexNext(l)
	if tok.Kind != TOK_EOF { return fail("expected EOF after comment") }
	return ""
}

// --- Expression tests ---

func TestExprSimple() testing.TestResult {
	var l Lexer = NewLexer("42", 1)
	var tok Token
	l, tok = LexNext(l)
	var result ExprResult
	l, tok, result = ParseExpr(l, tok)
	if !result.Ok || result.Val != 42 { return fail("expected 42") }
	return ""
}

func TestExprArith() testing.TestResult {
	var l Lexer = NewLexer("3 + 4 * 2", 1)
	var tok Token
	l, tok = LexNext(l)
	var result ExprResult
	l, tok, result = ParseExpr(l, tok)
	// 3 + (4*2) = 11 (multiplication has higher precedence)
	if !result.Ok || result.Val != 11 { return fail("expected 11") }
	return ""
}

func TestExprBitwise() testing.TestResult {
	var l Lexer = NewLexer("(1 << 3) | 1", 1)
	var tok Token
	l, tok = LexNext(l)
	var result ExprResult
	l, tok, result = ParseExpr(l, tok)
	if !result.Ok || result.Val != 9 { return fail("expected 9") }
	return ""
}

// --- Directive tests ---

func TestParseArch() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	if p.HasError { return fail("arch directive failed") }
	if p.Arch != ARCH_AARCH64 { return fail("expected aarch64") }
	return ""
}

func TestParseSection() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.NumSections != 1 { return fail("expected 1 section") }
	return ""
}

func TestParseLabel() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "my_func:")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.NumSymbols != 1 { return fail("expected 1 symbol") }
	return ""
}

func TestParseGlobal() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "my_func:")
	ParseLine(p, ".global my_func")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.Symbols[0].Binding != asm.BIND_GLOBAL {
		return fail("expected global binding")
	}
	return ""
}

func TestParseData() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".section data")
	ParseLine(p, ".uint32 0xDEADBEEF")
	if p.HasError { return fail(p.ErrorMsg) }
	var s @asm.Section = p.Asm.Sections[0]
	if s.Len != 4 { return fail("expected 4 bytes") }
	if s.Data[0] != 0xEF { return fail("wrong byte 0") }
	if s.Data[3] != 0xDE { return fail("wrong byte 3") }
	return ""
}

func TestParseAsciz() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".section rodata")
	ParseLine(p, ".asciz \"hi\"")
	if p.HasError { return fail(p.ErrorMsg) }
	var s @asm.Section = p.Asm.Sections[0]
	if s.Len != 3 { return fail("expected 3 bytes") }
	if s.Data[0] != 'h' { return fail("expected 'h'") }
	if s.Data[2] != 0 { return fail("expected null") }
	return ""
}

func TestParseConst() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, "PAGE_SIZE = 4096")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.NumConsts != 1 { return fail("expected 1 constant") }
	if p.ConstVals[0] != 4096 { return fail("expected 4096") }
	return ""
}

func TestParseAlign() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".section text")
	ParseLine(p, ".uint8 0x01")
	ParseLine(p, ".align 4")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.Sections[0].Len != 4 { return fail("expected 4 bytes after align") }
	return ""
}

// --- Instruction parsing tests ---

func TestParseNop() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "nop")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xD503201F { return fail("NOP encoding wrong") }
	return ""
}

func TestParseRet() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "ret")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xD65F03C0 { return fail("RET encoding wrong") }
	return ""
}

func TestParseAddReg() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "add x0, x1, x2")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0x8B020020 { return fail("ADD X0, X1, X2 encoding wrong") }
	return ""
}

func TestParseAddImm() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "add x0, x1, #42")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0x9100A820 { return fail("ADD X0, X1, #42 encoding wrong") }
	return ""
}

func TestParseSvc() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "svc #0x80")
	if p.HasError { return fail(p.ErrorMsg) }
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0xD4001001 { return fail("SVC #0x80 encoding wrong") }
	return ""
}

func TestParseBranch() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "b target")
	ParseLine(p, "nop")
	ParseLine(p, "target:")
	ParseLine(p, "nop")
	if p.HasError { return fail(p.ErrorMsg) }
	aarch64.ResolveFixups(p.Asm)
	asm.Finalize(p.Asm)
	// B at offset 0 → target at offset 8, imm26 = 2
	var inst uint32 = readInst(p.Asm.Sections[0], 0)
	if inst != 0x14000002 { return fail("B encoding wrong after fixup") }
	return ""
}

// --- End-to-end: parse text, write Mach-O, link, run ---

func TestParseAndRun() testing.TestResult {
	var a @asm.Assembler = asm.New(8)
	var p @Parser = NewParser(a, "test.s")
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, ".global _main")
	ParseLine(p, "_main:")
	ParseLine(p, "sub w0, w0, w0")   // w0 = 0
	ParseLine(p, "add w0, w0, #33") // w0 = 33
	ParseLine(p, "  ret")
	if p.HasError { return fail(p.ErrorMsg) }

	aarch64.ResolveFixups(a)
	asm.Finalize(a)
	if a.HasError { return fail("finalize error") }

	var objPath []char = "/tmp/binate_parse_test.o"
	if !macho.WriteARM64(a, objPath) { return fail("write failed") }

	var exePath []char = "/tmp/binate_parse_test"
	var args @[]@[]char = make_slice(@[]char, 4)
	args[0] = bootstrap.Concat("-o", "")
	args[1] = bootstrap.Concat(exePath, "")
	args[2] = bootstrap.Concat(objPath, "")
	args[3] = bootstrap.Concat("-Wl,-e,_main", "")
	var exit int = bootstrap.Exec("cc", args)
	if exit != 0 { return fail("linking failed") }

	var runArgs @[]@[]char = make_slice(@[]char, 0)
	var exitCode int = bootstrap.Exec(exePath, runArgs)
	if exitCode != 33 { return fail("expected exit code 33") }
	return ""
}
