package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/aarch64"
import "pkg/asm/macho"
import "pkg/bootstrap"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func readInst(s @asm.Section, off int) uint32 {
	return cast(uint32, s.Data[off]) |
		(cast(uint32, s.Data[off + 1]) << 8) |
		(cast(uint32, s.Data[off + 2]) << 16) |
		(cast(uint32, s.Data[off + 3]) << 24)
}

func newTestParser() @Parser {
	var a @asm.Assembler = asm.New(8)
	return NewParser(a, "test.s")
}
// --- Directive tests ---

func TestParseArch() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	if p.HasError { return fail("arch directive failed") }
	if p.Arch != ARCH_AARCH64 { return fail("expected aarch64") }
	return ""
}

func TestParseSection() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.NumSections != 1 { return fail("expected 1 section") }
	return ""
}

func TestParseLabel() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "my_func:")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.NumSymbols != 1 { return fail("expected 1 symbol") }
	return ""
}

func TestParseGlobal() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".arch aarch64")
	ParseLine(p, ".section text")
	ParseLine(p, "my_func:")
	ParseLine(p, ".global my_func")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.Symbols[0].Binding != asm.BIND_GLOBAL {
		return fail("expected global binding")
	}
	return ""
}

func TestParseData() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".section data")
	ParseLine(p, ".uint32 0xDEADBEEF")
	if p.HasError { return fail(p.ErrorMsg) }
	var s @asm.Section = p.Asm.Sections[0]
	if s.Len != 4 { return fail("expected 4 bytes") }
	if s.Data[0] != 0xEF { return fail("wrong byte 0") }
	if s.Data[3] != 0xDE { return fail("wrong byte 3") }
	return ""
}

func TestParseAsciz() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".section rodata")
	ParseLine(p, ".asciz \"hi\"")
	if p.HasError { return fail(p.ErrorMsg) }
	var s @asm.Section = p.Asm.Sections[0]
	if s.Len != 3 { return fail("expected 3 bytes") }
	if s.Data[0] != 'h' { return fail("expected 'h'") }
	if s.Data[2] != 0 { return fail("expected null") }
	return ""
}

func TestParseConst() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, "PAGE_SIZE = 4096")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.NumConsts != 1 { return fail("expected 1 constant") }
	if p.ConstVals[0] != 4096 { return fail("expected 4096") }
	return ""
}

func TestParseAlign() testing.TestResult {
	var p @Parser = newTestParser()
	ParseLine(p, ".section text")
	ParseLine(p, ".uint8 0x01")
	ParseLine(p, ".align 4")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Asm.Sections[0].Len != 4 { return fail("expected 4 bytes after align") }
	return ""
}
