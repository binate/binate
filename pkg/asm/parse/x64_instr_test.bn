package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/x64"
import "pkg/builtin/testing"

// Instruction dispatch tests for x64_instr.bn.
// Helpers newX64Parser, readX64Byte, checkX64Bytes are in x64_test.bn.

func TestParseX64Imul2() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// imul rax, rcx = 48 0F AF C1
	ParseLine(p, "imul rax, rcx")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x0F
	expected[2] = 0xAF
	expected[3] = 0xC1
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("imul rax, rcx encoding wrong")
	}
	return ""
}

func TestParseX64Imul3() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// imul rax, rcx, 10 = 48 6B C1 0A
	ParseLine(p, "imul rax, rcx, 10")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x6B
	expected[2] = 0xC1
	expected[3] = 0x0A
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("imul rax, rcx, 10 encoding wrong")
	}
	return ""
}

func TestParseX64LeaMem() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// lea rax, [rbp - 16] = 48 8D 45 F0
	ParseLine(p, "lea rax, [rbp - 16]")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x8D
	expected[2] = 0x45
	expected[3] = 0xF0
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("lea rax, [rbp-16] encoding wrong")
	}
	return ""
}

func TestParseX64MovQwordPtrMem() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// mov qword [rbp - 8], rax = 48 89 45 F8
	ParseLine(p, "mov qword [rbp - 8], rax")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x89
	expected[2] = 0x45
	expected[3] = 0xF8
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("mov qword [rbp-8], rax wrong")
	}
	return ""
}

func TestParseX64JmpLabel() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "jmp target")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 0) != 0xE9 {
		return fail("jmp opcode wrong")
	}
	return ""
}

func TestParseX64SubRegReg() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// sub rax, rcx = 48 29 C8
	ParseLine(p, "sub rax, rcx")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x48
	expected[1] = 0x29
	expected[2] = 0xC8
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("sub rax, rcx encoding wrong")
	}
	return ""
}

func TestParseX64Cqo() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "cqo")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x48
	expected[1] = 0x99
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("cqo encoding wrong")
	}
	return ""
}

func TestParseX64Int80() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// int 0x80 = CD 80
	ParseLine(p, "int 0x80")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0xCD
	expected[1] = 0x80
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("int 0x80 encoding wrong")
	}
	return ""
}
