	p, a = newX64Parser()
	ParseLine(p, "call target")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 0) != 0xE8 {
		return fail("call opcode wrong")
	}
	return ""
}

