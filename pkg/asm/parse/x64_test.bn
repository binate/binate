	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "jne target")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 1) != 0x85 {
		return fail("jne cc byte wrong")
