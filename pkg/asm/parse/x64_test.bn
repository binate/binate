func TestParseX64CmpImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// cmp rax, 0 = 48 83 F8 00
	ParseLine(p, "cmp rax, 0")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x83
	expected[2] = 0xF8
	expected[3] = 0x00
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("cmp rax, 0 encoding wrong")
	}
	return ""
}

func TestParseX64ArchDirective() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	p.Arch = ARCH_UNKNOWN
	ParseLine(p, ".arch x64")
	if p.HasError { return fail(p.ErrorMsg) }
	if p.Arch != ARCH_X64 {
		return fail("arch not set to X64")
	}
	return ""
}

func TestParseX64ShlImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// shl rax, 4 = 48 C1 E0 04
	ParseLine(p, "shl rax, 4")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0xC1
	expected[2] = 0xE0
	expected[3] = 0x04
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("shl rax, 4 encoding wrong")
	}
	return ""
}

func TestParseX64IncReg() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// inc rax = 48 FF C0
	ParseLine(p, "inc rax")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x48
	expected[1] = 0xFF
	expected[2] = 0xC0
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("inc rax encoding wrong")
	}
	return ""
}
