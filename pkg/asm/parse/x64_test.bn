package "pkg/asm/parse"

import "pkg/asm"
import "pkg/asm/x64"
import "pkg/builtin/testing"

// Helper: create a parser for x86-64
func newX64Parser() (@Parser, @asm.Assembler) {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	var p @Parser = NewParser(a, "test.s")
	p.Arch = ARCH_X64
	return p, a
}

func readX64Byte(s @asm.Section, off int) int {
	return cast(int, s.Data[off])
}

func checkX64Bytes(s @asm.Section, off int, expected @[]int) bool {
	for i := 0; i < len(expected); i++ {
		if cast(int, s.Data[off + i]) != expected[i] {
			return false
		}
	}
	return true
}

// --- Register parsing tests ---

func TestX64ParseReg64() testing.TestResult {
	var reg int = 0
	var sz int = 0
	reg, sz = parseX64Reg("rax")
	if reg != x64.RAX || sz != x64.SZ64 { return fail("rax") }
	reg, sz = parseX64Reg("r15")
	if reg != x64.R15 || sz != x64.SZ64 { return fail("r15") }
	return ""
}

func TestX64ParseReg32() testing.TestResult {
	var reg int = 0
	var sz int = 0
	reg, sz = parseX64Reg("eax")
	if reg != x64.RAX || sz != x64.SZ32 { return fail("eax") }
	reg, sz = parseX64Reg("r8d")
	if reg != x64.R8 || sz != x64.SZ32 { return fail("r8d") }
	return ""
}

func TestX64ParseReg8() testing.TestResult {
	var reg int = 0
	var sz int = 0
	reg, sz = parseX64Reg("al")
	if reg != x64.RAX || sz != x64.SZ8 { return fail("al") }
	reg, sz = parseX64Reg("sil")
	if reg != x64.RSI || sz != x64.SZ8 { return fail("sil") }
	return ""
}

func TestX64ParseRegInvalid() testing.TestResult {
	var reg int = 0
	var sz int = 0
	reg, sz = parseX64Reg("r16")
	if reg != -1 { return fail("r16 should be invalid") }
	reg, sz = parseX64Reg("xmm0")
	if reg != -1 { return fail("xmm0 should be invalid") }
	return ""
}

// --- Instruction parsing tests ---

func TestParseX64Nop() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "nop")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 0) != 0x90 {
		return fail("nop encoding wrong")
	}
	return ""
}

func TestParseX64Ret() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "ret")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 0) != 0xC3 {
		return fail("ret encoding wrong")
	}
	return ""
}

func TestParseX64Syscall() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "syscall")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x0F
	expected[1] = 0x05
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("syscall encoding wrong")
	}
	return ""
}

func TestParseX64MovRegReg() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// mov rax, rcx = 48 89 C8
	ParseLine(p, "mov rax, rcx")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x48
	expected[1] = 0x89
	expected[2] = 0xC8
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("mov rax, rcx encoding wrong")
	}
	return ""
}

func TestParseX64MovRegImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// mov eax, 42 = B8 2A000000
	ParseLine(p, "mov eax, 42")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 5)
	expected[0] = 0xB8
	expected[1] = 42
	expected[2] = 0
	expected[3] = 0
	expected[4] = 0
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("mov eax, 42 encoding wrong")
	}
	return ""
}

func TestParseX64AddRegImm() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// add rax, 1 = 48 83 C0 01
	ParseLine(p, "add rax, 1")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x83
	expected[2] = 0xC0
	expected[3] = 0x01
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("add rax, 1 encoding wrong")
	}
	return ""
}

func TestParseX64XorRegReg() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// xor eax, eax = 31 C0
	ParseLine(p, "xor eax, eax")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x31
	expected[1] = 0xC0
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("xor eax, eax encoding wrong")
	}
	return ""
}

func TestParseX64PushPop() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	ParseLine(p, "push rbp")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 0) != 0x55 {
		return fail("push rbp wrong")
	}
	ParseLine(p, "pop rbp")
	if p.HasError { return fail(p.ErrorMsg) }
	if readX64Byte(a.Sections[0], 1) != 0x5D {
		return fail("pop rbp wrong")
	}
	return ""
}

func TestParseX64MovMem() testing.TestResult {
	var p @Parser
	var a @asm.Assembler
	p, a = newX64Parser()
	// mov rax, [rbp - 8] = 48 8B 45 F8
	ParseLine(p, "mov rax, [rbp - 8]")
	if p.HasError { return fail(p.ErrorMsg) }
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x8B
	expected[2] = 0x45
	expected[3] = 0xF8
	if !checkX64Bytes(a.Sections[0], 0, expected) {
		return fail("mov rax, [rbp-8] encoding wrong")
	}
	return ""
}

