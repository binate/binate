package "pkg/asm/x64"

import "pkg/asm"
import "pkg/builtin/testing"

// --- MOV tests ---

func TestMovRegReg64() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV RAX, RCX = REX.W 89 C8 (mov r/m64, r64)
	// REX.W=0x48, 0x89, ModRM=11|001|000 = 0xC8
	Mov(a, Reg(RAX, SZ64), Reg(RCX, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x48
	expected[1] = 0x89
	expected[2] = 0xC8
	if !checkBytes(s, 0, expected) {
		return fail("MOV RAX, RCX encoding wrong")
	}
	return ""
}

func TestMovRegReg32() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV EAX, ECX = 89 C8 (no REX needed for 32-bit)
	Mov(a, Reg(RAX, SZ32), Reg(RCX, SZ32))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x89
	expected[1] = 0xC8
	if !checkBytes(s, 0, expected) {
		return fail("MOV EAX, ECX encoding wrong")
	}
	return ""
}

func TestMovRegImm32() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV EAX, 42 = B8 2A000000
	Mov(a, Reg(RAX, SZ32), Imm(42))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 5)
	expected[0] = 0xB8
	expected[1] = 42
	expected[2] = 0
	expected[3] = 0
	expected[4] = 0
	if !checkBytes(s, 0, expected) {
		return fail("MOV EAX, 42 encoding wrong")
	}
	return ""
}

func TestMovRegImm64() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV RAX, 42 = REX.W B8 2A000000
	Mov(a, Reg(RAX, SZ64), Imm(42))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 6)
	expected[0] = 0x48
	expected[1] = 0xB8
	expected[2] = 42
	expected[3] = 0
	expected[4] = 0
	expected[5] = 0
	if !checkBytes(s, 0, expected) {
		return fail("MOV RAX, 42 encoding wrong")
	}
	return ""
}

func TestMovR8Reg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV R8, RAX = REX.WB 89 C0
	// REX = 0x49 (W=1, B=1), 0x89, ModRM = 11|000|000 = 0xC0
	Mov(a, Reg(R8, SZ64), Reg(RAX, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x49
	expected[1] = 0x89
	expected[2] = 0xC0
	if !checkBytes(s, 0, expected) {
		return fail("MOV R8, RAX encoding wrong")
	}
	return ""
}

func TestMovMemReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV [RBP-8], RAX = REX.W 89 45 F8
	// REX.W=0x48, 0x89, ModRM=01|000|101=0x45, disp8=0xF8(-8)
	Mov(a, Mem(RBP, -8, SZ64), Reg(RAX, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x89
	expected[2] = 0x45
	expected[3] = 0xF8
	if !checkBytes(s, 0, expected) {
		return fail("MOV [RBP-8], RAX encoding wrong")
	}
	return ""
}

func TestMovRegMem() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// MOV RAX, [RBP-8] = REX.W 8B 45 F8
	Mov(a, Reg(RAX, SZ64), Mem(RBP, -8, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x8B
	expected[2] = 0x45
	expected[3] = 0xF8
	if !checkBytes(s, 0, expected) {
		return fail("MOV RAX, [RBP-8] encoding wrong")
	}
	return ""
}

// --- ADD tests ---

func TestAddRegReg64() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADD RAX, RCX = REX.W 01 C8
	Add(a, Reg(RAX, SZ64), Reg(RCX, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x48
	expected[1] = 0x01
	expected[2] = 0xC8
	if !checkBytes(s, 0, expected) {
		return fail("ADD RAX, RCX encoding wrong")
	}
	return ""
}

func TestAddRegImm8() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADD RAX, 1 = REX.W 83 C0 01 (sign-extended imm8)
	Add(a, Reg(RAX, SZ64), Imm(1))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x83
	expected[2] = 0xC0
	expected[3] = 0x01
	if !checkBytes(s, 0, expected) {
		return fail("ADD RAX, 1 encoding wrong")
	}
	return ""
}

func TestAddRegImm32() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// ADD RAX, 256 = REX.W 81 C0 00010000
	Add(a, Reg(RAX, SZ64), Imm(256))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 7)
	expected[0] = 0x48
	expected[1] = 0x81
	expected[2] = 0xC0
	expected[3] = 0x00
	expected[4] = 0x01
	expected[5] = 0x00
	expected[6] = 0x00
	if !checkBytes(s, 0, expected) {
		return fail("ADD RAX, 256 encoding wrong")
	}
	return ""
}

// --- SUB / XOR / CMP ---

func TestSubRegReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SUB EAX, ECX = 29 C8
	Sub(a, Reg(RAX, SZ32), Reg(RCX, SZ32))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x29
	expected[1] = 0xC8
	if !checkBytes(s, 0, expected) {
		return fail("SUB EAX, ECX encoding wrong")
	}
	return ""
}

func TestXorRegReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// XOR EAX, EAX = 31 C0 (common zero-register idiom)
	Xor(a, Reg(RAX, SZ32), Reg(RAX, SZ32))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x31
	expected[1] = 0xC0
	if !checkBytes(s, 0, expected) {
		return fail("XOR EAX, EAX encoding wrong")
	}
	return ""
}

func TestCmpRegImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CMP RAX, 0 = REX.W 83 F8 00
	Cmp(a, Reg(RAX, SZ64), Imm(0))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x83
	expected[2] = 0xF8
	expected[3] = 0x00
	if !checkBytes(s, 0, expected) {
		return fail("CMP RAX, 0 encoding wrong")
	}
	return ""
}

// --- Unary ops ---

func TestIncReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// INC RAX = REX.W FF C0
	Inc(a, Reg(RAX, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 3)
	expected[0] = 0x48
	expected[1] = 0xFF
	expected[2] = 0xC0
	if !checkBytes(s, 0, expected) {
		return fail("INC RAX encoding wrong")
	}
	return ""
}

func TestNegReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// NEG EAX = F7 D8 (no REX for 32-bit)
	Neg(a, Reg(RAX, SZ32))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0xF7
	expected[1] = 0xD8
	if !checkBytes(s, 0, expected) {
		return fail("NEG EAX encoding wrong")
	}
	return ""
}

// --- Shift ---

func TestShlImm() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// SHL RAX, 4 = REX.W C1 E0 04
	Shl(a, Reg(RAX, SZ64), Imm(4))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0xC1
	expected[2] = 0xE0
	expected[3] = 0x04
	if !checkBytes(s, 0, expected) {
		return fail("SHL RAX, 4 encoding wrong")
	}
	return ""
}

// --- PUSH / POP ---

func TestPushReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// PUSH RBP = 55
	Push(a, Reg(RBP, SZ64))
	if readByte(a.Sections[0], 0) != 0x55 {
		return fail("PUSH RBP encoding wrong")
	}
	return ""
}

func TestPopReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// POP RBP = 5D
	Pop(a, Reg(RBP, SZ64))
	if readByte(a.Sections[0], 0) != 0x5D {
		return fail("POP RBP encoding wrong")
	}
	return ""
}

func TestPushR8() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// PUSH R8 = 41 50 (REX.B + 50)
	Push(a, Reg(R8, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x41
	expected[1] = 0x50
	if !checkBytes(s, 0, expected) {
		return fail("PUSH R8 encoding wrong")
	}
	return ""
}

// --- LEA ---

func TestLeaRbpOff() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// LEA RAX, [RBP-16] = REX.W 8D 45 F0
	Lea(a, Reg(RAX, SZ64), Mem(RBP, -16, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x8D
	expected[2] = 0x45
	expected[3] = 0xF0
	if !checkBytes(s, 0, expected) {
		return fail("LEA RAX, [RBP-16] encoding wrong")
	}
	return ""
}

// --- IMUL ---

func TestImul2() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// IMUL RAX, RCX = REX.W 0F AF C1
	Imul2(a, Reg(RAX, SZ64), Reg(RCX, SZ64))
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x0F
	expected[2] = 0xAF
	expected[3] = 0xC1
	if !checkBytes(s, 0, expected) {
		return fail("IMUL RAX, RCX encoding wrong")
	}
	return ""
}

func TestImul3() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// IMUL RAX, RCX, 10 = REX.W 6B C1 0A
	Imul3(a, Reg(RAX, SZ64), Reg(RCX, SZ64), 10)
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 4)
	expected[0] = 0x48
	expected[1] = 0x6B
	expected[2] = 0xC1
	expected[3] = 0x0A
	if !checkBytes(s, 0, expected) {
		return fail("IMUL RAX, RCX, 10 encoding wrong")
	}
	return ""
}

// --- CQO / CDQ ---

func TestCqo() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CQO = 48 99
	Cqo(a)
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x48
	expected[1] = 0x99
	if !checkBytes(s, 0, expected) {
		return fail("CQO encoding wrong")
	}
	return ""
}
