package "pkg/asm/x64"

import "pkg/asm"
import "pkg/builtin/testing"

// --- JMP ---

func TestJmpLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// JMP label = E9 + rel32 placeholder
	Jmp(a, "target")
	var s @asm.Section = a.Sections[0]
	if readByte(s, 0) != 0xE9 { return fail("JMP opcode wrong") }
	if s.Len != 5 { return fail("JMP length wrong") }
	return ""
}

func TestJmpReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// JMP RAX = FF E0
	JmpReg(a, RAX)
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0xFF
	expected[1] = 0xE0
	if !checkBytes(s, 0, expected) {
		return fail("JMP RAX encoding wrong")
	}
	return ""
}

// --- Jcc ---

func TestJeLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// JE label = 0F 84 + rel32 placeholder
	Jcc(a, CC_E, "target")
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x0F
	expected[1] = 0x84
	if !checkBytes(s, 0, expected) {
		return fail("JE opcode wrong")
	}
	if s.Len != 6 { return fail("JE length wrong") }
	return ""
}

func TestJneLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// JNE label = 0F 85 + rel32
	Jcc(a, CC_NE, "target")
	if readByte(a.Sections[0], 1) != 0x85 {
		return fail("JNE cc byte wrong")
	}
	return ""
}

// --- CALL / RET ---

func TestCallLabel() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CALL label = E8 + rel32
	Call(a, "target")
	if readByte(a.Sections[0], 0) != 0xE8 {
		return fail("CALL opcode wrong")
	}
	if a.Sections[0].Len != 5 {
		return fail("CALL length wrong")
	}
	return ""
}

func TestCallReg() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// CALL RAX = FF D0
	CallReg(a, RAX)
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0xFF
	expected[1] = 0xD0
	if !checkBytes(s, 0, expected) {
		return fail("CALL RAX encoding wrong")
	}
	return ""
}

func TestRet() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// RET = C3
	Ret(a)
	if readByte(a.Sections[0], 0) != 0xC3 {
		return fail("RET encoding wrong")
	}
	return ""
}

// --- Fixup resolution ---

func TestJmpForwardFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// JMP target ; fixup at offset 1 (the rel32), target at offset 7
	// JMP = E9 rel32 (5 bytes), then NOP NOP, then target:
	// rel32 = target - (fixup + 4) = 7 - (1+4) = 2
	Jmp(a, "target")
	Nop(a)  // offset 5
	Nop(a)  // offset 6
	asm.DefineLabel(a, "target")
	Nop(a)  // offset 7

	var ok bool = ResolveFixups(a)
	if !ok { return fail("fixup resolution failed") }
	var s @asm.Section = a.Sections[0]
	// rel32 at offset 1 should be 2
	if s.Data[1] != 2 || s.Data[2] != 0 {
		return fail("JMP forward fixup wrong")
	}
	return ""
}

func TestCallBackwardFixup() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// target: NOP ; offset 0
	// CALL target ; offset 1, fixup at offset 2
	// rel32 = 0 - (2+4) = -6
	asm.DefineLabel(a, "target")
	Nop(a)  // offset 0
	Call(a, "target")  // offset 1

	var ok bool = ResolveFixups(a)
	if !ok { return fail("fixup resolution failed") }
	var s @asm.Section = a.Sections[0]
	// rel32 at offset 2: -6 = 0xFFFFFFFA
	if s.Data[2] != 0xFA || s.Data[3] != 0xFF {
		return fail("CALL backward fixup wrong")
	}
	return ""
}
