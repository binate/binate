package "pkg/asm/x64"

import "pkg/asm"
import "pkg/builtin/testing"

func TestNop() testing.TestResult {
	var a @asm.Assembler = newAsm()
	Nop(a)
	if readByte(a.Sections[0], 0) != 0x90 {
		return fail("NOP encoding wrong")
	}
	return ""
}

func TestSyscall() testing.TestResult {
	var a @asm.Assembler = newAsm()
	Syscall(a)
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0x0F
	expected[1] = 0x05
	if !checkBytes(s, 0, expected) {
		return fail("SYSCALL encoding wrong")
	}
	return ""
}

func TestInt() testing.TestResult {
	var a @asm.Assembler = newAsm()
	// INT 0x80 = CD 80
	Int(a, 0x80)
	var s @asm.Section = a.Sections[0]
	var expected @[]int = make_slice(int, 2)
	expected[0] = 0xCD
	expected[1] = 0x80
	if !checkBytes(s, 0, expected) {
		return fail("INT 0x80 encoding wrong")
	}
	return ""
}
