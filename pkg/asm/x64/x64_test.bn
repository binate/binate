package "pkg/asm/x64"

import "pkg/asm"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func newAsm() @asm.Assembler {
	var a @asm.Assembler = asm.New(8)
	asm.SetSection(a, "text", -1)
	return a
}

// readByte reads a single byte from section data.
func readByte(s @asm.Section, off int) int {
	return cast(int, s.Data[off])
}

// readBytes returns a slice of bytes from the section for comparison.
// Returns the bytes as a hex-comparable string for error messages.
func checkBytes(s @asm.Section, off int, expected @[]int) bool {
	for i := 0; i < len(expected); i++ {
		if cast(int, s.Data[off + i]) != expected[i] {
			return false
		}
	}
	return true
}

// --- Operand constructor tests ---

func TestRegOperand() testing.TestResult {
	var op Operand = Reg(RAX, SZ64)
	if op.Kind != OP_REG || op.Reg != RAX || op.Size != SZ64 {
		return fail("Reg(RAX, SZ64) wrong")
	}
	return ""
}

func TestImmOperand() testing.TestResult {
	var op Operand = Imm(42)
	if op.Kind != OP_IMM || op.Imm != 42 {
		return fail("Imm(42) wrong")
	}
	return ""
}

func TestMemOperand() testing.TestResult {
	var op Operand = Mem(RBP, -8, SZ64)
	if op.Kind != OP_MEM || op.Base != RBP || op.Disp != -8 {
		return fail("Mem(RBP, -8) wrong")
	}
	return ""
}

// --- Register constants ---

func TestRegisterConstants() testing.TestResult {
	if RAX != 0 || RCX != 1 || RDX != 2 || RBX != 3 {
		return fail("RAX-RBX wrong")
	}
	if RSP != 4 || RBP != 5 || RSI != 6 || RDI != 7 {
		return fail("RSP-RDI wrong")
	}
	if R8 != 8 || R15 != 15 {
		return fail("R8-R15 wrong")
	}
	return ""
}

// --- Condition code constants ---

func TestConditionCodes() testing.TestResult {
	if CC_E != 4 || CC_NE != 5 || CC_L != 12 || CC_G != 15 {
		return fail("condition codes wrong")
	}
	if CC_Z != CC_E || CC_NZ != CC_NE {
		return fail("aliases wrong")
	}
	return ""
}
