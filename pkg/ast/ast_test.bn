package "pkg/ast"

import "pkg/token"

// String comparison helper (same-package, so not exported)
func streq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func assert_streq(got []char, want []char, msg []char) {
	if !streq(got, want) {
		panic(msg)
	}
}

// Tests

func TestExprKindName() {
	assert_streq(ExprKindName(EXPR_IDENT), "IDENT", "EXPR_IDENT")
	assert_streq(ExprKindName(EXPR_INT_LIT), "INT_LIT", "EXPR_INT_LIT")
	assert_streq(ExprKindName(EXPR_BINARY), "BINARY", "EXPR_BINARY")
	assert_streq(ExprKindName(EXPR_CALL), "CALL", "EXPR_CALL")
	assert_streq(ExprKindName(EXPR_SELECTOR), "SELECTOR", "EXPR_SELECTOR")
	assert_streq(ExprKindName(EXPR_BUILTIN), "BUILTIN", "EXPR_BUILTIN")
	assert_streq(ExprKindName(99), "UNKNOWN_EXPR", "unknown")
}

func TestStmtKindName() {
	assert_streq(StmtKindName(STMT_BLOCK), "BLOCK", "STMT_BLOCK")
	assert_streq(StmtKindName(STMT_IF), "IF", "STMT_IF")
	assert_streq(StmtKindName(STMT_FOR), "FOR", "STMT_FOR")
	assert_streq(StmtKindName(STMT_RETURN), "RETURN", "STMT_RETURN")
	assert_streq(StmtKindName(STMT_DECL), "DECL", "STMT_DECL")
	assert_streq(StmtKindName(99), "UNKNOWN_STMT", "unknown")
}

func TestDeclKindName() {
	assert_streq(DeclKindName(DECL_FUNC), "FUNC", "DECL_FUNC")
	assert_streq(DeclKindName(DECL_VAR), "VAR", "DECL_VAR")
	assert_streq(DeclKindName(DECL_CONST), "CONST", "DECL_CONST")
	assert_streq(DeclKindName(DECL_TYPE), "TYPE", "DECL_TYPE")
	assert_streq(DeclKindName(DECL_GROUP), "GROUP", "DECL_GROUP")
	assert_streq(DeclKindName(99), "UNKNOWN_DECL", "unknown")
}

func TestTypeExprKindName() {
	assert_streq(TypeExprKindName(TEXPR_NAMED), "NAMED", "TEXPR_NAMED")
	assert_streq(TypeExprKindName(TEXPR_POINTER), "POINTER", "TEXPR_POINTER")
	assert_streq(TypeExprKindName(TEXPR_SLICE), "SLICE", "TEXPR_SLICE")
	assert_streq(TypeExprKindName(TEXPR_STRUCT), "STRUCT", "TEXPR_STRUCT")
	assert_streq(TypeExprKindName(99), "UNKNOWN_TEXPR", "unknown")
}

func TestBuildExpr() {
	// Build an identifier expression
	var ident @Expr = make(Expr)
	ident.Kind = EXPR_IDENT
	ident.Name = "x"
	if ident.Kind != EXPR_IDENT {
		panic("ident kind")
	}
	if !streq(ident.Name, "x") {
		panic("ident name")
	}

	// Build an int literal
	var lit @Expr = make(Expr)
	lit.Kind = EXPR_INT_LIT
	lit.Name = "42"

	// Build a binary expression: x + 42
	var binop @Expr = make(Expr)
	binop.Kind = EXPR_BINARY
	binop.Op = cast(int, token.PLUS)
	binop.X = ident
	binop.Y = lit
	if binop.Kind != EXPR_BINARY {
		panic("binop kind")
	}
	if binop.X.Kind != EXPR_IDENT {
		panic("binop.X kind")
	}
	if binop.Y.Kind != EXPR_INT_LIT {
		panic("binop.Y kind")
	}
}

func TestBuildStmt() {
	// Build a return statement with one result
	var expr @Expr = make(Expr)
	expr.Kind = EXPR_INT_LIT
	expr.Name = "0"

	var ret @Stmt = make(Stmt)
	ret.Kind = STMT_RETURN
	ret.Exprs = append(ret.Exprs, expr)
	if ret.Kind != STMT_RETURN {
		panic("ret kind")
	}
	if len(ret.Exprs) != 1 {
		panic("ret exprs len")
	}

	// Build a block containing the return
	var block @Stmt = make(Stmt)
	block.Kind = STMT_BLOCK
	block.Stmts = append(block.Stmts, ret)
	if len(block.Stmts) != 1 {
		panic("block stmts len")
	}
}

func TestBuildDecl() {
	// Build a function declaration
	var intType @TypeExpr = make(TypeExpr)
	intType.Kind = TEXPR_NAMED
	intType.Name = "int"

	var param @ParamDecl = make(ParamDecl)
	param.Name = "n"
	param.Type = intType

	var body @Stmt = make(Stmt)
	body.Kind = STMT_BLOCK

	var fn @Decl = make(Decl)
	fn.Kind = DECL_FUNC
	fn.Name = "add"
	fn.Params = append(fn.Params, param)
	fn.Results = append(fn.Results, intType)
	fn.Body = body

	if fn.Kind != DECL_FUNC {
		panic("fn kind")
	}
	if !streq(fn.Name, "add") {
		panic("fn name")
	}
	if len(fn.Params) != 1 {
		panic("fn params len")
	}
	if !streq(fn.Params[0].Name, "n") {
		panic("param name")
	}
	if len(fn.Results) != 1 {
		panic("fn results len")
	}
}

func TestBuildTypeExpr() {
	// Named type
	var intType @TypeExpr = make(TypeExpr)
	intType.Kind = TEXPR_NAMED
	intType.Name = "int"
	if !streq(intType.Name, "int") {
		panic("named type name")
	}

	// Qualified type: token.Pos
	var qualType @TypeExpr = make(TypeExpr)
	qualType.Kind = TEXPR_NAMED
	qualType.Name = "Pos"
	qualType.Pkg = "token"
	if !streq(qualType.Pkg, "token") {
		panic("qualified pkg")
	}

	// Slice type: []int
	var sliceType @TypeExpr = make(TypeExpr)
	sliceType.Kind = TEXPR_SLICE
	sliceType.Base = intType
	if sliceType.Base.Kind != TEXPR_NAMED {
		panic("slice elem kind")
	}

	// Pointer type: *int
	var ptrType @TypeExpr = make(TypeExpr)
	ptrType.Kind = TEXPR_POINTER
	ptrType.Base = intType
	if ptrType.Kind != TEXPR_POINTER {
		panic("ptr kind")
	}
}

func TestBuildFile() {
	var imp @ImportSpec = make(ImportSpec)
	imp.Path = "pkg/token"

	var fn @Decl = make(Decl)
	fn.Kind = DECL_FUNC
	fn.Name = "main"

	var file @File = make(File)
	file.PkgName = "main"
	file.Imports = append(file.Imports, imp)
	file.Decls = append(file.Decls, fn)

	if !streq(file.PkgName, "main") {
		panic("file pkg")
	}
	if len(file.Imports) != 1 {
		panic("file imports len")
	}
	if !streq(file.Imports[0].Path, "pkg/token") {
		panic("import path")
	}
	if len(file.Decls) != 1 {
		panic("file decls len")
	}
	if !streq(file.Decls[0].Name, "main") {
		panic("decl name")
	}
}
