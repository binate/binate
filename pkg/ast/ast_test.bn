	r = check_streq(DeclKindName(DECL_VAR), "VAR", "DECL_VAR"); if len(r) > 0 { return r }
	r = check_streq(DeclKindName(DECL_CONST), "CONST", "DECL_CONST"); if len(r) > 0 { return r }
