func TestTypeExprKindName() testing.TestResult {
	var r testing.TestResult
	r = check_streq(TypeExprKindName(TEXPR_NAMED), "NAMED", "TEXPR_NAMED"); if len(r) > 0 { return r }
	r = check_streq(TypeExprKindName(TEXPR_POINTER), "POINTER", "TEXPR_POINTER"); if len(r) > 0 { return r }
	r = check_streq(TypeExprKindName(TEXPR_SLICE), "SLICE", "TEXPR_SLICE"); if len(r) > 0 { return r }
	r = check_streq(TypeExprKindName(TEXPR_STRUCT), "STRUCT", "TEXPR_STRUCT"); if len(r) > 0 { return r }
	r = check_streq(TypeExprKindName(99), "UNKNOWN_TEXPR", "unknown"); if len(r) > 0 { return r }
	return ""
}

func TestBuildExpr() testing.TestResult {
	// Build an identifier expression
	var ident @Expr = make(Expr)
	ident.Kind = EXPR_IDENT
	ident.Name = "x"
	if ident.Kind != EXPR_IDENT {
		return "ident kind"
	}
	if !streq(ident.Name, "x") {
		return "ident name"
	}

	// Build an int literal
	var lit @Expr = make(Expr)
	lit.Kind = EXPR_INT_LIT
	lit.Name = "42"

	// Build a binary expression: x + 42
	var binop @Expr = make(Expr)
	binop.Kind = EXPR_BINARY
	binop.Op = cast(int, token.PLUS)
	binop.X = ident
	binop.Y = lit
	if binop.Kind != EXPR_BINARY {
		return "binop kind"
	}
	if binop.X.Kind != EXPR_IDENT {
		return "binop.X kind"
	}
	if binop.Y.Kind != EXPR_INT_LIT {
		return "binop.Y kind"
	}
	return ""
}

func TestBuildStmt() testing.TestResult {
	// Build a return statement with one result
	var expr @Expr = make(Expr)
	expr.Kind = EXPR_INT_LIT
	expr.Name = "0"

	var ret @Stmt = make(Stmt)
	ret.Kind = STMT_RETURN
	var retExprs @[]@Expr = make_slice(@Expr, 1)
	retExprs[0] = expr
	ret.Exprs = retExprs
	if ret.Kind != STMT_RETURN {
		return "ret kind"
	}
	if len(ret.Exprs) != 1 {
		return "ret exprs len"
	}

	// Build a block containing the return
	var block @Stmt = make(Stmt)
	block.Kind = STMT_BLOCK
	var blockStmts @[]@Stmt = make_slice(@Stmt, 1)
	blockStmts[0] = ret
	block.Stmts = blockStmts
	if len(block.Stmts) != 1 {
		return "block stmts len"
	}
	return ""
}

func TestBuildDecl() testing.TestResult {
	// Build a function declaration
	var intType @TypeExpr = make(TypeExpr)
	intType.Kind = TEXPR_NAMED
	intType.Name = "int"

	var param @ParamDecl = make(ParamDecl)
	param.Name = "n"
	param.Type = intType

	var body @Stmt = make(Stmt)
	body.Kind = STMT_BLOCK

	var fn @Decl = make(Decl)
	fn.Kind = DECL_FUNC
	fn.Name = "add"
	var params @[]@ParamDecl = make_slice(@ParamDecl, 1)
	params[0] = param
	fn.Params = params
	var results @[]@TypeExpr = make_slice(@TypeExpr, 1)
	results[0] = intType
	fn.Results = results
	fn.Body = body

	if fn.Kind != DECL_FUNC {
		return "fn kind"
	}
	if !streq(fn.Name, "add") {
		return "fn name"
	}
	if len(fn.Params) != 1 {
		return "fn params len"
	}
	if !streq(fn.Params[0].Name, "n") {
		return "param name"
	}
	if len(fn.Results) != 1 {
		return "fn results len"
	}
	return ""
}

func TestBuildTypeExpr() testing.TestResult {
	// Named type
	var intType @TypeExpr = make(TypeExpr)
	intType.Kind = TEXPR_NAMED
	intType.Name = "int"
	if !streq(intType.Name, "int") {
		return "named type name"
	}

	// Qualified type: token.Pos
	var qualType @TypeExpr = make(TypeExpr)
	qualType.Kind = TEXPR_NAMED
	qualType.Name = "Pos"
	qualType.Pkg = "token"
	if !streq(qualType.Pkg, "token") {
		return "qualified pkg"
	}

	// Slice type: []int
	var sliceType @TypeExpr = make(TypeExpr)
	sliceType.Kind = TEXPR_SLICE
	sliceType.Base = intType
	if sliceType.Base.Kind != TEXPR_NAMED {
		return "slice elem kind"
	}

	// Pointer type: *int
	var ptrType @TypeExpr = make(TypeExpr)
	ptrType.Kind = TEXPR_POINTER
	ptrType.Base = intType
	if ptrType.Kind != TEXPR_POINTER {
		return "ptr kind"
	}
	return ""
}

func TestBuildFile() testing.TestResult {
	var imp @ImportSpec = make(ImportSpec)
	imp.Path = "pkg/token"

	var fn @Decl = make(Decl)
	fn.Kind = DECL_FUNC
	fn.Name = "main"

	var file @File = make(File)
	file.PkgName = "main"
	var imports @[]@ImportSpec = make_slice(@ImportSpec, 1)
	imports[0] = imp
	file.Imports = imports
	var decls @[]@Decl = make_slice(@Decl, 1)
	decls[0] = fn
	file.Decls = decls

	if !streq(file.PkgName, "main") {
		return "file pkg"
	}
	if len(file.Imports) != 1 {
		return "file imports len"
	}
	if !streq(file.Imports[0].Path, "pkg/token") {
		return "import path"
	}
	if len(file.Decls) != 1 {
		return "file decls len"
	}
	if !streq(file.Decls[0].Name, "main") {
		return "decl name"
	}
	return ""
}
