package "pkg/ast"

import "pkg/token"
import "pkg/builtin/testing"

// String comparison helper (same-package, so not exported)
func streq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func check_streq(got []char, want []char, msg @[]char) testing.TestResult {
	if !streq(got, want) {
		return msg
	}
	return ""
}

// Tests

func TestExprKindName() testing.TestResult {
	var r testing.TestResult
	r = check_streq(ExprKindName(EXPR_IDENT), "IDENT", "EXPR_IDENT"); if len(r) > 0 { return r }
	r = check_streq(ExprKindName(EXPR_INT_LIT), "INT_LIT", "EXPR_INT_LIT"); if len(r) > 0 { return r }
	r = check_streq(ExprKindName(EXPR_BINARY), "BINARY", "EXPR_BINARY"); if len(r) > 0 { return r }
	r = check_streq(ExprKindName(EXPR_CALL), "CALL", "EXPR_CALL"); if len(r) > 0 { return r }
	r = check_streq(ExprKindName(EXPR_SELECTOR), "SELECTOR", "EXPR_SELECTOR"); if len(r) > 0 { return r }
	r = check_streq(ExprKindName(EXPR_BUILTIN), "BUILTIN", "EXPR_BUILTIN"); if len(r) > 0 { return r }
	r = check_streq(ExprKindName(99), "UNKNOWN_EXPR", "unknown"); if len(r) > 0 { return r }
	return ""
}

func TestStmtKindName() testing.TestResult {
	var r testing.TestResult
	r = check_streq(StmtKindName(STMT_BLOCK), "BLOCK", "STMT_BLOCK"); if len(r) > 0 { return r }
	r = check_streq(StmtKindName(STMT_IF), "IF", "STMT_IF"); if len(r) > 0 { return r }
	r = check_streq(StmtKindName(STMT_FOR), "FOR", "STMT_FOR"); if len(r) > 0 { return r }
	r = check_streq(StmtKindName(STMT_RETURN), "RETURN", "STMT_RETURN"); if len(r) > 0 { return r }
	r = check_streq(StmtKindName(STMT_DECL), "DECL", "STMT_DECL"); if len(r) > 0 { return r }
	r = check_streq(StmtKindName(99), "UNKNOWN_STMT", "unknown"); if len(r) > 0 { return r }
	return ""
}

func TestDeclKindName() testing.TestResult {
	var r testing.TestResult
