package "pkg/buf"

import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func charsEq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func TestNew() testing.TestResult {
	var b CharBuf = New()
	if b.Len != 0 { return fail("new buf should have len 0") }
	if len(b.Data) < INITIAL_CAP { return fail("new buf should have initial capacity") }
	return ""
}

func TestWriteByte() testing.TestResult {
	var b CharBuf = New()
	b = WriteByte(b, 'A')
	b = WriteByte(b, 'B')
	if b.Len != 2 { return fail("expected len 2 after writing 2 bytes") }
	var s @[]char = Bytes(b)
	if len(s) != 2 { return fail("Bytes len should be 2") }
	if s[0] != 'A' || s[1] != 'B' { return fail("bytes should be AB") }
	return ""
}

func TestWriteStr() testing.TestResult {
	var b CharBuf = New()
	b = WriteStr(b, "hello")
	if b.Len != 5 { return fail("expected len 5") }
	var s @[]char = Bytes(b)
	if !charsEq(s, "hello") { return fail("expected hello") }
	return ""
}

func TestWriteInt() testing.TestResult {
	var b CharBuf = New()
	b = WriteInt(b, 0)
	if !charsEq(Bytes(b), "0") { return fail("expected 0") }

	b = New()
	b = WriteInt(b, 42)
	if !charsEq(Bytes(b), "42") { return fail("expected 42") }

	b = New()
	b = WriteInt(b, -7)
	if !charsEq(Bytes(b), "-7") { return fail("expected -7") }

	b = New()
	b = WriteInt(b, 12345)
	if !charsEq(Bytes(b), "12345") { return fail("expected 12345") }
	return ""
}

func TestWriteHexByte() testing.TestResult {
	var b CharBuf = New()
	b = WriteHexByte(b, 0)
	if !charsEq(Bytes(b), "00") { return fail("expected 00") }

	b = New()
	b = WriteHexByte(b, 255)
	if !charsEq(Bytes(b), "FF") { return fail("expected FF") }

	b = New()
	b = WriteHexByte(b, 171)
	if !charsEq(Bytes(b), "AB") { return fail("expected AB") }
	return ""
}

func TestFreeze() testing.TestResult {
	var b CharBuf = New()
	b = WriteStr(b, "frozen")
	var s @[]char = Freeze(b)
	if len(s) != 6 { return fail("expected len 6") }
	var raw []char = s
	if !charsEq(raw, "frozen") { return fail("expected frozen") }
	return ""
}

func TestCopyStr() testing.TestResult {
	var s @[]char = CopyStr("copy")
	var raw []char = s
	if len(raw) != 4 { return fail("expected len 4") }
	if !charsEq(raw, "copy") { return fail("expected copy") }
	return ""
}

func TestGrow() testing.TestResult {
	// Write more than INITIAL_CAP bytes to trigger growth
	var b CharBuf = New()
	for i := 0; i < 100; i++ {
		b = WriteByte(b, 'x')
	}
	if b.Len != 100 { return fail("expected len 100") }
	if len(b.Data) < 100 { return fail("capacity should have grown") }
	return ""
}

func TestLen() testing.TestResult {
	var b CharBuf = New()
	if Len(b) != 0 { return fail("expected 0") }
	b = WriteStr(b, "abc")
	if Len(b) != 3 { return fail("expected 3") }
	return ""
}
