package "pkg/builtin/testing"

func TestTestResultPassIsEmpty() @[]char {
	var r TestResult = ""
	if len(r) != 0 {
		return "expected empty TestResult for pass"
	}
	return ""
}

func TestTestResultFailIsNonEmpty() @[]char {
	var r TestResult = "something failed"
	if len(r) == 0 {
		return "expected non-empty TestResult for fail"
	}
	return ""
}
