// Package codegen emits LLVM IR text from the Binate IR representation.
package "pkg/codegen"

import "pkg/ir"

// SetDebugInfo enables/disables DWARF debug metadata in emitted LLVM IR.
func SetDebugInfo(enabled bool)

// EmitModule produces LLVM IR text (.ll) for the given IR module.
func EmitModule(m @ir.Module) []char
