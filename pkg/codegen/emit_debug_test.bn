package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// Tests for DWARF debug metadata emission.

func TestEmitDebugMetadata() testing.TestResult {
	SetDebugInfo(true)
	var src []char = "package \"main\"\nfunc main() { println(1) }\n"
	var out []char = compileToLLVM(src)
	SetDebugInfo(false)
	if !contains(out, "!DICompileUnit") {
		return fail("expected DICompileUnit in debug output")
	}
	if !contains(out, "!DISubprogram") {
		return fail("expected DISubprogram in debug output")
	}
	return nil
}

func TestEmitNoDebugByDefault() testing.TestResult {
	SetDebugInfo(false)
	var src []char = "package \"main\"\nfunc main() { println(1) }\n"
	var out []char = compileToLLVM(src)
	if contains(out, "!DICompileUnit") {
		return fail("should not emit debug info when disabled")
	}
	return nil
}
