package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// Tests for extracted emitInstr helpers (nontrivial op handlers).

func TestEmitConstNilSlice() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var s []int; _ = s }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "%BnSlice zeroinitializer") {
		return fail("expected nil slice zeroinitializer")
	}
	return nil
}

func TestEmitAllocStructZeroInit() testing.TestResult {
	var src []char = "package \"main\"\ntype P struct { X int }\nfunc main() { var p P }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "alloca") {
		return fail("expected alloca for struct")
	}
	if !contains(out, "zeroinitializer") {
		return fail("expected zeroinitializer for struct")
	}
	return nil
}

func TestEmitGetFieldPtr() testing.TestResult {
	var src []char = "package \"main\"\ntype P struct { X int; Y int }\nfunc main() { var p P; p.Y = 5 }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "getelementptr inbounds") {
		return fail("expected getelementptr for field access")
	}
	return nil
}

func TestEmitMultiReturn() testing.TestResult {
	var src []char = "package \"main\"\nfunc f() (int, int) { return 1, 2 }\nfunc main() { a, b := f() }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "insertvalue") {
		return fail("expected insertvalue for multi-return packing")
	}
	return nil
}

func TestEmitMakeSlice() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var s @[]int = make_slice(int, 5) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "bn_rt__MakeManagedSlice") {
		return fail("expected MakeManagedSlice call")
	}
	return nil
}

func TestEmitBoxInstr() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var p *int = box(42) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "bn_rt__Box") {
		return fail("expected Box call")
	}
	return nil
}

func TestEmitRefcountInc() testing.TestResult {
	var src []char = "package \"main\"\ntype N struct { V int }\nfunc main() { var a @N = make(N); var b @N = a; println(b.V) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "bn_rt__RefInc") {
		return fail("expected RefInc for managed ptr copy")
	}
	return nil
}

func TestEmitManagedToRaw() testing.TestResult {
	var src []char = "package \"main\"\nfunc f() []int { var s @[]int = make_slice(int, 3); return s }\nfunc main() { f() }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "extractvalue %BnManagedSlice") {
		return fail("expected extractvalue from managed slice")
	}
	return nil
}
