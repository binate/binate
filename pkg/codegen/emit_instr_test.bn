package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// Tests for the emitInstr dispatch (simple inline cases).

func TestEmitConstInt() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { println(42) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "add i64 42, 0") {
		return fail("expected const int emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitConstBool() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x bool = true }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "add i1 1, 0") {
		return fail("expected const bool emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitLoadStore() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x int = 1; x = 2; println(x) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "store i64") {
		return fail("expected store emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitJumpBranch() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { if true { println(1) } }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "br i1") {
		return fail("expected branch emission")
	}
	if !contains(out, "br label") {
		return fail("expected jump emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitReturnVoid() testing.TestResult {
	var src []char = "package \"main\"\nfunc f() { return }\nfunc main() { f() }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "ret void") {
		return fail("expected void return")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitUnaryNeg() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { println(-42) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "sub i64 0,") {
		return fail("expected sub for negation")
	}
	var pass testing.TestResult
	return pass
}

func TestSliceElemPtrEmission() testing.TestResult {
	// Slice element pointer should emit getelementptr
	var src []char = "package \"main\"\ntype Point struct {\n\tX int\n\tY int\n}\nfunc main() {\n\tvar pts @[]Point = make_slice(Point, 1)\n\tpts[0] = Point{1, 2}\n\tpts[0].X = 99\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	if !contains(out, "getelementptr") {
		return fail("expected getelementptr for slice element access")
	}
	var pass testing.TestResult
	return pass
}

func TestSliceExprStructEmission() testing.TestResult {
	var src []char = "package \"main\"\ntype Item struct {\n\tVal int\n}\nfunc main() {\n\tvar items @[]Item = make_slice(Item, 2)\n\titems[0] = Item{1}\n\titems[1] = Item{2}\n\tvar sub []Item = items[0:1]\n\t_ = sub\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	if !contains(out, "getelementptr") {
		return fail("expected getelementptr for struct slice expression")
	}
	var pass testing.TestResult
	return pass
}

func TestManagedSliceForInEmission() testing.TestResult {
	// for-in over @[]T uses extractvalue for len and data ptr, then GEP for element access.
	var src []char = "package \"main\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 2)\n\ts[0] = 1\n\ts[1] = 2\n\tfor v in s { println(v) }\n}\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "extractvalue") {
		return fail("expected extractvalue for slice field access")
	}
	if !contains(out, "getelementptr") {
		return fail("expected getelementptr for slice element access")
	}
	var pass testing.TestResult
	return pass
}
