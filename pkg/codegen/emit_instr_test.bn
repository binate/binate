package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// Tests for the emitInstr dispatch (simple inline cases).

func TestEmitConstInt() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { println(42) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "add i64 42, 0") {
		return fail("expected const int emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitConstBool() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x bool = true }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "add i1 1, 0") {
		return fail("expected const bool emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitLoadStore() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x int = 1; x = 2; println(x) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "store i64") {
		return fail("expected store emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitJumpBranch() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { if true { println(1) } }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "br i1") {
		return fail("expected branch emission")
	}
	if !contains(out, "br label") {
		return fail("expected jump emission")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitReturnVoid() testing.TestResult {
	var src []char = "package \"main\"\nfunc f() { return }\nfunc main() { f() }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "ret void") {
		return fail("expected void return")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitUnaryNeg() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { println(-42) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "sub i64 0,") {
		return fail("expected sub for negation")
	}
	var pass testing.TestResult
	return pass
}
