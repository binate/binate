package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// Tests for emitBinop, emitCmp, emitLogical, emitCall, emitCast, emitBitCast.

func TestEmitBinopAdd() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { println(1 + 2) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "add i64") {
		return fail("expected add instruction")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitCmpLT() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x bool = 1 < 2 }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "icmp ult") {
		return fail("expected icmp ult for untyped int less-than")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitLogicalAnd() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x bool = true && false }\n"
	var out []char = compileToLLVM(src)
	// Logical and uses short-circuit branching
	if !contains(out, "br i1") {
		return fail("expected branch for short-circuit and")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitCallFunc() testing.TestResult {
	var src []char = "package \"main\"\nfunc add(a int, b int) int { return a + b }\nfunc main() { println(add(1, 2)) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "call i64 @bn_main__add") {
		return fail("expected call to mangled function name")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitCastIntWidth() testing.TestResult {
	var src []char = "package \"main\"\nfunc main() { var x int8 = cast(int8, 42) }\n"
	var out []char = compileToLLVM(src)
	if !contains(out, "trunc i64") {
		return fail("expected trunc for narrowing cast")
	}
	var pass testing.TestResult
	return pass
}
