package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

func TestSliceElemPtrEmission() testing.TestResult {
	// OP_SLICE_ELEM_PTR should emit bn_slice_get_struct + bitcast
	var src []char = "package \"main\"\ntype Point struct {\n\tX int\n\tY int\n}\nfunc main() {\n\tvar pts @[]Point = make_slice(Point, 1)\n\tpts[0] = Point{1, 2}\n\tpts[0].X = 99\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	if !contains(out, "bn_slice_get_struct") {
		return fail("expected call to bn_slice_get_struct")
	}
	if !contains(out, "bitcast i8*") {
		return fail("expected bitcast from i8* to struct ptr")
	}
	return nil
}

func TestSliceExprStructEmission() testing.TestResult {
	// Slice expression on struct slices should use bn_slice_expr_struct with elem_size
	var src []char = "package \"main\"\ntype Item struct {\n\tVal int\n}\nfunc main() {\n\tvar items @[]Item = make_slice(Item, 2)\n\titems[0] = Item{1}\n\titems[1] = Item{2}\n\tvar sub []Item = items[0:1]\n\t_ = sub\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	if !contains(out, "bn_slice_expr_struct") {
		return fail("expected call to bn_slice_expr_struct for struct slice expression")
	}
	return nil
}
