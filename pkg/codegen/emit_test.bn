package "pkg/codegen"

import "pkg/ir"
import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/mangle"
import "pkg/builtin/testing"

// ============================================================
// Helpers
// ============================================================

func fail(msg @[]char) testing.TestResult {
	return msg
}

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func strToBytes(s []char) []uint8 {
	var r @[]uint8 = make_slice(uint8, len(s))
	for i := 0; i < len(s); i++ {
		r[i] = cast(uint8, s[i])
	}
	return r
}

func contains(haystack []char, needle []char) bool {
	if len(needle) > len(haystack) { return false }
	for i := 0; i <= len(haystack) - len(needle); i++ {
		var match bool = true
		for j := 0; j < len(needle); j++ {
			if haystack[i + j] != needle[j] {
				match = false
				break
			}
		}
		if match { return true }
	}
	return false
}

// compileToLLVM compiles Binate source to LLVM IR text.
func compileToLLVM(src []char) @[]char {
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)
	return EmitModule(m)
}

// ============================================================
// mangle tests (now in pkg/mangle, tested via import)
// ============================================================

func TestPkgShortNameSimple() testing.TestResult {
	var r []char = mangle.PkgShortName("main")
	if !seq(r, "main") { return fail("expected main") }
	var pass testing.TestResult
	return pass
}

func TestPkgShortNamePath() testing.TestResult {
	var r []char = mangle.PkgShortName("pkg/parser")
	if !seq(r, "parser") { return fail("expected parser") }
	var pass testing.TestResult
	return pass
}

func TestPkgShortNameDeep() testing.TestResult {
	var r []char = mangle.PkgShortName("a/b/c")
	if !seq(r, "c") { return fail("expected c") }
	var pass testing.TestResult
	return pass
}

func TestMangleFuncNameMain() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.FuncName("main", "main"))
	if !seq(r, "bn_main") { return fail("expected bn_main") }
	var pass testing.TestResult
	return pass
}

func TestMangleFuncNameLocal() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.FuncName("parser", "New"))
	if !seq(r, "bn_parser__New") { return fail("expected bn_parser__New") }
	var pass testing.TestResult
	return pass
}

func TestMangleFuncNameQualified() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.FuncName("main", "parser.New"))
	if !seq(r, "bn_parser__New") { return fail("expected bn_parser__New") }
	var pass testing.TestResult
	return pass
}

func TestMangleFuncNameBootstrap() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.FuncName("main", "bootstrap.Open"))
	if !seq(r, "bn_bootstrap__Open") { return fail("expected bn_bootstrap__Open") }
	var pass testing.TestResult
	return pass
}

func TestMangleGlobalName() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.GlobalName("main", "count"))
	if !seq(r, "bn_main__count") { return fail("expected bn_main__count") }
	var pass testing.TestResult
	return pass
}

func TestMangleStructNameLocal() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.StructName("parser", "Parser"))
	if !seq(r, "bn_parser__Parser") { return fail("expected bn_parser__Parser") }
	var pass testing.TestResult
	return pass
}

func TestMangleStructNameQualified() testing.TestResult {
	var r @[]char = buf.Bytes(mangle.StructName("main", "ast.File"))
	if !seq(r, "bn_ast__File") { return fail("expected bn_ast__File") }
	var pass testing.TestResult
	return pass
}

// ============================================================
// EmitModule tests (extern declarations)
// ============================================================

func TestEmitExternDeclaration() testing.TestResult {
	var m @ir.Module = ir.NewModule("\"main\"")

	// Add an extern function
	var params @[]@ir.Param = make_slice(@ir.Param, 1)
	var p1 @ir.Param = make(ir.Param)
	p1.Name = "x"
	p1.Typ = types.TypInt()
	params[0] = p1
	var results @[]@types.Type = make_slice(@types.Type, 1)
	results[0] = types.TypInt()
	var f @ir.Func = ir.NewExternFunc("helper.Double", params, results)
	ir.AddFunc(m, f)

	var out @[]char = EmitModule(m)
	if !contains(out, "declare i64 @bn_helper__Double(i64)") {
		return fail("expected declare for extern func")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitCExternSret() testing.TestResult {
	// C extern returning @[]char (BnManagedSlice = 32 bytes) should use sret
	var m @ir.Module = ir.NewModule("\"main\"")

	var params @[]@ir.Param = make_slice(@ir.Param, 2)
	var p1 @ir.Param = make(ir.Param)
	p1.Name = "a"
	p1.Typ = types.MakeSliceType(types.TypChar())
	params[0] = p1
	var p2 @ir.Param = make(ir.Param)
	p2.Name = "b"
	p2.Typ = types.MakeSliceType(types.TypChar())
	params[1] = p2
	var results @[]@types.Type = make_slice(@types.Type, 1)
	results[0] = types.MakeManagedSliceType(types.TypChar())
	var f @ir.Func = ir.NewExternFunc("bootstrap.Concat", params, results)
	f.IsCExtern = true
	ir.AddFunc(m, f)

	var out @[]char = EmitModule(m)
	// Should have sret declaration (void return, ptr sret first param)
	if !contains(out, "declare void @bn_bootstrap__Concat(ptr sret(%BnManagedSlice) align 8") {
		return fail("expected sret declaration for C extern returning @[]char")
	}
	var pass testing.TestResult
	return pass
}

func TestEmitNonCExternNoSret() testing.TestResult {
	// Binate extern returning @[]char should NOT use sret (LLVM handles it)
	var m @ir.Module = ir.NewModule("\"main\"")

	var noParams @[]@ir.Param
	var results @[]@types.Type = make_slice(@types.Type, 1)
	results[0] = types.MakeManagedSliceType(types.TypInt())
	var f @ir.Func = ir.NewExternFunc("helper.GetSlice", noParams, results)
	// IsCExtern defaults to false
	ir.AddFunc(m, f)

	var out @[]char = EmitModule(m)
	// Should have direct return (not sret)
	if !contains(out, "declare %BnManagedSlice @bn_helper__GetSlice()") {
		return fail("expected direct return for non-C extern")
	}
	if contains(out, "sret") {
		return fail("non-C extern should not use sret")
	}
	var pass testing.TestResult
	return pass
}
