// mangleFuncName tests
// ============================================================

func TestMangleFuncNameMain() testing.TestResult {
	modulePkgName = "main"
	var r []char = mangleFuncName("main")
	if !seq(r, "bn_main") { return fail("expected bn_main") }
	return nil
}

func TestMangleFuncNameLocal() testing.TestResult {
	modulePkgName = "parser"
	var r []char = mangleFuncName("New")
	if !seq(r, "bn_parser__New") { return fail("expected bn_parser__New") }
	return nil
}

func TestMangleFuncNameQualified() testing.TestResult {
	modulePkgName = "main"
	var r []char = mangleFuncName("parser.New")
	if !seq(r, "bn_parser__New") { return fail("expected bn_parser__New") }
	return nil
}

func TestMangleFuncNameBootstrap() testing.TestResult {
	modulePkgName = "main"
	var r []char = mangleFuncName("bootstrap.Open")
