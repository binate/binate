package "pkg/codegen"

import "pkg/ir"
import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// ============================================================
// Helpers
// ============================================================

func fail(msg []char) testing.TestResult {
	return msg
}

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func strToBytes(s []char) []uint8 {
	var r []uint8
	for i := 0; i < len(s); i++ {
		r = append(r, cast(uint8, s[i]))
	}
	return r
}

func contains(haystack []char, needle []char) bool {
	if len(needle) > len(haystack) { return false }
	for i := 0; i <= len(haystack) - len(needle); i++ {
		var match bool = true
		for j := 0; j < len(needle); j++ {
			if haystack[i + j] != needle[j] {
				match = false
				break
			}
		}
		if match { return true }
	}
	return false
}

// ============================================================
// pkgShortName tests
// ============================================================

func TestPkgShortNameSimple() testing.TestResult {
	var r []char = pkgShortName("main")
	if !seq(r, "main") { return fail("expected main") }
	return nil
}

func TestPkgShortNamePath() testing.TestResult {
	var r []char = pkgShortName("pkg/parser")
	if !seq(r, "parser") { return fail("expected parser") }
	return nil
}

func TestPkgShortNameDeep() testing.TestResult {
	var r []char = pkgShortName("a/b/c")
	if !seq(r, "c") { return fail("expected c") }
	return nil
}

