// ============================================================
// EmitModule tests (extern declarations)
// ============================================================

func TestEmitExternDeclaration() testing.TestResult {
	var m @ir.Module = ir.NewModule("\"main\"")

	// Add an extern function
	var params []@ir.Param
	var p1 @ir.Param = make(ir.Param)
	p1.Name = "x"
	p1.Typ = types.TypInt()
	params = append(params, p1)
	var results []@types.Type
	results = append(results, types.TypInt())
	var f @ir.Func = ir.NewExternFunc("helper.Double", params, results)
	ir.AddFunc(m, f)

	var out []char = EmitModule(m)
	if !contains(out, "declare i64 @bn_helper__Double(i64)") {
		return fail("expected declare for extern func")
	}
	return nil
}

func TestSliceElemPtrEmission() testing.TestResult {
	// OP_SLICE_ELEM_PTR should emit bn_slice_get_struct + bitcast
	var src []char = "package \"main\"\ntype Point struct {\n\tX int\n\tY int\n}\nfunc main() {\n\tvar pts []Point\n\tpts = append(pts, Point{1, 2})\n\tpts[0].X = 99\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	if !contains(out, "bn_slice_get_struct") {
		return fail("expected call to bn_slice_get_struct")
	}
	if !contains(out, "bitcast i8*") {
		return fail("expected bitcast from i8* to struct ptr")
	}
	return nil
}

func TestSliceExprStructEmission() testing.TestResult {
	// Slice expression on struct slices should use bn_slice_expr_struct with elem_size
	var src []char = "package \"main\"\ntype Item struct {\n\tVal int\n}\nfunc main() {\n\tvar items []Item\n\titems = append(items, Item{1})\n\titems = append(items, Item{2})\n\tvar sub []Item = items[0:1]\n\t_ = sub\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	if !contains(out, "bn_slice_expr_struct") {
		return fail("expected call to bn_slice_expr_struct for struct slice expression")
	}
	return nil
}

func TestEmitPackedStruct() testing.TestResult {
	// Generate a module from source that uses a struct
	var src []char = "package \"main\"\ntype Mixed struct {\n\tA int8\n\tB int\n}\nfunc main() {\n\tvar m Mixed\n\tm.A = cast(int8, 1)\n\tm.B = 42\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	// Should be a packed struct with padding
	if !contains(out, "%bn_main__Mixed = type <{") {
		return fail("expected packed struct type def")
	}
	return nil
}
