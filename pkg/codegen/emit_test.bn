package "pkg/codegen"

import "pkg/ir"
import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

// ============================================================
// Helpers
// ============================================================

func fail(msg []char) testing.TestResult {
	return msg
}

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func strToBytes(s []char) []uint8 {
	var r []uint8
	for i := 0; i < len(s); i++ {
		r = append(r, cast(uint8, s[i]))
	}
	return r
}

func contains(haystack []char, needle []char) bool {
	if len(needle) > len(haystack) { return false }
	for i := 0; i <= len(haystack) - len(needle); i++ {
		var match bool = true
		for j := 0; j < len(needle); j++ {
			if haystack[i + j] != needle[j] {
				match = false
				break
			}
		}
		if match { return true }
	}
	return false
}

// compileToLLVM compiles Binate source to LLVM IR text.
func compileToLLVM(src []char) []char {
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)
	return EmitModule(m)
}

// ============================================================
// pkgShortName tests
// ============================================================

func TestPkgShortNameSimple() testing.TestResult {
	var r []char = pkgShortName("main")
	if !seq(r, "main") { return fail("expected main") }
	return nil
}

func TestPkgShortNamePath() testing.TestResult {
	var r []char = pkgShortName("pkg/parser")
	if !seq(r, "parser") { return fail("expected parser") }
	return nil
}

func TestPkgShortNameDeep() testing.TestResult {
	var r []char = pkgShortName("a/b/c")
	if !seq(r, "c") { return fail("expected c") }
	return nil
}

// ============================================================
// mangleFuncName tests
// ============================================================

func TestMangleFuncNameMain() testing.TestResult {
	modulePkgName = "main"
	var r []char = buf.Bytes(mangleFuncName("main"))
	if !seq(r, "bn_main") { return fail("expected bn_main") }
	return nil
}

func TestMangleFuncNameLocal() testing.TestResult {
	modulePkgName = "parser"
	var r []char = buf.Bytes(mangleFuncName("New"))
	if !seq(r, "bn_parser__New") { return fail("expected bn_parser__New") }
	return nil
}

func TestMangleFuncNameQualified() testing.TestResult {
	modulePkgName = "main"
	var r []char = buf.Bytes(mangleFuncName("parser.New"))
	if !seq(r, "bn_parser__New") { return fail("expected bn_parser__New") }
	return nil
}

func TestMangleFuncNameBootstrap() testing.TestResult {
	modulePkgName = "main"
	var r []char = buf.Bytes(mangleFuncName("bootstrap.Open"))
	if !seq(r, "bn_bootstrap__Open") { return fail("expected bn_bootstrap__Open") }
	return nil
}

