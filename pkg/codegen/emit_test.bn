// ============================================================
// EmitModule tests (extern declarations)
// ============================================================

func TestEmitExternDeclaration() testing.TestResult {
	var m @ir.Module = ir.NewModule("\"main\"")

	// Add an extern function
	var params @[]@ir.Param = make_slice(@ir.Param, 1)
	var p1 @ir.Param = make(ir.Param)
	p1.Name = "x"
	p1.Typ = types.TypInt()
	params[0] = p1
	var results @[]@types.Type = make_slice(@types.Type, 1)
	results[0] = types.TypInt()
	var f @ir.Func = ir.NewExternFunc("helper.Double", params, results)
	ir.AddFunc(m, f)

	var out []char = EmitModule(m)
	if !contains(out, "declare i64 @bn_helper__Double(i64)") {
		return fail("expected declare for extern func")
	}
	return nil
}
