package "pkg/codegen"

import "pkg/ir"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"

func TestEmitPackedStruct() testing.TestResult {
	// Generate a module from source that uses a struct
	var src []char = "package \"main\"\ntype Mixed struct {\n\tA int8\n\tB int\n}\nfunc main() {\n\tvar m Mixed\n\tm.A = cast(int8, 1)\n\tm.B = 42\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @ir.Module = ir.GenModule(file)

	var out []char = EmitModule(m)
	// Should be a packed struct with padding
	if !contains(out, "%bn_main__Mixed = type <{") {
		return fail("expected packed struct type def")
	}
	return nil
}
