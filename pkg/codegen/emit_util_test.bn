package "pkg/codegen"

import "pkg/types"
import "pkg/builtin/testing"

// Tests for llvmTypeBits, typeSizeBytes, elemSizeOf, charsEqual, etc.

func TestCharsEqual() testing.TestResult {
	if !charsEqual("hello", "hello") { return fail("same strings") }
	if charsEqual("hello", "world") { return fail("different strings") }
	if charsEqual("abc", "ab") { return fail("different lengths") }
	return nil
}

func TestTypeSizeBytes() testing.TestResult {
	if typeSizeBytes(types.TypInt()) != 8 { return fail("int should be 8 bytes") }
	if typeSizeBytes(types.TypBool()) != 1 { return fail("bool should be 1 byte") }
	if typeSizeBytes(types.TypInt8()) != 1 { return fail("int8 should be 1 byte") }
	return nil
}

func TestElemSizeOf() testing.TestResult {
	// elemSizeOf returns SizeOf(t) — used with the elem type, not the slice type
	if elemSizeOf(types.TypInt()) != 8 { return fail("int should be 8") }
	if elemSizeOf(types.TypUint8()) != 1 { return fail("uint8 should be 1") }
	return nil
}

func TestStripQuotes() testing.TestResult {
	var r []char = stripQuotes("\"hello\"")
	if !seq(r, "hello") { return fail("expected hello") }
	return nil
}

func TestStripQuotesNoQuotes() testing.TestResult {
	var r []char = stripQuotes("hello")
	if !seq(r, "hello") { return fail("expected hello unchanged") }
	return nil
}
