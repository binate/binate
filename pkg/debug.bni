// Package debug provides a global verbose logging flag and a Log function
// that writes prefixed messages to stderr when verbose mode is enabled.
package "pkg/debug"

// SetVerbose enables or disables verbose logging.
func SetVerbose(v bool)

// IsVerbose returns whether verbose mode is currently enabled.
func IsVerbose() bool

// Log writes msg to stderr with a "[verbose] " prefix if verbose mode is on.
func Log(msg []char)
