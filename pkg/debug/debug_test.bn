package "pkg/debug"

import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func TestSetVerbose() testing.TestResult {
	SetVerbose(false)
	if IsVerbose() { return fail("expected not verbose") }
	SetVerbose(true)
	if !IsVerbose() { return fail("expected verbose") }
	SetVerbose(false)
	return ""
}

func TestLogSilent() testing.TestResult {
	// When verbose is off, Log should be a no-op (no crash)
	SetVerbose(false)
	Log("this should not appear")
	return ""
}
