package "pkg/interp"

import "pkg/types"
import "pkg/builtin/testing"

func fail(msg []char) testing.TestResult { return msg }

func TestMakeBuiltinVal() testing.TestResult {
	var v @Value = makeBuiltinVal(BID_OPEN, "Open")
	if v == nil { return fail("nil value") }
	if v.Kind != VAL_BUILTIN { return fail("expected VAL_BUILTIN") }
	if v.BuiltinID != BID_OPEN { return fail("expected BID_OPEN") }
	return ""
}

func TestSliceToChars() testing.TestResult {
	// Build a VAL_SLICE with character values
	var elems @[]@Value = make_slice(@Value, 3)
	elems[0] = MakeIntVal(cast(int, 'a'), types.TypChar())
	elems[1] = MakeIntVal(cast(int, 'b'), types.TypChar())
	elems[2] = MakeIntVal(cast(int, 'c'), types.TypChar())
	var sv @Value = MakeSliceVal(elems, types.MakeSliceType(types.TypChar()))
	var chars []char = sliceToChars(sv)
	if len(chars) != 3 { return fail("expected len 3") }
	if chars[0] != 'a' || chars[1] != 'b' || chars[2] != 'c' {
		return fail("expected abc")
	}
	return ""
}

func TestRegisterBootstrapPackage() testing.TestResult {
	var interp @Interpreter = NewInterpreter()
	RegisterBootstrapPackage(interp)
	// Should have at least 1 package registered
	if len(interp.Packages) < 1 { return fail("expected at least 1 package") }
	// Find the bootstrap package
	var found bool = false
	for i := 0; i < len(interp.Packages); i++ {
		var pkg @PkgEnv = interp.Packages[i]
		if len(pkg.Path) >= 13 {
			found = true
		}
	}
	if !found { return fail("bootstrap package not registered") }
	return ""
}
