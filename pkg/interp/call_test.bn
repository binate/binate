// ============================================================
// bit_cast tests
// ============================================================

func TestBitCastPtrToPtr() testing.TestResult {
	// bit_cast(*int, ptr) — reinterpret pointer type
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar ip *int = bit_cast(*int, p)\n\tip[0] = 42\n\tprintln(ip[0])\n\trt.c_free(p)\n}\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitCastPtrToInt() testing.TestResult {
	// bit_cast(int, ptr) — get address as integer
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar addr int = bit_cast(int, p)\n\tif addr != 0 { println(1) } else { println(0) }\n\trt.c_free(p)\n}\n")
	if !seq(out, "1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitCastIntToPtr() testing.TestResult {
	// bit_cast(*uint8, int) — create pointer from integer
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar addr int = bit_cast(int, p)\n\tvar q *uint8 = bit_cast(*uint8, addr)\n\tvar ip *int = bit_cast(*int, q)\n\tip[0] = 99\n\tvar ip2 *int = bit_cast(*int, p)\n\tprintln(ip2[0])\n\trt.c_free(p)\n}\n")
	if !seq(out, "99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// rt forwarding tests
// ============================================================

func TestRtAllocFree() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.Alloc(16)\n\tif p != nil { println(1) } else { println(0) }\n\trt.Free(p)\n}\n")
	if !seq(out, "1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestRtRefcount() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.Alloc(8)\n\tprintln(rt.Refcount(p))\n\trt.RefInc(p)\n\tprintln(rt.Refcount(p))\n\trt.RefDec(p, nil)\n\tprintln(rt.Refcount(p))\n}\n")
	if !seq(out, "1\n2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Pointer indexing tests
// ============================================================

func TestPointerIndexing() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar arr [3]int\n\tarr[0] = 10\n\tarr[1] = 20\n\tarr[2] = 30\n\tvar p *int = &arr[0]\n\tprintln(p[0])\n\tprintln(p[1])\n\tp[2] = 99\n\tprintln(arr[2])\n}\n")
	if !seq(out, "10\n20\n99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Pointer comparison tests
// ============================================================

func TestPointerComparison() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar q *uint8 = p\n\tif p == q { println(1) } else { println(0) }\n\tvar r *uint8 = rt.c_malloc(8)\n\tif p == r { println(1) } else { println(0) }\n\trt.c_free(p)\n\trt.c_free(r)\n}\n")
	if !seq(out, "1\n0\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// MakeManagedSlice tests
// ============================================================

func TestMakeManagedSlice() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar ms rt.ManagedSlice = rt.MakeManagedSlice(8, 3)\n\tprintln(ms.Len)\n\tprintln(ms.BackingLen)\n\tif ms.Data != nil { println(1) } else { println(0) }\n}\n")
	if !seq(out, "3\n3\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Managed pointer refcount tests
// ============================================================

func TestManagedPtrRefcount() testing.TestResult {
	// make(T) should have rc=1, copy should RefInc to 2
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\ntype Node struct { Val int }\nfunc main() {\n\tvar n @Node = make(Node)\n\tvar ptr *uint8 = bit_cast(*uint8, n)\n\tprintln(rt.Refcount(ptr))\n\tvar m @Node = n\n\tprintln(rt.Refcount(ptr))\n}\n")
	if !seq(out, "1\n2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestManagedPtrReassignRefcount() testing.TestResult {
	// Reassigning a managed var: old gets RefDec'd, new gets RefInc'd.
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\ntype Node struct { Val int }\nfunc main() {\n\tvar a @Node = make(Node)\n\tvar keep @Node = a\n\tvar ptr *uint8 = bit_cast(*uint8, a)\n\tprintln(rt.Refcount(ptr))\n\tvar b @Node = make(Node)\n\ta = b\n\tprintln(rt.Refcount(ptr))\n\tvar ptrB *uint8 = bit_cast(*uint8, b)\n\tprintln(rt.Refcount(ptrB))\n}\n")
	if !seq(out, "2\n1\n2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFieldAssignRefcount() testing.TestResult {
	// Assigning @T to struct field should RefInc
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\ntype Inner struct { Val int }\ntype Outer struct { Child @Inner }\nfunc main() {\n\tvar inner @Inner = make(Inner)\n\tvar ptr *uint8 = bit_cast(*uint8, inner)\n\tprintln(rt.Refcount(ptr))\n\tvar outer @Outer = make(Outer)\n\touter.Child = inner\n\tprintln(rt.Refcount(ptr))\n}\n")
	if !seq(out, "1\n2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestStructFieldDtorRefDec() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\ntype Inner struct { X int }\ntype Outer struct { Child @Inner }\nfunc main() {\n\tvar inner @Inner = make(Inner)\n\tvar ptr *uint8 = bit_cast(*uint8, inner)\n\tvar outer @Outer = make(Outer)\n\touter.Child = inner\n\tprintln(rt.Refcount(ptr))\n\touter = make(Outer)\n\tprintln(rt.Refcount(ptr))\n}\n")
	if !seq(out, "2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestArrayManagedSliceElemRefcount() testing.TestResult {
	// Storing @[]char in an array element should RefInc its backing.
	// Overwriting should RefDec the old backing.
	var src []char = "package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar a @[]char = make_slice(char, 1)\n\tvar pa *int = bit_cast(*int, &a)\n\tvar bp *uint8 = bit_cast(*uint8, pa[2])\n\tprintln(rt.Refcount(bp))\n\tvar arr [2]@[]char\n\tarr[0] = a\n\tprintln(rt.Refcount(bp))\n\tvar b @[]char = make_slice(char, 1)\n\tarr[0] = b\n\tprintln(rt.Refcount(bp))\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "1\n2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSliceElemDtorRefDec() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\ntype Node struct { Val int }\nfunc main() {\n\tvar n @Node = make(Node)\n\tvar ptr *uint8 = bit_cast(*uint8, n)\n\tvar s @[]@Node = make_slice(@Node, 1)\n\ts[0] = n\n\tprintln(rt.Refcount(ptr))\n\ts = make_slice(@Node, 0)\n\tprintln(rt.Refcount(ptr))\n}\n")
	if !seq(out, "2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBootstrapItoaConcat() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/bootstrap\"\nfunc main() {\n\tvar s @[]char = bootstrap.Itoa(42)\n\tprintln(s)\n\tvar t @[]char = bootstrap.Concat(\"hello\", \" world\")\n\tprintln(t)\n}\n")
	if !seq(out, "42\nhello world\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Flat struct field read/write: managed-slice
// ============================================================

func TestFlatStructManagedSliceField() testing.TestResult {
	// Write @[]int to flat struct field, read back len and elements
	var src []char = "package \"test\"\ntype Container struct { Items @[]int }\nfunc main() {\n\tvar c @Container = make(Container)\n\tc.Items = make_slice(int, 3)\n\tc.Items[0] = 10\n\tc.Items[1] = 20\n\tc.Items[2] = 30\n\tprintln(len(c.Items))\n\tprintln(c.Items[0])\n\tprintln(c.Items[1])\n\tprintln(c.Items[2])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "3\n10\n20\n30\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatStructManagedPtrField() testing.TestResult {
	// Write @T to flat struct field, read back through it
	var src []char = "package \"test\"\nimport \"pkg/rt\"\ntype Inner struct { X int }\ntype Outer struct { Child @Inner }\nfunc main() {\n\tvar o @Outer = make(Outer)\n\tvar c @Inner = make(Inner)\n\tc.X = 77\n\to.Child = c\n\tprintln(o.Child.X)\n\tvar ptr *uint8 = bit_cast(*uint8, c)\n\tprintln(rt.Refcount(ptr))\n}\n"
	var out []char = runAndGetOutput(src)
	// rc=2: one from var c, one from o.Child field
	if !seq(out, "77\n2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatStructStringToManagedChars() testing.TestResult {
	// Assign string literal to @[]char field in flat struct
	var src []char = "package \"test\"\ntype Widget struct { Name @[]char }\nfunc main() {\n\tvar w @Widget = make(Widget)\n\tw.Name = \"hello\"\n\tprintln(w.Name)\n\tprintln(len(w.Name))\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "hello\n5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatStructNilManagedSliceField() testing.TestResult {
	// Nil managed-slice field should have len 0
	var src []char = "package \"test\"\ntype Container struct { Items @[]int }\nfunc main() {\n\tvar c @Container = make(Container)\n\tif len(c.Items) == 0 { println(\"empty\") } else { println(\"FAIL\") }\n\tc.Items = make_slice(int, 2)\n\tvar zero @[]int\n\tc.Items = zero\n\tif len(c.Items) == 0 { println(\"empty again\") } else { println(\"FAIL\") }\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "empty\nempty again\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Self-referential type resolution
// ============================================================

func TestSelfReferentialType() testing.TestResult {
	// Node with self-referential @Node field — field access must work
	var src []char = "package \"test\"\ntype Node struct { Val int; Next @Node }\nfunc main() {\n\tvar a @Node = make(Node)\n\ta.Val = 1\n\tvar b @Node = make(Node)\n\tb.Val = 2\n\ta.Next = b\n\tprintln(a.Val)\n\tprintln(a.Next.Val)\n\tif a.Next.Next == nil { println(\"nil\") }\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "1\n2\nnil\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSelfReferentialRecursive() testing.TestResult {
	// Recursive list construction and traversal
	var src []char = "package \"test\"\ntype Node struct { Val int; Next @Node }\nfunc buildList(n int) @Node {\n\tif n <= 0 { return nil }\n\tvar node @Node = make(Node)\n\tnode.Val = n\n\tnode.Next = buildList(n - 1)\n\treturn node\n}\nfunc sum(n @Node) int {\n\tif n == nil { return 0 }\n\treturn n.Val + sum(n.Next)\n}\nfunc main() { println(sum(buildList(5))) }\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "15\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Managed-slice return value survives scope cleanup
// ============================================================

func TestReturnManagedSlicePreservesElements() testing.TestResult {
	// Returning @[]@T from a function: elements must survive scope cleanup
	var src []char = "package \"test\"\nimport \"pkg/rt\"\ntype Item struct { Val int }\nfunc makeItems() @[]@Item {\n\tvar items @[]@Item = make_slice(@Item, 2)\n\tvar a @Item = make(Item)\n\ta.Val = 10\n\titems[0] = a\n\tvar b @Item = make(Item)\n\tb.Val = 20\n\titems[1] = b\n\treturn items\n}\nfunc main() {\n\tvar items @[]@Item = makeItems()\n\tprintln(items[0].Val)\n\tprintln(items[1].Val)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "10\n20\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestReturnManagedSliceRefcountCorrect() testing.TestResult {
	// After returning @[]@T, elements should have correct refcount
	var src []char = "package \"test\"\nimport \"pkg/rt\"\ntype Item struct { Val int }\nfunc makeOne() @[]@Item {\n\tvar s @[]@Item = make_slice(@Item, 1)\n\tvar it @Item = make(Item)\n\tit.Val = 42\n\ts[0] = it\n\treturn s\n}\nfunc main() {\n\tvar s @[]@Item = makeOne()\n\tvar ptr *uint8 = bit_cast(*uint8, s[0])\n\tprintln(rt.Refcount(ptr))\n\tprintln(s[0].Val)\n}\n"
	var out []char = runAndGetOutput(src)
	// rc=1: local `it` and param cleaned up, only s[0] holds reference
	if !seq(out, "1\n42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Managed-slice len/index through flat struct field
