package "pkg/interp"

import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Function Call and Builtin Tests
// ============================================================

func TestFuncCall() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc add(a int, b int) int { return a + b }\nfunc main() { println(add(3, 4)) }\n")
	if !seq(out, "7\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestMakeSliceAndAssign() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var s @[]int = make_slice(int, 2); s[0] = 1; s[1] = 2; println(len(s)) }\n")
	if !seq(out, "2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestMakeStruct() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\ntype Node struct { Val int }\nfunc main() { var n @Node = make(Node); n.Val = 42; println(n.Val) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestCast() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var x int = cast(int, 42); println(x) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestLen() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(len(\"hello\")) }\n")
	if !seq(out, "5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestMultiReturn() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc swap(a int, b int) (int, int) { return b, a }\nfunc main() { x, y := swap(1, 2); println(x); println(y) }\n")
	if !seq(out, "2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestRecursion() testing.TestResult {
	var src []char = "package \"test\"\nfunc fib(n int) int { if n <= 1 { return n }; return fib(n-1) + fib(n-2) }\nfunc main() { println(fib(10)) }\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "55\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Multiple print args
// ============================================================
func TestPrintMultipleArgs() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(\"sum:\", 1 + 2) }\n")
	if !seq(out, "sum: 3\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Make raw deprecated slice with size
// ============================================================
func TestMakeSliceRaw() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 3)\n\tprintln(len(s))\n\tprintln(s[0])\n\ts[1] = 42\n\tprintln(s[1])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "3\n0\n42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestMakeSlice() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 3)\n\tprintln(len(s))\n\tprintln(s[0])\n\ts[1] = 42\n\tprintln(s[1])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "3\n0\n42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Box builtin
// ============================================================
func TestBox() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() { var p *int = box(42); println(*p) }\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Nested function calls
// ============================================================
func TestNestedCalls() testing.TestResult {
	var src []char = "package \"test\"\nfunc f(x int) int { return x * 2 }\nfunc g(x int) int { return x + 1 }\nfunc main() { println(f(g(3))) }\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "8\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Len on nil slice
// ============================================================
func TestLenNilSlice() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var s []int; println(len(s)) }\n")
	if !seq(out, "0\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// make_slice and set element
// ============================================================
func TestMakeSliceAndSet() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 1)\n\ts[0] = 42\n\tprintln(len(s))\n\tprintln(s[0])\n}\n")
	if !seq(out, "1\n42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// bit_cast tests
// ============================================================

func TestBitCastPtrToPtr() testing.TestResult {
	// bit_cast(*int, ptr) — reinterpret pointer type
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar ip *int = bit_cast(*int, p)\n\tip[0] = 42\n\tprintln(ip[0])\n\trt.c_free(p)\n}\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitCastPtrToInt() testing.TestResult {
	// bit_cast(int, ptr) — get address as integer
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar addr int = bit_cast(int, p)\n\tif addr != 0 { println(1) } else { println(0) }\n\trt.c_free(p)\n}\n")
	if !seq(out, "1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitCastIntToPtr() testing.TestResult {
	// bit_cast(*uint8, int) — create pointer from integer
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.c_malloc(8)\n\tvar addr int = bit_cast(int, p)\n\tvar q *uint8 = bit_cast(*uint8, addr)\n\tvar ip *int = bit_cast(*int, q)\n\tip[0] = 99\n\tvar ip2 *int = bit_cast(*int, p)\n\tprintln(ip2[0])\n\trt.c_free(p)\n}\n")
	if !seq(out, "99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// rt forwarding tests
// ============================================================

func TestRtAllocFree() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.Alloc(16)\n\tif p != nil { println(1) } else { println(0) }\n\trt.Free(p)\n}\n")
	if !seq(out, "1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestRtRefcount() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\nfunc main() {\n\tvar p *uint8 = rt.Alloc(8)\n\tprintln(rt.Refcount(p))\n\trt.RefInc(p)\n\tprintln(rt.Refcount(p))\n\trt.RefDec(p, nil)\n\tprintln(rt.Refcount(p))\n}\n")
	if !seq(out, "1\n2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Pointer indexing tests
// ============================================================

func TestPointerIndexing() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar arr [3]int\n\tarr[0] = 10\n\tarr[1] = 20\n\tarr[2] = 30\n\tvar p *int = &arr[0]\n\tprintln(p[0])\n\tprintln(p[1])\n\tp[2] = 99\n\tprintln(arr[2])\n}\n")
	if !seq(out, "10\n20\n99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}
