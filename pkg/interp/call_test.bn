func TestFlatStructSliceLenAfterReassign() testing.TestResult {
	// Assign, read len, reassign, read new len
	var src []char = "package \"test\"\ntype Container struct { Items @[]int }\nfunc main() {\n\tvar c @Container = make(Container)\n\tc.Items = make_slice(int, 3)\n\tprintln(len(c.Items))\n\tc.Items = make_slice(int, 5)\n\tprintln(len(c.Items))\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "3\n5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatStructSliceIndexWrite() testing.TestResult {
	// Write to individual elements via struct.field[i] = val
	var src []char = "package \"test\"\ntype Data struct { Vals @[]int }\nfunc main() {\n\tvar d @Data = make(Data)\n\td.Vals = make_slice(int, 3)\n\td.Vals[0] = 100\n\td.Vals[1] = 200\n\td.Vals[2] = 300\n\tprintln(d.Vals[0] + d.Vals[1] + d.Vals[2])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "600\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Nested struct field access on flat memory
// ============================================================

func TestFlatNestedStructField() testing.TestResult {
	// Embedded struct field access: outer.Inner.X
	var src []char = "package \"test\"\ntype Inner struct { X int; Y int }\ntype Outer struct { A int; Inner Inner }\nfunc main() {\n\tvar o @Outer = make(Outer)\n\to.A = 1\n\to.Inner.X = 42\n\to.Inner.Y = 99\n\tprintln(o.A)\n\tprintln(o.Inner.X)\n\tprintln(o.Inner.Y)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "1\n42\n99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatStructNamedTypeField() testing.TestResult {
	// Named type (type Foo int) used in struct fields must serialize correctly
	var src []char = "package \"test\"\ntype Kind int\nconst K_FOO Kind = 42\ntype Token struct { Typ Kind; Val int }\nfunc main() {\n\tvar t Token\n\tt.Typ = K_FOO\n\tt.Val = 99\n\tvar c @Token = make(Token)\n\tc.Typ = K_FOO\n\tc.Val = 77\n\tprintln(cast(int, t.Typ))\n\tprintln(t.Val)\n\tprintln(cast(int, c.Typ))\n\tprintln(c.Val)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "42\n99\n42\n77\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatNestedManagedPtrInStruct() testing.TestResult {
	// Struct with both scalar and @T fields accessed through flat memory
	var src []char = "package \"test\"\ntype Leaf struct { V int }\ntype Branch struct { Left @Leaf; Right @Leaf; Tag int }\nfunc main() {\n\tvar b @Branch = make(Branch)\n\tb.Tag = 99\n\tvar l @Leaf = make(Leaf)\n\tl.V = 10\n\tvar r @Leaf = make(Leaf)\n\tr.V = 20\n\tb.Left = l\n\tb.Right = r\n\tprintln(b.Left.V)\n\tprintln(b.Right.V)\n\tprintln(b.Tag)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "10\n20\n99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFlatStructCopyOutAndBack() testing.TestResult {
	// Copy a struct field out of @Outer, modify copy, write back — lazy struct paths
	var src []char = "package \"test\"\ntype Inner struct { X int; Y int }\ntype Outer struct { A int; Inner Inner }\nfunc main() {\n\tvar o @Outer = make(Outer)\n\to.Inner.X = 42\n\to.Inner.Y = 99\n\tvar inner Inner = o.Inner\n\tprintln(inner.X)\n\tinner.X = 0\n\tprintln(o.Inner.X)\n\tinner.X = 77\n\to.Inner = inner\n\tprintln(o.Inner.X)\n\tprintln(o.Inner.Y)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "42\n42\n77\n99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestScopeCleanupRefDec() testing.TestResult {
	// Function-local managed ptr should be RefDec'd on scope exit
	var out []char = runAndGetOutput("package \"test\"\nimport \"pkg/rt\"\ntype Node struct { Val int }\nfunc doWork(n @Node) int {\n\tvar local @Node = n\n\treturn local.Val\n}\nfunc main() {\n\tvar n @Node = make(Node)\n\tn.Val = 42\n\tvar ptr *uint8 = bit_cast(*uint8, n)\n\tprintln(rt.Refcount(ptr))\n\tvar v int = doWork(n)\n\tprintln(v)\n\tprintln(rt.Refcount(ptr))\n}\n")
	// Before doWork: rc=1. During doWork: param+local = rc=3. After: rc=1.
	if !seq(out, "1\n42\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}
