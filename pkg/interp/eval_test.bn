}

// ============================================================
// String operations
// ============================================================

func TestStringComparison() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(\"abc\" == \"abc\"); println(\"abc\" == \"def\"); println(\"abc\" != \"def\") }\n")
	if !seq(out, "true\nfalse\ntrue\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestStringIndex() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var s []char = \"hello\"; println(cast(int, s[0])); println(cast(int, s[4])) }\n")
	if !seq(out, "104\n111\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}







// ============================================================
// String null-terminator invariant
// ============================================================

func TestStringLiteralLen() testing.TestResult {
	// String literal typed as []char: len excludes null terminator
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s []char = \"hello\"\n\tprintln(len(s))\n\tprintln(s)\n}\n")
	if !seq(out, "5\nhello\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestStringNullTermLiteral() testing.TestResult {
	// String literal should have null at end, len should not count it
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s []char = \"abc\"\n\tprintln(len(s))\n\tprintln(s)\n}\n")
	if !seq(out, "3\nabc\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Print []char slice as string (isCharSlice / ValueToString)
// ============================================================

func TestCharSlicePrint() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s @[]char = make_slice(char, 2)\n\ts[0] = 'h'\n\ts[1] = 'i'\n\tprintln(s)\n}\n")
	if !seq(out, "hi\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Slice expression on []char from string
// ============================================================

func TestStringSliceExpr() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s @[]char = make_slice(char, 5)\n\ts[0] = 'h'\n\ts[1] = 'e'\n\ts[2] = 'l'\n\ts[3] = 'l'\n\ts[4] = 'o'\n\tvar t []char = s[1:4]\n\tprintln(t)\n}\n")
	if !seq(out, "ell\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// For-in over []char slice, printing each char as int
// ============================================================

func TestForInCharSlice() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s @[]char = make_slice(char, 3)\n\ts[0] = 'A'\n\ts[1] = 'B'\n\ts[2] = 'C'\n\tfor v in s { println(cast(int, v)) }\n}\n")
	if !seq(out, "65\n66\n67\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// String literal assigned to []char variable (coercion)
// ============================================================

func TestStringToCharSliceCoerce() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s []char = \"hello\"\n\tprintln(s)\n\tprintln(len(s))\n}\n")
	if !seq(out, "hello\n5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Slice expression on string-assigned []char
// ============================================================

func TestStringAssignedSliceExpr() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s []char = \"hello\"\n\tprintln(s[1:4])\n\tprintln(s[3:])\n\tprintln(len(s[1:4]))\n}\n")
	if !seq(out, "ell\nlo\n3\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Direct string slicing (VAL_SLICE with char elements)
// ============================================================

func TestStringDirectSlice() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s []char = \"world\"\n\tvar t []char = s[0:3]\n\tprintln(t)\n}\n")
	if !seq(out, "wor\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}
