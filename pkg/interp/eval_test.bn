func TestModulo() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(15 % 4) }\n")
	if !seq(out, "3\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
