func TestArrayLiteral() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var a [3]int = [3]int{10, 20, 30}; println(a[0]); println(a[1]); println(a[2]) }\n")
	if !seq(out, "10\n20\n30\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestArrayLen() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var a [5]int; println(len(a)) }\n")
	if !seq(out, "5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestArrayAssignment() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var a [3]int; a[0] = 100; a[1] = 200; a[2] = 300; println(a[1]) }\n")
	if !seq(out, "200\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Pointer Operations
// ============================================================

func TestPointerDeref() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 42; var p *int = &x; println(*p) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestPointerAssignDeref() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 1; var p *int = &x; *p = 99; println(x) }\n")
	if !seq(out, "99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestManagedPointer() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\ntype Node struct { Val int }\nfunc main() { var n @Node = make(Node); n.Val = 7; println(n.Val) }\n")
	if !seq(out, "7\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestManagedPointerNil() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\ntype Node struct { Val int }\nfunc main() { var n @Node; if n == nil { println(\"nil\") } }\n")
	if !seq(out, "nil\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Slice Expressions
// ============================================================

func TestSliceExpression() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 4)\n\ts[0] = 10\n\ts[1] = 20\n\ts[2] = 30\n\ts[3] = 40\n\tvar t []int = s[1:3]\n\tprintln(len(t))\n\tprintln(t[0])\n\tprintln(t[1])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "2\n20\n30\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSliceFromStart() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 3)\n\ts[0] = 1\n\ts[1] = 2\n\ts[2] = 3\n\tvar t []int = s[:2]\n\tprintln(len(t))\n\tprintln(t[0])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSliceToEnd() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 3)\n\ts[0] = 1\n\ts[1] = 2\n\ts[2] = 3\n\tvar t []int = s[1:]\n\tprintln(len(t))\n\tprintln(t[0])\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "2\n2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

