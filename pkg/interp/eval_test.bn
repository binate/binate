// Nested Structs
// ============================================================

func TestNestedStruct() testing.TestResult {
	var src []char = "package \"test\"\ntype Inner struct { Val int }\ntype Outer struct { X int; Inner Inner }\nfunc main() { var o Outer; o.X = 1; o.Inner.Val = 42; println(o.Inner.Val) }\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestManagedPtrAutoDeref() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { X int; Y int }\nfunc main() {\n\tvar p @Point = make(Point)\n\tp.X = 10\n\tp.Y = 20\n\tprintln(p.X + p.Y)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "30\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

