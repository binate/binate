func TestLogicalOr() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(false || true); println(false || false) }\n")
	if !seq(out, "true\nfalse\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
