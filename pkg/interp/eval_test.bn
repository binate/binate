package "pkg/interp"

import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Expression Evaluation Tests
// ============================================================

func TestArithmetic() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(2 + 3 * 4) }\n")
	if !seq(out, "14\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestComparison() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(3 > 2) }\n")
	if !seq(out, "true\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestLogicalAnd() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(true && false) }\n")
	if !seq(out, "false\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestUnaryMinus() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(-42) }\n")
	if !seq(out, "-42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestUnaryNot() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(!true) }\n")
	if !seq(out, "false\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSliceIndex() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var s @[]int = make_slice(int, 2); s[0] = 10; s[1] = 20; println(s[1]) }\n")
	if !seq(out, "20\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestStructDecl() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\ntype Point struct { X int; Y int }\nfunc main() { var p Point; p.X = 3; p.Y = 4; println(p.X + p.Y) }\n")
	if !seq(out, "7\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestCompositeLit() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\ntype Point struct { X int; Y int }\nfunc main() { var p Point = Point{X: 1, Y: 2}; println(p.X + p.Y) }\n")
	if !seq(out, "3\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestNilComparison() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var p *int; if p == nil { println(\"nil\") } }\n")
	if !seq(out, "nil\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestCharLit() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var c uint8 = 'A'; println(c) }\n")
	if !seq(out, "65\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestEscapeString() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(\"a\\tb\") }\n")
	// Tab between a and b
	var expected @[]char = make_slice(char, 4)
	expected[0] = 'a'
	expected[1] = '\t'
	expected[2] = 'b'
	expected[3] = '\n'
	if !seq(out, expected) { return fail("escape wrong") }
	return ""
}

// ============================================================
// Bitwise Operations
// ============================================================

func TestBitwiseAnd() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(0xFF & 0x0F) }\n")
	if !seq(out, "15\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitwiseOr() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(0xF0 | 0x0F) }\n")
	if !seq(out, "255\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitwiseXor() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(0xFF ^ 0x0F) }\n")
	if !seq(out, "240\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitwiseShiftLeft() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(1 << 4) }\n")
	if !seq(out, "16\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitwiseShiftRight() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(32 >> 2) }\n")
	if !seq(out, "8\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBitwiseNot() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(~0) }\n")
	if !seq(out, "-1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Array Operations
