	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 10; x -= 3; println(x) }\n")
	if !seq(out, "7\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestMulAssign() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 5; x *= 3; println(x) }\n")
	if !seq(out, "15\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestDivAssign() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 20; x /= 4; println(x) }\n")
	if !seq(out, "5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestRemAssign() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 17; x %= 5; println(x) }\n")
	if !seq(out, "2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestAndAssign() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 0xFF; x &= 0x0F; println(x) }\n")
	if !seq(out, "15\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestOrAssign() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 0xF0; x |= 0x0F; println(x) }\n")
	if !seq(out, "255\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Decrement
// ============================================================
func TestDecrement() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 10; x--; println(x) }\n")
	if !seq(out, "9\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Scope shadowing
// ============================================================
func TestScopeShadowing() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar x int = 1\n\t{\n\t\tvar x int = 2\n\t\tprintln(x)\n\t}\n\tprintln(x)\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "2\n1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Early return in loop
// ============================================================
func TestReturnInLoop() testing.TestResult {
	var src []char = "package \"test\"\nfunc find(target int) int {\n\tfor i := 0; i < 10; i++ {\n\t\tif i == target { return i }\n\t}\n\treturn -1\n}\nfunc main() { println(find(5)) }\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "5\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// Struct copy semantics in interpreter
// ============================================================
func TestStructCopyOnAssign() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { x int; y int }\nfunc main() {\n\tvar a Point\n\ta.x = 1\n\ta.y = 2\n\tvar b Point = a\n\tb.x = 99\n\tprintln(a.x)\n\tprintln(b.x)\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "1\n99\n") { return fail(bootstrap.Concat("expected '1\\n99\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestArrayCopyOnAssign() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar a [3]int\n\ta[0] = 10\n\ta[1] = 20\n\ta[2] = 30\n\tvar b [3]int = a\n\tb[0] = 99\n\tprintln(a[0])\n\tprintln(b[0])\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "10\n99\n") { return fail(bootstrap.Concat("expected '10\\n99\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestStructCopyOnFuncArg() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { x int; y int }\nfunc modify(p Point) { p.x = 99 }\nfunc main() {\n\tvar a Point\n\ta.x = 1\n\tmodify(a)\n\tprintln(a.x)\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "1\n") { return fail(bootstrap.Concat("expected '1\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestStructCopyShortVar() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { x int; y int }\nfunc main() {\n\tvar a Point\n\ta.x = 5\n\tb := a\n\tb.x = 77\n\tprintln(a.x)\n\tprintln(b.x)\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "5\n77\n") { return fail(bootstrap.Concat("expected '5\\n77\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}
