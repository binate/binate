package "pkg/interp"

import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Statement Execution Tests
// ============================================================

func TestIfTrue() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { if true { println(1) } else { println(2) } }\n")
	if !seq(out, "1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestIfFalse() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { if false { println(1) } else { println(2) } }\n")
	if !seq(out, "2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestForLoop() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var s int = 0; for i := 0; i < 5; i++ { s = s + i }; println(s) }\n")
	if !seq(out, "10\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestShortVarDecl() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { x := 99; println(x) }\n")
	if !seq(out, "99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestIncDec() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 5; x++; println(x) }\n")
	if !seq(out, "6\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestCompoundAssign() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 10; x += 5; println(x) }\n")
	if !seq(out, "15\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestBreakLoop() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { for i := 0; i < 10; i++ { if i == 3 { break }; println(i) } }\n")
	if !seq(out, "0\n1\n2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestContinueLoop() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { for i := 0; i < 5; i++ { if i == 2 { continue }; println(i) } }\n")
	if !seq(out, "0\n1\n3\n4\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSwitchStmt() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 2; switch x { case 1: println(\"one\"); case 2: println(\"two\"); default: println(\"other\") } }\n")
	if !seq(out, "two\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestSwitchDefault() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 99; switch x { case 1: println(\"one\"); default: println(\"other\") } }\n")
	if !seq(out, "other\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestInfiniteLoop() testing.TestResult {
	var out @[]char = runAndGetOutput("package \"test\"\nfunc main() { var i int = 0; for { i++; if i >= 3 { break } }; println(i) }\n")
	if !seq(out, "3\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

// ============================================================
// For-In Loop
// ============================================================
func TestForInSlice() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 3)\n\ts[0] = 10\n\ts[1] = 20\n\ts[2] = 30\n\tvar sum int = 0\n\tfor v in s { sum = sum + v }\n\tprintln(sum)\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "60\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestForInWithIndex() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s @[]int = make_slice(int, 3)\n\ts[0] = 10\n\ts[1] = 20\n\ts[2] = 30\n\tfor i, v in s { println(i, v) }\n}\n"
	var out @[]char = runAndGetOutput(src)
	if !seq(out, "0 10\n1 20\n2 30\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

