package "pkg/interp"

import "pkg/builtin/testing"
import "pkg/types"
import "pkg/rt"

// ============================================================
// Flat memory read/write tests
// ============================================================

// --- readScalar / writeScalar round-trip ---

func TestScalarRoundTrip1Byte() testing.TestResult {
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var t @types.Type = types.TypUint8()
	writeScalar(buf, t, 42)
	var got int = readScalar(buf, t)
	rt.c_free(buf)
	if got != 42 { return fail("uint8 round-trip: expected 42") }
	return ""
}

func TestScalarRoundTrip2Byte() testing.TestResult {
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var t @types.Type = types.TypInt16()
	writeScalar(buf, t, 12345)
	var got int = readScalar(buf, t)
	rt.c_free(buf)
	if got != 12345 { return fail("int16 round-trip: expected 12345") }
	return ""
}

func TestScalarRoundTrip4Byte() testing.TestResult {
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var t @types.Type = types.TypInt32()
	writeScalar(buf, t, 100000)
	var got int = readScalar(buf, t)
	rt.c_free(buf)
	if got != 100000 { return fail("int32 round-trip: expected 100000") }
	return ""
}

func TestScalarRoundTrip8Byte() testing.TestResult {
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var t @types.Type = types.TypInt()
	writeScalar(buf, t, 9876543210)
	var got int = readScalar(buf, t)
	rt.c_free(buf)
	if got != 9876543210 { return fail("int round-trip: expected 9876543210") }
	return ""
}

// --- resolveUnderlying ---

func TestResolveUnderlyingPlain() testing.TestResult {
	var t @types.Type = types.TypInt()
	var resolved @types.Type = resolveUnderlying(t)
	if resolved != t { return fail("plain type should resolve to itself") }
	return ""
}

func TestResolveUnderlyingAlias() testing.TestResult {
	var target @types.Type = types.TypInt()
	var alias @types.Type = types.MakeAliasType("MyAlias", target)
	var resolved @types.Type = resolveUnderlying(alias)
	if resolved != target { return fail("alias should resolve to target") }
	return ""
}

func TestResolveUnderlyingNamed() testing.TestResult {
	var underlying @types.Type = types.TypInt()
	var named @types.Type = types.MakeNamedType("MyInt")
	named.Underlying = underlying
	var resolved @types.Type = resolveUnderlying(named)
	if resolved != underlying { return fail("named type should resolve to underlying") }
	return ""
}

// --- readFlatValue / writeFlatValue round-trip for int ---

func TestFlatValueInt() testing.TestResult {
	var t @types.Type = types.TypInt()
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var val @Value = MakeIntVal(777, t)
	writeFlatValue(buf, val, t)
	var got @Value = readFlatValue(buf, t)
	rt.c_free(buf)

	if got == nil { return fail("readFlatValue returned nil for int") }
	if got.Kind != VAL_INT { return fail("expected VAL_INT") }
	if got.IntVal != 777 { return fail("int round-trip: expected 777") }
	return ""
}

// --- readFlatValue / writeFlatValue round-trip for bool ---

func TestFlatValueBoolTrue() testing.TestResult {
	var t @types.Type = types.TypBool()
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var val @Value = MakeBoolVal(true)
	writeFlatValue(buf, val, t)
	var got @Value = readFlatValue(buf, t)
	rt.c_free(buf)

	if got == nil { return fail("readFlatValue returned nil for bool") }
	if got.Kind != VAL_BOOL { return fail("expected VAL_BOOL") }
	if !got.BoolVal { return fail("bool round-trip: expected true") }
	return ""
}

func TestFlatValueBoolFalse() testing.TestResult {
	var t @types.Type = types.TypBool()
	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var val @Value = MakeBoolVal(false)
	writeFlatValue(buf, val, t)
	var got @Value = readFlatValue(buf, t)
	rt.c_free(buf)

	if got == nil { return fail("readFlatValue returned nil for bool") }
	if got.Kind != VAL_BOOL { return fail("expected VAL_BOOL") }
	if got.BoolVal { return fail("bool round-trip: expected false") }
	return ""
}

// --- readFlatValue / writeFlatValue round-trip for pointer ---

func TestFlatValuePointer() testing.TestResult {
	var elemType @types.Type = types.TypInt()
	var ptrType @types.Type = types.MakePointerType(elemType)

	// Allocate a fake target so we have a non-nil address
	var target *uint8 = rt.c_malloc(8)
	rt.c_memset(target, 0, 8)

	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	var val @Value = MakePointerValRaw(target, ptrType)
	writeFlatValue(buf, val, ptrType)
	var got @Value = readFlatValue(buf, ptrType)

	rt.c_free(buf)
	rt.c_free(target)

	if got == nil { return fail("readFlatValue returned nil for pointer") }
	if got.Kind != VAL_POINTER { return fail("expected VAL_POINTER") }
	if got.RawAddr == nil { return fail("pointer round-trip: expected non-nil RawAddr") }
	return ""
}

func TestFlatValueNilPointer() testing.TestResult {
	var elemType @types.Type = types.TypInt()
	var ptrType @types.Type = types.MakePointerType(elemType)

	var buf *uint8 = rt.c_malloc(8)
	rt.c_memset(buf, 0, 8)

	// Write nil pointer
	var val @Value = MakeNilVal()
	writeFlatValue(buf, val, ptrType)
	var got @Value = readFlatValue(buf, ptrType)
	rt.c_free(buf)

	if got == nil { return fail("readFlatValue returned nil") }
	if got.Kind != VAL_NIL { return fail("nil pointer round-trip: expected VAL_NIL") }
	return ""
}

// --- readFlatValue / writeFlatValue for struct with int fields ---

func TestFlatValueStruct() testing.TestResult {
	// Create a struct type with two int fields: { X int, Y int }
	var fields @[]@types.Field = make_slice(@types.Field, 2)
	var f0 @types.Field = make(types.Field)
	f0.Name = "X"
	f0.Type = types.TypInt()
	fields[0] = f0
	var f1 @types.Field = make(types.Field)
	f1.Name = "Y"
	f1.Type = types.TypInt()
	fields[1] = f1
	var st @types.Type = types.MakeStructType("TestStruct", fields)

	// Allocate flat memory for the struct
	var size int = types.SizeOf(st)
	var buf *uint8 = rt.c_malloc(size)
	rt.c_memset(buf, 0, size)

	// Write field values directly into flat memory at field offsets
	var off0 int = types.FieldOffset(st, 0)
	var off1 int = types.FieldOffset(st, 1)
	var addr0 *uint8 = bit_cast(*uint8, bit_cast(int, buf) + off0)
	var addr1 *uint8 = bit_cast(*uint8, bit_cast(int, buf) + off1)
	writeScalar(addr0, types.TypInt(), 111)
	writeScalar(addr1, types.TypInt(), 222)

	// Read the struct back as a Value
	var got @Value = readFlatValue(buf, st)
	rt.c_free(buf)

	if got == nil { return fail("readFlatValue returned nil for struct") }
	if got.Kind != VAL_STRUCT { return fail("expected VAL_STRUCT") }
	if got.RawAddr == nil { return fail("struct should have RawAddr set") }
	if got.StructTyp == nil { return fail("struct should have StructTyp set") }

	// Verify we can read fields back from the flat struct via readScalar
	// (readFlatValue returns a lazy struct, so fields are read on demand)
	var rX int = readScalar(bit_cast(*uint8, bit_cast(int, got.RawAddr) + off0), types.TypInt())
	var rY int = readScalar(bit_cast(*uint8, bit_cast(int, got.RawAddr) + off1), types.TypInt())
	if rX != 111 { return fail("struct field X: expected 111") }
	if rY != 222 { return fail("struct field Y: expected 222") }
	return ""
}

func TestFlatValueStructWriteRead() testing.TestResult {
	// Create a struct type with two int fields
	var fields @[]@types.Field = make_slice(@types.Field, 2)
	var f0 @types.Field = make(types.Field)
	f0.Name = "A"
	f0.Type = types.TypInt()
	fields[0] = f0
	var f1 @types.Field = make(types.Field)
	f1.Name = "B"
	f1.Type = types.TypInt()
	fields[1] = f1
	var st @types.Type = types.MakeStructType("Pair", fields)

	// Build a struct Value with Fields populated
	var sv @Value = make(Value)
	sv.Kind = VAL_STRUCT
	sv.StructTyp = st
	sv.Fields = make_slice(@Value, 2)
	sv.Fields[0] = MakeIntVal(333, types.TypInt())
	sv.Fields[1] = MakeIntVal(444, types.TypInt())

	// Write to flat memory
	var size int = types.SizeOf(st)
	var buf *uint8 = rt.c_malloc(size)
	rt.c_memset(buf, 0, size)
	writeFlatValue(buf, sv, st)

	// Read back and verify field values
	var off0 int = types.FieldOffset(st, 0)
	var off1 int = types.FieldOffset(st, 1)
	var gotA int = readScalar(bit_cast(*uint8, bit_cast(int, buf) + off0), types.TypInt())
	var gotB int = readScalar(bit_cast(*uint8, bit_cast(int, buf) + off1), types.TypInt())
	rt.c_free(buf)

	if gotA != 333 { return fail("struct write/read field A: expected 333") }
	if gotB != 444 { return fail("struct write/read field B: expected 444") }
	return ""
}

// --- allocFlat / freeFlat ---

func TestAllocFreeFlat() testing.TestResult {
	var t @types.Type = types.TypInt()
	var ptr *uint8 = allocFlat(t)
	if ptr == nil { return fail("allocFlat returned nil") }

	// allocFlat should zero-initialize
	var val int = readScalar(ptr, t)
	if val != 0 { return fail("allocFlat memory not zero-initialized") }

	// Write and read back to verify the memory is usable
	writeScalar(ptr, t, 12345)
	var got int = readScalar(ptr, t)
	freeFlat(ptr)
	if got != 12345 { return fail("allocFlat/freeFlat: read back failed") }
	return ""
}
