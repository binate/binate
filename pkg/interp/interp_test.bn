package "pkg/interp"

import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Helpers
// ============================================================

func seq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func fail(msg @[]char) testing.TestResult {
	return msg
}

func toBytes(s []char) []uint8 {
	var b @[]uint8 = make_slice(uint8, len(s))
	for i := 0; i < len(s); i++ {
		b[i] = cast(uint8, s[i])
	}
	return b
}

func runSrc(src []char) @Interpreter {
	var p @parser.Parser = parser.New(toBytes(src), "test.bn")
	var file @ast.File = parser.ParseFile(p)
	var interp @Interpreter = New()
	RegisterBootstrapPackage(interp)
	RegisterRtPackage(interp)
	interp.CaptureOut = true
	Run(interp, file)
	return interp
}

func runAndGetOutput(src []char) []char {
	var interp @Interpreter = runSrc(src)
	return GetOutput(interp)
}

// ============================================================
// Interpreter Integration Tests
// ============================================================

func TestPrintInt() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(42) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("expected '42\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestPrintString() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(\"hello\") }\n")
	if !seq(out, "hello\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestPrintBool() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(true) }\n")
	if !seq(out, "true\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestVarDeclAndPrint() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 10; println(x) }\n")
	if !seq(out, "10\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestFuncReturnVoid() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc f() { println(1); return; println(2) }\nfunc main() { f() }\n")
	if !seq(out, "1\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestConstDecl() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nconst x int = 42\nfunc main() { println(x) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestConstIota() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nconst (\n\tA int = iota\n\tB\n\tC\n)\nfunc main() { println(C) }\n")
	if !seq(out, "2\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestTopLevelVar() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nvar x int = 100\nfunc main() { println(x) }\n")
	if !seq(out, "100\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}




// ============================================================
// Forward function reference
// ============================================================

func TestForwardFuncRef() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() { println(helper()) }\nfunc helper() int { return 99 }\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "99\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}



