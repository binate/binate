// ============================================================
// For-in over []char slice, printing each char as int
// ============================================================

func TestForInCharSlice() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() {\n\tvar s []char\n\ts = append(s, 'A')\n\ts = append(s, 'B')\n\ts = append(s, 'C')\n\tfor v in s { println(cast(int, v)) }\n}\n")
	if !seq(out, "65\n66\n67\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}
