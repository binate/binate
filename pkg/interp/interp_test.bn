// ============================================================
// Comparison operators
// ============================================================

func TestLessOrEqual() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(3 <= 3); println(3 <= 4); println(4 <= 3) }\n")
	if !seq(out, "true\ntrue\nfalse\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestGreaterOrEqual() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(3 >= 3); println(4 >= 3); println(3 >= 4) }\n")
