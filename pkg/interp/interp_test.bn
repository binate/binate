	var out []char = runAndGetOutput(src)
	if !seq(out, "55\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestEscapeString() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(\"a\\tb\") }\n")
	// Tab between a and b
	var expected []char
	expected = append(expected, 'a')
	expected = append(expected, '\t')
	expected = append(expected, 'b')
	expected = append(expected, '\n')
	if !seq(out, expected) { return fail("escape wrong") }
	return ""
}

