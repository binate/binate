package "pkg/interp"

import "pkg/ast"
import "pkg/parser"
import "pkg/types"
import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Helpers
// ============================================================

func seq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func fail(msg []char) testing.TestResult {
	return msg
}

func toBytes(s []char) []uint8 {
	var b []uint8
	for i := 0; i < len(s); i++ {
		b = append(b, cast(uint8, s[i]))
	}
	return b
}

func runSrc(src []char) @Interpreter {
	var p @parser.Parser = parser.New(toBytes(src), "test.bn")
	var file @ast.File = parser.ParseFile(p)
	var interp @Interpreter = New()
	interp.CaptureOut = true
	Run(interp, file)
	return interp
}

func runAndGetOutput(src []char) []char {
	var interp @Interpreter = runSrc(src)
	return GetOutput(interp)
}

// ============================================================
// Value Tests
// ============================================================

func TestMakeNilVal() testing.TestResult {
	var v @Value = MakeNilVal()
	if v.Kind != VAL_NIL { return fail("kind wrong") }
	return ""
}

func TestMakeIntVal() testing.TestResult {
	var v @Value = MakeIntVal(42, types.TypInt())
	if v.Kind != VAL_INT { return fail("kind wrong") }
	if v.IntVal != 42 { return fail("value wrong") }
	return ""
}

func TestMakeBoolVal() testing.TestResult {
	var v @Value = MakeBoolVal(true)
	if v.Kind != VAL_BOOL { return fail("kind wrong") }
	if !v.BoolVal { return fail("value wrong") }
	return ""
}

func TestMakeStringVal() testing.TestResult {
	var v @Value = MakeStringVal("hello")
	if v.Kind != VAL_STRING { return fail("kind wrong") }
	if !seq(v.StrVal, "hello") { return fail("value wrong") }
	return ""
}

func TestZeroValueInt() testing.TestResult {
	var v @Value = ZeroValue(types.TypInt())
	if v.Kind != VAL_INT { return fail("kind wrong") }
	if v.IntVal != 0 { return fail("value should be 0") }
	return ""
}

func TestZeroValueBool() testing.TestResult {
	var v @Value = ZeroValue(types.TypBool())
	if v.Kind != VAL_BOOL { return fail("kind wrong") }
	if v.BoolVal { return fail("value should be false") }
	return ""
}

func TestZeroValueString() testing.TestResult {
	var v @Value = ZeroValue(types.TypString())
	if v.Kind != VAL_STRING { return fail("kind wrong") }
	if len(v.StrVal) != 0 { return fail("value should be empty") }
	return ""
}

func TestZeroValuePointer() testing.TestResult {
	var v @Value = ZeroValue(types.MakePointerType(types.TypInt()))
	if v.Kind != VAL_POINTER { return fail("kind wrong") }
	if v.HeapObj != nil { return fail("should be nil") }
	return ""
}

// ============================================================
// Environment Tests
// ============================================================

func TestEnvDefineGet() testing.TestResult {
	var e @Env = newEnv(nil)
	envDefine(e, "x", MakeIntVal(42, types.TypInt()))
	var v @Value = envGet(e, "x")
	if v == nil { return fail("should find x") }
	if v.IntVal != 42 { return fail("x should be 42") }
	return ""
}

func TestEnvSetExisting() testing.TestResult {
	var e @Env = newEnv(nil)
	envDefine(e, "x", MakeIntVal(1, types.TypInt()))
	envSet(e, "x", MakeIntVal(2, types.TypInt()))
	var v @Value = envGet(e, "x")
	if v.IntVal != 2 { return fail("x should be 2") }
	return ""
}

func TestEnvParentLookup() testing.TestResult {
	var parent @Env = newEnv(nil)
	envDefine(parent, "x", MakeIntVal(10, types.TypInt()))
	var child @Env = newEnv(parent)
	var v @Value = envGet(child, "x")
	if v == nil { return fail("should find x from parent") }
	if v.IntVal != 10 { return fail("x should be 10") }
	return ""
}

// ============================================================
// Interpreter Integration Tests
// ============================================================

func TestPrintInt() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(42) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("expected '42\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}

