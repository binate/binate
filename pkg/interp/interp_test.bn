	var out []char = runAndGetOutput("package \"test\"\nfunc main() { var x int = 2; switch x { case 1: println(\"one\"); case 2: println(\"two\"); default: println(\"other\") } }\n")
	if !seq(out, "two\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

