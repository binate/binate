// ============================================================
// For-In Loop
// ============================================================

func TestForInSlice() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s []int\n\ts = append(s, 10)\n\ts = append(s, 20)\n\ts = append(s, 30)\n\tvar sum int = 0\n\tfor v in s { sum = sum + v }\n\tprintln(sum)\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "60\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestForInWithIndex() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar s []int\n\ts = append(s, 10)\n\ts = append(s, 20)\n\ts = append(s, 30)\n\tfor i, v in s { println(i, v) }\n}\n"
	var out []char = runAndGetOutput(src)
	if !seq(out, "0 10\n1 20\n2 30\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

