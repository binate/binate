package "pkg/interp"

import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Helpers
// ============================================================

func seq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func fail(msg []char) testing.TestResult {
	return msg
}

func toBytes(s []char) []uint8 {
	var b []uint8
	for i := 0; i < len(s); i++ {
		b = append(b, cast(uint8, s[i]))
	}
	return b
}

func runSrc(src []char) @Interpreter {
	var p @parser.Parser = parser.New(toBytes(src), "test.bn")
	var file @ast.File = parser.ParseFile(p)
	var interp @Interpreter = New()
	interp.CaptureOut = true
	Run(interp, file)
	return interp
}

func runAndGetOutput(src []char) []char {
	var interp @Interpreter = runSrc(src)
	return GetOutput(interp)
}

// ============================================================
// Interpreter Integration Tests
// ============================================================

func TestPrintInt() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(42) }\n")
	if !seq(out, "42\n") { return fail(bootstrap.Concat("expected '42\\n', got '", bootstrap.Concat(out, "'"))) }
	return ""
}

func TestPrintString() testing.TestResult {
	var out []char = runAndGetOutput("package \"test\"\nfunc main() { println(\"hello\") }\n")
	if !seq(out, "hello\n") { return fail(bootstrap.Concat("got '", bootstrap.Concat(out, "'"))) }
	return ""
}

