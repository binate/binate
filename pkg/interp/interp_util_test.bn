package "pkg/interp"

import "pkg/types"
import "pkg/token"
import "pkg/builtin/testing"

func charsEq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func TestParseIntLiteral() testing.TestResult {
	if parseIntLiteral("0") != 0 { return fail("expected 0") }
	if parseIntLiteral("42") != 42 { return fail("expected 42") }
	if parseIntLiteral("0xFF") != 255 { return fail("expected 255") }
	if parseIntLiteral("0o17") != 15 { return fail("expected 15") }
	if parseIntLiteral("0b1010") != 10 { return fail("expected 10") }
	return ""
}

func TestCompoundToBase() testing.TestResult {
	if compoundToBase(cast(int, token.ADD_ASSIGN)) != cast(int, token.PLUS) {
		return fail("+= should map to +")
	}
	if compoundToBase(cast(int, token.SUB_ASSIGN)) != cast(int, token.MINUS) {
		return fail("-= should map to -")
	}
	return ""
}

func TestTruncateInt() testing.TestResult {
	// int8 range: -128..127
	var t8 @types.Type = types.TypInt8()
	if truncateInt(127, t8) != 127 { return fail("127 in int8 should be 127") }
	if truncateInt(128, t8) != -128 { return fail("128 in int8 should wrap to -128") }
	if truncateInt(255, t8) != -1 { return fail("255 in int8 should wrap to -1") }
	return ""
}

func TestUnescapeString() testing.TestResult {
	var s @[]char = unescapeString("\"hello\\nworld\"")
	if len(s) != 11 { return fail("expected len 11") }
	if s[5] != '\n' { return fail("expected newline at pos 5") }
	return ""
}

func TestEvalCharLit() testing.TestResult {
	if evalCharLit("'A'") != 65 { return fail("expected 65 for 'A'") }
	if evalCharLit("'\\n'") != 10 { return fail("expected 10 for newline") }
	if evalCharLit("'\\t'") != 9 { return fail("expected 9 for tab") }
	return ""
}

func TestStripQuotes() testing.TestResult {
	var s []char = stripQuotes("\"hello\"")
	if !charsEq(s, "hello") { return fail("expected hello") }
	return ""
}

func TestLastPathSegment() testing.TestResult {
	var seg []char = lastPathSegment("pkg/ast")
	if !charsEq(seg, "ast") { return fail("expected ast") }

	var single []char = lastPathSegment("main")
	if !charsEq(single, "main") { return fail("expected main") }
	return ""
}

func TestShiftOps() testing.TestResult {
	if shiftLeft(1, 3) != 8 { return fail("1<<3 should be 8") }
	if shiftRight(16, 2) != 4 { return fail("16>>2 should be 4") }
	return ""
}

func TestHexDigit() testing.TestResult {
	if hexDigit('0') != 0 { return fail("expected 0") }
	if hexDigit('9') != 9 { return fail("expected 9") }
	if hexDigit('a') != 10 { return fail("expected 10") }
	if hexDigit('F') != 15 { return fail("expected 15") }
	return ""
}
