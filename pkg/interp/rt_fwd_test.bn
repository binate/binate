package "pkg/interp"

import "pkg/builtin/testing"
import "pkg/types"
import "pkg/rt"

// ============================================================
// makeManagedSliceType tests
// ============================================================

func TestMakeManagedSliceType() testing.TestResult {
	var t @types.Type = makeManagedSliceType()
	if t == nil { return fail("nil type") }
	if t.Kind != types.TYP_STRUCT { return fail("expected TYP_STRUCT") }
	if len(t.Fields) != 4 { return fail("expected 4 fields") }
	if !seq(t.Fields[0].Name, "Data") { return fail("field 0 should be Data") }
	if !seq(t.Fields[1].Name, "Len") { return fail("field 1 should be Len") }
	if !seq(t.Fields[2].Name, "Refptr") { return fail("field 2 should be Refptr") }
	if !seq(t.Fields[3].Name, "BackingLen") { return fail("field 3 should be BackingLen") }
	return ""
}

// ============================================================
// makeManagedSliceValue tests
// ============================================================

func TestMakeManagedSliceValue() testing.TestResult {
	var ms rt.ManagedSlice = rt.MakeManagedSlice(8, 5)
	var v @Value = makeManagedSliceValue(ms)
	if v == nil { return fail("nil value") }
	if v.Kind != VAL_STRUCT { return fail("expected VAL_STRUCT") }
	if len(v.Fields) != 4 { return fail("expected 4 fields") }
	// Data field should be a pointer
	if v.Fields[0].Kind != VAL_POINTER { return fail("Data should be VAL_POINTER") }
	if v.Fields[0].RawAddr == nil { return fail("Data should not be nil") }
	// Len field
	if v.Fields[1].Kind != VAL_INT { return fail("Len should be VAL_INT") }
	if v.Fields[1].IntVal != 5 { return fail("Len should be 5") }
	// Refptr field
	if v.Fields[2].Kind != VAL_POINTER { return fail("Refptr should be VAL_POINTER") }
	if v.Fields[2].RawAddr == nil { return fail("Refptr should not be nil") }
	// BackingLen field
	if v.Fields[3].Kind != VAL_INT { return fail("BackingLen should be VAL_INT") }
	if v.Fields[3].IntVal != 5 { return fail("BackingLen should be 5") }
	// Clean up
	rt.Free(ms.Refptr)
	return ""
}

// ============================================================
// RegisterRtPackage tests
// ============================================================

func TestRegisterRtPackage() testing.TestResult {
	var interp @Interpreter = make(Interpreter)
	interp.Env = newEnv(nil)
	RegisterRtPackage(interp)
	// Should have at least 1 package
	if len(interp.Packages) < 1 { return fail("expected at least 1 package") }
	// Find the pkg/rt package
	var found bool = false
	for i := 0; i < len(interp.Packages); i++ {
		if seq(interp.Packages[i].Path, "pkg/rt") {
			found = true
		}
	}
	if !found { return fail("pkg/rt not registered") }
	return ""
}

// ============================================================
// dispatchRtBuiltin tests
// ============================================================

func TestDispatchCMalloc() testing.TestResult {
	var args @[]@Value = make_slice(@Value, 1)
	args[0] = MakeIntVal(64, types.TypInt())
	var result @Value = dispatchRtBuiltin(nil, BID_RT_C_MALLOC, args)
	if result == nil { return fail("nil result") }
	if result.Kind != VAL_POINTER { return fail("expected VAL_POINTER") }
	if result.RawAddr == nil { return fail("expected non-nil pointer") }
	// Free the allocation
	var freeArgs @[]@Value = make_slice(@Value, 1)
	freeArgs[0] = MakePointerValRaw(result.RawAddr, types.MakePointerType(types.TypUint8()))
	dispatchRtBuiltin(nil, BID_RT_C_FREE, freeArgs)
	return ""
}

func TestDispatchAllocFree() testing.TestResult {
	// Alloc 32 bytes of managed memory
	var args @[]@Value = make_slice(@Value, 1)
	args[0] = MakeIntVal(32, types.TypInt())
	var result @Value = dispatchRtBuiltin(nil, BID_RT_ALLOC, args)
	if result == nil { return fail("nil result") }
	if result.Kind != VAL_POINTER { return fail("expected VAL_POINTER") }
	if result.RawAddr == nil { return fail("expected non-nil pointer") }
	// Free
	var freeArgs @[]@Value = make_slice(@Value, 1)
	freeArgs[0] = MakePointerValRaw(result.RawAddr, types.MakePointerType(types.TypUint8()))
	dispatchRtBuiltin(nil, BID_RT_FREE, freeArgs)
	return ""
}

func TestDispatchRefIncRefDec() testing.TestResult {
	// Alloc managed memory
	var allocArgs @[]@Value = make_slice(@Value, 1)
	allocArgs[0] = MakeIntVal(16, types.TypInt())
	var result @Value = dispatchRtBuiltin(nil, BID_RT_ALLOC, allocArgs)
	if result.RawAddr == nil { return fail("alloc returned nil") }
	var ptr *uint8 = result.RawAddr

	// RefInc
	var incArgs @[]@Value = make_slice(@Value, 1)
	incArgs[0] = MakePointerValRaw(ptr, types.MakePointerType(types.TypUint8()))
	dispatchRtBuiltin(nil, BID_RT_REFINC, incArgs)

	// Check refcount is 2
	var rcArgs @[]@Value = make_slice(@Value, 1)
	rcArgs[0] = MakePointerValRaw(ptr, types.MakePointerType(types.TypUint8()))
	var rcVal @Value = dispatchRtBuiltin(nil, BID_RT_REFCOUNT, rcArgs)
	if rcVal.IntVal != 2 { return fail("expected refcount 2 after RefInc") }

	// RefDec back to 1
	var decArgs @[]@Value = make_slice(@Value, 1)
	decArgs[0] = MakePointerValRaw(ptr, types.MakePointerType(types.TypUint8()))
	dispatchRtBuiltin(nil, BID_RT_REFDEC, decArgs)

	// Check refcount is 1
	var rc2Val @Value = dispatchRtBuiltin(nil, BID_RT_REFCOUNT, rcArgs)
	if rc2Val.IntVal != 1 { return fail("expected refcount 1 after RefDec") }

	// Final free
	var freeArgs @[]@Value = make_slice(@Value, 1)
	freeArgs[0] = MakePointerValRaw(ptr, types.MakePointerType(types.TypUint8()))
	dispatchRtBuiltin(nil, BID_RT_FREE, freeArgs)
	return ""
}

func TestDispatchRefcount() testing.TestResult {
	// Alloc managed memory -- starts at refcount 1
	var allocArgs @[]@Value = make_slice(@Value, 1)
	allocArgs[0] = MakeIntVal(16, types.TypInt())
	var result @Value = dispatchRtBuiltin(nil, BID_RT_ALLOC, allocArgs)
	if result.RawAddr == nil { return fail("alloc returned nil") }

	var rcArgs @[]@Value = make_slice(@Value, 1)
	rcArgs[0] = MakePointerValRaw(result.RawAddr, types.MakePointerType(types.TypUint8()))
	var rcVal @Value = dispatchRtBuiltin(nil, BID_RT_REFCOUNT, rcArgs)
	if rcVal.Kind != VAL_INT { return fail("expected VAL_INT") }
	if rcVal.IntVal != 1 { return fail("expected refcount 1") }

	// Clean up
	var freeArgs @[]@Value = make_slice(@Value, 1)
	freeArgs[0] = MakePointerValRaw(result.RawAddr, types.MakePointerType(types.TypUint8()))
	dispatchRtBuiltin(nil, BID_RT_FREE, freeArgs)
	return ""
}

func TestDispatchMakeManagedSlice() testing.TestResult {
	var args @[]@Value = make_slice(@Value, 2)
	args[0] = MakeIntVal(8, types.TypInt())   // elemSize
	args[1] = MakeIntVal(3, types.TypInt())   // length
	var result @Value = dispatchRtBuiltin(nil, BID_RT_MAKEMANAGEDSLICE, args)
	if result == nil { return fail("nil result") }
	if result.Kind != VAL_STRUCT { return fail("expected VAL_STRUCT") }
	if len(result.Fields) != 4 { return fail("expected 4 fields") }
	// Data pointer
	if result.Fields[0].Kind != VAL_POINTER { return fail("Data should be VAL_POINTER") }
	if result.Fields[0].RawAddr == nil { return fail("Data should not be nil") }
	// Len
	if result.Fields[1].IntVal != 3 { return fail("Len should be 3") }
	// Refptr
	if result.Fields[2].Kind != VAL_POINTER { return fail("Refptr should be VAL_POINTER") }
	// BackingLen
	if result.Fields[3].IntVal != 3 { return fail("BackingLen should be 3") }
	// Clean up: free via the refptr
	if result.Fields[2].RawAddr != nil {
		rt.Free(result.Fields[2].RawAddr)
	}
	return ""
}
