package "pkg/interp"

import "pkg/types"
import "pkg/builtin/testing"

// ============================================================
// Value Construction Tests
// ============================================================

func TestMakeNilVal() testing.TestResult {
	var v @Value = MakeNilVal()
	if v.Kind != VAL_NIL { return fail("kind wrong") }
	return ""
}

func TestMakeIntVal() testing.TestResult {
	var v @Value = MakeIntVal(42, types.TypInt())
	if v.Kind != VAL_INT { return fail("kind wrong") }
	if v.IntVal != 42 { return fail("value wrong") }
	return ""
}

func TestMakeBoolVal() testing.TestResult {
	var v @Value = MakeBoolVal(true)
	if v.Kind != VAL_BOOL { return fail("kind wrong") }
	if !v.BoolVal { return fail("value wrong") }
	return ""
}

func TestMakeStringVal() testing.TestResult {
	var v @Value = MakeStringVal("hello")
	if v.Kind != VAL_STRING { return fail("kind wrong") }
	if strLen(v.StrVal) != 5 { return fail("strLen wrong") }
	if !seq(strContent(v.StrVal), "hello") { return fail("content wrong") }
	// Null terminator invariant
	if v.StrVal[5] != cast(char, 0) { return fail("missing null terminator") }
	return ""
}

// ============================================================
// Zero Value Tests
// ============================================================

func TestZeroValueInt() testing.TestResult {
	var v @Value = ZeroValue(types.TypInt())
	if v.Kind != VAL_INT { return fail("kind wrong") }
	if v.IntVal != 0 { return fail("value should be 0") }
	return ""
}

func TestZeroValueBool() testing.TestResult {
	var v @Value = ZeroValue(types.TypBool())
	if v.Kind != VAL_BOOL { return fail("kind wrong") }
	if v.BoolVal { return fail("value should be false") }
	return ""
}

func TestZeroValueString() testing.TestResult {
	var v @Value = ZeroValue(types.TypString())
	if v.Kind != VAL_STRING { return fail("kind wrong") }
	if strLen(v.StrVal) != 0 { return fail("strLen should be 0") }
	// Empty string still has null terminator
	if len(v.StrVal) != 1 { return fail("backing should have null") }
	return ""
}

func TestZeroValuePointer() testing.TestResult {
	var v @Value = ZeroValue(types.MakePointerType(types.TypInt()))
	if v.Kind != VAL_POINTER { return fail("kind wrong") }
	if v.HeapObj != nil { return fail("should be nil") }
	return ""
}

// ============================================================
// copyValue Tests
// ============================================================

func TestCopyValueNil() testing.TestResult {
	var v @Value = copyValue(nil)
	if v != nil { return fail("nil should copy to nil") }
	return ""
}

func TestCopyValueInt() testing.TestResult {
	var v @Value = MakeIntVal(42, types.TypInt())
	var c @Value = copyValue(v)
	if c.IntVal != 42 { return fail("int value should be preserved") }
	// Scalars return same reference (no deep copy needed)
	return ""
}

func TestCopyValueStruct() testing.TestResult {
	var fields @[]@Value = make_slice(@Value, 2)
	fields[0] = MakeIntVal(10, types.TypInt())
	fields[1] = MakeIntVal(20, types.TypInt())
	var st @types.Type = types.TypInt() // placeholder
	var v @Value = MakeStructVal(fields, st)
	var c @Value = copyValue(v)
	if c.Kind != VAL_STRUCT { return fail("copy should be struct") }
	if len(c.Fields) != 2 { return fail("should have 2 fields") }
	if c.Fields[0].IntVal != 10 { return fail("field 0 wrong") }
	if c.Fields[1].IntVal != 20 { return fail("field 1 wrong") }
	// Mutating copy should not affect original
	c.Fields[0] = MakeIntVal(99, types.TypInt())
	if v.Fields[0].IntVal != 10 { return fail("original field 0 should be unchanged") }
	return ""
}

func TestCopyValueArray() testing.TestResult {
	var elems @[]@Value = make_slice(@Value, 3)
	elems[0] = MakeIntVal(1, types.TypInt())
	elems[1] = MakeIntVal(2, types.TypInt())
	elems[2] = MakeIntVal(3, types.TypInt())
	var v @Value = MakeArrayVal(elems, types.MakeArrayType(types.TypInt(), 3))
	var c @Value = copyValue(v)
	if c.Kind != VAL_ARRAY { return fail("copy should be array") }
	if len(c.Elems) != 3 { return fail("should have 3 elems") }
	// Mutating copy should not affect original
	c.Elems[1] = MakeIntVal(99, types.TypInt())
	if v.Elems[1].IntVal != 2 { return fail("original elem 1 should be unchanged") }
	return ""
}

func TestCopyValueNestedStruct() testing.TestResult {
	// Struct containing another struct — deep copy
	var inner @[]@Value = make_slice(@Value, 1)
	inner[0] = MakeIntVal(5, types.TypInt())
	var st @types.Type = types.TypInt()
	var innerVal @Value = MakeStructVal(inner, st)
	var outer @[]@Value = make_slice(@Value, 1)
	outer[0] = innerVal
	var outerVal @Value = MakeStructVal(outer, st)
	var c @Value = copyValue(outerVal)
	// Mutate the inner struct in the copy
	c.Fields[0].Fields[0] = MakeIntVal(99, types.TypInt())
	if outerVal.Fields[0].Fields[0].IntVal != 5 { return fail("original nested field should be unchanged") }
	return ""
}
