package "pkg/interp"

import "pkg/types"
import "pkg/builtin/testing"

// ============================================================
// Value Construction Tests
// ============================================================

func TestMakeNilVal() testing.TestResult {
	var v @Value = MakeNilVal()
	if v.Kind != VAL_NIL { return fail("kind wrong") }
	return ""
}

func TestMakeIntVal() testing.TestResult {
	var v @Value = MakeIntVal(42, types.TypInt())
	if v.Kind != VAL_INT { return fail("kind wrong") }
	if IntOf(v) != 42 { return fail("value wrong") }
	return ""
}

func TestMakeBoolVal() testing.TestResult {
	var v @Value = MakeBoolVal(true)
	if v.Kind != VAL_BOOL { return fail("kind wrong") }
	if !BoolOf(v) { return fail("value wrong") }
	return ""
}

func TestMakeStringVal() testing.TestResult {
	var v @Value = MakeStringVal("hello")
	if v.Kind != VAL_MANAGED_SLICE { return fail("kind wrong") }
	var s @[]char = StrOf(v)
	if len(s) != 5 { return fail("len wrong") }
	if !seq(s, "hello") { return fail("content wrong") }
	return ""
}

// ============================================================
// Accessor Tests
// ============================================================

func TestIntOfValue() testing.TestResult {
	var v @Value = MakeIntVal(99, types.TypInt())
	if IntOf(v) != 99 { return fail("IntOf should return 99") }
	// IntOf on nil RawAddr returns 0
	var nilV @Value = make(Value)
	nilV.Kind = VAL_INT
	if IntOf(nilV) != 0 { return fail("IntOf on nil RawAddr should be 0") }
	return ""
}

func TestBoolOfValue() testing.TestResult {
	var t @Value = MakeBoolVal(true)
	if !BoolOf(t) { return fail("BoolOf(true) should be true") }
	var f @Value = MakeBoolVal(false)
	if BoolOf(f) { return fail("BoolOf(false) should be false") }
	// BoolOf on nil RawAddr returns false
	var nilV @Value = make(Value)
	nilV.Kind = VAL_BOOL
	if BoolOf(nilV) { return fail("BoolOf on nil RawAddr should be false") }
	return ""
}

func TestFieldValAccessor() testing.TestResult {
	// Create struct type { X int, Y int }
	var fields @[]@types.Field = make_slice(@types.Field, 2)
	var f0 @types.Field = make(types.Field)
	f0.Name = "X"
	f0.Type = types.TypInt()
	fields[0] = f0
	var f1 @types.Field = make(types.Field)
	f1.Name = "Y"
	f1.Type = types.TypInt()
	fields[1] = f1
	var st @types.Type = types.MakeStructType("P", fields)

	var v @Value = make(Value)
	v.Kind = VAL_STRUCT
	v.Typ = st
	v.RawAddr = allocFlat(st)
	writeScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + types.FieldOffset(st, 0)), types.TypInt(), 11)
	writeScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + types.FieldOffset(st, 1)), types.TypInt(), 22)

	if IntOf(FieldVal(v, 0)) != 11 { return fail("FieldVal(0) should be 11") }
	if IntOf(FieldVal(v, 1)) != 22 { return fail("FieldVal(1) should be 22") }
	if FieldCount(v) != 2 { return fail("FieldCount should be 2") }
	return ""
}

// ============================================================
// Zero Value Tests
// ============================================================

func TestZeroValueInt() testing.TestResult {
	var v @Value = ZeroValue(types.TypInt())
	if v.Kind != VAL_INT { return fail("kind wrong") }
	if IntOf(v) != 0 { return fail("value should be 0") }
	return ""
}

func TestZeroValueBool() testing.TestResult {
	var v @Value = ZeroValue(types.TypBool())
	if v.Kind != VAL_BOOL { return fail("kind wrong") }
	if BoolOf(v) { return fail("value should be false") }
	return ""
}

func TestZeroValueString() testing.TestResult {
	var v @Value = ZeroValue(types.TypString())
	// String zero value is a managed slice (VAL_MANAGED_SLICE) with len 0
	if v.Kind != VAL_MANAGED_SLICE { return fail("kind wrong") }
	return ""
}

func TestZeroValuePointer() testing.TestResult {
	var v @Value = ZeroValue(types.MakePointerType(types.TypInt()))
	if v.Kind != VAL_POINTER { return fail("kind wrong") }
	if v.RawAddr != nil { return fail("should be nil") }
	return ""
}

// ============================================================
// copyValue Tests
// ============================================================

func TestCopyValueNil() testing.TestResult {
	var v @Value = copyValue(nil)
	if v != nil { return fail("nil should copy to nil") }
	return ""
}

func TestCopyValueInt() testing.TestResult {
	var v @Value = MakeIntVal(42, types.TypInt())
	var c @Value = copyValue(v)
	if IntOf(c) != 42 { return fail("int value should be preserved") }
	// Scalars return same reference (no deep copy needed)
	return ""
}

func TestCopyValueStruct() testing.TestResult {
	// Create struct type { A int, B int }
	var fields @[]@types.Field = make_slice(@types.Field, 2)
	var f0 @types.Field = make(types.Field)
	f0.Name = "A"
	f0.Type = types.TypInt()
	fields[0] = f0
	var f1 @types.Field = make(types.Field)
	f1.Name = "B"
	f1.Type = types.TypInt()
	fields[1] = f1
	var st @types.Type = types.MakeStructType("S", fields)

	// Build struct value in flat memory
	var v @Value = make(Value)
	v.Kind = VAL_STRUCT
	v.Typ = st
	v.RawAddr = allocFlat(st)
	var off0 int = types.FieldOffset(st, 0)
	var off1 int = types.FieldOffset(st, 1)
	writeScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + off0), types.TypInt(), 10)
	writeScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + off1), types.TypInt(), 20)

	var c @Value = copyValue(v)
	if c.Kind != VAL_STRUCT { return fail("copy should be struct") }
	if IntOf(FieldVal(c, 0)) != 10 { return fail("field 0 wrong") }
	if IntOf(FieldVal(c, 1)) != 20 { return fail("field 1 wrong") }
	// Mutating copy should not affect original
	writeScalar(bit_cast(*uint8, bit_cast(int, c.RawAddr) + off0), types.TypInt(), 99)
	if IntOf(FieldVal(v, 0)) != 10 { return fail("original field 0 should be unchanged") }
	return ""
}

func TestCopyValueArray() testing.TestResult {
	var arrTyp @types.Type = types.MakeArrayType(types.TypInt(), 3)
	var v @Value = make(Value)
	v.Kind = VAL_ARRAY
	v.Typ = arrTyp
	v.RawAddr = allocFlat(arrTyp)
	var elemSize int = types.SizeOf(types.TypInt())
	writeScalar(v.RawAddr, types.TypInt(), 1)
	writeScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + elemSize), types.TypInt(), 2)
	writeScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + 2 * elemSize), types.TypInt(), 3)

	var c @Value = copyValue(v)
	if c.Kind != VAL_ARRAY { return fail("copy should be array") }
	// Mutating copy should not affect original
	writeScalar(bit_cast(*uint8, bit_cast(int, c.RawAddr) + elemSize), types.TypInt(), 99)
	var origElem1 int = readScalar(bit_cast(*uint8, bit_cast(int, v.RawAddr) + elemSize), types.TypInt())
	if origElem1 != 2 { return fail("original elem 1 should be unchanged") }
	return ""
}
