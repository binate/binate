package "pkg/ir"

import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

func TestGenCompoundAssign() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { var x int = 10; x += 5; println(x) }\n")
	var entry @Block = m.Funcs[0].Blocks[0]
	var addCount int = 0
	var storeCount int = 0
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_ADD { addCount = addCount + 1 }
		if entry.Instrs[i].Op == OP_STORE { storeCount = storeCount + 1 }
	}
	if storeCount < 2 { return fail(bootstrap.Concat("expected >=2 stores, got ", bootstrap.Itoa(storeCount))) }
	if addCount < 1 { return fail("expected at least 1 add for compound assign") }
	return ""
}

func TestAssignStringToChars() testing.TestResult {
	var src []char = "package \"test\"\nfunc foo() []char {\n\tvar s []char\n\ts = \"hello\"\n\treturn s\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	var found bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			if blk.Instrs[j].Op == OP_STRING_TO_CHARS {
				found = true
			}
		}
	}
	if !found { return fail("no OP_STRING_TO_CHARS found — string literal assigned to []char must be converted") }
	return ""
}

func TestNilToSliceAssign() testing.TestResult {
	var src []char = "package \"test\"\nfunc foo() {\n\tvar s []int\n\ts = nil\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	var foundSliceNil bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_STORE && len(instr.Args) >= 2 {
				if instr.Args[1].Op == OP_CONST_NIL && instr.Args[1].Typ != nil {
					if instr.Args[1].Typ.Kind == types.TYP_SLICE {
						foundSliceNil = true
					}
				}
			}
		}
	}
	if !foundSliceNil { return fail("nil assigned to slice should re-emit as nil with TYP_SLICE type") }
	return ""
}

func TestSliceElemRefcount() testing.TestResult {
	var src []char = "package \"test\"\ntype Node struct { Val int }\nfunc foo() {\n\tvar s @[]@Node = make_slice(@Node, 2)\n\tvar n @Node = make(Node)\n\ts[0] = n\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	// Slice get/set lower to OP_EXTRACT + OP_GET_ELEM_PTR + OP_LOAD/STORE.
	// Check that refcounting ops (RefInc/RefDec) are still emitted for managed elements.
	var incCount int = 0
	var decCount int = 0
	var storeCount int = 0
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var op int = blk.Instrs[j].Op
			if op == OP_REFCOUNT_INC { incCount = incCount + 1 }
			if op == OP_REFCOUNT_DEC { decCount = decCount + 1 }
			if op == OP_STORE { storeCount = storeCount + 1 }
		}
	}
	if decCount < 1 { return fail(bootstrap.Concat("expected >=1 OP_REFCOUNT_DEC for old elem, got ", bootstrap.Itoa(decCount))) }
	if incCount < 1 { return fail(bootstrap.Concat("expected >=1 OP_REFCOUNT_INC for new value, got ", bootstrap.Itoa(incCount))) }
	if storeCount < 1 { return fail(bootstrap.Concat("expected >=1 OP_STORE for slice set, got ", bootstrap.Itoa(storeCount))) }
	return ""
}

func TestManagedPtrDeclNilInit() testing.TestResult {
	var src []char = "package \"test\"\nimport \"pkg/ast\"\nfunc foo() {\n\tvar d @ast.Decl\n\td = nil\n}\n"
	var m @Module = genFromSourcePkg(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	var foundNilStore bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_STORE && len(instr.Args) >= 2 {
				if instr.Args[1].Op == OP_CONST_NIL {
					foundNilStore = true
				}
			}
		}
	}
	if !foundNilStore { return fail("managed ptr decl should be initialized with nil store") }
	return ""
}
