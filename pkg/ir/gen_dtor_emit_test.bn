func TestGenStructDtorManagedSliceField() testing.TestResult {
	// Struct with @[]int field: dtor should have OP_REFCOUNT_DEC for backing
	var msTyp @types.Type = types.MakeManagedSliceType(types.TypInt())
	var fields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Items"
	f0.Type = msTyp
	fields[0] = f0
	var sTyp @types.Type = types.MakeStructType("Container", fields)

	var dtorFn @Func = genStructDtor("Container", sTyp)
	var decCount int = countOp(dtorFn, OP_REFCOUNT_DEC)
	if decCount < 1 {
		return fail("struct dtor with @[]int field should have OP_REFCOUNT_DEC")
	}
	return ""
}

func TestGenStructDtorNoDestructibleFields() testing.TestResult {
	// Struct with only int fields: dtor should still be valid (just return)
	var fields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Val"
	f0.Type = types.TypInt()
	fields[0] = f0
	var sTyp @types.Type = types.MakeStructType("Plain", fields)

	var dtorFn @Func = genStructDtor("Plain", sTyp)
	// Should have no OP_REFCOUNT_DEC since no managed fields
	var decCount int = countOp(dtorFn, OP_REFCOUNT_DEC)
	if decCount != 0 {
		return fail("plain struct dtor should have no OP_REFCOUNT_DEC")
	}
	// Should still have a return
	var retCount int = countOp(dtorFn, OP_RETURN)
	if retCount < 1 {
		return fail("plain struct dtor should still have OP_RETURN")
	}
	return ""
}

// ============================================================
// Managed-slice destructor generation tests
// ============================================================

func TestGenManagedSliceDtorName() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Node", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var msTyp @types.Type = types.MakeManagedSliceType(mpTyp)

	var dtorFn @Func = genManagedSliceDtor("__dtor_ms_mp_Node", msTyp)
	if !charsEqual(dtorFn.Name, "__dtor_ms_mp_Node") {
		return fail("managed-slice dtor name wrong")
	}
	return ""
}

func TestGenManagedSliceDtorIsLinkOnce() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Node", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var msTyp @types.Type = types.MakeManagedSliceType(mpTyp)

	var dtorFn @Func = genManagedSliceDtor("__dtor_ms_mp_Node", msTyp)
	if !dtorFn.IsLinkOnce {
		return fail("managed-slice dtor should be IsLinkOnce")
	}
	return ""
}

func TestGenManagedSliceDtorMultipleBlocks() testing.TestResult {
	// For element type that NeedsDestruction, dtor needs loop blocks
	var innerTyp @types.Type = types.MakeStructType("Node", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var msTyp @types.Type = types.MakeManagedSliceType(mpTyp)

	var dtorFn @Func = genManagedSliceDtor("__dtor_ms_mp_Node", msTyp)
	// Should have: entry, ms_dtor_init, ms_dtor_cond, ms_dtor_body, ms_dtor_exit = 5 blocks
	if len(dtorFn.Blocks) < 5 {
		return fail("managed-slice dtor with destructible elements should have at least 5 blocks")
	}
	return ""
}

func TestGenManagedSliceDtorHasBranch() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Node", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var msTyp @types.Type = types.MakeManagedSliceType(mpTyp)

	var dtorFn @Func = genManagedSliceDtor("__dtor_ms_mp_Node", msTyp)
	var brCount int = countOp(dtorFn, OP_BRANCH)
	if brCount < 1 {
		return fail("managed-slice dtor should have OP_BRANCH (conditional)")
	}
	return ""
}

func TestGenManagedSliceDtorHasLoopCondition() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Node", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var msTyp @types.Type = types.MakeManagedSliceType(mpTyp)

	var dtorFn @Func = genManagedSliceDtor("__dtor_ms_mp_Node", msTyp)
	var ltCount int = countOp(dtorFn, OP_LT)
	if ltCount < 1 {
		return fail("managed-slice dtor should have OP_LT for loop condition")
	}
	return ""
}

func TestGenManagedSliceDtorSimpleElem() testing.TestResult {
	// @[]int: elements don't need destruction, so just RefDec backing
	var msTyp @types.Type = types.MakeManagedSliceType(types.TypInt())

	var dtorFn @Func = genManagedSliceDtor("__dtor_ms_int", msTyp)
	// Should have only 1 block (entry) since no loop needed
	if len(dtorFn.Blocks) != 1 {
		return fail("managed-slice dtor for @[]int should have 1 block")
	}
	// Should have OP_REFCOUNT_DEC
	var decCount int = countOp(dtorFn, OP_REFCOUNT_DEC)
	if decCount < 1 {
		return fail("managed-slice dtor for @[]int should have OP_REFCOUNT_DEC")
	}
	return ""
}

