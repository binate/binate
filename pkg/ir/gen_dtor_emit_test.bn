// ============================================================
// declareExternDtor tests
// ============================================================

func TestDeclareExternDtor() testing.TestResult {
	var m @Module = NewModule("test")
	declareExternDtor(m, "__dtor_Foo")
	if len(m.Funcs) != 1 {
		return fail("declareExternDtor should add 1 func")
	}
	var ef @Func = m.Funcs[0]
	if !charsEqual(ef.Name, "__dtor_Foo") {
		return fail("extern dtor name should be __dtor_Foo")
	}
	if !ef.IsExtern {
		return fail("extern dtor should be extern")
	}
	if len(ef.Params) != 1 {
		return fail("extern dtor should have 1 param")
	}
	return ""
}
