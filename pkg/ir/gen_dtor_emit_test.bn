func TestGenStructDtorWithNameExplicit() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Inner", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var fields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Ptr"
	f0.Type = mpTyp
	fields[0] = f0
	var sTyp @types.Type = types.MakeStructType("Outer", fields)

	var dtorFn @Func = genStructDtorWithName("__custom_dtor", sTyp)
