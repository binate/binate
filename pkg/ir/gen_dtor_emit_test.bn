package "pkg/ir"

import "pkg/types"
import "pkg/builtin/testing"

// ============================================================
// Utility function tests
// ============================================================

func TestShortPkgNameQuotedSlash() testing.TestResult {
	var result @[]char = shortPkgName("\"pkg/parser\"")
	if !charsEqual(result, "parser") {
		return fail("shortPkgName(\"pkg/parser\") should be parser")
	}
	return ""
}

func TestShortPkgNameQuotedNoSlash() testing.TestResult {
	var result @[]char = shortPkgName("\"main\"")
	if !charsEqual(result, "main") {
		return fail("shortPkgName(\"main\") should be main")
	}
	return ""
}

func TestShortPkgNameUnquoted() testing.TestResult {
	var result @[]char = shortPkgName("main")
	if !charsEqual(result, "main") {
		return fail("shortPkgName(main) should be main")
	}
	return ""
}

func TestDotPrefixWithDot() testing.TestResult {
	if !charsEqual(dotPrefix("ast.File"), "ast") {
		return fail("dotPrefix(ast.File) should be ast")
	}
	return ""
}

func TestDotPrefixNoDot() testing.TestResult {
	if !charsEqual(dotPrefix("Node"), "Node") {
		return fail("dotPrefix(Node) should be Node")
	}
	return ""
}

func TestDotSuffixWithDot() testing.TestResult {
	if !charsEqual(dotSuffix("ast.File"), "File") {
		return fail("dotSuffix(ast.File) should be File")
	}
	return ""
}

func TestDotSuffixNoDot() testing.TestResult {
	if !charsEqual(dotSuffix("Node"), "Node") {
		return fail("dotSuffix(Node) should be Node")
	}
	return ""
}

func TestHasDotTrue() testing.TestResult {
	if !hasDot("ast.File") {
		return fail("hasDot(ast.File) should be true")
	}
	return ""
}

func TestHasDotFalse() testing.TestResult {
	if hasDot("Node") {
		return fail("hasDot(Node) should be false")
	}
	return ""
}

func TestHasNameEmpty() testing.TestResult {
	var empty @[]@[]char
	if hasName(empty, "foo") {
		return fail("hasName on empty list should be false")
	}
	return ""
}

func TestHasNameMatch() testing.TestResult {
	var names @[]@[]char = make_slice(@[]char, 2)
	names[0] = "alpha"
	names[1] = "beta"
	if !hasName(names, "beta") {
		return fail("hasName should find beta")
	}
	return ""
}

func TestHasNameNoMatch() testing.TestResult {
	var names @[]@[]char = make_slice(@[]char, 2)
	names[0] = "alpha"
	names[1] = "beta"
	if hasName(names, "gamma") {
		return fail("hasName should not find gamma")
	}
	return ""
}

// ============================================================
// Struct destructor generation tests
// ============================================================

func TestGenStructDtorName() testing.TestResult {
	// Create a struct with a @Inner field so NeedsDestruction is true
	var innerTyp @types.Type = types.MakeStructType("Inner", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var outerFields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Ptr"
	f0.Type = mpTyp
	outerFields[0] = f0
	var outerTyp @types.Type = types.MakeStructType("Outer", outerFields)

	var dtorFn @Func = genStructDtor("Outer", outerTyp)
	if !charsEqual(dtorFn.Name, "__dtor_Outer") {
		return fail("genStructDtor name should be __dtor_Outer")
	}
	return ""
}

func TestGenStructDtorIsLinkOnce() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Inner", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var fields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Ptr"
	f0.Type = mpTyp
	fields[0] = f0
	var sTyp @types.Type = types.MakeStructType("Outer", fields)

	var dtorFn @Func = genStructDtor("Outer", sTyp)
	if !dtorFn.IsLinkOnce {
		return fail("struct dtor should be IsLinkOnce")
	}
	return ""
}

func TestGenStructDtorOneParam() testing.TestResult {
	var innerTyp @types.Type = types.MakeStructType("Inner", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var fields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Ptr"
	f0.Type = mpTyp
	fields[0] = f0
	var sTyp @types.Type = types.MakeStructType("Outer", fields)

	var dtorFn @Func = genStructDtor("Outer", sTyp)
	if len(dtorFn.Params) != 1 {
		return fail("struct dtor should have 1 param")
	}
	if !charsEqual(dtorFn.Params[0].Name, "ptr") {
		return fail("param name should be ptr")
	}
	return ""
}

func TestGenStructDtorHasRefDec() testing.TestResult {
	// Struct with @Inner field: dtor should have OP_REFCOUNT_DEC
	var innerTyp @types.Type = types.MakeStructType("Inner", noFields)
	var mpTyp @types.Type = types.MakeManagedPtrType(innerTyp)
	var fields @[]@types.Field = make_slice(@types.Field, 1)
	var f0 @types.Field = make(types.Field)
	f0.Name = "Ptr"
	f0.Type = mpTyp
	fields[0] = f0
	var sTyp @types.Type = types.MakeStructType("Outer", fields)

	var dtorFn @Func = genStructDtor("Outer", sTyp)
	var decCount int = countOp(dtorFn, OP_REFCOUNT_DEC)
	if decCount < 1 {
		return fail("struct dtor should have OP_REFCOUNT_DEC for @Inner field")
	}
	return ""
}

