package "pkg/ir"

import "pkg/types"
import "pkg/buf"
import "pkg/builtin/testing"

// ============================================================
// Destructor naming tests
// ============================================================

func TestDtorNameStruct() testing.TestResult {
	var t @types.Type = types.MakeStructType("Node", noFields)
	var name @[]char = dtorNameForType(t)
	if !charsEqual(name, "__dtor_Node") {
		return fail("expected __dtor_Node")
	}
	return ""
}

func TestDtorNameManagedPtr() testing.TestResult {
	var inner @types.Type = types.MakeStructType("Node", noFields)
	var t @types.Type = types.MakeManagedPtrType(inner)
	var name @[]char = dtorNameForType(t)
	if !charsEqual(name, "__dtor_mp_Node") {
		return fail("expected __dtor_mp_Node")
	}
	return ""
}

func TestDtorNameManagedSlice() testing.TestResult {
	var inner @types.Type = types.MakeStructType("Node", noFields)
	var mpT @types.Type = types.MakeManagedPtrType(inner)
	var t @types.Type = types.MakeManagedSliceType(mpT)
	var name @[]char = dtorNameForType(t)
	if !charsEqual(name, "__dtor_ms_mp_Node") {
		return fail("expected __dtor_ms_mp_Node")
	}
	return ""
}

func TestDtorNameArray() testing.TestResult {
	var inner @types.Type = types.MakeStructType("Node", noFields)
	var mpT @types.Type = types.MakeManagedPtrType(inner)
	var t @types.Type = types.MakeArrayType(mpT, 5)
	var name @[]char = dtorNameForType(t)
	if !charsEqual(name, "__dtor_arr5_mp_Node") {
		return fail("expected __dtor_arr5_mp_Node")
	}
	return ""
}

func TestDtorNameNestedManagedSlice() testing.TestResult {
	var inner @types.Type = types.MakeStructType("Node", noFields)
	var mpT @types.Type = types.MakeManagedPtrType(inner)
	var ms1 @types.Type = types.MakeManagedSliceType(mpT)
	var t @types.Type = types.MakeManagedSliceType(ms1)
	var name @[]char = dtorNameForType(t)
	if !charsEqual(name, "__dtor_ms_ms_mp_Node") {
		return fail("expected __dtor_ms_ms_mp_Node")
	}
	return ""
}

// ============================================================
// Qualified dtor naming
// ============================================================

func TestQualifiedDtorNameLocal() testing.TestResult {
	var name @[]char = qualifiedDtorName("Node")
	if !charsEqual(name, "__dtor_Node") {
		return fail("expected __dtor_Node")
	}
	return ""
}

func TestQualifiedDtorNameCrossPkg() testing.TestResult {
	var name @[]char = qualifiedDtorName("ast.File")
	if !charsEqual(name, "ast.__dtor_File") {
		return fail("expected ast.__dtor_File")
	}
	return ""
}

// ============================================================
// Hash and hex helpers
// ============================================================

func TestWriteHexZero() testing.TestResult {
	var cb buf.CharBuf = buf.New()
	cb = writeHex(cb, 0)
	var s @[]char = buf.Bytes(cb)
	if !charsEqual(s, "0") {
		return fail("expected 0")
	}
	return ""
}

func TestWriteHex255() testing.TestResult {
	var cb buf.CharBuf = buf.New()
	cb = writeHex(cb, 255)
	var s @[]char = buf.Bytes(cb)
	if !charsEqual(s, "ff") {
		return fail("expected ff")
	}
	return ""
}

func TestHashStrDeterministic() testing.TestResult {
	var h1 int = hashStr("hello")
	var h2 int = hashStr("hello")
	if h1 != h2 {
		return fail("hash should be deterministic")
	}
	return ""
}

func TestHashStrDifferent() testing.TestResult {
	var h1 int = hashStr("hello")
	var h2 int = hashStr("world")
	if h1 == h2 {
		return fail("different strings should hash differently")
	}
	return ""
}
