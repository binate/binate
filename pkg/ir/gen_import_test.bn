package "pkg/ir"

import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

func TestRegisterImportFunc() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	// Parse a .bni-like source with a function declaration
	var src []char = "package \"pkg/helper\"\nfunc Add(a int, b int) int\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "test.bni")
	var file @ast.File = parser.ParseFile(p)

	RegisterImport("helper", file, m)

	// The module should have an extern function
	if m.Funcs == nil || len(m.Funcs) == 0 {
		return fail("expected extern function in module")
	}
	var f @Func = m.Funcs[0]
	if !seq(f.Name, "helper.Add") { return fail("expected qualified name helper.Add") }
	if !f.IsExtern { return fail("expected extern function") }
	if len(f.Params) != 2 { return fail("expected 2 params") }
	if len(f.Results) != 1 { return fail("expected 1 result") }
	return ""
}

func TestRegisterImportStruct() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	var src []char = "package \"pkg/geom\"\ntype Point struct {\n\tX int\n\tY int\n}\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "test.bni")
	var file @ast.File = parser.ParseFile(p)

	RegisterImport("geom", file, m)

	// The struct type should be registered with qualified name
	var si int = lookupStructIdx("geom.Point")
	if si < 0 { return fail("expected struct geom.Point registered") }
	if moduleStructs[si].Fields == nil || len(moduleStructs[si].Fields) != 2 {
		return fail("expected 2 fields")
	}
	return ""
}

func TestRegisterImportConst() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	var src []char = "package \"pkg/vals\"\nconst MAX int = 100\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "test.bni")
	var file @ast.File = parser.ParseFile(p)

	RegisterImport("vals", file, m)

	var v int
	var found bool
	v, found = lookupConst("vals.MAX")
	if !found { return fail("expected constant vals.MAX") }
	if v != 100 { return fail("expected value 100") }
	return ""
}

func TestRegisterImportIotaConsts() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	var src []char = "package \"pkg/color\"\nconst (\n\tRED int = iota\n\tGREEN\n\tBLUE\n)\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "test.bni")
	var file @ast.File = parser.ParseFile(p)

	RegisterImport("color", file, m)

	var rv int
	var rf bool
	rv, rf = lookupConst("color.RED")
	if !rf || rv != 0 { return fail("expected RED=0") }

	var gv int
	var gf bool
	gv, gf = lookupConst("color.GREEN")
	if !gf || gv != 1 { return fail("expected GREEN=1") }

	var bv int
	var bf bool
	bv, bf = lookupConst("color.BLUE")
	if !bf || bv != 2 { return fail("expected BLUE=2") }
	return ""
}

func TestRegisterImportsIotaConsts() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	var src []char = "package \"pkg/token\"\nconst (\n\tEOF int = iota\n\tIDENT\n\tINT\n\tSTRING\n)\nfunc Name(t int) []char\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "token.bni")
	var file @ast.File = parser.ParseFile(p)

	var aliases @[][]char = make_slice([]char, 1)
	aliases[0] = "token"
	var files @[]@ast.File = make_slice(@ast.File, 1)
	files[0] = file
	RegisterImports(aliases, files, m)

	var ev int
	var ef bool
	ev, ef = lookupConst("token.EOF")
	if !ef || ev != 0 { return fail("expected EOF=0") }

	var iv int
	var iff bool
	iv, iff = lookupConst("token.IDENT")
	if !iff || iv != 1 { return fail("expected IDENT=1") }

	var nv int
	var nf bool
	nv, nf = lookupConst("token.INT")
	if !nf || nv != 2 { return fail("expected INT=2") }

	var sv int
	var sf bool
	sv, sf = lookupConst("token.STRING")
	if !sf || sv != 3 { return fail("expected STRING=3") }
	return ""
}
