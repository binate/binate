package "pkg/ir"

import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

func TestInitModule() testing.TestResult {
	var m @Module = InitModule("\"pkg/helper\"")
	if m == nil { return fail("InitModule returned nil") }
	if !seq(m.Name, "\"pkg/helper\"") { return fail("wrong module name") }
	return ""
}

func TestGeneratePackage() testing.TestResult {
	var m @Module = InitModule("\"pkg/helper\"")

	var src []char = "package \"pkg/helper\"\nfunc Double(x int) int {\n\treturn x + x\n}\n"
	var p @parser.Parser = parser.New(strToBytes(src), "test.bn")
	var file @ast.File = parser.ParseFile(p)

	GeneratePackage(file, m)

	if m.Funcs == nil || len(m.Funcs) == 0 {
		return fail("expected function in module")
	}
	var f @Func = m.Funcs[0]
	if !seq(f.Name, "Double") { return fail("expected function named Double") }
	if f.IsExtern { return fail("should not be extern") }
	if f.Blocks == nil || len(f.Blocks) == 0 { return fail("expected blocks") }
	return ""
}

func TestGeneratePackageWithImport() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	// Register an import first
	var bniSrc []char = "package \"pkg/helper\"\nfunc Double(x int) int\n"
	var bp @parser.Parser = parser.NewInterface(strToBytes(bniSrc), "helper.bni")
	var bniFile @ast.File = parser.ParseFile(bp)
	RegisterImport("helper", bniFile, m)

	// Generate main package that calls imported function
	var mainSrc []char = "package \"main\"\nimport \"pkg/helper\"\nfunc main() {\n\tvar x int = helper.Double(21)\n\tprintln(x)\n}\n"
	var mp @parser.Parser = parser.New(strToBytes(mainSrc), "main.bn")
	var mainFile @ast.File = parser.ParseFile(mp)
	GeneratePackage(mainFile, m)

	// Should have extern func + main func
	if len(m.Funcs) < 2 { return fail("expected at least 2 funcs (1 extern + 1 main)") }

	// Find main function
	var mainFn @Func = nil
	for i := 0; i < len(m.Funcs); i++ {
		if seq(m.Funcs[i].Name, "main") {
			mainFn = m.Funcs[i]
		}
	}
	if mainFn == nil { return fail("expected main function") }

	// Check for a call instruction with qualified name
	var foundCall bool = false
	for i := 0; i < len(mainFn.Blocks); i++ {
		for j := 0; j < len(mainFn.Blocks[i].Instrs); j++ {
			var instr @Instr = mainFn.Blocks[i].Instrs[j]
			if instr.Op == OP_CALL && seq(instr.StrVal, "helper.Double") {
				foundCall = true
			}
		}
	}
	if !foundCall { return fail("expected call to helper.Double") }
	return ""
}

func TestGeneratePackageStructLitInit() testing.TestResult {
	// GeneratePackage must populate ModuleStruct.Fields so that
	// genCompositeLit can initialize struct literal field values.
	// Regression: only Typ.Fields was set, so composites were zeroinitializer.
	var src []char = "package \"test\"\ntype Pt struct {\n\tx int\n\ty int\n}\nfunc main() {\n\tvar p Pt = Pt{x: 10, y: 20}\n\tprintln(p.x)\n}\n"
	var m @Module = genFromSourcePkg(src)
	if len(m.Funcs) == 0 { return fail("expected at least 1 func") }
	var mainFn @Func = m.Funcs[0]
	// Look for OP_STORE instructions that store non-zero values (the field inits)
	var foundFieldStore bool = false
	for i := 0; i < len(mainFn.Blocks); i++ {
		var blk @Block = mainFn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_STORE && len(instr.Args) >= 2 {
				// Check if the stored value (Args[1]) is a constant 10 or 20
				if instr.Args[1].Op == OP_CONST_INT {
					if instr.Args[1].IntVal == 10 || instr.Args[1].IntVal == 20 {
						foundFieldStore = true
					}
				}
			}
		}
	}
	if !foundFieldStore {
		return fail("no store of field values 10 or 20 found — struct literal init missing")
	}
	return ""
}
