package "pkg/ir"

import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

func TestGenSelfRefStruct() testing.TestResult {
	// A struct type that references itself via managed pointer
	var src []char = "package \"test\"\ntype Node struct {\n\tval int\n\tnext @Node\n}\nfunc main() {\n\tvar n @Node = make(Node)\n\tn.val = 42\n}\n"
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("expected main func") }
	// main should have an OP_MAKE instruction
	var makeInstr @Instr = findOp(mainFn, OP_MAKE)
	if makeInstr == nil { return fail("expected OP_MAKE in main") }
	// The TypeArg should be a struct type with 2 fields
	if makeInstr.TypeArg == nil { return fail("OP_MAKE should have TypeArg") }
	if makeInstr.TypeArg.Kind != types.TYP_STRUCT { return fail("TypeArg should be struct") }
	if len(makeInstr.TypeArg.Fields) != 2 { return fail(bootstrap.Concat("expected 2 fields, got ", bootstrap.Itoa(len(makeInstr.TypeArg.Fields)))) }
	// Second field should be a managed pointer
	var f2 @types.Type = makeInstr.TypeArg.Fields[1].Type
	if f2 == nil { return fail("field 2 type is nil") }
	if f2.Kind != types.TYP_MANAGED_PTR { return fail("field 2 should be managed ptr") }
	return ""
}

func TestGenSelfRefStructFieldAccess() testing.TestResult {
	// Accessing fields on a self-referential struct
	var src []char = "package \"test\"\ntype Node struct {\n\tval int\n\tnext @Node\n}\nfunc main() {\n\tvar n @Node = make(Node)\n\tn.val = 42\n\tprintln(n.val)\n}\n"
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("expected main func") }
	// Should have GET_FIELD_PTR instructions for field access
	var gfp int = countOp(mainFn, OP_GET_FIELD_PTR)
	if gfp < 2 { return fail(bootstrap.Concat("expected >=2 GET_FIELD_PTR, got ", bootstrap.Itoa(gfp))) }
	return ""
}

func TestGenStringToCharsOnFieldAssign() testing.TestResult {
	// Assigning a string literal to a []char field should emit STRING_TO_CHARS
	var src []char = "package \"test\"\ntype Buf struct {\n\tname []char\n}\nfunc main() {\n\tvar b Buf\n\tb.name = \"hello\"\n}\n"
	var m @Module = genFromSource(src)
	var stc @Instr = findOp(m.Funcs[0], OP_STRING_TO_CHARS)
	if stc == nil { return fail("expected STRING_TO_CHARS for string-to-slice field assignment") }
	return ""
}

func TestGenStructWithSliceField() testing.TestResult {
	// Struct with a slice field — make_slice and len should work
	var src []char = "package \"test\"\ntype Buf struct {\n\tdata []int\n}\nfunc main() {\n\tvar b Buf\n\tvar d @[]int = make_slice(int, 1)\n\td[0] = 1\n\tb.data = d\n\tprintln(len(b.data))\n}\n"
	var m @Module = genFromSource(src)
	// Should generate MAKE_SLICE and EXTRACT (lowered from SLICE_LEN)
	var msInstr @Instr = findOp(m.Funcs[0], OP_MAKE_SLICE)
	if msInstr == nil { return fail("expected OP_MAKE_SLICE for slice through struct") }
	var extractInstr @Instr = findOp(m.Funcs[0], OP_EXTRACT)
	if extractInstr == nil { return fail("expected OP_EXTRACT for len through struct field") }
	return ""
}

func TestNestedManagedSelectorPtr() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Inner struct { Value int }\n")
	src = concatChars(src, "type Outer struct { Inner @Inner\n  Tag int }\n")
	src = concatChars(src, "func main() {\n")
	src = concatChars(src, "  var o @Outer = make(Outer)\n")
	src = concatChars(src, "  o.Inner = make(Inner)\n")
	src = concatChars(src, "  o.Inner.Value = 100\n")
	src = concatChars(src, "  println(o.Inner.Value)\n")
	src = concatChars(src, "}\n")
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("no main func") }
	var foundStore bool = false
	for i := 0; i < len(mainFn.Blocks); i++ {
		var b @Block = mainFn.Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			var instr @Instr = b.Instrs[j]
			if instr.Op == OP_STORE {
				if len(instr.Args) >= 2 {
					if instr.Args[1].Op == OP_CONST_INT && instr.Args[1].IntVal == 100 {
						foundStore = true
					}
				}
			}
		}
	}
	if !foundStore {
		return fail("no store of 100 found — nested managed selector ptr broken")
	}
	return ""
}

func TestFieldAssignRefcount() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Inner struct { X int }\n")
	src = concatChars(src, "type Outer struct { Ptr @Inner }\n")
	src = concatChars(src, "func main() {\n")
	src = concatChars(src, "  var o @Outer = make(Outer)\n")
	src = concatChars(src, "  var a @Inner = make(Inner)\n")
	src = concatChars(src, "  o.Ptr = a\n")
	src = concatChars(src, "}\n")
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("no main func") }
	var incCount int = 0
	var decCount int = 0
	for i := 0; i < len(mainFn.Blocks); i++ {
		var b @Block = mainFn.Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			if b.Instrs[j].Op == OP_REFCOUNT_INC { incCount = incCount + 1 }
			if b.Instrs[j].Op == OP_REFCOUNT_DEC { decCount = decCount + 1 }
		}
	}
	if incCount < 1 { return fail("expected at least 1 OP_REFCOUNT_INC for field assignment") }
	if decCount < 1 { return fail("expected at least 1 OP_REFCOUNT_DEC for field assignment") }
	return ""
}

func TestArrayElemFieldAccess() testing.TestResult {
	// arr[i].Field where arr is [N]@T — should generate GET_FIELD_PTR after loading managed ptr
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Node struct { Val int }\n")
	src = concatChars(src, "func main() {\n")
	src = concatChars(src, "  var arr [2]@Node\n")
	src = concatChars(src, "  arr[0] = make(Node)\n")
	src = concatChars(src, "  arr[0].Val = 42\n")
	src = concatChars(src, "  println(arr[0].Val)\n")
	src = concatChars(src, "}\n")
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("no main func") }
	// Should have GET_FIELD_PTR for .Val access
	var gfp int = countOp(mainFn, OP_GET_FIELD_PTR)
	if gfp < 1 { return fail(bootstrap.Concat("expected >=1 GET_FIELD_PTR for arr[i].Val, got ", bootstrap.Itoa(gfp))) }
	return ""
}

func TestSelectorBaseArrayAssign() testing.TestResult {
	// cont.Items[i] = v where Items is an array field
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Node struct { Val int }\n")
	src = concatChars(src, "type Container struct { Items [2]@Node }\n")
	src = concatChars(src, "func main() {\n")
	src = concatChars(src, "  var c @Container = make(Container)\n")
	src = concatChars(src, "  c.Items[0] = make(Node)\n")
	src = concatChars(src, "  println(c.Items[0].Val)\n")
	src = concatChars(src, "}\n")
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("no main func") }
	// Should have OP_STORE for the array element assignment
	var storeCount int = countOp(mainFn, OP_STORE)
	if storeCount < 2 { return fail(bootstrap.Concat("expected >=2 OP_STORE, got ", bootstrap.Itoa(storeCount))) }
	return ""
}
