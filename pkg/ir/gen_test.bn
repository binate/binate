package "pkg/ir"

import "pkg/types"
import "pkg/builtin/testing"

// Tests for gen.bn: package-level globals and lookup functions.

func TestLookupStructIdxNotFound() testing.TestResult {
	// With empty moduleStructs, lookup should return -1
	moduleStructs = nil
	var idx int = lookupStructIdx("Nonexistent")
	if idx != -1 { return fail("expected -1 for missing struct") }
	return ""
}

func TestLookupFuncExistsNotFound() testing.TestResult {
	moduleFuncs = nil
	if lookupFuncExists("Nonexistent") { return fail("expected false") }
	return ""
}
