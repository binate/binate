package "pkg/ir"

import "pkg/builtin/testing"

// ============================================================
// parseCharLit tests
// ============================================================

func TestParseCharLitSimple() testing.TestResult {
	var v int = parseCharLit("'A'")
	if v != 65 { return fail("expected 65 for 'A'") }
	return ""
}

func TestParseCharLitNewline() testing.TestResult {
	var v int = parseCharLit("'\\n'")
	if v != 10 { return fail("expected 10 for newline") }
	return ""
}

func TestParseCharLitTab() testing.TestResult {
	var v int = parseCharLit("'\\t'")
	if v != 9 { return fail("expected 9 for tab") }
	return ""
}

func TestParseCharLitBackslash() testing.TestResult {
	var v int = parseCharLit("'\\\\'")
	if v != 92 { return fail("expected 92 for backslash") }
	return ""
}

func TestParseCharLitNull() testing.TestResult {
	var v int = parseCharLit("'\\0'")
	if v != 0 { return fail("expected 0 for null") }
	return ""
}

func TestParseCharLitHex() testing.TestResult {
	var v int = parseCharLit("'\\x41'")
	if v != 65 { return fail("expected 65 for \\x41") }
	return ""
}

// ============================================================
// unescapeStr tests
// ============================================================

func TestUnescapeStrSimple() testing.TestResult {
	var s @[]char = unescapeStr("\"hello\"")
	if len(s) != 5 { return fail("expected len 5") }
	if s[0] != 'h' { return fail("expected h") }
	return ""
}

func TestUnescapeStrNewline() testing.TestResult {
	var s @[]char = unescapeStr("\"a\\nb\"")
	if len(s) != 3 { return fail("expected len 3") }
	if s[1] != '\n' { return fail("expected newline") }
	return ""
}

func TestUnescapeStrHex() testing.TestResult {
	var s @[]char = unescapeStr("\"\\x41\"")
	if len(s) != 1 { return fail("expected len 1") }
	if s[0] != 'A' { return fail("expected A") }
	return ""
}

func TestUnescapeStrEscapedQuote() testing.TestResult {
	var s @[]char = unescapeStr("\"a\\\"b\"")
	if len(s) != 3 { return fail("expected len 3") }
	if s[1] != '"' { return fail("expected quote") }
	return ""
}

// ============================================================
// streq / charEq tests
// ============================================================

func TestStreqSame() testing.TestResult {
	if !streq("hello", "hello") {
		return fail("same strings should be equal")
	}
	return ""
}

func TestStreqDifferent() testing.TestResult {
	if streq("hello", "world") {
		return fail("different strings should not be equal")
	}
	return ""
}

func TestStreqDifferentLen() testing.TestResult {
	if streq("hi", "hello") {
		return fail("different lengths should not be equal")
	}
	return ""
}

// ============================================================
// buildQualName tests
// ============================================================

func TestBuildQualName() testing.TestResult {
	var name @[]char = buildQualName("pkg", "Func")
	if !charsEqual(name, "pkg.Func") {
		return fail("expected pkg.Func")
	}
	return ""
}

// ============================================================
// hexVal tests
// ============================================================

func TestHexValDigit() testing.TestResult {
	if hexVal('0') != 0 { return fail("0 should be 0") }
	if hexVal('9') != 9 { return fail("9 should be 9") }
	return ""
}

func TestHexValLower() testing.TestResult {
	if hexVal('a') != 10 { return fail("a should be 10") }
	if hexVal('f') != 15 { return fail("f should be 15") }
	return ""
}

func TestHexValUpper() testing.TestResult {
	if hexVal('A') != 10 { return fail("A should be 10") }
	if hexVal('F') != 15 { return fail("F should be 15") }
	return ""
}

// ============================================================
// parseIntLit negative
// ============================================================

func TestParseIntLitNegative() testing.TestResult {
	var v int = parseIntLit("-42")
	if v != -42 { return fail("expected -42") }
	return ""
}

func TestParseIntLitEmpty() testing.TestResult {
	var v int = parseIntLit("")
	if v != 0 { return fail("expected 0 for empty") }
	return ""
}
