package "pkg/ir"

import "pkg/types"
import "pkg/builtin/testing"

// ============================================================
// Type query helpers
// ============================================================

func TestIsSliceType() testing.TestResult {
	var t @types.Type = types.MakeSliceType(types.TypInt())
	if !isSliceType(t) {
		return fail("[]int should be a slice type")
	}
	return ""
}

func TestIsSliceTypeManagedSlice() testing.TestResult {
	var t @types.Type = types.MakeManagedSliceType(types.TypInt())
	if !isSliceType(t) {
		return fail("@[]int should be a slice type")
	}
	return ""
}

func TestIsSliceTypeNonSlice() testing.TestResult {
	if isSliceType(types.TypInt()) {
		return fail("int should not be a slice type")
	}
	return ""
}

func TestIsCharSliceType() testing.TestResult {
	var t @types.Type = types.MakeSliceType(types.TypChar())
	if !isCharSliceType(t) {
		return fail("[]char should be char slice")
	}
	return ""
}

func TestIsCharSliceTypeNotChar() testing.TestResult {
	var t @types.Type = types.MakeSliceType(types.TypInt())
	if isCharSliceType(t) {
		return fail("[]int should not be char slice")
	}
	return ""
}

func TestIsNillableTypeSlice() testing.TestResult {
	var t @types.Type = types.MakeSliceType(types.TypInt())
	if !isNillableType(t) {
		return fail("[]int should be nillable")
	}
	return ""
}

func TestIsNillableTypeManagedPtr() testing.TestResult {
	var t @types.Type = types.MakeManagedPtrType(types.TypInt())
	if !isNillableType(t) {
		return fail("@int should be nillable")
	}
	return ""
}

func TestIsNillableTypeInt() testing.TestResult {
	if isNillableType(types.TypInt()) {
		return fail("int should not be nillable")
	}
	return ""
}

func TestIsManagedPtrToStruct() testing.TestResult {
	var s @types.Type = types.MakeStructType("Node", noFields)
	var t @types.Type = types.MakeManagedPtrType(s)
	if !isManagedPtrToStruct(t) {
		return fail("@Node should be managed-ptr-to-struct")
	}
	return ""
}

func TestIsManagedPtrToStructNonStruct() testing.TestResult {
	var t @types.Type = types.MakeManagedPtrType(types.TypInt())
	if isManagedPtrToStruct(t) {
		return fail("@int should not be managed-ptr-to-struct")
	}
	return ""
}

// ============================================================
// Fresh allocation detection
// ============================================================

func TestIsFreshManagedPtrNil() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var instr @Instr = EmitConstNil(f, b, types.MakeManagedPtrType(nil))
	if !isFreshManagedPtr(instr) {
		return fail("nil should be fresh managed ptr")
	}
	return ""
}

func TestIsFreshManagedPtrMake() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var s @types.Type = types.MakeStructType("S", noFields)
	var instr @Instr = EmitMake(f, b, s)
	if !isFreshManagedPtr(instr) {
		return fail("make should be fresh managed ptr")
	}
	return ""
}

func TestIsFreshManagedSliceMakeSlice() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var n @Instr = EmitConstInt(f, b, 10, types.TypInt())
	var instr @Instr = EmitMakeSlice(f, b, types.TypInt(), n)
	if !isFreshManagedSlice(instr) {
		return fail("make_slice should be fresh managed slice")
	}
	return ""
}
