package "pkg/ir"

import "pkg/token"
import "pkg/types"
import "pkg/builtin/testing"

// Tests for gen_util.bn: tokenToOp, resolveTypeExpr, parseIntLit, etc.

func TestTokenToOp() testing.TestResult {
	if tokenToOp(cast(int, token.PLUS)) != OP_ADD { return fail("PLUS should map to OP_ADD") }
	if tokenToOp(cast(int, token.MINUS)) != OP_SUB { return fail("MINUS should map to OP_SUB") }
	if tokenToOp(cast(int, token.STAR)) != OP_MUL { return fail("STAR should map to OP_MUL") }
	return ""
}

func TestParseIntLitDecimal() testing.TestResult {
	if parseIntLit("42") != 42 { return fail("expected 42") }
	if parseIntLit("0") != 0 { return fail("expected 0") }
	return ""
}

func TestParseIntLitHex() testing.TestResult {
	if parseIntLit("0xFF") != 255 { return fail("expected 255") }
	if parseIntLit("0x10") != 16 { return fail("expected 16") }
	return ""
}

func TestParseIntLitOctal() testing.TestResult {
	if parseIntLit("0o77") != 63 { return fail("expected 63") }
	return ""
}

func TestParseIntLitBinary() testing.TestResult {
	if parseIntLit("0b1010") != 10 { return fail("expected 10") }
	return ""
}

func TestIsManagedPtrType() testing.TestResult {
	var mp @types.Type = types.MakeManagedPtrType(types.TypInt())
	if !isManagedPtrType(mp) { return fail("should be managed ptr") }
	if isManagedPtrType(types.TypInt()) { return fail("int should not be managed ptr") }
	return ""
}

func TestIsManagedSliceType() testing.TestResult {
	var ms @types.Type = types.MakeManagedSliceType(types.TypInt())
	if !isManagedSliceType(ms) { return fail("should be managed slice") }
	if isManagedSliceType(types.TypInt()) { return fail("int should not be managed slice") }
	return ""
}
