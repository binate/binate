func EmitExtract(f @Func, b @Block, multi @Instr, index int, typ @types.Type) @Instr {
	var instr @Instr = newInstr(f, OP_EXTRACT, typ)
	instr.Args = append(instr.Args, multi)
	instr.Index = index
	addInstr(b, instr)
	return instr
}

// ============================================================
// Helpers
// ============================================================

func OpName(op int) []char {
	if op == OP_CONST_INT { return "const_int" }
	if op == OP_CONST_BOOL { return "const_bool" }
	if op == OP_CONST_STRING { return "const_string" }
	if op == OP_CONST_NIL { return "const_nil" }
	if op == OP_ADD { return "add" }
	if op == OP_SUB { return "sub" }
	if op == OP_MUL { return "mul" }
	if op == OP_DIV { return "div" }
	if op == OP_REM { return "rem" }
	if op == OP_AND { return "and" }
	if op == OP_OR { return "or" }
	if op == OP_XOR { return "xor" }
	if op == OP_SHL { return "shl" }
	if op == OP_SHR { return "shr" }
	if op == OP_EQ { return "eq" }
	if op == OP_NE { return "ne" }
	if op == OP_LT { return "lt" }
	if op == OP_LE { return "le" }
	if op == OP_GT { return "gt" }
	if op == OP_GE { return "ge" }
	if op == OP_LAND { return "land" }
	if op == OP_LOR { return "lor" }
	if op == OP_NEG { return "neg" }
	if op == OP_NOT { return "not" }
	if op == OP_BITNOT { return "bitnot" }
	if op == OP_ALLOC { return "alloc" }
	if op == OP_LOAD { return "load" }
	if op == OP_STORE { return "store" }
	if op == OP_GET_FIELD_PTR { return "get_field_ptr" }
	if op == OP_GET_ELEM_PTR { return "get_elem_ptr" }
	if op == OP_BOX { return "box" }
	if op == OP_MAKE { return "make" }
	if op == OP_MAKE_RAW_SLICE_DEPRECATED { return "make_raw_slice_deprecated" }
	if op == OP_DEREF { return "deref" }
	if op == OP_NIL_CHECK { return "nil_check" }
	if op == OP_REFCOUNT_INC { return "refcount_inc" }
	if op == OP_REFCOUNT_DEC { return "refcount_dec" }
	if op == OP_SLICE_LEN { return "slice_len" }
	if op == OP_SLICE_PTR { return "slice_ptr" }
	if op == OP_SLICE_GET { return "slice_get" }
	if op == OP_SLICE_SET { return "slice_set" }
	if op == OP_SLICE_EXPR { return "slice_expr" }
	if op == OP_SLICE_ELEM_PTR { return "slice_elem_ptr" }
	if op == OP_BOUNDS_CHECK { return "bounds_check" }
	if op == OP_APPEND { return "append" }
	if op == OP_SLICE_FREE { return "slice_free" }
	if op == OP_STRING_TO_CHARS { return "string_to_chars" }
	if op == OP_STRING_TO_ARRAY { return "string_to_array" }
	if op == OP_JUMP { return "jump" }
	if op == OP_BRANCH { return "branch" }
	if op == OP_RETURN { return "return" }
	if op == OP_PANIC { return "panic" }
	if op == OP_PHI { return "phi" }
	if op == OP_CALL { return "call" }
	if op == OP_CALL_BUILTIN { return "call_builtin" }
	if op == OP_CAST { return "cast" }
	if op == OP_BIT_CAST { return "bit_cast" }
	if op == OP_STRUCT_LIT { return "struct_lit" }
	if op == OP_EXTRACT { return "extract" }
	if op == OP_UNREACHABLE { return "unreachable" }
	return "unknown"
}

func IsTerminator(instr @Instr) bool {
	if instr.Op == OP_JUMP { return true }
	if instr.Op == OP_BRANCH { return true }
	if instr.Op == OP_RETURN { return true }
	if instr.Op == OP_PANIC { return true }
	if instr.Op == OP_UNREACHABLE { return true }
	return false
}
