// ============================================================
// Struct
// ============================================================

func EmitStructLit(f @Func, b @Block, fields []@Instr, structTyp @types.Type) @Instr {
	var instr @Instr = newInstr(f, OP_STRUCT_LIT, structTyp)
	instr.Args = fields
	instr.TypeArg = structTyp
	addInstr(b, instr)
