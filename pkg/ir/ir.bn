}

func EmitBitCast(f @Func, b @Block, val @Instr, targetTyp @types.Type) @Instr {
	var instr @Instr = newInstr(f, OP_BIT_CAST, targetTyp)
	instr.Args = append(instr.Args, val)
	instr.TypeArg = targetTyp
