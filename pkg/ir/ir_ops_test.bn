package "pkg/ir"

import "pkg/types"
import "pkg/builtin/testing"

// ============================================================
// Control flow tests
// ============================================================

func TestEmitJump() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b1 @Block = AddBlock(f, "entry")
	var b2 @Block = AddBlock(f, "next")
	EmitJump(b1, b2)
	if len(b1.Instrs) != 1 { return fail("expected 1 instr") }
	if b1.Instrs[0].Op != OP_JUMP { return fail("op wrong") }
	return ""
}

func TestEmitBranch() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var entry @Block = AddBlock(f, "entry")
	var thenBlk @Block = AddBlock(f, "then")
	var elseBlk @Block = AddBlock(f, "else")
	var cond @Instr = EmitConstBool(f, entry, true)
	EmitBranch(entry, cond, thenBlk, elseBlk)
	var br @Instr = entry.Instrs[1]
	if br.Op != OP_BRANCH { return fail("op wrong") }
	if len(br.Args) != 1 { return fail("expected 1 arg (cond)") }
	return ""
}

func TestEmitReturn() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 0, types.TypInt())
	var retArgs @[]@Instr = make_slice(@Instr, 1)
	retArgs[0] = val
	EmitReturn(b, retArgs)
	if b.Instrs[1].Op != OP_RETURN { return fail("op wrong") }
	return ""
}

func TestEmitReturnVoid() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	EmitReturn(b, noArgs)
	if b.Instrs[0].Op != OP_RETURN { return fail("op wrong") }
	if len(b.Instrs[0].Args) != 0 { return fail("void return should have no args") }
	return ""
}

// ============================================================
// Call tests
// ============================================================

func TestEmitCall() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var arg @Instr = EmitConstInt(f, b, 1, types.TypInt())
	var callArgs @[]@Instr = make_slice(@Instr, 1)
	callArgs[0] = arg
	var result @Instr = EmitCall(f, b, "add", callArgs, types.TypInt())
	if result.Op != OP_CALL { return fail("op wrong") }
	if len(result.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

func TestEmitCallBuiltin() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var result @Instr = EmitCallBuiltin(f, b, "Exit", noArgs, nil)
	if result.Op != OP_CALL_BUILTIN { return fail("op wrong") }
	return ""
}

// ============================================================
// Helper tests
// ============================================================

func TestOpName() testing.TestResult {
	if !seq(OpName(OP_ADD), "add") { return fail("add wrong") }
	if !seq(OpName(OP_RETURN), "return") { return fail("return wrong") }
	if !seq(OpName(OP_CALL), "call") { return fail("call wrong") }
	if !seq(OpName(OP_CONST_INT), "const_int") { return fail("const_int wrong") }
	if !seq(OpName(999), "unknown") { return fail("unknown wrong") }
	return ""
}

func TestIsTerminator() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 0, types.TypInt())
	if IsTerminator(val) { return fail("const should not be terminator") }
	EmitReturn(b, noArgs)
	if !IsTerminator(b.Instrs[1]) { return fail("return should be terminator") }
	return ""
}

// ============================================================
// Slice tests
// ============================================================

func TestEmitSliceOps() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var slen @Instr = EmitSliceLen(f, b, s)
	if slen.Op != OP_EXTRACT { return fail("len should lower to extract") }
	var idx @Instr = EmitConstInt(f, b, 0, types.TypInt())
	var elem @Instr = EmitSliceGet(f, b, s, idx, types.TypInt())
	// EmitSliceGet now lowers to extract + GEP + load
	if elem.Op != OP_LOAD { return fail("get should lower to load") }
	return ""
}

func TestEmitSliceSet() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var idx @Instr = EmitConstInt(f, b, 0, types.TypInt())
	var val @Instr = EmitConstInt(f, b, 42, types.TypInt())
	EmitSliceSet(f, b, s, idx, val)
	// Should lower to: extract(0) + get_elem_ptr + store
	var extract @Instr = b.Instrs[3]
	if extract.Op != OP_EXTRACT { return fail("expected extract for data ptr") }
	var gep @Instr = b.Instrs[4]
	if gep.Op != OP_GET_ELEM_PTR { return fail("expected GEP") }
	var store @Instr = b.Instrs[5]
	if store.Op != OP_STORE { return fail("expected store") }
	return ""
}

func TestEmitSliceExpr() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var lo @Instr = EmitConstInt(f, b, 1, types.TypInt())
	var hi @Instr = EmitConstInt(f, b, 5, types.TypInt())
	var se @Instr = EmitSliceExpr(f, b, s, lo, hi, sliceTyp)
	if se.Op != OP_SLICE_EXPR { return fail("op wrong") }
	if len(se.Args) != 3 { return fail("expected 3 args") }
	return ""
}

func TestEmitBoundsCheck() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var idx @Instr = EmitConstInt(f, b, 3, types.TypInt())
	var length @Instr = EmitConstInt(f, b, 10, types.TypInt())
	EmitBoundsCheck(b, idx, length)
	var bc @Instr = b.Instrs[2]
	if bc.Op != OP_BOUNDS_CHECK { return fail("op wrong") }
	if bc.ID != -1 { return fail("bounds_check should be void") }
	if len(bc.Args) != 2 { return fail("expected 2 args") }
	return ""
}

func TestEmitSliceFree() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	EmitSliceFree(b, s)
	var sf @Instr = b.Instrs[1]
	if sf.Op != OP_SLICE_FREE { return fail("op wrong") }
	if sf.ID != -1 { return fail("slice_free should be void") }
	return ""
}

func TestEmitSliceElemPtr() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var idx @Instr = EmitConstInt(f, b, 0, types.TypInt())
	var ep @Instr = EmitSliceElemPtr(f, b, s, idx, types.TypInt())
	if ep.Op != OP_SLICE_ELEM_PTR { return fail("op wrong") }
	if len(ep.Args) != 2 { return fail("expected 2 args") }
	if ep.TypeArg == nil { return fail("TypeArg should not be nil") }
	return ""
}

// ============================================================
// String conversion tests
// ============================================================

func TestEmitStringToArray() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var str @Instr = EmitConstString(f, b, "hello")
	var arrayTyp @types.Type = types.MakeArrayType(types.TypChar(), 5)
	var sta @Instr = EmitStringToArray(f, b, str, arrayTyp)
	if sta.Op != OP_STRING_TO_ARRAY { return fail("op wrong") }
	if len(sta.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

// ============================================================
// Conversion tests
// ============================================================

func TestEmitCast() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 65, types.TypInt())
	var casted @Instr = EmitCast(f, b, val, types.TypUint8())
	if casted.Op != OP_CAST { return fail("op wrong") }
	return ""
}

func TestEmitBitCast() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 42, types.TypInt())
	var bc @Instr = EmitBitCast(f, b, val, types.TypUint64())
	if bc.Op != OP_BIT_CAST { return fail("op wrong") }
	if len(bc.Args) != 1 { return fail("expected 1 arg") }
	if bc.TypeArg == nil { return fail("TypeArg should not be nil") }
	return ""
}

// ============================================================
// Struct tests
// ============================================================

func TestEmitStructLit() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var structTyp @types.Type = types.TypInt() // placeholder
	var f1 @Instr = EmitConstInt(f, b, 10, types.TypInt())
	var f2 @Instr = EmitConstInt(f, b, 20, types.TypInt())
	var fields @[]@Instr = make_slice(@Instr, 2)
	fields[0] = f1
	fields[1] = f2
	var lit @Instr = EmitStructLit(f, b, fields, structTyp)
	if lit.Op != OP_STRUCT_LIT { return fail("op wrong") }
	if len(lit.Args) != 2 { return fail("expected 2 fields") }
	return ""
}

func TestEmitExtract() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var multi @Instr = EmitCall(f, b, "multi_ret", noArgs, types.TypInt())
	var extracted @Instr = EmitExtract(f, b, multi, 0, types.TypInt())
	if extracted.Op != OP_EXTRACT { return fail("op wrong") }
	if extracted.Index != 0 { return fail("index wrong") }
	return ""
}

// ============================================================
// SSA / Phi tests
// ============================================================

func TestEmitPhi() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b1 @Block = AddBlock(f, "left")
	var b2 @Block = AddBlock(f, "right")
	var merge @Block = AddBlock(f, "merge")
	var val1 @Instr = EmitConstInt(f, b1, 1, types.TypInt())
	var val2 @Instr = EmitConstInt(f, b2, 2, types.TypInt())
	var pe1 PhiEntry
	pe1.Block = b1
	pe1.Val = val1
	var pe2 PhiEntry
	pe2.Block = b2
	pe2.Val = val2
	var phiEntries @[]PhiEntry = make_slice(PhiEntry, 2)
	phiEntries[0] = pe1
	phiEntries[1] = pe2
	var phi @Instr = EmitPhi(f, merge, types.TypInt(), phiEntries)
	if phi.Op != OP_PHI { return fail("op wrong") }
	if len(phi.Phis) != 2 { return fail("expected 2 phi entries") }
	return ""
}

// ============================================================
// Panic / Unreachable tests
// ============================================================

func TestEmitPanic() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	var msg @Instr = EmitConstString(f, b, "oops")
	EmitPanic(b, msg)
	var p @Instr = b.Instrs[1]
	if p.Op != OP_PANIC { return fail("op wrong") }
	if p.ID != -1 { return fail("panic should be void") }
	if !IsTerminator(p) { return fail("panic should be terminator") }
	return ""
}

func TestEmitUnreachable() testing.TestResult {
	var f @Func = NewFunc("test", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	EmitUnreachable(b)
	var u @Instr = b.Instrs[0]
	if u.Op != OP_UNREACHABLE { return fail("op wrong") }
	if u.ID != -1 { return fail("unreachable should be void") }
	if !IsTerminator(u) { return fail("unreachable should be terminator") }
	return ""
}
