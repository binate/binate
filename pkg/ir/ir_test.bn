package "pkg/ir"

import "pkg/types"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Helpers
// ============================================================

func fail(msg []char) testing.TestResult {
	return msg
}

func seq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func strToBytes(s []char) []uint8 {
	var r []uint8
	for i := 0; i < len(s); i++ {
		r = append(r, cast(uint8, s[i]))
	}
	return r
}

func genFromSource(src []char) @Module {
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	return GenModule(file)
}

func genFromSourcePkg(src []char) @Module {
	var p @parser.Parser = parser.New(strToBytes(src), "test")
	var file @ast.File = parser.ParseFile(p)
	var m @Module = InitModule(file.PkgName)
	moduleConsts = nil
	moduleStructs = nil
	moduleGlobals = nil
	moduleFuncs = nil
	GeneratePackage(file, m)
	return m
}

func startsWith(s []char, prefix []char) bool {
	if len(s) < len(prefix) { return false }
	for i := 0; i < len(prefix); i++ {
		if s[i] != prefix[i] { return false }
	}
	return true
}

// ============================================================
// Module tests
// ============================================================

func TestNewModule() testing.TestResult {
	var m @Module = NewModule("test")
	if len(m.Funcs) != 0 { return fail("funcs not empty") }
	if len(m.Globals) != 0 { return fail("globals not empty") }
	if len(m.Types) != 0 { return fail("types not empty") }
	return ""
}

func TestAddFunc() testing.TestResult {
	var m @Module = NewModule("test")
	var f @Func = NewFunc("main", nil, nil)
	AddFunc(m, f)
	if len(m.Funcs) != 1 { return fail("expected 1 func") }
	return ""
}

func TestAddGlobal() testing.TestResult {
	var m @Module = NewModule("test")
	var g @Global = make(Global)
	g.Name = "x"
	g.Typ = types.TypInt()
	AddGlobal(m, g)
	if len(m.Globals) != 1 { return fail("expected 1 global") }
	return ""
}

// ============================================================
// Function tests
// ============================================================

func TestNewFunc() testing.TestResult {
	var f @Func = NewFunc("add", nil, nil)
	if !seq(f.Name, "add") { return fail("name wrong") }
	if f.IsExtern { return fail("should not be extern") }
	if len(f.Blocks) != 0 { return fail("blocks not empty") }
	return ""
}

func TestNewExternFunc() testing.TestResult {
	var f @Func = NewExternFunc("write", nil, nil)
	if !f.IsExtern { return fail("should be extern") }
	return ""
}

func TestNewParam() testing.TestResult {
	var f @Func = NewFunc("foo", nil, nil)
	var p @Param = NewParam(f, "x", types.TypInt())
	if !seq(p.Name, "x") { return fail("name wrong") }
	if p.ID != 0 { return fail("first param ID should be 0") }
	var p2 @Param = NewParam(f, "y", types.TypBool())
	if p2.ID != 1 { return fail("second param ID should be 1") }
	return ""
}

func TestAddBlock() testing.TestResult {
	var f @Func = NewFunc("main", nil, nil)
	var entry @Block = AddBlock(f, "entry")
	if !startsWith(entry.Label, "entry") { return fail("label should start with entry") }
	if len(f.Blocks) != 1 { return fail("expected 1 block") }
	var exit @Block = AddBlock(f, "exit")
	if len(f.Blocks) != 2 { return fail("expected 2 blocks") }
	if !startsWith(exit.Label, "exit") { return fail("exit label should start with exit") }
	return ""
}

func TestBlockLabelsUnique() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b1 @Block = AddBlock(f, "if.then")
	var b2 @Block = AddBlock(f, "if.then")
	var b3 @Block = AddBlock(f, "if.then")
	// All should have distinct labels
	if seq(b1.Label, b2.Label) { return fail("b1 and b2 have same label") }
	if seq(b2.Label, b3.Label) { return fail("b2 and b3 have same label") }
	if seq(b1.Label, b3.Label) { return fail("b1 and b3 have same label") }
	// All should start with the base name
	if !startsWith(b1.Label, "if.then") { return fail("b1 should start with if.then") }
	if !startsWith(b2.Label, "if.then") { return fail("b2 should start with if.then") }
	if !startsWith(b3.Label, "if.then") { return fail("b3 should start with if.then") }
	return ""
}

// ============================================================
// Instruction emission tests
// ============================================================

func TestEmitConstInt() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var instr @Instr = EmitConstInt(f, b, 42, types.TypInt())
	if instr.Op != OP_CONST_INT { return fail("op wrong") }
	if instr.IntVal != 42 { return fail("value wrong") }
	if len(b.Instrs) != 1 { return fail("expected 1 instr") }
	return ""
}

func TestEmitConstBool() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var instr @Instr = EmitConstBool(f, b, true)
	if instr.Op != OP_CONST_BOOL { return fail("op wrong") }
	if !instr.BoolVal { return fail("value wrong") }
	return ""
}

func TestEmitConstString() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var instr @Instr = EmitConstString(f, b, "hello")
	if instr.Op != OP_CONST_STRING { return fail("op wrong") }
	return ""
}

func TestEmitConstNil() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var ptrTyp @types.Type = types.MakePointerType(types.TypInt())
	var instr @Instr = EmitConstNil(f, b, ptrTyp)
	if instr.Op != OP_CONST_NIL { return fail("op wrong") }
	return ""
}

func TestEmitBinop() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var lhs @Instr = EmitConstInt(f, b, 3, types.TypInt())
	var rhs @Instr = EmitConstInt(f, b, 4, types.TypInt())
	var add @Instr = EmitBinop(f, b, OP_ADD, lhs, rhs, types.TypInt())
	if add.Op != OP_ADD { return fail("op wrong") }
	if len(add.Args) != 2 { return fail("expected 2 args") }
	if len(b.Instrs) != 3 { return fail("expected 3 instrs") }
	return ""
}

func TestEmitUnary() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 5, types.TypInt())
	var neg @Instr = EmitUnary(f, b, OP_NEG, val, types.TypInt())
	if neg.Op != OP_NEG { return fail("op wrong") }
	if len(neg.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

// ============================================================
// Memory tests
// ============================================================

func TestEmitAllocLoadStore() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var ptr @Instr = EmitAlloc(f, b, types.TypInt())
	if ptr.Op != OP_ALLOC { return fail("alloc op wrong") }
	var val @Instr = EmitConstInt(f, b, 10, types.TypInt())
	EmitStore(b, ptr, val)
	var loaded @Instr = EmitLoad(f, b, ptr, types.TypInt())
	if loaded.Op != OP_LOAD { return fail("load op wrong") }
	if len(b.Instrs) != 4 { return fail("expected 4 instrs") }
	// Store should be void (ID = -1)
	if b.Instrs[2].ID != -1 { return fail("store should be void") }
	return ""
}

func TestEmitGetFieldPtr() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var structTyp @types.Type = types.TypInt() // placeholder
	var ptr @Instr = EmitAlloc(f, b, structTyp)
	var fptr @Instr = EmitGetFieldPtr(f, b, ptr, 0, types.TypInt())
	if fptr.Op != OP_GET_FIELD_PTR { return fail("op wrong") }
	if fptr.Index != 0 { return fail("index wrong") }
	return ""
}

