func TestEmitBox() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 42, types.TypInt())
	var ptrTyp @types.Type = types.MakeManagedPtrType(types.TypInt())
	var boxed @Instr = EmitBox(f, b, val, ptrTyp)
	if boxed.Op != OP_BOX { return fail("op wrong") }
	if len(boxed.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

