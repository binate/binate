func TestEmitSliceOps() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var slen @Instr = EmitSliceLen(f, b, s)
	if slen.Op != OP_SLICE_LEN { return fail("len op wrong") }
	var idx @Instr = EmitConstInt(f, b, 0, types.TypInt())
	var elem @Instr = EmitSliceGet(f, b, s, idx, types.TypInt())
	if elem.Op != OP_SLICE_GET { return fail("get op wrong") }
	return ""
}

func TestEmitAppend() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var sliceTyp @types.Type = types.MakeSliceType(types.TypInt())
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var val @Instr = EmitConstInt(f, b, 1, types.TypInt())
	var result @Instr = EmitAppend(f, b, s, val, sliceTyp)
	if result.Op != OP_APPEND { return fail("op wrong") }
	if len(result.Args) != 2 { return fail("expected 2 args") }
	return ""
}

