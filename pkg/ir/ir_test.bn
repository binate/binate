	var val2 @Instr = EmitConstInt(f, b2, 2, types.TypInt())
	var entries []PhiEntry
	var pe1 PhiEntry
	pe1.Block = b1
	pe1.Val = val1
	entries = append(entries, pe1)
	var pe2 PhiEntry
	pe2.Block = b2
	pe2.Val = val2
	entries = append(entries, pe2)
	var phi @Instr = EmitPhi(f, merge, types.TypInt(), entries)
	if phi.Op != OP_PHI { return fail("op wrong") }
	if len(phi.Phis) != 2 { return fail("expected 2 phi entries") }
	return ""
}

