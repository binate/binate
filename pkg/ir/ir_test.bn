// ============================================================
// Gen-level test: switch statement
// ============================================================

func TestGenSwitchStmt() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar x int = 1\n\tswitch x {\n\tcase 1:\n\t\tprintln(10)\n\tcase 2:\n\t\tprintln(20)\n\tcase 3:\n\t\tprintln(30)\n\t}\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) == 0 { return fail("expected at least 1 func") }
	var mainFn @Func = m.Funcs[0]
	// A switch with 3 cases should generate multiple blocks:
	// entry + case comparison blocks + case body blocks + merge
	if len(mainFn.Blocks) < 4 { return fail(bootstrap.Concat("expected >=4 blocks for switch, got ", bootstrap.Itoa(len(mainFn.Blocks)))) }
	// Should have branch instructions for case comparisons
	var branchCount int = 0
	for i := 0; i < len(mainFn.Blocks); i++ {
		var blk @Block = mainFn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			if blk.Instrs[j].Op == OP_BRANCH {
				branchCount = branchCount + 1
			}
		}
	}
	if branchCount < 2 { return fail(bootstrap.Concat("expected >=2 branches for switch cases, got ", bootstrap.Itoa(branchCount))) }
	return ""
}

func TestGenForShortCircuitBackedge() testing.TestResult {
	// For loop with || in condition: the post block must jump back to the
	// condition start (for.cond), not the short-circuit merge block.
	var src []char = "package \"test\"\nfunc main() {\n\tvar x int = 0\n\tfor x == 1 || x == 2 {\n\t\tx = x + 1\n\t}\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) == 0 { return fail("expected at least 1 func") }
	var mainFn @Func = m.Funcs[0]
	// Should have: entry, for.cond, for.body, for.post, for.exit, plus short-circuit blocks
	if len(mainFn.Blocks) < 5 { return fail(bootstrap.Concat("expected >=5 blocks, got ", bootstrap.Itoa(len(mainFn.Blocks)))) }
	// Find the for.post block and verify it jumps to for.cond (not a merge block)
	var condLabel []char
	var postTarget []char
	for i := 0; i < len(mainFn.Blocks); i++ {
		var blk @Block = mainFn.Blocks[i]
		if len(blk.Label) >= 8 && blk.Label[0] == 'f' && blk.Label[1] == 'o' && blk.Label[2] == 'r' && blk.Label[3] == '.' && blk.Label[4] == 'c' {
			condLabel = blk.Label
		}
		if len(blk.Label) >= 8 && blk.Label[0] == 'f' && blk.Label[1] == 'o' && blk.Label[2] == 'r' && blk.Label[3] == '.' && blk.Label[4] == 'p' {
			// for.post block — check its terminator target
			if len(blk.Instrs) > 0 {
				var last @Instr = blk.Instrs[len(blk.Instrs)-1]
				if last.Op == OP_JUMP && last.Block1 != nil {
					postTarget = last.Block1.Label
				}
			}
		}
	}
	if condLabel == nil { return fail("no for.cond block found") }
	if postTarget == nil { return fail("no for.post jump target found") }
	// The post block must jump to for.cond, not to a lor.merge or land.merge block
	if !charsEqual(postTarget, condLabel) {
		var msg []char = "for.post jumps to '"
		msg = appendChars(msg, postTarget)
		msg = appendChars(msg, "' but should jump to '")
		msg = appendChars(msg, condLabel)
		msg = appendChars(msg, "'")
		return msg
	}
	return ""
}

func charsEqual(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func appendChars(dst []char, src []char) []char {
	for i := 0; i < len(src); i++ {
		dst = append(dst, src[i])
	}
	return dst
}

func TestGeneratePackageStructLitInit() testing.TestResult {
	// GeneratePackage must populate ModuleStruct.Fields so that
	// genCompositeLit can initialize struct literal field values.
	// Regression: only Typ.Fields was set, so composites were zeroinitializer.
	var src []char = "package \"test\"\ntype Pt struct {\n\tx int\n\ty int\n}\nfunc main() {\n\tvar p Pt = Pt{x: 10, y: 20}\n\tprintln(p.x)\n}\n"
	var m @Module = genFromSourcePkg(src)
	if len(m.Funcs) == 0 { return fail("expected at least 1 func") }
	var mainFn @Func = m.Funcs[0]
	// Look for OP_STORE instructions that store non-zero values (the field inits)
	var foundFieldStore bool = false
	for i := 0; i < len(mainFn.Blocks); i++ {
		var blk @Block = mainFn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_STORE && len(instr.Args) >= 2 {
				// Check if the stored value (Args[1]) is a constant 10 or 20
				if instr.Args[1].Op == OP_CONST_INT {
					if instr.Args[1].IntVal == 10 || instr.Args[1].IntVal == 20 {
						foundFieldStore = true
					}
				}
			}
		}
	}
	if !foundFieldStore {
		return fail("no store of field values 10 or 20 found — struct literal init missing")
	}
	return ""
}

// Test: string literal assigned to [][]char element emits OP_STRING_TO_CHARS
func TestSliceSetStringToChars() testing.TestResult {
	var src []char
	src = appendChars(src, "package \"main\"\nfunc main() {\n")
	src = appendChars(src, "  var ss [][]char\n")
	src = appendChars(src, "  ss = append(ss, \"hello\")\n")
	src = appendChars(src, "  ss[0] = \"replaced\"\n")
	src = appendChars(src, "}\n")
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("no funcs") }
	// The slice set of a string literal to a []char element should emit string_to_chars
	var found bool = false
	for i := 0; i < len(m.Funcs[0].Blocks); i++ {
		var b @Block = m.Funcs[0].Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			if b.Instrs[j].Op == OP_SLICE_SET {
				// Check that the value arg (Args[2]) was converted from string
				// The presence of OP_STRING_TO_CHARS before the slice_set is what matters
				found = true
			}
		}
	}
	if !found { return fail("no OP_SLICE_SET found") }
	// Also check that OP_STRING_TO_CHARS appears (for the "replaced" assignment)
	var stcCount int = 0
	for i := 0; i < len(m.Funcs[0].Blocks); i++ {
		var b @Block = m.Funcs[0].Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			if b.Instrs[j].Op == OP_STRING_TO_CHARS {
				stcCount = stcCount + 1
			}
		}
	}
	// Should have at least 2: one for append("hello"), one for ss[0] = "replaced"
	if stcCount < 2 { return fail("expected at least 2 OP_STRING_TO_CHARS") }
	return ""
}

// Test: nested managed pointer selector in genSelectorPtr (o.Inner.Value = 100)
func TestNestedManagedSelectorPtr() testing.TestResult {
	var src []char
	src = appendChars(src, "package \"main\"\n")
	src = appendChars(src, "type Inner struct { Value int }\n")
	src = appendChars(src, "type Outer struct { Inner @Inner\n  Tag int }\n")
	src = appendChars(src, "func main() {\n")
	src = appendChars(src, "  var o @Outer = make(Outer)\n")
	src = appendChars(src, "  o.Inner = make(Inner)\n")
	src = appendChars(src, "  o.Inner.Value = 100\n")
	src = appendChars(src, "  println(o.Inner.Value)\n")
	src = appendChars(src, "}\n")
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("no funcs") }
	// The assignment o.Inner.Value = 100 needs to: load managed ptr from Inner field,
	// then GEP into the Inner struct to get Value field ptr, then store.
	// Check that we have a store of constant 100.
	var foundStore bool = false
	for i := 0; i < len(m.Funcs[0].Blocks); i++ {
		var b @Block = m.Funcs[0].Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			var instr @Instr = b.Instrs[j]
			if instr.Op == OP_STORE {
				if len(instr.Args) >= 2 {
					if instr.Args[1].Op == OP_CONST_INT && instr.Args[1].IntVal == 100 {
						foundStore = true
					}
				}
			}
		}
	}
	if !foundStore {
		return fail("no store of 100 found — nested managed selector ptr broken")
	}
	return ""
}

// Test: field assignment to managed pointer field emits refcount management
func TestFieldAssignRefcount() testing.TestResult {
	var src []char
	src = appendChars(src, "package \"main\"\n")
	src = appendChars(src, "type Inner struct { X int }\n")
	src = appendChars(src, "type Outer struct { Ptr @Inner }\n")
	src = appendChars(src, "func main() {\n")
	src = appendChars(src, "  var o @Outer = make(Outer)\n")
	src = appendChars(src, "  var a @Inner = make(Inner)\n")
	src = appendChars(src, "  o.Ptr = a\n")
	src = appendChars(src, "}\n")
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("no funcs") }
	// o.Ptr = a should emit: load old value, refcount_dec old, refcount_inc new, store
	var incCount int = 0
	var decCount int = 0
	for i := 0; i < len(m.Funcs[0].Blocks); i++ {
		var b @Block = m.Funcs[0].Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			if b.Instrs[j].Op == OP_REFCOUNT_INC { incCount = incCount + 1 }
			if b.Instrs[j].Op == OP_REFCOUNT_DEC { decCount = decCount + 1 }
		}
	}
	// At minimum: 1 inc for the field assignment, 1 dec for old value in field assignment
	// (plus possible inc/dec for parameter passing, variable cleanup, etc.)
	if incCount < 1 { return fail("expected at least 1 OP_REFCOUNT_INC for field assignment") }
	if decCount < 1 { return fail("expected at least 1 OP_REFCOUNT_DEC for field assignment") }
	return ""
}

func TestNilSliceArgCoercion() testing.TestResult {
	// Passing nil to a function expecting a slice parameter should produce
	// a nil instruction with slice type (not TYP_NIL), so codegen emits
	// %BnSlice zeroinitializer instead of i8* null.
	var src []char = "package \"test\"\nfunc take(s []int, n int) int { return n }\nfunc main() { take(nil, 42) }\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 2 { return fail(bootstrap.Concat("expected 2 funcs, got ", bootstrap.Itoa(len(m.Funcs)))) }
	// Find main function
	var mainFunc @Func = nil
	for i := 0; i < len(m.Funcs); i++ {
		if seq(m.Funcs[i].Name, "main") { mainFunc = m.Funcs[i] }
	}
	if mainFunc == nil { return fail("no main func") }
	// Find the OP_CALL instruction to "take" in main
	var callInstr @Instr = nil
	for i := 0; i < len(mainFunc.Blocks); i++ {
		var blk @Block = mainFunc.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_CALL && seq(instr.StrVal, "take") {
				callInstr = instr
			}
		}
	}
	if callInstr == nil { return fail("no call to take()") }
	// First arg should be nil with slice type, not TYP_NIL
	if len(callInstr.Args) < 2 { return fail(bootstrap.Concat("expected 2 args, got ", bootstrap.Itoa(len(callInstr.Args)))) }
	var nilArg @Instr = callInstr.Args[0]
	if nilArg.Op != OP_CONST_NIL { return fail("first arg should be OP_CONST_NIL") }
	if nilArg.Typ == nil { return fail("nil arg type is nil") }
	if nilArg.Typ.Kind == types.TYP_NIL { return fail("nil arg should have slice type, not TYP_NIL") }
	if nilArg.Typ.Kind != types.TYP_SLICE { return fail(bootstrap.Concat("nil arg should be TYP_SLICE, got kind ", bootstrap.Itoa(nilArg.Typ.Kind))) }
	return ""
}

// ============================================================
// TestDeclShortCircuitBlock
// ============================================================

func TestDeclShortCircuitBlock() testing.TestResult {
	// When a variable declaration uses || in its initializer, genDecl creates
	// new basic blocks for short-circuit evaluation and updates ctx.CurBlock.
	// genStmt must return ctx.CurBlock (not the original block) so subsequent
	// statements are generated on the correct (merge) block.
	var src []char = "package \"test\"\nfunc foo(x []int) int {\n\tvar empty bool = x == nil || len(x) == 0\n\tif empty { return 0 }\n\treturn x[0]\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	// After the fix, no block should end with an unreachable instruction
	// unless it's genuinely unreachable (e.g., after a return).
	// The bug caused the merge block from || to have unreachable because
	// statements after the decl were generated on the old (terminated) block.
	// Check that the function has more than 1 block (short-circuit creates blocks)
	if len(fn.Blocks) < 3 { return fail(bootstrap.Concat("expected >=3 blocks from || decl, got ", bootstrap.Itoa(len(fn.Blocks)))) }
	// Check that no block has unreachable as its only terminator when it shouldn't
	var unreachableCount int = 0
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			if blk.Instrs[j].Op == OP_UNREACHABLE {
				unreachableCount = unreachableCount + 1
			}
		}
	}
	// With the bug, the merge block gets unreachable. With the fix, there should
	// be zero unreachable instructions (all paths return properly).
	if unreachableCount > 0 { return fail(bootstrap.Concat("unexpected unreachable instructions: ", bootstrap.Itoa(unreachableCount))) }
	return ""
}

// ============================================================
// TestDeclAfterIfBlock
// ============================================================

func TestDeclAfterIfBlock() testing.TestResult {
	// Uninitialized slice decl after an if statement must not drop subsequent
	// statements. The bug was that genIf doesn't set ctx.CurBlock, so after
	// returning the merge block, ctx.CurBlock was stale (pointed to then-block).
	// STMT_DECL returned ctx.CurBlock which had a terminator, causing genBlock
	// to stop processing remaining statements.
	var src []char = "package \"test\"\nfunc foo(x int) int {\n\tif x == 0 { return -1 }\n\tvar s []int\n\treturn 42\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	// The function must have a return instruction in the merge path (not just
	// in the if-then path). Count return instructions across all blocks.
	var retCount int = 0
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			if blk.Instrs[j].Op == OP_RETURN {
				retCount = retCount + 1
			}
		}
	}
	// With the bug, only 1 return (in the if-then block). With the fix, 2
	// returns (if-then and the normal path after the slice decl).
	if retCount < 2 { return fail(bootstrap.Concat("expected 2 returns, got ", bootstrap.Itoa(retCount))) }
	return ""
}

// ============================================================
// TestAssignStringToChars
// ============================================================

func TestAssignStringToChars() testing.TestResult {
	// Assigning a string literal to an existing []char variable must emit
	// OP_STRING_TO_CHARS, not store the raw string pointer. Without the
	// conversion, the compiled code stores i8* into a %BnSlice alloca,
	// corrupting the slice length.
	var src []char = "package \"test\"\nfunc foo() []char {\n\tvar s []char\n\ts = \"hello\"\n\treturn s\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	// Look for OP_STRING_TO_CHARS in any block
	var found bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			if blk.Instrs[j].Op == OP_STRING_TO_CHARS {
				found = true
			}
		}
	}
	if !found { return fail("no OP_STRING_TO_CHARS found — string literal assigned to []char must be converted") }
	return ""
}

// ============================================================
// TestManagedPtrDeclNilInit
// ============================================================

func TestEmitSliceElemPtr() testing.TestResult {
	// EmitSliceElemPtr should create OP_SLICE_ELEM_PTR with TypeArg set
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var fields []@types.Field
	var fld @types.Field = make(types.Field)
	fld.Name = "X"
	fld.Type = types.TypInt()
	fields = append(fields, fld)
	var structTyp @types.Type = types.MakeStructType("Point", fields)
	var sliceTyp @types.Type = types.MakeSliceType(structTyp)
	var s @Instr = EmitConstNil(f, b, sliceTyp)
	var idx @Instr = EmitConstInt(f, b, 0, types.TypInt())
	var ptr @Instr = EmitSliceElemPtr(f, b, s, idx, structTyp)
	if ptr.Op != OP_SLICE_ELEM_PTR { return fail("op wrong") }
	if len(ptr.Args) != 2 { return fail("expected 2 args") }
	if ptr.Args[0].Op != OP_CONST_NIL { return fail("arg0 should be slice") }
	if ptr.Args[1].Op != OP_CONST_INT { return fail("arg1 should be index") }
	if ptr.TypeArg == nil { return fail("TypeArg must be set") }
	if !seq(ptr.TypeArg.Name, "Point") { return fail("TypeArg should be Point struct") }
	return ""
}

func TestNilToSliceAssign() testing.TestResult {
	// Assigning nil to a slice variable should emit OP_CONST_NIL with TYP_SLICE type
	var src []char = "package \"test\"\nfunc foo() {\n\tvar s []int\n\ts = nil\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	// Look for a store where the value is OP_CONST_NIL with TYP_SLICE type
	var foundSliceNil bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_STORE && len(instr.Args) >= 2 {
				if instr.Args[1].Op == OP_CONST_NIL && instr.Args[1].Typ != nil {
					if instr.Args[1].Typ.Kind == types.TYP_SLICE {
						foundSliceNil = true
					}
				}
			}
		}
	}
	if !foundSliceNil { return fail("nil assigned to slice should re-emit as nil with TYP_SLICE type") }
	return ""
}

func TestGenIndexPtrSliceOfStructs() testing.TestResult {
	// sliceOfStructs[i].field = value should produce OP_SLICE_ELEM_PTR
	var src []char = "package \"test\"\ntype Point struct {\n\tX int\n\tY int\n}\nfunc foo() {\n\tvar pts []Point\n\tpts = append(pts, Point{1, 2})\n\tpts[0].X = 99\n}\n"
	var m @Module = genFromSource(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	var foundSliceElemPtr bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			if blk.Instrs[j].Op == OP_SLICE_ELEM_PTR {
				foundSliceElemPtr = true
			}
		}
	}
	if !foundSliceElemPtr { return fail("slice-of-structs index assign should emit OP_SLICE_ELEM_PTR") }
	return ""
}

func TestManagedPtrDeclNilInit() testing.TestResult {
	// Uninitialized managed pointer declarations must store nil so that
	// refcount_dec on first assignment doesn't operate on garbage.
	var src []char = "package \"test\"\nimport \"pkg/ast\"\nfunc foo() {\n\tvar d @ast.Decl\n\td = nil\n}\n"
	var m @Module = genFromSourcePkg(src)
	if len(m.Funcs) < 1 { return fail("expected at least 1 func") }
	var fn @Func = m.Funcs[0]
	// The alloca for d should be followed by a store of OP_CONST_NIL
	var foundNilStore bool = false
	for i := 0; i < len(fn.Blocks); i++ {
		var blk @Block = fn.Blocks[i]
		for j := 0; j < len(blk.Instrs); j++ {
			var instr @Instr = blk.Instrs[j]
			if instr.Op == OP_STORE && len(instr.Args) >= 2 {
				if instr.Args[1].Op == OP_CONST_NIL {
					foundNilStore = true
				}
			}
		}
	}
	if !foundNilStore { return fail("managed ptr decl should be initialized with nil store") }
	return ""
}
