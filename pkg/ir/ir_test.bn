func TestEmitCall() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var arg @Instr = EmitConstInt(f, b, 1, types.TypInt())
	var callArgs []@Instr
	callArgs = append(callArgs, arg)
	var result @Instr = EmitCall(f, b, "add", callArgs, types.TypInt())
	if result.Op != OP_CALL { return fail("op wrong") }
	if len(result.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

func TestEmitCallBuiltin() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var result @Instr = EmitCallBuiltin(f, b, "Exit", nil, nil)
	if result.Op != OP_CALL_BUILTIN { return fail("op wrong") }
	return ""
}

// ============================================================
// SSA ID tests
// ============================================================

func TestSSAIDs() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var i1 @Instr = EmitConstInt(f, b, 1, types.TypInt())
	var i2 @Instr = EmitConstInt(f, b, 2, types.TypInt())
	var i3 @Instr = EmitBinop(f, b, OP_ADD, i1, i2, types.TypInt())
	if i1.ID != 0 { return fail(bootstrap.Concat("i1 ID wrong: ", bootstrap.Itoa(i1.ID))) }
	if i2.ID != 1 { return fail(bootstrap.Concat("i2 ID wrong: ", bootstrap.Itoa(i2.ID))) }
	if i3.ID != 2 { return fail(bootstrap.Concat("i3 ID wrong: ", bootstrap.Itoa(i3.ID))) }
	return ""
}

func TestParamIDsOffset() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var p @Param = NewParam(f, "x", types.TypInt())
	var b @Block = AddBlock(f, "entry")
	var i1 @Instr = EmitConstInt(f, b, 1, types.TypInt())
	// Param gets ID 0, first instr gets ID 1
	if p.ID != 0 { return fail("param ID should be 0") }
	if i1.ID != 1 { return fail("instr ID should be 1") }
	return ""
}

// ============================================================
// Helper tests
// ============================================================

func TestOpName() testing.TestResult {
	if !seq(OpName(OP_ADD), "add") { return fail("add wrong") }
	if !seq(OpName(OP_RETURN), "return") { return fail("return wrong") }
	if !seq(OpName(OP_CALL), "call") { return fail("call wrong") }
	if !seq(OpName(OP_CONST_INT), "const_int") { return fail("const_int wrong") }
	if !seq(OpName(999), "unknown") { return fail("unknown wrong") }
	return ""
}

func TestIsTerminator() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 0, types.TypInt())
	if IsTerminator(val) { return fail("const should not be terminator") }
	EmitReturn(b, nil)
	if !IsTerminator(b.Instrs[1]) { return fail("return should be terminator") }
	return ""
}

