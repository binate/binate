func TestOpName() testing.TestResult {
	if !seq(OpName(OP_ADD), "add") { return fail("add wrong") }
	if !seq(OpName(OP_RETURN), "return") { return fail("return wrong") }
	if !seq(OpName(OP_CALL), "call") { return fail("call wrong") }
	if !seq(OpName(OP_CONST_INT), "const_int") { return fail("const_int wrong") }
	if !seq(OpName(999), "unknown") { return fail("unknown wrong") }
	return ""
}

func TestIsTerminator() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var val @Instr = EmitConstInt(f, b, 0, types.TypInt())
	if IsTerminator(val) { return fail("const should not be terminator") }
	EmitReturn(b, nil)
	if !IsTerminator(b.Instrs[1]) { return fail("return should be terminator") }
	return ""
}

