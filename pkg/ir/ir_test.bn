}

// ============================================================
// Integration: build a small function
// ============================================================

func TestBuildAddFunc() testing.TestResult {
	// Build: func add(a int, b int) int { return a + b }
	var f @Func = NewFunc("add", nil, nil)
	var pa @Param = NewParam(f, "a", types.TypInt())
	var pb @Param = NewParam(f, "b", types.TypInt())
	var params []@Param
	params = append(params, pa)
	params = append(params, pb)
	f.Params = params
	var results []@types.Type
	results = append(results, types.TypInt())
	f.Results = results

	var entry @Block = AddBlock(f, "entry")

	// Alloca approach: allocate slots for params, store, then load
	var aPtr @Instr = EmitAlloc(f, entry, types.TypInt())
	var bPtr @Instr = EmitAlloc(f, entry, types.TypInt())

	// Store params (using const as stand-in since we can't reference params as Instr)
	var aVal @Instr = EmitConstInt(f, entry, 0, types.TypInt()) // placeholder
	var bVal @Instr = EmitConstInt(f, entry, 0, types.TypInt()) // placeholder
	EmitStore(entry, aPtr, aVal)
	EmitStore(entry, bPtr, bVal)

	// Load and add
	var a @Instr = EmitLoad(f, entry, aPtr, types.TypInt())
	var b_ @Instr = EmitLoad(f, entry, bPtr, types.TypInt())
	var sum @Instr = EmitBinop(f, entry, OP_ADD, a, b_, types.TypInt())

	// Return
	var retArgs []@Instr
	retArgs = append(retArgs, sum)
	EmitReturn(entry, retArgs)

	// Verify structure
	if len(f.Blocks) != 1 { return fail("expected 1 block") }
	// 2 allocs + 2 consts + 2 stores + 2 loads + 1 add + 1 return = 10
	if len(entry.Instrs) != 10 { return fail(bootstrap.Concat("expected 10 instrs, got ", bootstrap.Itoa(len(entry.Instrs)))) }
	// Last instr should be return (terminator)
	if !IsTerminator(entry.Instrs[len(entry.Instrs)-1]) { return fail("last instr should be terminator") }

	return ""
}

func TestBuildIfElse() testing.TestResult {
	// Build: func f(x int) int { if x > 0 { return 1 } else { return 0 } }
	var f @Func = NewFunc("f", nil, nil)

	var entry @Block = AddBlock(f, "entry")
	var thenBlk @Block = AddBlock(f, "if.then")
	var elseBlk @Block = AddBlock(f, "if.else")

	// Condition
	var x @Instr = EmitConstInt(f, entry, 5, types.TypInt())
	var zero @Instr = EmitConstInt(f, entry, 0, types.TypInt())
	var cond @Instr = EmitBinop(f, entry, OP_GT, x, zero, types.TypBool())
	EmitBranch(entry, cond, thenBlk, elseBlk)

	// Then
	var one @Instr = EmitConstInt(f, thenBlk, 1, types.TypInt())
	var retOne []@Instr
	retOne = append(retOne, one)
	EmitReturn(thenBlk, retOne)

	// Else
	var z @Instr = EmitConstInt(f, elseBlk, 0, types.TypInt())
	var retZ []@Instr
	retZ = append(retZ, z)
	EmitReturn(elseBlk, retZ)

	if len(f.Blocks) != 3 { return fail("expected 3 blocks") }
	if !IsTerminator(entry.Instrs[len(entry.Instrs)-1]) { return fail("entry not terminated") }
	if !IsTerminator(thenBlk.Instrs[len(thenBlk.Instrs)-1]) { return fail("then not terminated") }
	if !IsTerminator(elseBlk.Instrs[len(elseBlk.Instrs)-1]) { return fail("else not terminated") }
	return ""
}

// ============================================================
// IR Generation tests (gen.bn)
// ============================================================

func TestGenHelloWorld() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { println(\"hello\") }\n")
	if len(m.Funcs) != 1 { return fail(bootstrap.Concat("expected 1 func, got ", bootstrap.Itoa(len(m.Funcs)))) }
	if !seq(m.Funcs[0].Name, "main") { return fail("func name wrong") }
	if len(m.Funcs[0].Blocks) == 0 { return fail("no blocks") }
	// Should have instructions: const_string, call_builtin(bn_print_string), call_builtin(bn_print_newline), const_nil, return
	var entry @Block = m.Funcs[0].Blocks[0]
	if len(entry.Instrs) < 4 { return fail(bootstrap.Concat("too few instrs: ", bootstrap.Itoa(len(entry.Instrs)))) }
	if entry.Instrs[0].Op != OP_CONST_STRING { return fail("first instr should be const_string") }
	return ""
}

func TestGenArithmetic() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { println(2 + 3) }\n")
	var entry @Block = m.Funcs[0].Blocks[0]
	// Should have: const 2, const 3, add, call(bn_print_int), call(bn_print_newline), const_nil, return
	var foundAdd bool = false
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_ADD { foundAdd = true }
	}
	if !foundAdd { return fail("no add instruction found") }
	return ""
}

func TestGenVariable() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { var x int = 42; println(x) }\n")
	var entry @Block = m.Funcs[0].Blocks[0]
	var foundAlloc bool = false
	var foundStore bool = false
	var foundLoad bool = false
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_ALLOC { foundAlloc = true }
		if entry.Instrs[i].Op == OP_STORE { foundStore = true }
		if entry.Instrs[i].Op == OP_LOAD { foundLoad = true }
	}
	if !foundAlloc { return fail("no alloc") }
	if !foundStore { return fail("no store") }
	if !foundLoad { return fail("no load") }
	return ""
}

func TestGenIfElse() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { if true { println(1) } else { println(2) } }\n")
	// Should have multiple blocks: entry + if.then + if.merge + if.else
	if len(m.Funcs[0].Blocks) < 3 { return fail(bootstrap.Concat("expected >=3 blocks, got ", bootstrap.Itoa(len(m.Funcs[0].Blocks)))) }
	// Check entry has a branch
	var entry @Block = m.Funcs[0].Blocks[0]
	var lastInstr @Instr = entry.Instrs[len(entry.Instrs)-1]
	if lastInstr.Op != OP_BRANCH { return fail("entry should end with branch") }
	return ""
}

func TestGenForLoop() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { for i := 0; i < 5; i++ { println(i) } }\n")
	// Should have blocks: entry, for.cond, for.body, for.post, for.exit
	if len(m.Funcs[0].Blocks) < 5 { return fail(bootstrap.Concat("expected >=5 blocks, got ", bootstrap.Itoa(len(m.Funcs[0].Blocks)))) }
	return ""
}

func TestGenFuncParams() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc add(a int, b int) int { return a + b }\nfunc main() { println(add(3, 4)) }\n")
	if len(m.Funcs) != 2 { return fail(bootstrap.Concat("expected 2 funcs, got ", bootstrap.Itoa(len(m.Funcs)))) }
	var addFunc @Func = m.Funcs[0]
	if !seq(addFunc.Name, "add") { return fail("first func should be add") }
	if len(addFunc.Params) != 2 { return fail("add should have 2 params") }
	if len(addFunc.Results) != 1 { return fail("add should have 1 result") }
	return ""
}

func TestGenCompoundAssign() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nfunc main() { var x int = 10; x += 5; println(x) }\n")
	var entry @Block = m.Funcs[0].Blocks[0]
	// Should have: alloc, const 10, store, load, const 5, add, store, load, print, ...
	var addCount int = 0
	var storeCount int = 0
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_ADD { addCount = addCount + 1 }
		if entry.Instrs[i].Op == OP_STORE { storeCount = storeCount + 1 }
	}
	// Should have at least 2 stores (initial + compound) and 1 add (the compound op; print_int uses call not add)
	if storeCount < 2 { return fail(bootstrap.Concat("expected >=2 stores, got ", bootstrap.Itoa(storeCount))) }
	if addCount < 1 { return fail("expected at least 1 add for compound assign") }
	return ""
}

func TestGenConstIota() testing.TestResult {
	var m @Module = genFromSource("package \"test\"\nconst (\n\tA int = iota\n\tB\n\tC\n)\nfunc main() { println(A); println(B); println(C) }\n")
	var entry @Block = m.Funcs[0].Blocks[0]
	// First three instrs should be const ints 0, 1, 2
	if entry.Instrs[0].Op != OP_CONST_INT { return fail("first should be const_int") }
	if entry.Instrs[0].IntVal != 0 { return fail(bootstrap.Concat("A should be 0, got ", bootstrap.Itoa(entry.Instrs[0].IntVal))) }
	// Find the second and third const_int values
	var constVals []int
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_CONST_INT {
			constVals = append(constVals, entry.Instrs[i].IntVal)
		}
	}
	// First three const ints should be 0, 1, 2
	if len(constVals) < 3 { return fail("expected at least 3 const ints") }
	if constVals[0] != 0 { return fail("A != 0") }
	if constVals[1] != 1 { return fail("B != 1") }
	if constVals[2] != 2 { return fail("C != 2") }
	return ""
}

func TestGenScopeShadow() testing.TestResult {
	var src []char = "package \"test\"\nfunc main() {\n\tvar x int = 1\n\t{\n\t\tvar x int = 2\n\t\tprintln(x)\n\t}\n\tprintln(x)\n}\n"
	var m @Module = genFromSource(src)
	var entry @Block = m.Funcs[0].Blocks[0]
	// Should have 2 allocs (outer x, inner x)
	var allocCount int = 0
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_ALLOC { allocCount = allocCount + 1 }
	}
	if allocCount < 2 { return fail(bootstrap.Concat("expected >=2 allocs for shadowed vars, got ", bootstrap.Itoa(allocCount))) }
	return ""
}

func TestGenPrintBoolExpr() testing.TestResult {
	// println(3 > 2) should use bn_print_bool, not bn_print_int
	var m @Module = genFromSource("package \"test\"\nfunc main() { println(3 > 2) }\n")
	var entry @Block = m.Funcs[0].Blocks[0]
	var foundPrintBool bool = false
	for i := 0; i < len(entry.Instrs); i++ {
		if entry.Instrs[i].Op == OP_CALL_BUILTIN {
			if seq(entry.Instrs[i].StrVal, "bn_print_bool") {
				foundPrintBool = true
			}
		}
	}
	if !foundPrintBool { return fail("comparison result should be printed with bn_print_bool") }
	return ""
}

// ============================================================
// Helper: find an instruction by op across all blocks in a func
// ============================================================

func findOp(fn @Func, op int) @Instr {
	for i := 0; i < len(fn.Blocks); i++ {
		var b @Block = fn.Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			if b.Instrs[j].Op == op {
				return b.Instrs[j]
			}
		}
	}
	return nil
}

func countOp(fn @Func, op int) int {
	var n int = 0
	for i := 0; i < len(fn.Blocks); i++ {
		var b @Block = fn.Blocks[i]
		for j := 0; j < len(b.Instrs); j++ {
			if b.Instrs[j].Op == op {
				n = n + 1
			}
		}
	}
	return n
}

// ============================================================
// Self-referential struct registration
// ============================================================

func TestGenSelfRefStruct() testing.TestResult {
	// A struct type that references itself via managed pointer
	var src []char = "package \"test\"\ntype Node struct {\n\tval int\n\tnext @Node\n}\nfunc main() {\n\tvar n @Node = make(Node)\n\tn.val = 42\n}\n"
	var m @Module = genFromSource(src)
	// Should have at least one function (main)
	if len(m.Funcs) == 0 { return fail("expected at least 1 func") }
	// main should have an OP_MAKE instruction
	var makeInstr @Instr = findOp(m.Funcs[0], OP_MAKE)
	if makeInstr == nil { return fail("expected OP_MAKE in main") }
	// The TypeArg should be a struct type with 2 fields
	if makeInstr.TypeArg == nil { return fail("OP_MAKE should have TypeArg") }
	if makeInstr.TypeArg.Kind != types.TYP_STRUCT { return fail("TypeArg should be struct") }
	if len(makeInstr.TypeArg.Fields) != 2 { return fail(bootstrap.Concat("expected 2 fields, got ", bootstrap.Itoa(len(makeInstr.TypeArg.Fields)))) }
	// Second field should be a managed pointer
	var f2 @types.Type = makeInstr.TypeArg.Fields[1].Type
	if f2 == nil { return fail("field 2 type is nil") }
	if f2.Kind != types.TYP_MANAGED_PTR { return fail("field 2 should be managed ptr") }
	return ""
}

func TestGenSelfRefStructFieldAccess() testing.TestResult {
	// Accessing fields on a self-referential struct
	var src []char = "package \"test\"\ntype Node struct {\n\tval int\n\tnext @Node\n}\nfunc main() {\n\tvar n @Node = make(Node)\n\tn.val = 42\n\tprintln(n.val)\n}\n"
	var m @Module = genFromSource(src)
	// Should have GET_FIELD_PTR instructions for field access
	var gfp int = countOp(m.Funcs[0], OP_GET_FIELD_PTR)
	if gfp < 2 { return fail(bootstrap.Concat("expected >=2 GET_FIELD_PTR, got ", bootstrap.Itoa(gfp))) }
	return ""
}

// ============================================================
// String-to-chars conversion for selector assignment
// ============================================================

func TestGenStringToCharsOnFieldAssign() testing.TestResult {
	// Assigning a string literal to a []char field should emit STRING_TO_CHARS
	var src []char = "package \"test\"\ntype Buf struct {\n\tname []char\n}\nfunc main() {\n\tvar b Buf\n\tb.name = \"hello\"\n}\n"
	var m @Module = genFromSource(src)
	var stc @Instr = findOp(m.Funcs[0], OP_STRING_TO_CHARS)
	if stc == nil { return fail("expected STRING_TO_CHARS for string-to-slice field assignment") }
	return ""
}

// ============================================================
// Struct with slice field — slice operations through struct
// ============================================================

func TestGenStructWithSliceField() testing.TestResult {
	// Struct with a slice field — append and len should work
	var src []char = "package \"test\"\ntype Buf struct {\n\tdata []int\n}\nfunc main() {\n\tvar b Buf\n\tb.data = append(b.data, 1)\n\tprintln(len(b.data))\n}\n"
	var m @Module = genFromSource(src)
	// Should generate APPEND and SLICE_LEN ops
	var appendInstr @Instr = findOp(m.Funcs[0], OP_APPEND)
	if appendInstr == nil { return fail("expected OP_APPEND for slice append through struct") }
	var lenInstr @Instr = findOp(m.Funcs[0], OP_SLICE_LEN)
	if lenInstr == nil { return fail("expected OP_SLICE_LEN for len through struct field") }
	return ""
}

// ============================================================
// Refcount insertion for managed pointer params and locals
// ============================================================

func TestGenRefcountOnManagedParam() testing.TestResult {
	// Function taking a managed pointer should inc on entry, dec on exit
	var src []char = "package \"test\"\ntype Node struct { val int }\nfunc use(n @Node) int {\n\treturn n.val\n}\nfunc main() {\n\tvar n @Node = make(Node)\n\tprintln(use(n))\n}\n"
	var m @Module = genFromSource(src)
	// Find the 'use' function
	var useFn @Func = nil
	for i := 0; i < len(m.Funcs); i++ {
		if seq(m.Funcs[i].Name, "use") {
			useFn = m.Funcs[i]
		}
	}
	if useFn == nil { return fail("expected 'use' function") }
	// Should have REFCOUNT_INC (param entry) and REFCOUNT_DEC (before return)
	var incCount int = countOp(useFn, OP_REFCOUNT_INC)
	var decCount int = countOp(useFn, OP_REFCOUNT_DEC)
	if incCount < 1 { return fail("expected REFCOUNT_INC for managed ptr param") }
	if decCount < 1 { return fail("expected REFCOUNT_DEC before return") }
	return ""
}

// ============================================================
// Multi-package IR gen tests
// ============================================================

func TestInitModule() testing.TestResult {
	var m @Module = InitModule("\"pkg/helper\"")
	if m == nil { return fail("InitModule returned nil") }
	if !seq(m.Name, "\"pkg/helper\"") { return fail("wrong module name") }
	return ""
}

func TestRegisterImportFunc() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	// Parse a .bni-like source with a function declaration
	var src []char = "package \"pkg/helper\"\nfunc Add(a int, b int) int\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "test.bni")
	var file @ast.File = parser.ParseFile(p)

	RegisterImport("helper", file, m)

	// The module should have an extern function
	if m.Funcs == nil || len(m.Funcs) == 0 {
		return fail("expected extern function in module")
	}
	var f @Func = m.Funcs[0]
	if !seq(f.Name, "helper.Add") { return fail("expected qualified name helper.Add") }
	if !f.IsExtern { return fail("expected extern function") }
	if len(f.Params) != 2 { return fail("expected 2 params") }
	if len(f.Results) != 1 { return fail("expected 1 result") }
	return ""
}

func TestRegisterImportStruct() testing.TestResult {
	var m @Module = InitModule("\"main\"")

	var src []char = "package \"pkg/geom\"\ntype Point struct {\n\tX int\n\tY int\n}\n"
	var p @parser.Parser = parser.NewInterface(strToBytes(src), "test.bni")
	var file @ast.File = parser.ParseFile(p)

	RegisterImport("geom", file, m)

	// The struct type should be registered with qualified name
	var si int = lookupStructIdx("geom.Point")
	if si < 0 { return fail("expected struct geom.Point registered") }
	if moduleStructs[si].Fields == nil || len(moduleStructs[si].Fields) != 2 {
		return fail("expected 2 fields")
	}
	return ""
}

func TestRegisterImportConst() testing.TestResult {
