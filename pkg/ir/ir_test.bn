// ============================================================
// TestCallSelectorManaged — genSelector handles call().Field on @Struct result
// ============================================================

func TestCallSelectorManaged() testing.TestResult {
	var src []char = "package \"main\"\ntype Inner struct { Val int }\nfunc getInner() @Inner {\n\tvar x @Inner = make(Inner)\n\tx.Val = 42\n\treturn x\n}\nfunc main() {\n\tvar n int = getInner().Val\n\tprintln(n)\n}\n"
	var m @Module = genFromSource(src)
	// Find the main function
	var mainFn @Func = nil
	for i := 0; i < len(m.Funcs); i++ {
		if seq(m.Funcs[i].Name, "main") {
			mainFn = m.Funcs[i]
		}
	}
	if mainFn == nil { return fail("main func not found") }
	// Should have a CALL instruction for getInner()
	var callInstr @Instr = findOp(mainFn, OP_CALL)
	if callInstr == nil { return fail("expected OP_CALL for getInner()") }
	// Should have a GET_FIELD_PTR to access .Val
	var gfp @Instr = findOp(mainFn, OP_GET_FIELD_PTR)
	if gfp == nil { return fail("expected OP_GET_FIELD_PTR for .Val access") }
	return ""
}

// ============================================================
// Destructor generation tests
// ============================================================

func TestDtorGeneratedForStructWithManagedField() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Node struct { Val int\n Next @Node }\n")
	src = concatChars(src, "func main() { var n @Node = make(Node) }\n")
	var m @Module = genFromSource(src)
	var dtorFn @Func = findFunc(m, "__dtor_Node")
	if dtorFn == nil { return fail("expected __dtor_Node function") }
	// Dtor should have 1 parameter (ptr *uint8)
	if len(dtorFn.Params) != 1 { return fail("dtor should have 1 param") }
	// Dtor should contain OP_REFCOUNT_DEC for the @Node field
	var decCount int = countOp(dtorFn, OP_REFCOUNT_DEC)
	if decCount < 1 { return fail("dtor should have at least 1 OP_REFCOUNT_DEC") }
	// Dtor should contain OP_BIT_CAST (ptr → *Node)
	var castCount int = countOp(dtorFn, OP_BIT_CAST)
	if castCount < 1 { return fail("dtor should have OP_BIT_CAST") }
	return ""
}

func TestDtorNotGeneratedForPlainStruct() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Point struct { X int\n Y int }\n")
	src = concatChars(src, "func main() { }\n")
	var m @Module = genFromSource(src)
	var dtorFn @Func = findFunc(m, "__dtor_Point")
	if dtorFn != nil { return fail("plain struct should not have a dtor") }
	return ""
}

func TestDtorForStructWithManagedSlice() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Container struct { Items @[]int }\n")
	src = concatChars(src, "func main() { }\n")
	var m @Module = genFromSource(src)
	var dtorFn @Func = findFunc(m, "__dtor_Container")
	if dtorFn == nil { return fail("expected __dtor_Container function") }
	// Should have OP_REFCOUNT_DEC for the managed-slice backing
	var decCount int = countOp(dtorFn, OP_REFCOUNT_DEC)
	if decCount < 1 { return fail("dtor should RefDec the managed-slice backing") }
	return ""
}

func TestDtorSelfRefPassesDtor() testing.TestResult {
	// A struct with @Node field should pass __dtor_Node as dtor arg
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Node struct { Val int\n Next @Node }\n")
	src = concatChars(src, "func main() { }\n")
	var m @Module = genFromSource(src)
	var dtorFn @Func = findFunc(m, "__dtor_Node")
	if dtorFn == nil { return fail("expected __dtor_Node") }
	// Should have OP_FUNC_ADDR to reference its own dtor
	var addrCount int = countOp(dtorFn, OP_FUNC_ADDR)
	if addrCount < 1 { return fail("expected OP_FUNC_ADDR for self-referential dtor") }
	return ""
}

func TestTempSliceParamNotConsumed() testing.TestResult {
	// When @[]T is passed as []T param, the temp should NOT be consumed —
	// it stays in the cleanup list and gets RefDec'd at end of statement.
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "func foo(s []int) int { return s[0] }\n")
	src = concatChars(src, "func main() {\n")
	src = concatChars(src, "  var x int = foo(make_slice(int, 3))\n")
	src = concatChars(src, "  println(x)\n")
	src = concatChars(src, "}\n")
	var m @Module = genFromSource(src)
	var mainFn @Func = findFunc(m, "main")
	if mainFn == nil { return fail("no main func") }
	// Should have OP_REFCOUNT_DEC for the temp managed-slice
	var decCount int = countOp(mainFn, OP_REFCOUNT_DEC)
	if decCount < 1 { return fail("expected OP_REFCOUNT_DEC for temp managed-slice (was being leaked)") }
	return ""
}

func TestArrayDtorGenerated() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Node struct { Val int }\n")
	src = concatChars(src, "type Container struct { Items [3]@Node }\n")
	src = concatChars(src, "func main() { }\n")
	var m @Module = genFromSource(src)
	// Should generate __dtor_arr3_mp_Node
	var dtorFn @Func = findFunc(m, "__dtor_arr3_mp_Node")
	if dtorFn == nil { return fail("expected __dtor_arr3_mp_Node function") }
	// Should have a loop (OP_LT comparison)
	var cmpCount int = countOp(dtorFn, OP_LT)
	if cmpCount < 1 { return fail("array dtor should have loop condition") }
	return ""
}

func TestArrayDtorNotGeneratedForPlainElems() testing.TestResult {
	var src []char
	src = concatChars(src, "package \"main\"\n")
	src = concatChars(src, "type Foo struct { Vals [5]int }\n")
	src = concatChars(src, "func main() { }\n")
	var m @Module = genFromSource(src)
	// [5]int doesn't need destruction — no dtor should be generated
	var dtorFn @Func = findFunc(m, "__dtor_Foo")
	if dtorFn != nil { return fail("Foo with [5]int should not need a dtor") }
	return ""
}
