	var arrTyp @types.Type = types.MakeArrayType(types.TypInt(), 5)
	var ptr @Instr = EmitAlloc(f, b, arrTyp)
	var idx @Instr = EmitConstInt(f, b, 2, types.TypInt())
	var ep @Instr = EmitGetElemPtr(f, b, ptr, idx, types.TypInt())
	if ep.Op != OP_GET_ELEM_PTR { return fail("op wrong") }
	if len(ep.Args) != 2 { return fail("expected 2 args") }
	return ""
}

