// Tests RegisterImports (plural) with iota const groups — the DECL_GROUP code path.
// This was a bug: registerImportFieldsAndFuncs didn't handle DECL_GROUP,
// so iota constants from imported packages all resolved to 0.
// ============================================================
// Additional instruction emission tests
// ============================================================

func TestEmitGetElemPtr() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var arrTyp @types.Type = types.MakeArrayType(types.TypInt(), 5)
	var ptr @Instr = EmitAlloc(f, b, arrTyp)
	var idx @Instr = EmitConstInt(f, b, 2, types.TypInt())
	var ep @Instr = EmitGetElemPtr(f, b, ptr, idx, types.TypInt())
	if ep.Op != OP_GET_ELEM_PTR { return fail("op wrong") }
	if len(ep.Args) != 2 { return fail("expected 2 args") }
	return ""
}

func TestEmitMakeRawSliceDeprecated() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var length @Instr = EmitConstInt(f, b, 10, types.TypInt())
	var sl @Instr = EmitMakeRawSliceDeprecated(f, b, types.TypInt(), length)
	if sl.Op != OP_MAKE_RAW_SLICE_DEPRECATED { return fail("op wrong") }
	if len(sl.Args) != 1 { return fail("expected 1 arg (length)") }
	if sl.TypeArg == nil { return fail("TypeArg should not be nil") }
	return ""
}

func TestEmitMakeSlice() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var length @Instr = EmitConstInt(f, b, 5, types.TypInt())
	var ms @Instr = EmitMakeSlice(f, b, types.TypInt(), length)
	if ms.Op != OP_MAKE_SLICE { return fail("op wrong") }
	if len(ms.Args) != 1 { return fail("expected 1 arg (length)") }
	if ms.TypeArg == nil { return fail("TypeArg should not be nil") }
	if ms.Typ == nil { return fail("Typ should not be nil") }
	if ms.Typ.Kind != types.TYP_MANAGED_SLICE { return fail("result type should be managed-slice") }
	return ""
}

func TestEmitDeref() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var ptr @Instr = EmitAlloc(f, b, types.TypInt())
	var derefed @Instr = EmitDeref(f, b, ptr, types.TypInt())
	if derefed.Op != OP_DEREF { return fail("op wrong") }
	if len(derefed.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

func TestEmitNilCheck() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var ptrTyp @types.Type = types.MakePointerType(types.TypInt())
	var ptr @Instr = EmitConstNil(f, b, ptrTyp)
	EmitNilCheck(b, ptr)
	// NilCheck is void, so ID should be -1
	var nc @Instr = b.Instrs[1]
	if nc.Op != OP_NIL_CHECK { return fail("op wrong") }
	if nc.ID != -1 { return fail("nil_check should be void") }
	if len(nc.Args) != 1 { return fail("expected 1 arg") }
	return ""
}

func TestAddTypeDef() testing.TestResult {
	var m @Module = NewModule("test")
	var td @TypeDef = make(TypeDef)
	td.Name = "MyStruct"
	td.Typ = types.TypInt()
	AddTypeDef(m, td)
	if len(m.Types) != 1 { return fail("expected 1 type def") }
	if !seq(m.Types[0].Name, "MyStruct") { return fail("name wrong") }
	return ""
}

// ============================================================
// Gen-level test: switch statement
// ============================================================

func charsEqual(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func concatChars(a []char, b []char) []char {
	var cb buf.CharBuf = buf.New()
	cb = buf.WriteStr(cb, a)
	cb = buf.WriteStr(cb, b)
	return buf.Bytes(cb)
}

