func TestEmitStructLit() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var structTyp @types.Type = types.TypInt() // placeholder
	var f1 @Instr = EmitConstInt(f, b, 10, types.TypInt())
	var f2 @Instr = EmitConstInt(f, b, 20, types.TypInt())
	var fields []@Instr
	fields = append(fields, f1)
	fields = append(fields, f2)
	var lit @Instr = EmitStructLit(f, b, fields, structTyp)
	if lit.Op != OP_STRUCT_LIT { return fail("op wrong") }
	if len(lit.Args) != 2 { return fail("expected 2 fields") }
	return ""
}

func TestEmitExtract() testing.TestResult {
	var f @Func = NewFunc("test", nil, nil)
	var b @Block = AddBlock(f, "entry")
	var multi @Instr = EmitCall(f, b, "multi_ret", nil, types.TypInt())
	var extracted @Instr = EmitExtract(f, b, multi, 0, types.TypInt())
	if extracted.Op != OP_EXTRACT { return fail("op wrong") }
	if extracted.Index != 0 { return fail("index wrong") }
	return ""
}

// ============================================================
// Integration: build a small function
// ============================================================

func TestBuildAddFunc() testing.TestResult {
	// Build: func add(a int, b int) int { return a + b }
	var f @Func = NewFunc("add", nil, nil)
	var pa @Param = NewParam(f, "a", types.TypInt())
	var pb @Param = NewParam(f, "b", types.TypInt())
	var params []@Param
	params = append(params, pa)
	params = append(params, pb)
	f.Params = params
	var results []@types.Type
	results = append(results, types.TypInt())
	f.Results = results

	var entry @Block = AddBlock(f, "entry")

	// Alloca approach: allocate slots for params, store, then load
	var aPtr @Instr = EmitAlloc(f, entry, types.TypInt())
	var bPtr @Instr = EmitAlloc(f, entry, types.TypInt())

	// Store params (using const as stand-in since we can't reference params as Instr)
	var aVal @Instr = EmitConstInt(f, entry, 0, types.TypInt()) // placeholder
	var bVal @Instr = EmitConstInt(f, entry, 0, types.TypInt()) // placeholder
	EmitStore(entry, aPtr, aVal)
	EmitStore(entry, bPtr, bVal)

	// Load and add
	var a @Instr = EmitLoad(f, entry, aPtr, types.TypInt())
	var b_ @Instr = EmitLoad(f, entry, bPtr, types.TypInt())
	var sum @Instr = EmitBinop(f, entry, OP_ADD, a, b_, types.TypInt())

	// Return
	var retArgs []@Instr
	retArgs = append(retArgs, sum)
	EmitReturn(entry, retArgs)

	// Verify structure
	if len(f.Blocks) != 1 { return fail("expected 1 block") }
	// 2 allocs + 2 consts + 2 stores + 2 loads + 1 add + 1 return = 10
	if len(entry.Instrs) != 10 { return fail(bootstrap.Concat("expected 10 instrs, got ", bootstrap.Itoa(len(entry.Instrs)))) }
	// Last instr should be return (terminator)
	if !IsTerminator(entry.Instrs[len(entry.Instrs)-1]) { return fail("last instr should be terminator") }

	return ""
}

func TestBuildIfElse() testing.TestResult {
	// Build: func f(x int) int { if x > 0 { return 1 } else { return 0 } }
	var f @Func = NewFunc("f", nil, nil)

	var entry @Block = AddBlock(f, "entry")
	var thenBlk @Block = AddBlock(f, "if.then")
	var elseBlk @Block = AddBlock(f, "if.else")

	// Condition
	var x @Instr = EmitConstInt(f, entry, 5, types.TypInt())
	var zero @Instr = EmitConstInt(f, entry, 0, types.TypInt())
	var cond @Instr = EmitBinop(f, entry, OP_GT, x, zero, types.TypBool())
	EmitBranch(entry, cond, thenBlk, elseBlk)

	// Then
	var one @Instr = EmitConstInt(f, thenBlk, 1, types.TypInt())
	var retOne []@Instr
	retOne = append(retOne, one)
	EmitReturn(thenBlk, retOne)

	// Else
	var z @Instr = EmitConstInt(f, elseBlk, 0, types.TypInt())
	var retZ []@Instr
	retZ = append(retZ, z)
	EmitReturn(elseBlk, retZ)

	if len(f.Blocks) != 3 { return fail("expected 3 blocks") }
	if !IsTerminator(entry.Instrs[len(entry.Instrs)-1]) { return fail("entry not terminated") }
	if !IsTerminator(thenBlk.Instrs[len(thenBlk.Instrs)-1]) { return fail("then not terminated") }
	if !IsTerminator(elseBlk.Instrs[len(elseBlk.Instrs)-1]) { return fail("else not terminated") }
	return ""
}
