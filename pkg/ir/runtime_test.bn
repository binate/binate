package "pkg/ir"

import "pkg/builtin/testing"

// ============================================================
// RuntimeFuncs tests
// ============================================================

func TestRuntimeFuncsCount() testing.TestResult {
	var funcs @[]RuntimeFunc = RuntimeFuncs()
	if len(funcs) != 12 {
		return fail("expected 12 runtime funcs")
	}
	return ""
}

func TestRuntimeFuncsFirstIsPrintString() testing.TestResult {
	var funcs @[]RuntimeFunc = RuntimeFuncs()
	if !charsEqual(funcs[0].Name, "bn_print_string") {
		return fail("first should be bn_print_string")
	}
	if len(funcs[0].ParamKinds) != 2 {
		return fail("expected 2 params")
	}
	if funcs[0].RetKind != RT_VOID {
		return fail("expected void return")
	}
	return ""
}

func TestRuntimeFuncsSliceGetInlineable() testing.TestResult {
	var funcs @[]RuntimeFunc = RuntimeFuncs()
	// bn_slice_expr_i8 is at index 8 (after removal of get/set functions)
	if !charsEqual(funcs[8].Name, "bn_slice_expr_i8") {
		return fail("expected bn_slice_expr_i8 at index 8")
	}
	if !funcs[8].Inlineable {
		return fail("slice_expr_i8 should be inlineable")
	}
	return ""
}

func TestRuntimeFuncsMakeSlice() testing.TestResult {
	var funcs @[]RuntimeFunc = RuntimeFuncs()
	// bn_make_slice is at index 6
	if !charsEqual(funcs[6].Name, "bn_make_slice") {
		return fail("expected bn_make_slice at index 6")
	}
	if funcs[6].RetKind != RT_SLICE {
		return fail("expected slice return")
	}
	if funcs[6].Inlineable {
		return fail("make_slice should not be inlineable")
	}
	return ""
}

