package "pkg/ir"

import "pkg/types"
import "pkg/builtin/testing"

// Tests for slices.bn: per-type append helpers.

func TestAppendInstrPtr() testing.TestResult {
	var s @[]@Instr
	var instr @Instr = make(Instr)
	instr.Op = OP_ADD
	s = appendInstrPtr(s, instr)
	if len(s) != 1 { return fail("expected 1 element") }
	if s[0].Op != OP_ADD { return fail("wrong op") }
	s = appendInstrPtr(s, instr)
	if len(s) != 2 { return fail("expected 2 elements") }
	return ""
}

func TestAppendBlockPtr() testing.TestResult {
	var s @[]@Block
	var b @Block = make(Block)
	s = appendBlockPtr(s, b)
	if len(s) != 1 { return fail("expected 1 element") }
	return ""
}
