package "pkg/ir"

import "pkg/types"
import "pkg/builtin/testing"

// ============================================================
// CollectStrings / FindStringID tests
// ============================================================

func TestCollectStringsEmpty() testing.TestResult {
	var m @Module = NewModule("test")
	var strings @[]StringConst = CollectStrings(m)
	if len(strings) != 0 {
		return fail("expected 0 strings from empty module")
	}
	return ""
}

func TestCollectStringsSingle() testing.TestResult {
	var m @Module = NewModule("test")
	var f @Func = NewFunc("foo", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	EmitConstString(f, b, "hello")
	AddFunc(m, f)
	var strings @[]StringConst = CollectStrings(m)
	if len(strings) != 1 {
		return fail("expected 1 string")
	}
	if !charsEqual(strings[0].Data, "hello") {
		return fail("expected hello")
	}
	if strings[0].Len != 5 {
		return fail("expected len 5")
	}
	return ""
}

func TestCollectStringsDeduplicate() testing.TestResult {
	var m @Module = NewModule("test")
	var f @Func = NewFunc("foo", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	EmitConstString(f, b, "hello")
	EmitConstString(f, b, "world")
	EmitConstString(f, b, "hello")
	AddFunc(m, f)
	var strings @[]StringConst = CollectStrings(m)
	if len(strings) != 2 {
		return fail("expected 2 deduplicated strings")
	}
	return ""
}

func TestFindStringIDFound() testing.TestResult {
	var m @Module = NewModule("test")
	var f @Func = NewFunc("foo", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	EmitConstString(f, b, "alpha")
	EmitConstString(f, b, "beta")
	AddFunc(m, f)
	var strings @[]StringConst = CollectStrings(m)
	var id int = FindStringID(strings, "beta")
	if id != 1 {
		return fail("expected id 1 for beta")
	}
	return ""
}

func TestFindStringIDNotFound() testing.TestResult {
	var m @Module = NewModule("test")
	var f @Func = NewFunc("foo", noParams, noResults)
	var b @Block = AddBlock(f, "entry")
	EmitConstString(f, b, "alpha")
	AddFunc(m, f)
	var strings @[]StringConst = CollectStrings(m)
	var id int = FindStringID(strings, "missing")
	if id != -1 {
		return fail("expected -1 for missing string")
	}
	return ""
}
