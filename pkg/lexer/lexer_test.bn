package "pkg/lexer"

import "pkg/token"
import "pkg/builtin/testing"
import "pkg/bootstrap"

// streq compares two char slices.
func streq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

// toBytes converts a string literal ([]char) to []uint8 for the lexer.
func toBytes(s []char) []uint8 {
	var b @[]uint8 = make_slice(uint8, len(s))
	for i := 0; i < len(s); i++ {
		b[i] = cast(uint8, s[i])
	}
	return b
}

// checkTok verifies a single token's type and literal.
// Returns a failure message or "".
func checkTok(got token.Token, wantTyp token.Type, wantLit []char, idx int) testing.TestResult {
	if got.Typ != wantTyp {
		return bootstrap.Concat("token ", bootstrap.Concat(bootstrap.Itoa(idx),
			bootstrap.Concat(": want type ", bootstrap.Concat(token.TypeName(wantTyp),
			bootstrap.Concat(", got ", bootstrap.Concat(token.TypeName(got.Typ),
			bootstrap.Concat(" (lit=", bootstrap.Concat(got.Lit, ")"))))))))
	}
	if !streq(got.Lit, wantLit) {
		return bootstrap.Concat("token ", bootstrap.Concat(bootstrap.Itoa(idx),
			bootstrap.Concat(": want lit '", bootstrap.Concat(wantLit,
			bootstrap.Concat("', got '", bootstrap.Concat(got.Lit, "'"))))))
	}
	return ""
}

// Tests

func TestIdentifiersAndKeywords() testing.TestResult {
	var l @Lexer = New(toBytes("foo bar break const func if return struct type var"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "foo", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "bar", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.BREAK, "break", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CONST, "const", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.FUNC, "func", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IF, "if", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RETURN, "return", 6); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.STRUCT, "struct", 7); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.TYPE, "type", 8); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.VAR, "var", 9); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 10); if len(r) > 0 { return r }
	return ""
}

func TestBuiltinKeywords() testing.TestResult {
	var l @Lexer = New(toBytes("make box cast bit_cast len"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.MAKE, "make", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.BOX, "box", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CAST, "cast", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.BIT_CAST, "bit_cast", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LEN, "len", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 5); if len(r) > 0 { return r }
	return ""
}

func TestOperators() testing.TestResult {
	var l @Lexer = New(toBytes("+ - * / % & | ^ ~ << >> == != < > <= >= && || ! = := += -= *= /= %= &= |= ^= <<= >>= ++ --"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.PLUS, "+", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.MINUS, "-", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.STAR, "*", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SLASH, "/", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.PERCENT, "%", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.AMP, "&", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.PIPE, "|", 6); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CARET, "^", 7); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.TILDE, "~", 8); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SHL, "<<", 9); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SHR, ">>", 10); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EQ, "==", 11); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.NEQ, "!=", 12); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LT, "<", 13); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.GT, ">", 14); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LEQ, "<=", 15); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.GEQ, ">=", 16); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LAND, "&&", 17); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LOR, "||", 18); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.NOT, "!", 19); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.ASSIGN, "=", 20); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.DEFINE, ":=", 21); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.ADD_ASSIGN, "+=", 22); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SUB_ASSIGN, "-=", 23); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.MUL_ASSIGN, "*=", 24); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.QUO_ASSIGN, "/=", 25); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.REM_ASSIGN, "%=", 26); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.AND_ASSIGN, "&=", 27); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.OR_ASSIGN, "|=", 28); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.XOR_ASSIGN, "^=", 29); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SHL_ASSIGN, "<<=", 30); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SHR_ASSIGN, ">>=", 31); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INC, "++", 32); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.DEC, "--", 33); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 34); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 35); if len(r) > 0 { return r }
	return ""
}

func TestPunctuation() testing.TestResult {
	var l @Lexer = New(toBytes(". , ; : @ # ( ) [ ] { } ..."), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.DOT, ".", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.COMMA, ",", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, ";", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.COLON, ":", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.AT, "@", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.HASH, "#", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LPAREN, "(", 6); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RPAREN, ")", 7); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LBRACKET, "[", 8); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RBRACKET, "]", 9); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LBRACE, "{", 10); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RBRACE, "}", 11); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.ELLIPSIS, "...", 12); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 13); if len(r) > 0 { return r }
	return ""
}

func TestASIBasic() testing.TestResult {
	var l @Lexer = New(toBytes("x\ny"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "y", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

func TestASIAfterClosingDelimiters() testing.TestResult {
	var l @Lexer = New(toBytes(")\n]\n}"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.RPAREN, ")", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RBRACKET, "]", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RBRACE, "}", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 6); if len(r) > 0 { return r }
	return ""
}

func TestNoASIAfterOperators() testing.TestResult {
	var l @Lexer = New(toBytes("x +\ny"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.PLUS, "+", 1); if len(r) > 0 { return r }
	// No ASI after +
	r = checkTok(Next(l), token.IDENT, "y", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

func TestNoASIAfterOpeningDelimiters() testing.TestResult {
	var l @Lexer = New(toBytes("(\n[\n{"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.LPAREN, "(", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LBRACKET, "[", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LBRACE, "{", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 3); if len(r) > 0 { return r }
	return ""
}

func TestFuncDecl() testing.TestResult {
	var l @Lexer = New(toBytes("func add(a int, b int) int {\n\treturn a + b\n}"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.FUNC, "func", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "add", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LPAREN, "(", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "a", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "int", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.COMMA, ",", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "b", 6); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "int", 7); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RPAREN, ")", 8); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "int", 9); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.LBRACE, "{", 10); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RETURN, "return", 11); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "a", 12); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.PLUS, "+", 13); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "b", 14); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 15); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RBRACE, "}", 16); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 17); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 18); if len(r) > 0 { return r }
	return ""
}

func TestEmptyInput() testing.TestResult {
	var l @Lexer = New(toBytes(""), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.EOF, "", 0); if len(r) > 0 { return r }
	return ""
}

func TestPositionTracking() testing.TestResult {
	var l @Lexer = New(toBytes("x\ny\nz"), "test.bn")
	var tok token.Token

	tok = Next(l) // x
	if tok.Pos.Line != 1 || tok.Pos.Col != 1 {
		return bootstrap.Concat("token 1: want 1:1, got ", bootstrap.Concat(bootstrap.Itoa(tok.Pos.Line), bootstrap.Concat(":", bootstrap.Itoa(tok.Pos.Col))))
	}

	Next(l) // semicolon

	tok = Next(l) // y
	if tok.Pos.Line != 2 || tok.Pos.Col != 1 {
		return bootstrap.Concat("token 2: want 2:1, got ", bootstrap.Concat(bootstrap.Itoa(tok.Pos.Line), bootstrap.Concat(":", bootstrap.Itoa(tok.Pos.Col))))
	}

	Next(l) // semicolon

	tok = Next(l) // z
	if tok.Pos.Line != 3 || tok.Pos.Col != 1 {
		return bootstrap.Concat("token 3: want 3:1, got ", bootstrap.Concat(bootstrap.Itoa(tok.Pos.Line), bootstrap.Concat(":", bootstrap.Itoa(tok.Pos.Col))))
	}

	return ""
}

func TestShortVarDecl() testing.TestResult {
	var l @Lexer = New(toBytes("x := 42"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.DEFINE, ":=", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INT, "42", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

func TestManagedPointerSyntax() testing.TestResult {
	var l @Lexer = New(toBytes("@Point"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.AT, "@", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "Point", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 3); if len(r) > 0 { return r }
	return ""
}

// ============================================================
// ASI Edge Cases
// ============================================================

func TestASIAfterLiterals() testing.TestResult {
	// String, char, and int literals should trigger ASI
	var l @Lexer = New(toBytes("42\n\"s\"\n'x'"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.INT, "42", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.STRING, "\"s\"", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CHAR, "'x'", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 6); if len(r) > 0 { return r }
	return ""
}

func TestMultiTokenExpression() testing.TestResult {
	// Complex multi-line expression: no ASI in the middle
	var l @Lexer = New(toBytes("a + b *\nc"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "a", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.PLUS, "+", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "b", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.STAR, "*", 3); if len(r) > 0 { return r }
	// No ASI after *, so 'c' follows
	r = checkTok(Next(l), token.IDENT, "c", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 6); if len(r) > 0 { return r }
	return ""
}

func TestASIAfterKeywords() testing.TestResult {
	// break, continue, return trigger ASI
	var l @Lexer = New(toBytes("break\ncontinue\nreturn"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.BREAK, "break", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CONTINUE, "continue", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.RETURN, "return", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 6); if len(r) > 0 { return r }
	return ""
}

func TestPositionMultiline() testing.TestResult {
	// Track positions across multiple lines with varying content
	var l @Lexer = New(toBytes("ab\n  cd\nef"), "test.bn")
	var tok token.Token

	tok = Next(l) // ab at 1:1
	if tok.Pos.Line != 1 || tok.Pos.Col != 1 {
		return "ab: wrong position"
	}
	Next(l) // semicolon

	tok = Next(l) // cd at 2:3
	if tok.Pos.Line != 2 || tok.Pos.Col != 3 {
		return bootstrap.Concat("cd: want 2:3, got ", bootstrap.Concat(bootstrap.Itoa(tok.Pos.Line), bootstrap.Concat(":", bootstrap.Itoa(tok.Pos.Col))))
	}
	Next(l) // semicolon

	tok = Next(l) // ef at 3:1
	if tok.Pos.Line != 3 || tok.Pos.Col != 1 {
		return "ef: wrong position"
	}
	return ""
}
