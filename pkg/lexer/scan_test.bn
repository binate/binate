package "pkg/lexer"

import "pkg/token"
import "pkg/builtin/testing"

// ============================================================
// Number Scanning Tests
// ============================================================

func TestIntegerLiterals() testing.TestResult {
	var l @Lexer = New(toBytes("0 42 100 0xFF 0o77 0b1010"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.INT, "0", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INT, "42", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INT, "100", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INT, "0xFF", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INT, "0o77", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.INT, "0b1010", 5); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 6); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 7); if len(r) > 0 { return r }
	return ""
}

// ============================================================
// Comment Tests
// ============================================================

func TestLineComment() testing.TestResult {
	var l @Lexer = New(toBytes("x // comment\ny"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "y", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

func TestBlockComment() testing.TestResult {
	var l @Lexer = New(toBytes("x /* comment */ y"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "y", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 3); if len(r) > 0 { return r }
	return ""
}

func TestBlockCommentWithNewline() testing.TestResult {
	var l @Lexer = New(toBytes("x /* block\ncomment */ y"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "y", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

func TestCommentWithASI() testing.TestResult {
	// A line comment after an ASI-triggering token should still insert semicolon
	var l @Lexer = New(toBytes("x // comment\ny"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.IDENT, "x", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.IDENT, "y", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

// ============================================================
// String and Char Literal Tests
// ============================================================

func TestStringLiteral() testing.TestResult {
	var l @Lexer = New(toBytes("\"hello world\""), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.STRING, "\"hello world\"", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 2); if len(r) > 0 { return r }
	return ""
}

func TestStringLiteralEscapes() testing.TestResult {
	var l @Lexer = New(toBytes("\"a\\nb\\tc\\\\d\\\"e\""), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.STRING, "\"a\\nb\\tc\\\\d\\\"e\"", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 2); if len(r) > 0 { return r }
	return ""
}

func TestEmptyStringLiteral() testing.TestResult {
	var l @Lexer = New(toBytes("\"\""), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.STRING, "\"\"", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 2); if len(r) > 0 { return r }
	return ""
}

func TestCharLiteral() testing.TestResult {
	var l @Lexer = New(toBytes("'A' 'z' '0'"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.CHAR, "'A'", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CHAR, "'z'", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CHAR, "'0'", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 4); if len(r) > 0 { return r }
	return ""
}

func TestCharLiteralEscapes() testing.TestResult {
	var l @Lexer = New(toBytes("'\\n' '\\t' '\\\\' '\\''"), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.CHAR, "'\\n'", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CHAR, "'\\t'", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CHAR, "'\\\\'", 2); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.CHAR, "'\\''", 3); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 4); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 5); if len(r) > 0 { return r }
	return ""
}

func TestStringWithEmbeddedQuote() testing.TestResult {
	var l @Lexer = New(toBytes("\"he said \\\"hi\\\"\""), "")
	var r testing.TestResult
	r = checkTok(Next(l), token.STRING, "\"he said \\\"hi\\\"\"", 0); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.SEMICOLON, "\n", 1); if len(r) > 0 { return r }
	r = checkTok(Next(l), token.EOF, "", 2); if len(r) > 0 { return r }
	return ""
}
