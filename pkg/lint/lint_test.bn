package "pkg/lint"

import "pkg/ast"
import "pkg/types"
import "pkg/parser"
import "pkg/bootstrap"
import "pkg/buf"
import "pkg/builtin/testing"

// ============================================================
// Test Helpers
// ============================================================

func toBytes(s []char) @[]uint8 {
	var b @[]uint8 = make_slice(uint8, len(s))
	for i := 0; i < len(s); i++ {
		b[i] = cast(uint8, s[i])
	}
	return b
}

func fail(msg @[]char) testing.TestResult {
	return msg
}

// lintSrc parses, type-checks, and lints a source string.
// Returns the lint Result.
func lintSrc(src []char) @Result {
	var p @parser.Parser = parser.New(toBytes(src), "test.bn")
	var file @ast.File = parser.ParseFile(p)
	var c @types.Checker = types.NewChecker()
	types.Check(c, file)
	return LintFile(c, file)
}

func expectDiag(r @Result, rule []char) testing.TestResult {
	for i := 0; i < r.NumDiags; i++ {
		if charEq(r.Diags[i].Rule, rule) {
			return ""
		}
	}
	var cb buf.CharBuf = buf.New()
	cb = buf.WriteStr(cb, "expected diagnostic '")
	cb = buf.WriteStr(cb, rule)
	cb = buf.WriteStr(cb, "' but got ")
	cb = buf.WriteStr(cb, bootstrap.Itoa(r.NumDiags))
	cb = buf.WriteStr(cb, " diagnostics")
	return buf.Bytes(cb)
}

func expectNoDiag(r @Result, rule []char) testing.TestResult {
	for i := 0; i < r.NumDiags; i++ {
		if charEq(r.Diags[i].Rule, rule) {
			var cb buf.CharBuf = buf.New()
			cb = buf.WriteStr(cb, "unexpected diagnostic '")
			cb = buf.WriteStr(cb, rule)
			cb = buf.WriteStr(cb, "': ")
			cb = buf.WriteStr(cb, r.Diags[i].Message)
			return buf.Bytes(cb)
		}
	}
	return ""
}

func charEq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

// ============================================================
// managed-to-raw-assign: var decl
// ============================================================

func TestManagedToRawVarDecl() testing.TestResult {
	var src []char = "package \"test\"\nfunc foo() { var ms @[]int = make_slice(int, 10); var s []int = ms; _ = s }"
	var r @Result = lintSrc(src)
	return expectDiag(r, "managed-to-raw-assign")
}

func TestManagedToRawVarDeclNeg() testing.TestResult {
	// Assigning raw to raw — no warning
	var src []char = "package \"test\"\nfunc foo(s []int) { var s2 []int = s; _ = s2 }"
	var r @Result = lintSrc(src)
	return expectNoDiag(r, "managed-to-raw-assign")
}

func TestManagedToRawVarDeclManagedToManaged() testing.TestResult {
	// Assigning managed to managed — no warning
	var src []char = "package \"test\"\nfunc foo() { var ms @[]int = make_slice(int, 10); var ms2 @[]int = ms; _ = ms2 }"
	var r @Result = lintSrc(src)
	return expectNoDiag(r, "managed-to-raw-assign")
}

// ============================================================
// managed-to-raw-assign: assignment
// ============================================================

func TestManagedToRawAssign() testing.TestResult {
	var src []char = "package \"test\"\nfunc foo() { var ms @[]int = make_slice(int, 10); var s []int; s = ms; _ = s }"
	var r @Result = lintSrc(src)
	return expectDiag(r, "managed-to-raw-assign")
}

func TestManagedToRawAssignNeg() testing.TestResult {
	// Raw to raw assignment — no warning
	var src []char = "package \"test\"\nfunc foo(a []int) { var b []int; b = a; _ = b }"
	var r @Result = lintSrc(src)
	return expectNoDiag(r, "managed-to-raw-assign")
}

// ============================================================
// managed-to-raw-assign: function return value
// ============================================================

func TestManagedToRawFromCall() testing.TestResult {
	var src []char = "package \"test\"\nfunc bar() @[]int { return make_slice(int, 5) }\nfunc foo() { var s []int = bar(); _ = s }"
	var r @Result = lintSrc(src)
	return expectDiag(r, "managed-to-raw-assign")
}

// ============================================================
// No false positives for unrelated code
// ============================================================

func TestCleanCode() testing.TestResult {
	var src []char = "package \"test\"\nfunc foo() int { var x int = 42; return x }"
	var r @Result = lintSrc(src)
	if r.NumDiags != 0 {
		return "expected no diagnostics for clean code"
	}
	return ""
}
