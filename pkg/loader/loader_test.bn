package "pkg/loader"

import "pkg/ast"
import "pkg/builtin/testing"

// ============================================================
// Helpers
// ============================================================

func seq(a []char, b []char) bool {
	if a == nil && b == nil { return true }
	if a == nil || b == nil { return false }
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

func fail(msg []char) testing.TestResult {
	return msg
}

// ============================================================
// streq tests
// ============================================================

func TestStreqEqual() testing.TestResult {
	if !streq("hello", "hello") { return fail("equal strings should match") }
	return ""
}

func TestStreqDifferent() testing.TestResult {
	if streq("hello", "world") { return fail("different strings should not match") }
	return ""
}

func TestStreqDifferentLength() testing.TestResult {
	if streq("hi", "hello") { return fail("different length strings should not match") }
	return ""
}

func TestStreqEmpty() testing.TestResult {
	if !streq("", "") { return fail("empty strings should match") }
	return ""
}

func TestStreqNilNil() testing.TestResult {
	var a []char
	var b []char
	if !streq(a, b) { return fail("nil/nil should match") }
	return ""
}

func TestStreqNilNonNil() testing.TestResult {
	var a []char
	if streq(a, "hello") { return fail("nil vs non-nil should not match") }
	if streq("hello", a) { return fail("non-nil vs nil should not match") }
	return ""
}

// ============================================================
// pathJoin string building tests (replaces appendStr tests)
// ============================================================

func TestPathJoinBuild() testing.TestResult {
	var r []char = pathJoin("hello", "world")
	if !seq(r, "hello/world") { return fail("pathJoin build wrong") }
	return ""
}

// ============================================================
// hasSuffix tests
// ============================================================

func TestHasSuffixMatch() testing.TestResult {
	if !hasSuffix("hello.bn", ".bn") { return fail("should match .bn suffix") }
	return ""
}

func TestHasSuffixNoMatch() testing.TestResult {
	if hasSuffix("hello.go", ".bn") { return fail("should not match .bn suffix") }
	return ""
}

func TestHasSuffixEmpty() testing.TestResult {
	if !hasSuffix("anything", "") { return fail("empty suffix should always match") }
	return ""
}

func TestHasSuffixTooLong() testing.TestResult {
	if hasSuffix("hi", "hello") { return fail("suffix longer than string should not match") }
	return ""
}

// ============================================================
// pathJoin tests
// ============================================================

func TestPathJoin() testing.TestResult {
	var r []char = pathJoin("foo", "bar")
	if !seq(r, "foo/bar") { return fail("pathJoin should join with /") }
	return ""
}

func TestPathJoinNested() testing.TestResult {
	var r []char = pathJoin("a/b", "c.bn")
	if !seq(r, "a/b/c.bn") { return fail("pathJoin nested wrong") }
	return ""
}

// ============================================================
// unquote tests
// ============================================================

func TestUnquoteQuoted() testing.TestResult {
	var r []char = unquote("\"pkg/ast\"")
	if !seq(r, "pkg/ast") { return fail("unquote should strip quotes") }
	return ""
}

func TestUnquoteUnquoted() testing.TestResult {
	var r []char = unquote("plain")
	if !seq(r, "plain") { return fail("unquote should pass through unquoted") }
	return ""
}

func TestUnquoteEmpty() testing.TestResult {
	var r []char = unquote("")
	if !seq(r, "") { return fail("unquote empty should return empty") }
	return ""
}

func TestUnquoteEmptyQuoted() testing.TestResult {
	var r []char = unquote("\"\"")
	if len(r) != 0 { return fail("unquote empty quotes should return empty") }
	return ""
}

// ============================================================
// containsStr tests
// ============================================================

func TestContainsStrFound() testing.TestResult {
	var ss [][]char
	ss = appendCharSlice(ss,"alpha")
	ss = appendCharSlice(ss,"beta")
	ss = appendCharSlice(ss,"gamma")
	if !containsStr(ss, "beta") { return fail("should find beta") }
	return ""
}

func TestContainsStrNotFound() testing.TestResult {
	var ss [][]char
	ss = appendCharSlice(ss,"alpha")
	ss = appendCharSlice(ss,"beta")
	if containsStr(ss, "gamma") { return fail("should not find gamma") }
	return ""
}

func TestContainsStrNil() testing.TestResult {
	var ss [][]char
	if containsStr(ss, "anything") { return fail("nil slice should not contain anything") }
	return ""
}

// ============================================================
// sortStrings tests
// ============================================================

func TestSortStrings() testing.TestResult {
	var ss [][]char
	ss = appendCharSlice(ss,"cherry")
	ss = appendCharSlice(ss,"apple")
	ss = appendCharSlice(ss,"banana")
	sortStrings(ss)
	if !seq(ss[0], "apple") { return fail("first should be apple") }
	if !seq(ss[1], "banana") { return fail("second should be banana") }
	if !seq(ss[2], "cherry") { return fail("third should be cherry") }
	return ""
}

func TestSortStringsSingle() testing.TestResult {
	var ss [][]char
	ss = appendCharSlice(ss,"only")
	sortStrings(ss)
	if !seq(ss[0], "only") { return fail("single element sort wrong") }
	return ""
}

// ============================================================
// strLess tests
// ============================================================

func TestStrLessTrue() testing.TestResult {
	if !strLess("apple", "banana") { return fail("apple < banana") }
	return ""
}

func TestStrLessFalse() testing.TestResult {
	if strLess("banana", "apple") { return fail("banana not < apple") }
	return ""
}

func TestStrLessEqual() testing.TestResult {
	if strLess("same", "same") { return fail("equal strings not less") }
	return ""
}

func TestStrLessPrefix() testing.TestResult {
	if !strLess("ab", "abc") { return fail("ab < abc") }
	if strLess("abc", "ab") { return fail("abc not < ab") }
	return ""
}

// ============================================================
// MergeFiles tests
// ============================================================

func TestMergeFilesSingle() testing.TestResult {
	var f @ast.File = make(ast.File)
	f.PkgName = "mypkg"

	var imp @ast.ImportSpec = make(ast.ImportSpec)
	imp.Path = "\"pkg/foo\""
	f.Imports = appendImportSpec(f.Imports, imp)

	var d @ast.Decl = make(ast.Decl)
	d.Kind = ast.DECL_FUNC
	d.Name = "MyFunc"
	f.Decls = appendDeclPtr(f.Decls, d)

	var files []@ast.File
	files = appendFilePtr(files, f)
	var merged @ast.File = MergeFiles(files)

	if merged == nil { return fail("merged should not be nil") }
	if !seq(merged.PkgName, "mypkg") { return fail("PkgName wrong") }
	if len(merged.Imports) != 1 { return fail("should have 1 import") }
	if !seq(merged.Imports[0].Path, "\"pkg/foo\"") { return fail("import path wrong") }
	if len(merged.Decls) != 1 { return fail("should have 1 decl") }
	if !seq(merged.Decls[0].Name, "MyFunc") { return fail("decl name wrong") }
	return ""
}

func TestMergeFilesMultiple() testing.TestResult {
	var f1 @ast.File = make(ast.File)
	f1.PkgName = "mypkg"

	var imp1 @ast.ImportSpec = make(ast.ImportSpec)
	imp1.Path = "\"pkg/foo\""
	f1.Imports = appendImportSpec(f1.Imports,imp1)

	var d1 @ast.Decl = make(ast.Decl)
	d1.Kind = ast.DECL_FUNC
	d1.Name = "Func1"
	f1.Decls = appendDeclPtr(f1.Decls,d1)

	var f2 @ast.File = make(ast.File)
	f2.PkgName = "mypkg"

	// Overlapping import — same path
	var imp2 @ast.ImportSpec = make(ast.ImportSpec)
	imp2.Path = "\"pkg/foo\""
	f2.Imports = appendImportSpec(f2.Imports,imp2)

	// Unique import
	var imp3 @ast.ImportSpec = make(ast.ImportSpec)
	imp3.Path = "\"pkg/bar\""
	f2.Imports = appendImportSpec(f2.Imports,imp3)

	var d2 @ast.Decl = make(ast.Decl)
	d2.Kind = ast.DECL_VAR
	d2.Name = "Var2"
	f2.Decls = appendDeclPtr(f2.Decls,d2)

	var files []@ast.File
	files = appendFilePtr(files, f1)
	files = appendFilePtr(files, f2)
	var merged @ast.File = MergeFiles(files)

	if merged == nil { return fail("merged should not be nil") }
	if !seq(merged.PkgName, "mypkg") { return fail("PkgName wrong") }

	// Imports should be deduplicated: pkg/foo once + pkg/bar
	if len(merged.Imports) != 2 { return fail("should have 2 imports after dedup") }
	if !seq(merged.Imports[0].Path, "\"pkg/foo\"") { return fail("first import wrong") }
	if !seq(merged.Imports[1].Path, "\"pkg/bar\"") { return fail("second import wrong") }

	// Decls should be concatenated
	if len(merged.Decls) != 2 { return fail("should have 2 decls") }
	if !seq(merged.Decls[0].Name, "Func1") { return fail("first decl wrong") }
	if !seq(merged.Decls[1].Name, "Var2") { return fail("second decl wrong") }
	return ""
}

// ============================================================
// NewLoader tests
// ============================================================

func TestNewLoader() testing.TestResult {
	var l @Loader = NewLoader("/my/root")
	if l == nil { return fail("loader should not be nil") }
	if !seq(l.Root, "/my/root") { return fail("Root wrong") }
	if len(l.Packages) != 0 { return fail("Packages should be empty") }
	if len(l.Order) != 0 { return fail("Order should be empty") }
	if len(l.Errors) != 0 { return fail("Errors should be empty") }
	return ""
}

// ============================================================
// RegisterBuiltin / GetPackage tests
// ============================================================

func TestRegisterBuiltin() testing.TestResult {
	var l @Loader = NewLoader("/root")
	RegisterBuiltin(l, "pkg/bootstrap")

	var pkg @Package = GetPackage(l, "pkg/bootstrap")
	if pkg == nil { return fail("should find registered builtin") }
	if !seq(pkg.Path, "pkg/bootstrap") { return fail("path wrong") }
	if !pkg.Builtin { return fail("should be marked builtin") }
	return ""
}

func TestGetPackageNotFound() testing.TestResult {
	var l @Loader = NewLoader("/root")
	var pkg @Package = GetPackage(l, "nonexistent")
	if pkg != nil { return fail("should return nil for missing package") }
	return ""
}
