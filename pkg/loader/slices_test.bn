package "pkg/loader"

import "pkg/ast"
import "pkg/buf"
import "pkg/builtin/testing"

func TestAppendCharSlice() testing.TestResult {
	var s @[]@[]char
	s = appendCharSlice(s, buf.CopyStr("one"))
	s = appendCharSlice(s, buf.CopyStr("two"))
	if len(s) != 2 { return fail("expected len 2") }
	return ""
}

func TestAppendPackagePtr() testing.TestResult {
	var s @[]@Package
	var p @Package = make(Package)
	s = appendPackagePtr(s, p)
	if len(s) != 1 { return fail("expected len 1") }
	return ""
}

func TestAppendDeclPtr() testing.TestResult {
	var s @[]@ast.Decl
	var d @ast.Decl = make(ast.Decl)
	s = appendDeclPtr(s, d)
	s = appendDeclPtr(s, d)
	if len(s) != 2 { return fail("expected len 2") }
	return ""
}

func TestAppendImportSpec() testing.TestResult {
	var s @[]@ast.ImportSpec
	var imp @ast.ImportSpec = make(ast.ImportSpec)
	s = appendImportSpec(s, imp)
	if len(s) != 1 { return fail("expected len 1") }
	return ""
}
