package "pkg/mangle"

import "pkg/buf"
import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult {
	return msg
}

func bufStr(cb buf.CharBuf) @[]char {
	return buf.Bytes(cb)
}

func strEq(a []char, b []char) bool {
	if len(a) != len(b) { return false }
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] { return false }
	}
	return true
}

// ============================================================
// PkgShortName
// ============================================================

func TestPkgShortNameSimple() testing.TestResult {
	var s []char = PkgShortName("main")
	if !strEq(s, "main") { return fail("expected main") }
	return ""
}

func TestPkgShortNameSlash() testing.TestResult {
	var s []char = PkgShortName("pkg/parser")
	if !strEq(s, "parser") { return fail("expected parser") }
	return ""
}

func TestPkgShortNameDeep() testing.TestResult {
	var s []char = PkgShortName("pkg/asm/aarch64")
	if !strEq(s, "aarch64") { return fail("expected aarch64") }
	return ""
}

// ============================================================
// FuncName
// ============================================================

func TestFuncNameLocal() testing.TestResult {
	var b buf.CharBuf = FuncName("parser", "parseExpr")
	var s @[]char = bufStr(b)
	if !strEq(s, "bn_parser__parseExpr") {
		return fail("expected bn_parser__parseExpr")
	}
	return ""
}

func TestFuncNameMain() testing.TestResult {
	var b buf.CharBuf = FuncName("main", "main")
	var s @[]char = bufStr(b)
	if !strEq(s, "bn_main") {
		return fail("expected bn_main")
	}
	return ""
}

func TestFuncNameCrossPkg() testing.TestResult {
	var b buf.CharBuf = FuncName("main", "parser.New")
	var s @[]char = bufStr(b)
	if !strEq(s, "bn_parser__New") {
		return fail("expected bn_parser__New")
	}
	return ""
}

// ============================================================
// GlobalName
// ============================================================

func TestGlobalName() testing.TestResult {
	var b buf.CharBuf = GlobalName("ir", "moduleStructs")
	var s @[]char = bufStr(b)
	if !strEq(s, "bn_ir__moduleStructs") {
		return fail("expected bn_ir__moduleStructs")
	}
	return ""
}

// ============================================================
// StructName
// ============================================================

func TestStructNameLocal() testing.TestResult {
	var b buf.CharBuf = StructName("ir", "Instr")
	var s @[]char = bufStr(b)
	if !strEq(s, "bn_ir__Instr") {
		return fail("expected bn_ir__Instr")
	}
	return ""
}

func TestStructNameCrossPkg() testing.TestResult {
	var b buf.CharBuf = StructName("main", "parser.Parser")
	var s @[]char = bufStr(b)
	if !strEq(s, "bn_parser__Parser") {
		return fail("expected bn_parser__Parser")
	}
	return ""
}
