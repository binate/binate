package "pkg/parser"

import "pkg/token"
import "pkg/ast"
import "pkg/builtin/testing"

// ============================================================
// Statement Tests
// ============================================================
func TestParseReturnStmt() testing.TestResult {
	var p @Parser = mkParser("return 42")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_RETURN {
		return fail("TestParseReturnStmt", "expected STMT_RETURN")
	}
	if len(s.Exprs) != 1 {
		return fail("TestParseReturnStmt", "expected 1 result")
	}
	return ""
}

func TestParseBreakStmt() testing.TestResult {
	var p @Parser = mkParser("break")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_BREAK {
		return fail("TestParseBreakStmt", "expected STMT_BREAK")
	}
	return ""
}

func TestParseContinueStmt() testing.TestResult {
	var p @Parser = mkParser("continue")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_CONTINUE {
		return fail("TestParseContinueStmt", "expected STMT_CONTINUE")
	}
	return ""
}

func TestParseIfStmt() testing.TestResult {
	var p @Parser = mkParser("if x > 0 { return 1 }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_IF {
		return fail("TestParseIfStmt", "expected STMT_IF")
	}
	if s.X == nil {
		return fail("TestParseIfStmt", "expected condition")
	}
	if s.Body == nil {
		return fail("TestParseIfStmt", "expected body")
	}
	return ""
}

func TestParseIfElseStmt() testing.TestResult {
	var p @Parser = mkParser("if x { y() } else { z() }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_IF {
		return fail("TestParseIfElseStmt", "expected STMT_IF")
	}
	if s.Else == nil {
		return fail("TestParseIfElseStmt", "expected else branch")
	}
	return ""
}

func TestParseForCStyle() testing.TestResult {
	var p @Parser = mkParser("for i := 0; i < 10; i++ { x() }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_FOR {
		return fail("TestParseForCStyle", "expected STMT_FOR")
	}
	if s.Init == nil {
		return fail("TestParseForCStyle", "expected init")
	}
	if s.X == nil {
		return fail("TestParseForCStyle", "expected cond")
	}
	if s.Post == nil {
		return fail("TestParseForCStyle", "expected post")
	}
	return ""
}

func TestParseForIn() testing.TestResult {
	var p @Parser = mkParser("for x in items { f(x) }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_FOR {
		return fail("TestParseForIn", "expected STMT_FOR")
	}
	if s.ForVal == nil {
		return fail("TestParseForIn", "expected ForVal")
	}
	if s.X == nil {
		return fail("TestParseForIn", "expected iter expr")
	}
	return ""
}

func TestParseForKeyVal() testing.TestResult {
	var p @Parser = mkParser("for i, v in items { f(i, v) }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_FOR {
		return fail("TestParseForKeyVal", "expected STMT_FOR")
	}
	if s.ForKey == nil {
		return fail("TestParseForKeyVal", "expected ForKey")
	}
	if s.ForVal == nil {
		return fail("TestParseForKeyVal", "expected ForVal")
	}
	return ""
}

func TestParseInfiniteFor() testing.TestResult {
	var p @Parser = mkParser("for { break }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_FOR {
		return fail("TestParseInfiniteFor", "expected STMT_FOR")
	}
	if s.X != nil {
		return fail("TestParseInfiniteFor", "expected nil cond")
	}
	if s.Init != nil {
		return fail("TestParseInfiniteFor", "expected nil init")
	}
	return ""
}

func TestParseSwitchStmt() testing.TestResult {
	var p @Parser = mkParser("switch x { case 1: y() case 2, 3: z() default: w() }")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_SWITCH {
		return fail("TestParseSwitchStmt", "expected STMT_SWITCH")
	}
	if len(s.Cases) != 3 {
		return fail("TestParseSwitchStmt", "expected 3 cases")
	}
	// Check multi-value case
	if len(s.Cases[1].Exprs) != 2 {
		return fail("TestParseSwitchStmt", "expected 2 exprs in case 2")
	}
	return ""
}

func TestParseAssignStmt() testing.TestResult {
	var p @Parser = mkParser("x = 5")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_ASSIGN {
		return fail("TestParseAssignStmt", "expected STMT_ASSIGN")
	}
	if s.Op != cast(int, token.ASSIGN) {
		return fail("TestParseAssignStmt", "expected ASSIGN op")
	}
	return ""
}

func TestParseShortVarDecl() testing.TestResult {
	var p @Parser = mkParser("x := 5")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_SHORT_VAR {
		return fail("TestParseShortVarDecl", "expected STMT_SHORT_VAR")
	}
	return ""
}

func TestParseIncDec() testing.TestResult {
	var p @Parser = mkParser("i++")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_INC_DEC {
		return fail("TestParseIncDec", "expected STMT_INC_DEC")
	}
	if s.Op != cast(int, token.INC) {
		return fail("TestParseIncDec", "expected INC")
	}
	return ""
}
