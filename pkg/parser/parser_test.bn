func TestParseLenCall() testing.TestResult {
	var p @Parser = mkParser("len(x)")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_BUILTIN {
		return fail("TestParseLenCall", "expected EXPR_BUILTIN")
	}
	if e.Op != cast(int, token.LEN) {
		return fail("TestParseLenCall", "expected LEN op")
	}
	if len(e.Args) != 1 {
		return fail("TestParseLenCall", "expected 1 arg")
	}
	return ""
}

func TestParseCastCall() testing.TestResult {
	var p @Parser = mkParser("cast(int, x)")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_BUILTIN {
		return fail("TestParseCastCall", "expected EXPR_BUILTIN")
	}
	if e.Op != cast(int, token.CAST) {
		return fail("TestParseCastCall", "expected CAST op")
	}
	if e.TypeRef == nil {
		return fail("TestParseCastCall", "expected TypeRef")
	}
	return ""
}

