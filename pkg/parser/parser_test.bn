package "pkg/parser"

import "pkg/token"
import "pkg/ast"
import "pkg/builtin/testing"

// Helper to create a parser from a string
func mkParser(src []char) @Parser {
	var bytes []uint8
	for i := 0; i < len(src); i++ {
		bytes = append(bytes, cast(uint8, src[i]))
	}
	return New(bytes, "test.bn")
}

// Helper to build a failure message with context
func fail(msg []char, detail []char) testing.TestResult {
	var r []char
	r = appendStr(r, msg)
	r = appendStr(r, ": ")
	r = appendStr(r, detail)
	return r
}

func appendStr(dst []char, src []char) []char {
	for i := 0; i < len(src); i++ {
		dst = append(dst, src[i])
	}
	return dst
}

// charEq compares two []char for equality.
func charEq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

// ============================================================
// Expression Tests
// ============================================================

func TestParseIntLit() testing.TestResult {
	var p @Parser = mkParser("42")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_INT_LIT {
		return fail("TestParseIntLit", "expected EXPR_INT_LIT")
	}
	if !charEq(e.Name, "42") {
		return fail("TestParseIntLit", "expected '42'")
	}
	return ""
}

func TestParseStringLit() testing.TestResult {
	var p @Parser = mkParser("\"hello\"")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_STRING_LIT {
		return fail("TestParseStringLit", "expected EXPR_STRING_LIT")
	}
	return ""
}

func TestParseBoolLit() testing.TestResult {
	var p @Parser = mkParser("true")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_BOOL_LIT {
		return fail("TestParseBoolLit", "expected EXPR_BOOL_LIT")
	}
	if !e.BoolVal {
		return fail("TestParseBoolLit", "expected true")
	}
	return ""
}

func TestParseNilLit() testing.TestResult {
	var p @Parser = mkParser("nil")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_NIL_LIT {
		return fail("TestParseNilLit", "expected EXPR_NIL_LIT")
	}
	return ""
}

func TestParseIdent() testing.TestResult {
	var p @Parser = mkParser("foo")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_IDENT {
		return fail("TestParseIdent", "expected EXPR_IDENT")
	}
	if !charEq(e.Name, "foo") {
		return fail("TestParseIdent", "expected 'foo'")
	}
	return ""
}

func TestParseBinaryExpr() testing.TestResult {
	var p @Parser = mkParser("1 + 2")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_BINARY {
		return fail("TestParseBinaryExpr", "expected EXPR_BINARY")
	}
	if e.Op != cast(int, token.PLUS) {
		return fail("TestParseBinaryExpr", "expected PLUS op")
	}
	if e.X.Kind != ast.EXPR_INT_LIT {
		return fail("TestParseBinaryExpr", "expected X to be INT_LIT")
	}
	if e.Y.Kind != ast.EXPR_INT_LIT {
		return fail("TestParseBinaryExpr", "expected Y to be INT_LIT")
	}
	return ""
}

func TestParsePrecedence() testing.TestResult {
	// 1 + 2 * 3 should parse as 1 + (2 * 3)
	var p @Parser = mkParser("1 + 2 * 3")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_BINARY {
		return fail("TestParsePrecedence", "expected EXPR_BINARY at top")
	}
	if e.Op != cast(int, token.PLUS) {
		return fail("TestParsePrecedence", "expected PLUS at top")
	}
	if e.Y.Kind != ast.EXPR_BINARY {
		return fail("TestParsePrecedence", "expected BINARY on right")
	}
	if e.Y.Op != cast(int, token.STAR) {
		return fail("TestParsePrecedence", "expected STAR on right")
	}
	return ""
}

func TestParseUnary() testing.TestResult {
	var p @Parser = mkParser("-x")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_UNARY {
		return fail("TestParseUnary", "expected EXPR_UNARY")
	}
	if e.Op != cast(int, token.MINUS) {
		return fail("TestParseUnary", "expected MINUS op")
	}
	if e.X.Kind != ast.EXPR_IDENT {
		return fail("TestParseUnary", "expected IDENT operand")
	}
	return ""
}

func TestParseCallExpr() testing.TestResult {
	var p @Parser = mkParser("foo(1, 2)")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_CALL {
		return fail("TestParseCallExpr", "expected EXPR_CALL")
	}
	if e.X.Kind != ast.EXPR_IDENT {
		return fail("TestParseCallExpr", "expected IDENT callee")
	}
	if len(e.Args) != 2 {
		return fail("TestParseCallExpr", "expected 2 args")
	}
	return ""
}

func TestParseIndexExpr() testing.TestResult {
	var p @Parser = mkParser("arr[0]")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_INDEX {
		return fail("TestParseIndexExpr", "expected EXPR_INDEX")
	}
	if e.X.Kind != ast.EXPR_IDENT {
		return fail("TestParseIndexExpr", "expected IDENT base")
	}
	return ""
}

func TestParseSliceExpr() testing.TestResult {
	var p @Parser = mkParser("arr[1:3]")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_SLICE {
