package "pkg/parser"

import "pkg/token"
import "pkg/ast"
import "pkg/buf"
import "pkg/builtin/testing"

// Module-level source buffer — keeps the source alive while the parser borrows it.
var parserSrcBuf @[]uint8

// Helper to create a parser from a string.
// Stores the source in parserSrcBuf so the parser's borrow stays valid.
func mkParser(src []char) @Parser {
	parserSrcBuf = make_slice(uint8, len(src))
	for i := 0; i < len(src); i++ {
		parserSrcBuf[i] = cast(uint8, src[i])
	}
	return New(parserSrcBuf, "test.bn")
}

// Helper to build a failure message with context
func fail(msg []char, detail []char) testing.TestResult {
	var cb buf.CharBuf = buf.New()
	cb = buf.WriteStr(cb, msg)
	cb = buf.WriteStr(cb, ": ")
	cb = buf.WriteStr(cb, detail)
	var result @[]char = buf.Bytes(cb)
	return result
}

// charEq compares two []char for equality.
func charEq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

// ============================================================
// Type Tests
// ============================================================

func TestParseNamedType() testing.TestResult {
	var p @Parser = mkParser("int")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_NAMED {
		return fail("TestParseNamedType", "expected TEXPR_NAMED")
	}
	if !charEq(te.Name, "int") {
		return fail("TestParseNamedType", "expected 'int'")
	}
	return ""
}

func TestParseQualifiedType() testing.TestResult {
	var p @Parser = mkParser("token.Type")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_NAMED {
		return fail("TestParseQualifiedType", "expected TEXPR_NAMED")
	}
	if !charEq(te.Pkg, "token") {
		return fail("TestParseQualifiedType", "expected pkg 'token'")
	}
	if !charEq(te.Name, "Type") {
		return fail("TestParseQualifiedType", "expected name 'Type'")
	}
	return ""
}

func TestParsePointerType() testing.TestResult {
	var p @Parser = mkParser("*int")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_POINTER {
		return fail("TestParsePointerType", "expected TEXPR_POINTER")
	}
	if te.Base.Kind != ast.TEXPR_NAMED {
		return fail("TestParsePointerType", "expected NAMED base")
	}
	return ""
}

func TestParseSliceType() testing.TestResult {
	var p @Parser = mkParser("[]int")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_SLICE {
		return fail("TestParseSliceType", "expected TEXPR_SLICE")
	}
	return ""
}

func TestParseManagedPtrType() testing.TestResult {
	var p @Parser = mkParser("@Foo")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_MANAGED {
		return fail("TestParseManagedPtrType", "expected TEXPR_MANAGED")
	}
	return ""
}

func TestParseManagedSliceType() testing.TestResult {
	var p @Parser = mkParser("@[]int")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_MANAGED_SLICE {
		return fail("TestParseManagedSliceType", "expected TEXPR_MANAGED_SLICE")
	}
	return ""
}

func TestParseArrayType() testing.TestResult {
	var p @Parser = mkParser("[10]int")
	var te @ast.TypeExpr = parseType(p)
	if te.Kind != ast.TEXPR_ARRAY {
		return fail("TestParseArrayType", "expected TEXPR_ARRAY")
	}
	return ""
}



// ============================================================
// File Parsing Tests
// ============================================================

func TestParseImports() testing.TestResult {
	var src []char = "package \"test\"\nimport \"pkg/token\"\nimport \"pkg/ast\"\nfunc main() {}"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Imports) != 2 {
		return fail("TestParseImports", "expected 2 imports")
	}
	if !charEq(f.PkgName, "\"test\"") {
		return fail("TestParseImports", "expected pkg name '\"test\"'")
	}
	return ""
}

func TestParseNoErrors() testing.TestResult {
	var src []char = "package \"test\"\nimport \"pkg/token\"\nfunc foo(x int) int { return x + 1 }\nvar y int = 10"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	var errs @[]ParseError = Errors(p)
	if len(errs) != 0 {
		return fail("TestParseNoErrors", errs[0].Msg)
	}
	if len(f.Decls) != 2 {
		return fail("TestParseNoErrors", "expected 2 decls")
	}
	return ""
}

func TestParseCompositeLit() testing.TestResult {
	var p @Parser = mkParser("Foo{x: 1, y: 2}")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_COMPOSITE {
		return fail("TestParseCompositeLit", "expected EXPR_COMPOSITE")
	}
	if len(e.Elems) != 2 {
		return fail("TestParseCompositeLit", "expected 2 elements")
	}
	if e.Elems[0].Key == nil {
		return fail("TestParseCompositeLit", "expected key in element")
	}
	return ""
}

func TestParseMultiReturn() testing.TestResult {
	var src []char = "package \"test\"\nfunc divmod(a int, b int) (int, int) { return a / b, a % b }"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	var errs @[]ParseError = Errors(p)
	if len(errs) != 0 {
		return fail("TestParseMultiReturn", errs[0].Msg)
	}
	var d @ast.Decl = f.Decls[0]
	if len(d.Results) != 2 {
		return fail("TestParseMultiReturn", "expected 2 results")
	}
	return ""
}
