func TestParseIncDec() testing.TestResult {
	var p @Parser = mkParser("i++")
	var s @ast.Stmt = parseStmt(p)
	if s.Kind != ast.STMT_INC_DEC {
		return fail("TestParseIncDec", "expected STMT_INC_DEC")
