	return ""
}

// ============================================================
// Declaration Tests
// ============================================================

func TestParseVarDecl() testing.TestResult {
	var src []char = "package \"test\"\nvar x int = 5"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Decls) != 1 {
		return fail("TestParseVarDecl", "expected 1 decl")
	}
	var d @ast.Decl = f.Decls[0]
	if d.Kind != ast.DECL_VAR {
		return fail("TestParseVarDecl", "expected DECL_VAR")
	}
	if !charEq(d.Name, "x") {
		return fail("TestParseVarDecl", "expected name 'x'")
	}
	return ""
}

func TestParseFuncDecl() testing.TestResult {
	var src []char = "package \"test\"\nfunc add(a int, b int) int { return a + b }"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Decls) != 1 {
		return fail("TestParseFuncDecl", "expected 1 decl")
	}
	var d @ast.Decl = f.Decls[0]
	if d.Kind != ast.DECL_FUNC {
		return fail("TestParseFuncDecl", "expected DECL_FUNC")
	}
	if !charEq(d.Name, "add") {
		return fail("TestParseFuncDecl", "expected name 'add'")
	}
	if len(d.Params) != 2 {
		return fail("TestParseFuncDecl", "expected 2 params")
	}
	if len(d.Results) != 1 {
		return fail("TestParseFuncDecl", "expected 1 result")
	}
	return ""
}

func TestParseTypeDecl() testing.TestResult {
	var src []char = "package \"test\"\ntype Foo struct { x int; y int }"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Decls) != 1 {
		return fail("TestParseTypeDecl", "expected 1 decl")
	}
	var d @ast.Decl = f.Decls[0]
	if d.Kind != ast.DECL_TYPE {
		return fail("TestParseTypeDecl", "expected DECL_TYPE")
	}
	if !charEq(d.Name, "Foo") {
		return fail("TestParseTypeDecl", "expected name 'Foo'")
	}
	return ""
}

func TestParseTypeAlias() testing.TestResult {
	var src []char = "package \"test\"\ntype MyInt = int"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Decls) != 1 {
		return fail("TestParseTypeAlias", "expected 1 decl")
	}
	var d @ast.Decl = f.Decls[0]
	if d.Kind != ast.DECL_TYPE {
		return fail("TestParseTypeAlias", "expected DECL_TYPE")
	}
	if !d.IsAlias {
		return fail("TestParseTypeAlias", "expected IsAlias true")
	}
	return ""
}

func TestParseConstDecl() testing.TestResult {
	var src []char = "package \"test\"\nconst X int = 42"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Decls) != 1 {
		return fail("TestParseConstDecl", "expected 1 decl")
	}
	var d @ast.Decl = f.Decls[0]
	if d.Kind != ast.DECL_CONST {
		return fail("TestParseConstDecl", "expected DECL_CONST")
	}
	return ""
}

// ============================================================
// File Parsing Tests
// ============================================================

func TestParseImports() testing.TestResult {
	var src []char = "package \"test\"\nimport \"pkg/token\"\nimport \"pkg/ast\"\nfunc main() {}"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Imports) != 2 {
		return fail("TestParseImports", "expected 2 imports")
	}
	if !charEq(f.PkgName, "\"test\"") {
		return fail("TestParseImports", "expected pkg name '\"test\"'")
	}
	return ""
}

func TestParseGroupedConst() testing.TestResult {
	var src []char = "package \"test\"\nconst ( A int = 1; B int = 2; C int = 3 )"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	if len(f.Decls) != 1 {
		return fail("TestParseGroupedConst", "expected 1 decl (group)")
	}
	var d @ast.Decl = f.Decls[0]
	if d.Kind != ast.DECL_GROUP {
		return fail("TestParseGroupedConst", "expected DECL_GROUP")
	}
	if len(d.Decls) != 3 {
		return fail("TestParseGroupedConst", "expected 3 consts in group")
	}
	return ""
}

func TestParseNoErrors() testing.TestResult {
	var src []char = "package \"test\"\nimport \"pkg/token\"\nfunc foo(x int) int { return x + 1 }\nvar y int = 10"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	var errs []ParseError = Errors(p)
	if len(errs) != 0 {
		return fail("TestParseNoErrors", errs[0].Msg)
	}
	if len(f.Decls) != 2 {
		return fail("TestParseNoErrors", "expected 2 decls")
	}
	return ""
}

func TestParseCompositeLit() testing.TestResult {
	var p @Parser = mkParser("Foo{x: 1, y: 2}")
	var e @ast.Expr = parseExpr(p)
	if e.Kind != ast.EXPR_COMPOSITE {
		return fail("TestParseCompositeLit", "expected EXPR_COMPOSITE")
	}
	if len(e.Elems) != 2 {
		return fail("TestParseCompositeLit", "expected 2 elements")
	}
	if e.Elems[0].Key == nil {
		return fail("TestParseCompositeLit", "expected key in element")
	}
	return ""
}

func TestParseMultiReturn() testing.TestResult {
	var src []char = "package \"test\"\nfunc divmod(a int, b int) (int, int) { return a / b, a % b }"
	var p @Parser = mkParser(src)
	var f @ast.File = ParseFile(p)
	var errs []ParseError = Errors(p)
	if len(errs) != 0 {
		return fail("TestParseMultiReturn", errs[0].Msg)
	}
	var d @ast.Decl = f.Decls[0]
	if len(d.Results) != 2 {
		return fail("TestParseMultiReturn", "expected 2 results")
	}
	return ""
}
