package "pkg/parser"

import "pkg/ast"
import "pkg/builtin/testing"

func fail(msg []char) testing.TestResult { return msg }

func TestAppendParseError() testing.TestResult {
	var s @[]ParseError = nil
	var e ParseError
	e.Line = 1
	s = appendParseError(s, e)
	s = appendParseError(s, e)
	if len(s) != 2 { return fail("expected len 2") }
	if s[0].Line != 1 { return fail("expected line 1") }
	return ""
}

func TestAppendDecl() testing.TestResult {
	var s @[]@ast.Decl = nil
	var d @ast.Decl = make(ast.Decl)
	d.Kind = ast.DECL_VAR
	s = appendDecl(s, d)
	if len(s) != 1 { return fail("expected len 1") }
	if s[0].Kind != ast.DECL_VAR { return fail("expected DECL_VAR") }
	return ""
}

func TestAppendStmt() testing.TestResult {
	var s @[]@ast.Stmt = nil
	var st @ast.Stmt = make(ast.Stmt)
	s = appendStmt(s, st)
	s = appendStmt(s, st)
	s = appendStmt(s, st)
	if len(s) != 3 { return fail("expected len 3") }
	return ""
}

func TestAppendExpr() testing.TestResult {
	var s @[]@ast.Expr = nil
	var e @ast.Expr = make(ast.Expr)
	s = appendExpr(s, e)
	if len(s) != 1 { return fail("expected len 1") }
	return ""
}

