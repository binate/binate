// Tests for the Binate runtime (pkg/rt).
//
// These tests use bit_cast, pointer indexing, and C FFI — features that
// currently require compiled mode. Once the interpreter supports raw memory
// operations, these tests should pass in interpreted mode as well.
package "pkg/rt"

import "pkg/builtin/testing"

func fail(msg @[]char) testing.TestResult { return msg }

func TestAlloc() testing.TestResult {
	var p *any = Alloc(64)
	if p == nil { return fail("Alloc returned nil") }
	// Refcount should be 1 after allocation
	var ptr *uint8 = bit_cast(*uint8, p)
	if Refcount(ptr) != 1 { return fail("expected refcount 1") }
	Free(p)
	return ""
}

func TestRefIncDec() testing.TestResult {
	var p *any = Alloc(8)
	var ptr *uint8 = bit_cast(*uint8, p)
	if Refcount(ptr) != 1 { return fail("expected rc 1") }
	RefInc(p)
	if Refcount(ptr) != 2 { return fail("expected rc 2 after inc") }
	RefDec(p)
	if Refcount(ptr) != 1 { return fail("expected rc 1 after dec") }
	Free(p)
	return ""
}

func TestRefDecFrees() testing.TestResult {
	// RefDec to 0 should free — we can't verify free directly,
	// but we can verify it doesn't crash
	var p *any = Alloc(8)
	RefDec(p)
	// p is now freed — don't access it
	return ""
}

func TestRefcountNil() testing.TestResult {
	if Refcount(nil) != 0 { return fail("nil refcount should be 0") }
	return ""
}

func TestBox() testing.TestResult {
	var val int = 42
	var src *any = bit_cast(*any, &val)
	var boxed *any = Box(src, 8)
	if boxed == nil { return fail("Box returned nil") }
	var result *int = bit_cast(*int, boxed)
	if result[0] != 42 { return fail("boxed value should be 42") }
	var ptr *uint8 = bit_cast(*uint8, boxed)
	if Refcount(ptr) != 1 { return fail("boxed refcount should be 1") }
	Free(boxed)
	return ""
}

func TestMakeManagedSlice() testing.TestResult {
	var ms ManagedSlice = MakeManagedSlice(8, 4)
	if ms.Len != 4 { return fail("expected len 4") }
	if ms.Data == nil { return fail("data should not be nil") }
	if ms.Refptr == nil { return fail("refptr should not be nil") }
	var ptr *uint8 = bit_cast(*uint8, ms.Refptr)
	if Refcount(ptr) != 1 { return fail("backing refcount should be 1") }
	Free(ms.Refptr)
	return ""
}

func TestMakeManagedSliceZero() testing.TestResult {
	var ms ManagedSlice = MakeManagedSlice(8, 0)
	if ms.Len != 0 { return fail("expected len 0") }
	if ms.Data != nil { return fail("data should be nil for zero length") }
	if ms.Refptr != nil { return fail("refptr should be nil for zero length") }
	return ""
}

func TestBoundsCheck() testing.TestResult {
	// Valid indices should not panic
	BoundsCheck(0, 5)
	BoundsCheck(4, 5)
	// We can't test the failing case without catching panics
	return ""
}

func TestRefIncDecNil() testing.TestResult {
	// RefInc/RefDec on nil should be no-ops
	RefInc(nil)
	RefDec(nil)
	return ""
}
