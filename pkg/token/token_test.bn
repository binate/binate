package "pkg/token"

// Test helpers

func assert_streq(got []char, want []char, msg []char) {
	if !streq(got, want) {
		panic(bootstrap.Concat(msg, bootstrap.Concat(": got '", bootstrap.Concat(got, bootstrap.Concat("', want '", bootstrap.Concat(want, "'"))))))
	}
}

func assert_true(val bool, msg []char) {
	if !val {
		panic(bootstrap.Concat(msg, ": expected true"))
	}
}

func assert_false(val bool, msg []char) {
	if val {
		panic(bootstrap.Concat(msg, ": expected false"))
	}
}

func assert_type(got Type, want Type, msg []char) {
	if got != want {
		panic(bootstrap.Concat(msg, bootstrap.Concat(": got ", bootstrap.Concat(TypeName(got), bootstrap.Concat(", want ", TypeName(want))))))
	}
}

// Tests

func TestTypeName() {
	assert_streq(TypeName(ILLEGAL), "ILLEGAL", "ILLEGAL")
	assert_streq(TypeName(EOF), "EOF", "EOF")
	assert_streq(TypeName(SEMICOLON), ";", "SEMICOLON")
	assert_streq(TypeName(IDENT), "IDENT", "IDENT")
	assert_streq(TypeName(FUNC), "func", "FUNC")
	assert_streq(TypeName(RETURN), "return", "RETURN")
	assert_streq(TypeName(MAKE), "make", "MAKE")
	assert_streq(TypeName(PLUS), "+", "PLUS")
	assert_streq(TypeName(LBRACE), "{", "LBRACE")
	assert_streq(TypeName(ELLIPSIS), "...", "ELLIPSIS")
	assert_streq(TypeName(ASSIGN), "=", "ASSIGN")
	assert_streq(TypeName(DEFINE), ":=", "DEFINE")
}

func TestIsKeyword() {
	assert_true(IsKeyword(FUNC), "FUNC")
	assert_true(IsKeyword(RETURN), "RETURN")
	assert_true(IsKeyword(IF), "IF")
	assert_true(IsKeyword(FOR), "FOR")
	assert_true(IsKeyword(STRUCT), "STRUCT")
	assert_false(IsKeyword(PLUS), "PLUS")
	assert_false(IsKeyword(IDENT), "IDENT")
	assert_false(IsKeyword(MAKE), "MAKE")
	assert_false(IsKeyword(EOF), "EOF")
}

func TestIsBuiltin() {
	assert_true(IsBuiltin(MAKE), "MAKE")
	assert_true(IsBuiltin(LEN), "LEN")
	assert_true(IsBuiltin(BOX), "BOX")
	assert_true(IsBuiltin(CAST), "CAST")
	assert_true(IsBuiltin(BIT_CAST), "BIT_CAST")
	assert_false(IsBuiltin(FUNC), "FUNC")
	assert_false(IsBuiltin(PLUS), "PLUS")
	assert_false(IsBuiltin(IDENT), "IDENT")
}

func TestTriggersASI() {
	assert_true(TriggersASI(IDENT), "IDENT")
	assert_true(TriggersASI(INT), "INT")
	assert_true(TriggersASI(RBRACE), "RBRACE")
	assert_true(TriggersASI(RPAREN), "RPAREN")
	assert_true(TriggersASI(RETURN), "RETURN")
	assert_true(TriggersASI(BREAK), "BREAK")
	assert_true(TriggersASI(INC), "INC")
	assert_false(TriggersASI(PLUS), "PLUS")
	assert_false(TriggersASI(LBRACE), "LBRACE")
	assert_false(TriggersASI(FUNC), "FUNC")
	assert_false(TriggersASI(ASSIGN), "ASSIGN")
}

func TestLookup() {
	assert_type(Lookup("func"), FUNC, "func")
	assert_type(Lookup("return"), RETURN, "return")
	assert_type(Lookup("if"), IF, "if")
	assert_type(Lookup("make"), MAKE, "make")
	assert_type(Lookup("bit_cast"), BIT_CAST, "bit_cast")
	assert_type(Lookup("len"), LEN, "len")
	assert_type(Lookup("myVar"), IDENT, "myVar")
	assert_type(Lookup("x"), IDENT, "x")
	assert_type(Lookup(""), IDENT, "empty")
}

func TestPosString() {
	var p Pos
	p.File = "test.bn"
	p.Line = 42
	p.Col = 7
	assert_streq(PosString(p), "test.bn:42:7", "with file")

	var p2 Pos
	p2.Line = 10
	p2.Col = 3
	assert_streq(PosString(p2), "10:3", "without file")
}
