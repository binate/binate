package "pkg/token"

import "pkg/builtin/testing"

// Test helpers

func check_streq(got []char, want []char, msg []char) testing.TestResult {
	if !streq(got, want) {
		return bootstrap.Concat(msg, bootstrap.Concat(": got '", bootstrap.Concat(got, bootstrap.Concat("', want '", bootstrap.Concat(want, "'")))))
	}
	return ""
}

func check_true(val bool, msg []char) testing.TestResult {
	if !val {
		return bootstrap.Concat(msg, ": expected true")
	}
	return ""
}

func check_false(val bool, msg []char) testing.TestResult {
	if val {
		return bootstrap.Concat(msg, ": expected false")
	}
	return ""
}

func check_type(got Type, want Type, msg []char) testing.TestResult {
	if got != want {
		return bootstrap.Concat(msg, bootstrap.Concat(": got ", bootstrap.Concat(TypeName(got), bootstrap.Concat(", want ", TypeName(want)))))
	}
	return ""
}

// Tests

func TestTypeName() testing.TestResult {
	var r testing.TestResult
	r = check_streq(TypeName(ILLEGAL), "ILLEGAL", "ILLEGAL"); if len(r) > 0 { return r }
	r = check_streq(TypeName(EOF), "EOF", "EOF"); if len(r) > 0 { return r }
	r = check_streq(TypeName(SEMICOLON), ";", "SEMICOLON"); if len(r) > 0 { return r }
	r = check_streq(TypeName(IDENT), "IDENT", "IDENT"); if len(r) > 0 { return r }
	r = check_streq(TypeName(FUNC), "func", "FUNC"); if len(r) > 0 { return r }
	r = check_streq(TypeName(RETURN), "return", "RETURN"); if len(r) > 0 { return r }
	r = check_streq(TypeName(MAKE), "make", "MAKE"); if len(r) > 0 { return r }
	r = check_streq(TypeName(PLUS), "+", "PLUS"); if len(r) > 0 { return r }
	r = check_streq(TypeName(LBRACE), "{", "LBRACE"); if len(r) > 0 { return r }
	r = check_streq(TypeName(ELLIPSIS), "...", "ELLIPSIS"); if len(r) > 0 { return r }
	r = check_streq(TypeName(ASSIGN), "=", "ASSIGN"); if len(r) > 0 { return r }
	r = check_streq(TypeName(DEFINE), ":=", "DEFINE"); if len(r) > 0 { return r }
	return ""
}

func TestIsKeyword() testing.TestResult {
	var r testing.TestResult
	r = check_true(IsKeyword(FUNC), "FUNC"); if len(r) > 0 { return r }
	r = check_true(IsKeyword(RETURN), "RETURN"); if len(r) > 0 { return r }
	r = check_true(IsKeyword(IF), "IF"); if len(r) > 0 { return r }
	r = check_true(IsKeyword(FOR), "FOR"); if len(r) > 0 { return r }
	r = check_true(IsKeyword(STRUCT), "STRUCT"); if len(r) > 0 { return r }
	r = check_false(IsKeyword(PLUS), "PLUS"); if len(r) > 0 { return r }
	r = check_false(IsKeyword(IDENT), "IDENT"); if len(r) > 0 { return r }
	r = check_false(IsKeyword(MAKE), "MAKE"); if len(r) > 0 { return r }
	r = check_false(IsKeyword(EOF), "EOF"); if len(r) > 0 { return r }
	return ""
}

func TestIsBuiltin() testing.TestResult {
	var r testing.TestResult
	r = check_true(IsBuiltin(MAKE), "MAKE"); if len(r) > 0 { return r }
	r = check_true(IsBuiltin(LEN), "LEN"); if len(r) > 0 { return r }
	r = check_true(IsBuiltin(BOX), "BOX"); if len(r) > 0 { return r }
	r = check_true(IsBuiltin(CAST), "CAST"); if len(r) > 0 { return r }
	r = check_true(IsBuiltin(BIT_CAST), "BIT_CAST"); if len(r) > 0 { return r }
	r = check_false(IsBuiltin(FUNC), "FUNC"); if len(r) > 0 { return r }
	r = check_false(IsBuiltin(PLUS), "PLUS"); if len(r) > 0 { return r }
	r = check_false(IsBuiltin(IDENT), "IDENT"); if len(r) > 0 { return r }
	return ""
}

func TestTriggersASI() testing.TestResult {
	var r testing.TestResult
	r = check_true(TriggersASI(IDENT), "IDENT"); if len(r) > 0 { return r }
	r = check_true(TriggersASI(INT), "INT"); if len(r) > 0 { return r }
	r = check_true(TriggersASI(RBRACE), "RBRACE"); if len(r) > 0 { return r }
	r = check_true(TriggersASI(RPAREN), "RPAREN"); if len(r) > 0 { return r }
	r = check_true(TriggersASI(RETURN), "RETURN"); if len(r) > 0 { return r }
	r = check_true(TriggersASI(BREAK), "BREAK"); if len(r) > 0 { return r }
	r = check_true(TriggersASI(INC), "INC"); if len(r) > 0 { return r }
	r = check_false(TriggersASI(PLUS), "PLUS"); if len(r) > 0 { return r }
	r = check_false(TriggersASI(LBRACE), "LBRACE"); if len(r) > 0 { return r }
	r = check_false(TriggersASI(FUNC), "FUNC"); if len(r) > 0 { return r }
	r = check_false(TriggersASI(ASSIGN), "ASSIGN"); if len(r) > 0 { return r }
	return ""
}

func TestLookup() testing.TestResult {
	var r testing.TestResult
	r = check_type(Lookup("func"), FUNC, "func"); if len(r) > 0 { return r }
	r = check_type(Lookup("return"), RETURN, "return"); if len(r) > 0 { return r }
	r = check_type(Lookup("if"), IF, "if"); if len(r) > 0 { return r }
	r = check_type(Lookup("make"), MAKE, "make"); if len(r) > 0 { return r }
	r = check_type(Lookup("bit_cast"), BIT_CAST, "bit_cast"); if len(r) > 0 { return r }
	r = check_type(Lookup("len"), LEN, "len"); if len(r) > 0 { return r }
	r = check_type(Lookup("myVar"), IDENT, "myVar"); if len(r) > 0 { return r }
	r = check_type(Lookup("x"), IDENT, "x"); if len(r) > 0 { return r }
	r = check_type(Lookup(""), IDENT, "empty"); if len(r) > 0 { return r }
	return ""
}

func TestPosString() testing.TestResult {
	var r testing.TestResult
	var p Pos
	p.File = "test.bn"
	p.Line = 42
	p.Col = 7
	r = check_streq(PosString(p), "test.bn:42:7", "with file"); if len(r) > 0 { return r }

	var p2 Pos
	p2.Line = 10
	p2.Col = 3
	r = check_streq(PosString(p2), "10:3", "without file"); if len(r) > 0 { return r }
	return ""
}
