package "pkg/types"

import "pkg/builtin/testing"

func TestCheckVarDecl() testing.TestResult {
	var src []char = "package \"test\"\nvar x int = 42\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckVarDeclTypeMismatch() testing.TestResult {
	var src []char = "package \"test\"\nvar x bool = 42\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckStringVar() testing.TestResult {
	var src []char = "package \"test\"\nvar x string = \"hello\"\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckFuncDecl() testing.TestResult {
	var src []char = "package \"test\"\nfunc add(a int, b int) int { return a + b }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckFuncReturnTypeMismatch() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() int { return true }\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckUndefined() testing.TestResult {
	var src []char = "package \"test\"\nvar x int = y\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckConstDecl() testing.TestResult {
	var src []char = "package \"test\"\nconst x int = 42\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckConstGroup() testing.TestResult {
	var src []char = "package \"test\"\nconst (\n\tA int = iota\n\tB\n\tC\n)\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckTypeDecl() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { X int; Y int }\nfunc f() { var p Point; p.X = 1 }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}
