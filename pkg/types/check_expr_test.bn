package "pkg/types"

import "pkg/builtin/testing"

// ============================================================
// Expression Checking Tests
// ============================================================

func TestCheckBinaryExpr() testing.TestResult {
	var src []char = "package \"test\"\nvar x int = 1 + 2\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckBoolExpr() testing.TestResult {
	var src []char = "package \"test\"\nvar x bool = true && false\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckComparison() testing.TestResult {
	var src []char = "package \"test\"\nvar x bool = 1 < 2\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckUnaryNeg() testing.TestResult {
	var src []char = "package \"test\"\nvar x int = -42\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckUnaryNot() testing.TestResult {
	var src []char = "package \"test\"\nvar x bool = !true\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckSelectorUndefined() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { X int }\nfunc f() { var p Point; p.Z = 1 }\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckPointerDeref() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var p *int; var x int = *p }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckSliceIndex() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var s []int; var x int = s[0] }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckMakeBuiltin() testing.TestResult {
	var src []char = "package \"test\"\ntype Foo struct { X int }\nfunc f() { var p @Foo = make(Foo) }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckLenBuiltin() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var s []int; var n int = len(s) }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckCastBuiltin() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var x int = cast(int, 42) }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckCompositeLit() testing.TestResult {
	var src []char = "package \"test\"\ntype Point struct { X int; Y int }\nfunc f() { var p Point = Point{X: 1, Y: 2} }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckAppendBuiltin() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var s []int; s = append(s, 1) }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckStringConcat() testing.TestResult {
	var src []char = "package \"test\"\nvar x string = \"hello\" + \" world\"\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}
