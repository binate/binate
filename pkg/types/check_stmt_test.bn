package "pkg/types"

import "pkg/builtin/testing"

func TestCheckIfStmt() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { if true { var x int = 1 } }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckIfNonBoolCond() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { if 42 { } }\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckForLoop() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { for i := 0; i < 10; i++ { } }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckAssign() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var x int = 0; x = 1 }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckShortVarDecl() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { x := 42; var y int = x }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckIncDec() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var x int = 0; x++ }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckIncDecNonInt() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var x bool = true; x++ }\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckSwitchStmt() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { var x int = 1; switch x { case 1: case 2: } }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckReturnVoid() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { return }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckMultipleReturn() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() (int, bool) { return 1, true }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckReturnCountMismatch() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() (int, bool) { return 1 }\n"
	var c @Checker = checkSrc(src)
	return expectError(c)
}

func TestCheckBreakContinue() testing.TestResult {
	var src []char = "package \"test\"\nfunc f() { for i := 0; i < 10; i++ { break; continue } }\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}
