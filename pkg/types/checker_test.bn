package "pkg/types"

import "pkg/builtin/testing"
import "pkg/buf"


func TestNewChecker() testing.TestResult {
	var c @Checker = NewChecker()
	if c == nil { return fail("NewChecker returned nil") }
	if c.Scope == nil { return fail("expected universe scope") }
	return ""
}

func TestCheckerErrorsEmpty() testing.TestResult {
	var c @Checker = NewChecker()
	var errs @[]CheckError = CheckerErrors(c)
	if len(errs) != 0 { return fail("new checker should have no errors") }
	return ""
}

func TestUniverseScope() testing.TestResult {
	var s @Scope = universeScope()
	if s == nil { return fail("universe scope is nil") }
	// Should contain built-in types: int, bool, char, etc.
	var intSym @Symbol = Lookup(s, "int")
	if intSym == nil { return fail("int not in universe scope") }
	var boolSym @Symbol = Lookup(s, "bool")
	if boolSym == nil { return fail("bool not in universe scope") }
	return ""
}

func TestDefineAndLookup() testing.TestResult {
	var s @Scope = NewScope(nil)
	defineVar(s, buf.CopyStr("x"), TypInt())
	var sym @Symbol = Lookup(s, "x")
	if sym == nil { return fail("x not found after define") }
	if sym.Type == nil { return fail("x type is nil") }
	if sym.Type.Kind != TYP_INT { return fail("x should be int") }
	return ""
}

func TestScopeNesting() testing.TestResult {
	var outer @Scope = NewScope(nil)
	defineVar(outer, buf.CopyStr("a"), TypInt())
	var inner @Scope = NewScope(outer)
	defineVar(inner, buf.CopyStr("b"), TypBool())
	// Inner should see both a and b
	if Lookup(inner, "a") == nil { return fail("a not visible in inner") }
	if Lookup(inner, "b") == nil { return fail("b not visible in inner") }
	// Outer should only see a
	if Lookup(outer, "a") == nil { return fail("a not in outer") }
	if Lookup(outer, "b") != nil { return fail("b should not be in outer") }
	return ""
}
