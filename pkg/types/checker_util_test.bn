package "pkg/types"

import "pkg/token"
import "pkg/builtin/testing"


func TestCompoundToBase() testing.TestResult {
	if compoundToBase(cast(int, token.ADD_ASSIGN)) != cast(int, token.PLUS) {
		return fail("+= should map to +")
	}
	if compoundToBase(cast(int, token.SUB_ASSIGN)) != cast(int, token.MINUS) {
		return fail("-= should map to -")
	}
	if compoundToBase(cast(int, token.MUL_ASSIGN)) != cast(int, token.STAR) {
		return fail("*= should map to *")
	}
	return ""
}

func TestParseIntLiteral() testing.TestResult {
	if parseIntLiteral("0") != 0 { return fail("expected 0") }
	if parseIntLiteral("42") != 42 { return fail("expected 42") }
	if parseIntLiteral("0xFF") != 255 { return fail("expected 255 for 0xFF") }
	if parseIntLiteral("0o17") != 15 { return fail("expected 15 for 0o17") }
	if parseIntLiteral("0b1010") != 10 { return fail("expected 10 for 0b1010") }
	return ""
}

func TestDefaultType() testing.TestResult {
	var ut @Type = TypUntypedInt()
	var dt @Type = defaultType(ut)
	if dt.Kind != TYP_INT { return fail("untyped int should default to int") }

	var ub @Type = TypUntypedBool()
	var db @Type = defaultType(ub)
	if db.Kind != TYP_BOOL { return fail("untyped bool should default to bool") }

	var plain @Type = TypInt()
	if defaultType(plain).Kind != TYP_INT { return fail("typed int should stay int") }
	return ""
}

func TestStripQuotes() testing.TestResult {
	var s @[]char = stripQuotes("\"hello\"")
	if len(s) != 5 { return fail("expected len 5") }
	return ""
}
