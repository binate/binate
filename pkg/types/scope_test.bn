package "pkg/types"

import "pkg/builtin/testing"

// ============================================================
// Scope & Symbol Tests
// ============================================================

func TestScope() testing.TestResult {
	var s @Scope = NewScope(nil)
	var sym @Symbol = make(Symbol)
	sym.Name = "x"
	sym.Type = TypInt()
	sym.Kind = SYM_VAR
	Define(s, sym)

	var found @Symbol = Lookup(s, "x")
	if found == nil { return fail("lookup should find x") }
	if !Identical(found.Type, TypInt()) { return fail("x type wrong") }

	var notFound @Symbol = Lookup(s, "y")
	if !(notFound == nil) { return fail("y should not be found") }
	return ""
}

func TestScopeParent() testing.TestResult {
	var parent @Scope = NewScope(nil)
	var sym @Symbol = make(Symbol)
	sym.Name = "x"
	sym.Type = TypInt()
	sym.Kind = SYM_VAR
	Define(parent, sym)

	var child @Scope = NewScope(parent)
	var found @Symbol = Lookup(child, "x")
	if found == nil { return fail("should find x from parent") }

	// Shadow
	var sym2 @Symbol = make(Symbol)
	sym2.Name = "x"
	sym2.Type = TypBool()
	sym2.Kind = SYM_VAR
	Define(child, sym2)

	var shadowed @Symbol = Lookup(child, "x")
	if !Identical(shadowed.Type, TypBool()) { return fail("child should shadow parent") }

	// Parent unchanged
	var parentSym @Symbol = Lookup(parent, "x")
	if !Identical(parentSym.Type, TypInt()) { return fail("parent should be unchanged") }
	return ""
}

func TestFieldByName() testing.TestResult {
	var f1 @Field = make(Field)
	f1.Name = "X"
	f1.Type = TypInt()
	var f2 @Field = make(Field)
	f2.Name = "Y"
	f2.Type = TypBool()
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = f1
	fields[1] = f2
	var s @Type = MakeStructType("Point", fields)

	var found @Field = FieldByName(s, "Y")
	if found == nil { return fail("should find Y") }
	if !Identical(found.Type, TypBool()) { return fail("Y type wrong") }

	var notFound @Field = FieldByName(s, "Z")
	if !(notFound == nil) { return fail("Z should not be found") }
	return ""
}

// ============================================================
// Layout Tests
// ============================================================

func makeField(name @[]char, t @Type) @Field {
	var f @Field = make(Field)
	f.Name = name
	f.Type = t
	return f
}

func TestSizeOfPrimitives() testing.TestResult {
	if SizeOf(TypBool()) != 1 { return fail("bool size") }
	if SizeOf(TypInt8()) != 1 { return fail("int8 size") }
	if SizeOf(TypUint8()) != 1 { return fail("uint8 size") }
	if SizeOf(TypInt16()) != 2 { return fail("int16 size") }
	if SizeOf(TypUint16()) != 2 { return fail("uint16 size") }
	if SizeOf(TypInt32()) != 4 { return fail("int32 size") }
	if SizeOf(TypUint32()) != 4 { return fail("uint32 size") }
	if SizeOf(TypInt()) != 8 { return fail("int size") }
	if SizeOf(TypInt64()) != 8 { return fail("int64 size") }
	if SizeOf(TypUint64()) != 8 { return fail("uint64 size") }
	if SizeOf(TypString()) != 8 { return fail("string size") }
	return ""
}

func TestSizeOfPointers() testing.TestResult {
	if SizeOf(MakePointerType(TypInt())) != 8 { return fail("*int size") }
	if SizeOf(MakeManagedPtrType(TypInt())) != 8 { return fail("@int size") }
	return ""
}

func TestSizeOfSlice() testing.TestResult {
	if SizeOf(MakeSliceType(TypInt())) != 16 { return fail("[]int size") }
	if SizeOf(MakeSliceType(TypInt8())) != 16 { return fail("[]int8 size") }
	return ""
}

func TestSizeOfArray() testing.TestResult {
	if SizeOf(MakeArrayType(TypInt(), 5)) != 40 { return fail("[5]int size") }
	if SizeOf(MakeArrayType(TypInt8(), 10)) != 10 { return fail("[10]int8 size") }
	if SizeOf(MakeArrayType(TypInt(), 0)) != 0 { return fail("[0]int size") }
	return ""
}

func TestAlignOfPrimitives() testing.TestResult {
	if AlignOf(TypBool()) != 1 { return fail("bool align") }
	if AlignOf(TypInt8()) != 1 { return fail("int8 align") }
	if AlignOf(TypInt16()) != 2 { return fail("int16 align") }
	if AlignOf(TypInt32()) != 4 { return fail("int32 align") }
	if AlignOf(TypInt()) != 8 { return fail("int align") }
	if AlignOf(MakePointerType(TypInt())) != 8 { return fail("*int align") }
	if AlignOf(MakeSliceType(TypInt())) != 8 { return fail("[]int align") }
	return ""
}

func TestAlignOfArray() testing.TestResult {
	if AlignOf(MakeArrayType(TypInt(), 5)) != 8 { return fail("[5]int align") }
	if AlignOf(MakeArrayType(TypInt8(), 10)) != 1 { return fail("[10]int8 align") }
	if AlignOf(MakeArrayType(TypInt32(), 3)) != 4 { return fail("[3]int32 align") }
	return ""
}

func TestSizeOfUniformStruct() testing.TestResult {
	// struct { X int; Y int } — two 8-byte fields, no padding
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = makeField("X", TypInt())
	fields[1] = makeField("Y", TypInt())
	var s @Type = MakeStructType("TwoInts", fields)
	if SizeOf(s) != 16 { return fail("TwoInts size") }
	if AlignOf(s) != 8 { return fail("TwoInts align") }
	return ""
}

func TestSizeOfMixedStruct() testing.TestResult {
	// struct { a int8; b int64; c int8 }
	//   offset 0: a (1) + 7 padding
	//   offset 8: b (8)
	//   offset 16: c (1) + 7 trailing padding
	//   total: 24, align 8
	var fields @[]@Field = make_slice(@Field, 3)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", TypInt64())
	fields[2] = makeField("c", TypInt8())
	var s @Type = MakeStructType("Mixed", fields)
	if SizeOf(s) != 24 { return fail("Mixed size") }
	if AlignOf(s) != 8 { return fail("Mixed align") }
	return ""
}

func TestFieldOffsetUniform() testing.TestResult {
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = makeField("X", TypInt())
	fields[1] = makeField("Y", TypInt())
	var s @Type = MakeStructType("TwoInts", fields)
	if FieldOffset(s, 0) != 0 { return fail("X offset") }
	if FieldOffset(s, 1) != 8 { return fail("Y offset") }
	return ""
}

func TestFieldOffsetMixed() testing.TestResult {
	var fields @[]@Field = make_slice(@Field, 3)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", TypInt64())
	fields[2] = makeField("c", TypInt8())
	var s @Type = MakeStructType("Mixed", fields)
	if FieldOffset(s, 0) != 0 { return fail("a offset") }
	if FieldOffset(s, 1) != 8 { return fail("b offset") }
	if FieldOffset(s, 2) != 16 { return fail("c offset") }
	return ""
}

func TestFieldOffsetPackedSmall() testing.TestResult {
	// struct { a int8; b int8; c int16; d int32 }
	//   offset 0: a (1)
	//   offset 1: b (1)
	//   offset 2: c (2)
	//   offset 4: d (4)
	//   total: 8, align 4
	var fields @[]@Field = make_slice(@Field, 4)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", TypInt8())
	fields[2] = makeField("c", TypInt16())
	fields[3] = makeField("d", TypInt32())
	var s @Type = MakeStructType("Packed", fields)
	if FieldOffset(s, 0) != 0 { return fail("a offset") }
	if FieldOffset(s, 1) != 1 { return fail("b offset") }
	if FieldOffset(s, 2) != 2 { return fail("c offset") }
	if FieldOffset(s, 3) != 4 { return fail("d offset") }
	if SizeOf(s) != 8 { return fail("Packed size") }
	if AlignOf(s) != 4 { return fail("Packed align") }
	return ""
}

func TestSizeOfNestedStruct() testing.TestResult {
	// Inner: struct { x int; y int } — size 16, align 8
	var innerFields @[]@Field = make_slice(@Field, 2)
	innerFields[0] = makeField("x", TypInt())
	innerFields[1] = makeField("y", TypInt())
	var inner @Type = MakeStructType("Inner", innerFields)
	// Outer: struct { a int8; b Inner }
	//   offset 0: a (1) + 7 padding
	//   offset 8: b (16)
	//   total: 24, align 8
	var outerFields @[]@Field = make_slice(@Field, 2)
	outerFields[0] = makeField("a", TypInt8())
	outerFields[1] = makeField("b", inner)
	var outer @Type = MakeStructType("Outer", outerFields)
	if SizeOf(outer) != 24 { return fail("Outer size") }
	if FieldOffset(outer, 1) != 8 { return fail("b offset") }
	return ""
}

func TestSizeOfStructWithSlice() testing.TestResult {
	// struct { tag int8; data []int }
	//   offset 0: tag (1) + 7 padding
	//   offset 8: data (16)
	//   total: 24, align 8
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = makeField("tag", TypInt8())
	fields[1] = makeField("data", MakeSliceType(TypInt()))
	var s @Type = MakeStructType("Tagged", fields)
	if SizeOf(s) != 24 { return fail("Tagged size") }
	if FieldOffset(s, 1) != 8 { return fail("data offset") }
	return ""
}

func TestSizeOfEmptyStruct() testing.TestResult {
	var emptyFields @[]@Field
	var s @Type = MakeStructType("Empty", emptyFields)
	if SizeOf(s) != 0 { return fail("Empty size") }
	return ""
}

// ============================================================
// Target Tests (32-bit)
// ============================================================

func setTarget32() {
	var t TargetInfo
	t.PointerSize = 4
	t.IntSize = 4
	t.MaxAlign = 4
	SetTarget(t)
}

func setTarget64() {
	var t TargetInfo
	t.PointerSize = 8
	t.IntSize = 8
	t.MaxAlign = 8
	SetTarget(t)
}

func TestTarget32Primitives() testing.TestResult {
	setTarget32()
	// int/uint have explicit Width=64, so they stay 8 bytes regardless of target.
	// Making int target-sized (Width=0) is future work that requires updating
	// predeclared type initialization, type identity, IR width, and codegen.
	if SizeOf(TypInt()) != 8 { setTarget64(); return fail("int size 32") }
	if SizeOf(TypBool()) != 1 { setTarget64(); return fail("bool size 32") }
	if SizeOf(TypInt8()) != 1 { setTarget64(); return fail("int8 size 32") }
	if SizeOf(TypInt16()) != 2 { setTarget64(); return fail("int16 size 32") }
	if SizeOf(TypInt32()) != 4 { setTarget64(); return fail("int32 size 32") }
	if SizeOf(TypInt64()) != 8 { setTarget64(); return fail("int64 size 32") }
	if SizeOf(TypString()) != 4 { setTarget64(); return fail("string size 32") }
	setTarget64()
	return ""
}

func TestTarget32Pointers() testing.TestResult {
	setTarget32()
	if SizeOf(MakePointerType(TypInt())) != 4 { setTarget64(); return fail("*int size 32") }
	if SizeOf(MakeManagedPtrType(TypInt())) != 4 { setTarget64(); return fail("@int size 32") }
	if AlignOf(MakePointerType(TypInt())) != 4 { setTarget64(); return fail("*int align 32") }
	setTarget64()
	return ""
}

func TestTarget32Slices() testing.TestResult {
	setTarget32()
	if SizeOf(MakeSliceType(TypInt())) != 8 { setTarget64(); return fail("[]int size 32") }
	if SizeOf(MakeManagedSliceType(TypInt())) != 16 { setTarget64(); return fail("@[]int size 32") }
	if AlignOf(MakeSliceType(TypInt())) != 4 { setTarget64(); return fail("[]int align 32") }
	setTarget64()
	return ""
}

func TestTarget32StructLayout() testing.TestResult {
	setTarget32()
	// struct { a int8; b *int } on 32-bit:
	//   offset 0: a (1) + 3 padding
	//   offset 4: b (4)
	//   total: 8, align 4
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", MakePointerType(TypInt()))
	var s @Type = MakeStructType("S32", fields)
	if SizeOf(s) != 8 { setTarget64(); return fail("S32 size") }
	if AlignOf(s) != 4 { setTarget64(); return fail("S32 align") }
	if FieldOffset(s, 0) != 0 { setTarget64(); return fail("S32 a offset") }
	if FieldOffset(s, 1) != 4 { setTarget64(); return fail("S32 b offset") }
	setTarget64()
	return ""
}

func TestTarget32Func() testing.TestResult {
	setTarget32()
	var params @[]@Param
	var results @[]@Type
	var ft @Type = MakeFuncType(params, results)
	if SizeOf(ft) != 4 { setTarget64(); return fail("func size 32") }
	setTarget64()
	return ""
}

// ============================================================
// StructLayout Tests
// ============================================================

func TestStructLayoutUniform() testing.TestResult {
	// struct { X int; Y int } — no padding
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = makeField("X", TypInt())
	fields[1] = makeField("Y", TypInt())
	var s @Type = MakeStructType("TwoInts", fields)
	var layout @[]FieldLayout = StructLayout(s)
	if len(layout) != 2 { return fail("layout len") }
	if layout[0].Offset != 0 { return fail("X offset") }
	if layout[0].PaddingBefore != 0 { return fail("X padding") }
	if layout[0].Size != 8 { return fail("X size") }
	if layout[1].Offset != 8 { return fail("Y offset") }
	if layout[1].PaddingBefore != 0 { return fail("Y padding") }
	if TrailingPadding(s) != 0 { return fail("trailing") }
	return ""
}

func TestStructLayoutMixed() testing.TestResult {
	// struct { a int8; b int64; c int8 }
	//   a at 0 (1 byte), 7 padding, b at 8 (8 bytes), c at 16 (1 byte), 7 trailing
	var fields @[]@Field = make_slice(@Field, 3)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", TypInt64())
	fields[2] = makeField("c", TypInt8())
	var s @Type = MakeStructType("Mixed", fields)
	var layout @[]FieldLayout = StructLayout(s)
	if len(layout) != 3 { return fail("layout len") }
	if layout[0].Offset != 0 { return fail("a offset") }
	if layout[0].PaddingBefore != 0 { return fail("a padding") }
	if layout[0].Size != 1 { return fail("a size") }
	if layout[1].Offset != 8 { return fail("b offset") }
	if layout[1].PaddingBefore != 7 { return fail("b padding") }
	if layout[1].Size != 8 { return fail("b size") }
	if layout[2].Offset != 16 { return fail("c offset") }
	if layout[2].PaddingBefore != 0 { return fail("c padding") }
	if layout[2].Size != 1 { return fail("c size") }
	if TrailingPadding(s) != 7 { return fail("trailing") }
	return ""
}

func TestStructLayoutPacked() testing.TestResult {
	// struct { a int8; b int8; c int16; d int32 }
	//   a:0, b:1 (no pad), c:2 (no pad), d:4 (no pad), total 8, no trailing
	var fields @[]@Field = make_slice(@Field, 4)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", TypInt8())
	fields[2] = makeField("c", TypInt16())
	fields[3] = makeField("d", TypInt32())
	var s @Type = MakeStructType("Packed", fields)
	var layout @[]FieldLayout = StructLayout(s)
	if layout[0].PaddingBefore != 0 { return fail("a pad") }
	if layout[1].PaddingBefore != 0 { return fail("b pad") }
	if layout[2].PaddingBefore != 0 { return fail("c pad") }
	if layout[3].PaddingBefore != 0 { return fail("d pad") }
	if TrailingPadding(s) != 0 { return fail("trailing") }
	return ""
}

func TestStructLayoutEmpty() testing.TestResult {
	var emptyFields @[]@Field
	var s @Type = MakeStructType("Empty", emptyFields)
	var layout @[]FieldLayout = StructLayout(s)
	if len(layout) != 0 { return fail("empty should be empty") }
	if TrailingPadding(s) != 0 { return fail("trailing") }
	return ""
}

func TestStructLayout32Bit() testing.TestResult {
	setTarget32()
	// struct { a int8; b *int } on 32-bit:
	//   a at 0 (1 byte), 3 padding, b at 4 (4 bytes), total 8, no trailing
	var fields @[]@Field = make_slice(@Field, 2)
	fields[0] = makeField("a", TypInt8())
	fields[1] = makeField("b", MakePointerType(TypInt()))
	var s @Type = MakeStructType("S32", fields)
	var layout @[]FieldLayout = StructLayout(s)
	if layout[0].PaddingBefore != 0 { setTarget64(); return fail("a pad") }
	if layout[1].PaddingBefore != 3 { setTarget64(); return fail("b pad") }
	if layout[1].Offset != 4 { setTarget64(); return fail("b offset") }
	if layout[1].Size != 4 { setTarget64(); return fail("b size") }
	if TrailingPadding(s) != 0 { setTarget64(); return fail("trailing") }
	setTarget64()
	return ""
}

// ============================================================
// Composite Layout Tests
// ============================================================

func TestSliceLayout64() testing.TestResult {
	setTarget64()
	if SliceDataOffset() != 0 { return fail("data offset") }
	if SliceLenOffset() != 8 { return fail("len offset") }
	return ""
}

func TestSliceLayout32() testing.TestResult {
	setTarget32()
	if SliceDataOffset() != 0 { setTarget64(); return fail("data offset") }
	if SliceLenOffset() != 4 { setTarget64(); return fail("len offset") }
	setTarget64()
	return ""
}

func TestMSliceLayout64() testing.TestResult {
	setTarget64()
	if MSliceDataOffset() != 0 { return fail("data offset") }
	if MSliceLenOffset() != 8 { return fail("len offset") }
	if MSliceBackingOffset() != 16 { return fail("backing offset") }
	if MSliceBackingLenOffset() != 24 { return fail("backingLen offset") }
	return ""
}

func TestMSliceLayout32() testing.TestResult {
	setTarget32()
	if MSliceDataOffset() != 0 { setTarget64(); return fail("data offset") }
	if MSliceLenOffset() != 4 { setTarget64(); return fail("len offset") }
	if MSliceBackingOffset() != 8 { setTarget64(); return fail("backing offset") }
	if MSliceBackingLenOffset() != 12 { setTarget64(); return fail("backingLen offset") }
	setTarget64()
	return ""
}

func TestManagedHeader64() testing.TestResult {
	setTarget64()
	if ManagedHeaderSize() != 16 { return fail("header size") }
	if ManagedRefcountOffset() != -16 { return fail("refcount offset") }
	if ManagedFreeFnOffset() != -8 { return fail("free_fn offset") }
	return ""
}

func TestManagedHeader32() testing.TestResult {
	setTarget32()
	if ManagedHeaderSize() != 8 { setTarget64(); return fail("header size") }
	if ManagedRefcountOffset() != -8 { setTarget64(); return fail("refcount offset") }
	if ManagedFreeFnOffset() != -4 { setTarget64(); return fail("free_fn offset") }
	setTarget64()
	return ""
}

func TestTargetDefault64() testing.TestResult {
	// After resetting to 64-bit, ensure existing sizes are preserved
	setTarget64()
	if SizeOf(TypInt()) != 8 { return fail("int size after reset") }
	if SizeOf(MakePointerType(TypInt())) != 8 { return fail("*int size after reset") }
	if SizeOf(MakeSliceType(TypInt())) != 16 { return fail("[]int size after reset") }
	if SizeOf(MakeManagedSliceType(TypInt())) != 32 { return fail("@[]int size after reset") }
	return ""
}
