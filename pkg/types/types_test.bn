package "pkg/types"

import "pkg/token"
import "pkg/ast"
import "pkg/parser"
import "pkg/builtin/testing"
import "pkg/bootstrap"

// ============================================================
// Helpers
// ============================================================

func streq(a []char, b []char) bool {
	if len(a) != len(b) {
		return false
	}
	for i := 0; i < len(a); i++ {
		if a[i] != b[i] {
			return false
		}
	}
	return true
}

func fail(msgs []char) testing.TestResult {
	return msgs
}

// ============================================================
// Type Construction & Query Tests
// ============================================================

func TestPredeclaredTypes() testing.TestResult {
	var t @Type = TypInt()
	if t == nil { return fail("TypInt is nil") }
	if t.Kind != TYP_INT { return fail("TypInt kind wrong") }
	if !streq(t.Name, "int") { return fail("TypInt name wrong") }

	var b @Type = TypBool()
	if b == nil { return fail("TypBool is nil") }
	if b.Kind != TYP_BOOL { return fail("TypBool kind wrong") }

	var s @Type = TypString()
	if s == nil { return fail("TypString is nil") }
	if s.Kind != TYP_STRING { return fail("TypString kind wrong") }

	var v @Type = TypVoid()
	if v == nil { return fail("TypVoid is nil") }
	if v.Kind != TYP_VOID { return fail("TypVoid kind wrong") }

	return ""
}

func TestIntTypes() testing.TestResult {
	var t8 @Type = TypInt8()
	if t8.Width != 8 { return fail("int8 width wrong") }
	if !t8.Signed { return fail("int8 should be signed") }

	var u32 @Type = TypUint32()
	if u32.Width != 32 { return fail("uint32 width wrong") }
	if u32.Signed { return fail("uint32 should be unsigned") }

	return ""
}

func TestCharByteAlias() testing.TestResult {
	var ch @Type = TypChar()
	var by @Type = TypByte()
	var u8 @Type = TypUint8()
	if !Identical(ch, u8) { return fail("char should be uint8") }
	if !Identical(by, u8) { return fail("byte should be uint8") }
	return ""
}

func TestMakePointerType() testing.TestResult {
	var p @Type = MakePointerType(TypInt())
	if p.Kind != TYP_POINTER { return fail("kind wrong") }
	if !Identical(p.Elem, TypInt()) { return fail("elem wrong") }
	return ""
}

func TestMakeManagedPtrType() testing.TestResult {
	var p @Type = MakeManagedPtrType(TypInt())
	if p.Kind != TYP_MANAGED_PTR { return fail("kind wrong") }
	if !Identical(p.Elem, TypInt()) { return fail("elem wrong") }
	return ""
}

func TestMakeSliceType() testing.TestResult {
	var s @Type = MakeSliceType(TypInt())
	if s.Kind != TYP_SLICE { return fail("kind wrong") }
	if !Identical(s.Elem, TypInt()) { return fail("elem wrong") }
	return ""
}

func TestMakeArrayType() testing.TestResult {
	var a @Type = MakeArrayType(TypInt(), 10)
	if a.Kind != TYP_ARRAY { return fail("kind wrong") }
	if a.ArrayLen != 10 { return fail("length wrong") }
	return ""
}

func TestMakeStructType() testing.TestResult {
	var f1 @Field = make(Field)
	f1.Name = "X"
	f1.Type = TypInt()
	var f2 @Field = make(Field)
	f2.Name = "Y"
	f2.Type = TypBool()
	var fields []@Field
	fields = append(fields, f1)
	fields = append(fields, f2)
	var s @Type = MakeStructType("Point", fields)
	if s.Kind != TYP_STRUCT { return fail("kind wrong") }
	if len(s.Fields) != 2 { return fail("field count wrong") }
	return ""
}

func TestMakeFuncType() testing.TestResult {
	var p1 @Param = make(Param)
	p1.Name = "x"
	p1.Type = TypInt()
	var params []@Param
	params = append(params, p1)
	var results []@Type
	results = append(results, TypBool())
	var ft @Type = MakeFuncType(params, results)
	if ft.Kind != TYP_FUNC { return fail("kind wrong") }
	if len(ft.Params) != 1 { return fail("param count wrong") }
	if len(ft.Results) != 1 { return fail("result count wrong") }
	return ""
}

// ============================================================
// Type Query Tests
// ============================================================

func TestIsInteger() testing.TestResult {
	if !IsInteger(TypInt()) { return fail("int should be integer") }
	if !IsInteger(TypInt32()) { return fail("int32 should be integer") }
	if !IsInteger(TypUint64()) { return fail("uint64 should be integer") }
	if !IsInteger(TypUntypedInt()) { return fail("untyped int should be integer") }
	if IsInteger(TypBool()) { return fail("bool should not be integer") }
	if IsInteger(TypString()) { return fail("string should not be integer") }
	return ""
}

func TestIsBool() testing.TestResult {
	if !IsBool(TypBool()) { return fail("bool should be bool") }
	if !IsBool(TypUntypedBool()) { return fail("untyped bool should be bool") }
	if IsBool(TypInt()) { return fail("int should not be bool") }
	return ""
}

func TestIsPointer() testing.TestResult {
	if !IsPointer(MakePointerType(TypInt())) { return fail("*int should be pointer") }
	if !IsPointer(MakeManagedPtrType(TypInt())) { return fail("@int should be pointer") }
	if IsPointer(TypInt()) { return fail("int should not be pointer") }
	return ""
}

func TestIsSlice() testing.TestResult {
	if !IsSlice(MakeSliceType(TypInt())) { return fail("[]int should be slice") }
	if !IsSlice(MakeManagedSliceType(TypInt())) { return fail("@[]int should be slice") }
	if IsSlice(TypInt()) { return fail("int should not be slice") }
	return ""
}

func TestIsNillable() testing.TestResult {
	if !IsNillable(MakePointerType(TypInt())) { return fail("*int should be nillable") }
	if !IsNillable(MakeSliceType(TypInt())) { return fail("[]int should be nillable") }
	if IsNillable(TypInt()) { return fail("int should not be nillable") }
	return ""
}

func TestSliceElem() testing.TestResult {
	var s @Type = MakeSliceType(TypInt())
	var e @Type = SliceElem(s)
	if !Identical(e, TypInt()) { return fail("slice elem wrong") }
	if !(SliceElem(TypInt()) == nil) { return fail("non-slice should return nil") }
	return ""
}

func TestPointerElem() testing.TestResult {
	var p @Type = MakePointerType(TypBool())
	var e @Type = PointerElem(p)
	if !Identical(e, TypBool()) { return fail("pointer elem wrong") }
	if !(PointerElem(TypInt()) == nil) { return fail("non-pointer should return nil") }
	return ""
}

func TestIdentical() testing.TestResult {
	if !Identical(TypInt(), TypInt()) { return fail("int == int") }
	if Identical(TypInt(), TypBool()) { return fail("int != bool") }
	if !Identical(MakePointerType(TypInt()), MakePointerType(TypInt())) { return fail("*int == *int") }
	if Identical(MakePointerType(TypInt()), MakePointerType(TypBool())) { return fail("*int != *bool") }
	if !Identical(MakeSliceType(TypInt()), MakeSliceType(TypInt())) { return fail("[]int == []int") }
	if !Identical(MakeArrayType(TypInt(), 5), MakeArrayType(TypInt(), 5)) { return fail("[5]int == [5]int") }
	if Identical(MakeArrayType(TypInt(), 5), MakeArrayType(TypInt(), 10)) { return fail("[5]int != [10]int") }
	return ""
}

func TestAssignableTo() testing.TestResult {
	// Same types
	if !AssignableTo(TypInt(), TypInt()) { return fail("int to int") }
	// Untyped int to int
	if !AssignableTo(TypUntypedInt(), TypInt()) { return fail("untyped int to int") }
	if !AssignableTo(TypUntypedInt(), TypInt32()) { return fail("untyped int to int32") }
	// Untyped bool to bool
	if !AssignableTo(TypUntypedBool(), TypBool()) { return fail("untyped bool to bool") }
	// nil to pointer
	if !AssignableTo(TypNil(), MakePointerType(TypInt())) { return fail("nil to *int") }
	// nil to slice
	if !AssignableTo(TypNil(), MakeSliceType(TypInt())) { return fail("nil to []int") }
	// Managed to raw pointer
	if !AssignableTo(MakeManagedPtrType(TypInt()), MakePointerType(TypInt())) { return fail("@int to *int") }
	// String to []char
	if !AssignableTo(TypString(), MakeSliceType(TypChar())) { return fail("string to []char") }
	// []char to string
	if !AssignableTo(MakeSliceType(TypChar()), TypString()) { return fail("[]char to string") }
	// Not assignable
	if AssignableTo(TypInt(), TypBool()) { return fail("int to bool should fail") }
	return ""
}

func TestResolveAlias() testing.TestResult {
	var target @Type = TypInt()
	var alias @Type = MakeAliasType("MyInt", target)
	var resolved @Type = ResolveAlias(alias)
	if !Identical(resolved, target) { return fail("alias should resolve to target") }
	// Non-alias passthrough
	var plain @Type = TypBool()
	if !Identical(ResolveAlias(plain), plain) { return fail("non-alias should pass through") }
	return ""
}

func TestTypeName() testing.TestResult {
	if !streq(TypeName(TypInt()), "int") { return fail("int name") }
	if !streq(TypeName(TypBool()), "bool") { return fail("bool name") }
	if !streq(TypeName(MakePointerType(TypInt())), "*int") { return fail("*int name") }
	if !streq(TypeName(MakeManagedPtrType(TypInt())), "@int") { return fail("@int name") }
	if !streq(TypeName(MakeSliceType(TypInt())), "[]int") { return fail("[]int name") }
	if !streq(TypeName(nil), "nil") { return fail("nil name") }
	return ""
}

// ============================================================
// Scope & Symbol Tests
// ============================================================

func TestScope() testing.TestResult {
	var s @Scope = NewScope(nil)
	var sym @Symbol = make(Symbol)
	sym.Name = "x"
	sym.Type = TypInt()
	sym.Kind = SYM_VAR
	Define(s, sym)

	var found @Symbol = Lookup(s, "x")
	if found == nil { return fail("lookup should find x") }
	if !Identical(found.Type, TypInt()) { return fail("x type wrong") }

	var notFound @Symbol = Lookup(s, "y")
	if !(notFound == nil) { return fail("y should not be found") }
	return ""
}

func TestScopeParent() testing.TestResult {
	var parent @Scope = NewScope(nil)
	var sym @Symbol = make(Symbol)
	sym.Name = "x"
	sym.Type = TypInt()
	sym.Kind = SYM_VAR
	Define(parent, sym)

	var child @Scope = NewScope(parent)
	var found @Symbol = Lookup(child, "x")
	if found == nil { return fail("should find x from parent") }

	// Shadow
	var sym2 @Symbol = make(Symbol)
	sym2.Name = "x"
	sym2.Type = TypBool()
	sym2.Kind = SYM_VAR
	Define(child, sym2)

	var shadowed @Symbol = Lookup(child, "x")
	if !Identical(shadowed.Type, TypBool()) { return fail("child should shadow parent") }

	// Parent unchanged
	var parentSym @Symbol = Lookup(parent, "x")
	if !Identical(parentSym.Type, TypInt()) { return fail("parent should be unchanged") }
	return ""
}

func TestFieldByName() testing.TestResult {
	var f1 @Field = make(Field)
	f1.Name = "X"
	f1.Type = TypInt()
	var f2 @Field = make(Field)
	f2.Name = "Y"
	f2.Type = TypBool()
	var fields []@Field
	fields = append(fields, f1)
	fields = append(fields, f2)
	var s @Type = MakeStructType("Point", fields)

	var found @Field = FieldByName(s, "Y")
	if found == nil { return fail("should find Y") }
	if !Identical(found.Type, TypBool()) { return fail("Y type wrong") }

	var notFound @Field = FieldByName(s, "Z")
	if !(notFound == nil) { return fail("Z should not be found") }
	return ""
}

// ============================================================
// Layout Tests
// ============================================================

func TestSizeOfPrimitives() testing.TestResult {
	if SizeOf(TypBool()) != 1 { return fail("bool size") }
	if SizeOf(TypInt8()) != 1 { return fail("int8 size") }
	if SizeOf(TypUint8()) != 1 { return fail("uint8 size") }
	if SizeOf(TypInt16()) != 2 { return fail("int16 size") }
	if SizeOf(TypUint16()) != 2 { return fail("uint16 size") }
	if SizeOf(TypInt32()) != 4 { return fail("int32 size") }
	if SizeOf(TypUint32()) != 4 { return fail("uint32 size") }
	if SizeOf(TypInt()) != 8 { return fail("int size") }
	if SizeOf(TypInt64()) != 8 { return fail("int64 size") }
	if SizeOf(TypUint64()) != 8 { return fail("uint64 size") }
	if SizeOf(TypString()) != 8 { return fail("string size") }
	return ""
}

func TestSizeOfPointers() testing.TestResult {
	if SizeOf(MakePointerType(TypInt())) != 8 { return fail("*int size") }
	if SizeOf(MakeManagedPtrType(TypInt())) != 8 { return fail("@int size") }
	return ""
}

func TestSizeOfSlice() testing.TestResult {
	if SizeOf(MakeSliceType(TypInt())) != 16 { return fail("[]int size") }
	if SizeOf(MakeSliceType(TypInt8())) != 16 { return fail("[]int8 size") }
	return ""
}

func TestSizeOfArray() testing.TestResult {
	if SizeOf(MakeArrayType(TypInt(), 5)) != 40 { return fail("[5]int size") }
	if SizeOf(MakeArrayType(TypInt8(), 10)) != 10 { return fail("[10]int8 size") }
	if SizeOf(MakeArrayType(TypInt(), 0)) != 0 { return fail("[0]int size") }
	return ""
}

func TestAlignOfPrimitives() testing.TestResult {
	if AlignOf(TypBool()) != 1 { return fail("bool align") }
	if AlignOf(TypInt8()) != 1 { return fail("int8 align") }
	if AlignOf(TypInt16()) != 2 { return fail("int16 align") }
	if AlignOf(TypInt32()) != 4 { return fail("int32 align") }
	if AlignOf(TypInt()) != 8 { return fail("int align") }
	if AlignOf(MakePointerType(TypInt())) != 8 { return fail("*int align") }
	if AlignOf(MakeSliceType(TypInt())) != 8 { return fail("[]int align") }
	return ""
}

func TestAlignOfArray() testing.TestResult {
	if AlignOf(MakeArrayType(TypInt(), 5)) != 8 { return fail("[5]int align") }
	if AlignOf(MakeArrayType(TypInt8(), 10)) != 1 { return fail("[10]int8 align") }
	if AlignOf(MakeArrayType(TypInt32(), 3)) != 4 { return fail("[3]int32 align") }
	return ""
}

func makeField(name []char, t @Type) @Field {
	var f @Field = make(Field)
	f.Name = name
	f.Type = t
	return f
}

func TestSizeOfUniformStruct() testing.TestResult {
	// struct { X int; Y int } — two 8-byte fields, no padding
	var fields []@Field
	fields = append(fields, makeField("X", TypInt()))
	fields = append(fields, makeField("Y", TypInt()))
	var s @Type = MakeStructType("TwoInts", fields)
	if SizeOf(s) != 16 { return fail("TwoInts size") }
	if AlignOf(s) != 8 { return fail("TwoInts align") }
	return ""
}

func TestSizeOfMixedStruct() testing.TestResult {
	// struct { a int8; b int64; c int8 }
	//   offset 0: a (1) + 7 padding
	//   offset 8: b (8)
	//   offset 16: c (1) + 7 trailing padding
	//   total: 24, align 8
	var fields []@Field
	fields = append(fields, makeField("a", TypInt8()))
	fields = append(fields, makeField("b", TypInt64()))
	fields = append(fields, makeField("c", TypInt8()))
	var s @Type = MakeStructType("Mixed", fields)
	if SizeOf(s) != 24 { return fail("Mixed size") }
	if AlignOf(s) != 8 { return fail("Mixed align") }
	return ""
}

func TestFieldOffsetUniform() testing.TestResult {
	var fields []@Field
	fields = append(fields, makeField("X", TypInt()))
	fields = append(fields, makeField("Y", TypInt()))
	var s @Type = MakeStructType("TwoInts", fields)
	if FieldOffset(s, 0) != 0 { return fail("X offset") }
	if FieldOffset(s, 1) != 8 { return fail("Y offset") }
	return ""
}

func TestFieldOffsetMixed() testing.TestResult {
	var fields []@Field
	fields = append(fields, makeField("a", TypInt8()))
	fields = append(fields, makeField("b", TypInt64()))
	fields = append(fields, makeField("c", TypInt8()))
	var s @Type = MakeStructType("Mixed", fields)
	if FieldOffset(s, 0) != 0 { return fail("a offset") }
	if FieldOffset(s, 1) != 8 { return fail("b offset") }
	if FieldOffset(s, 2) != 16 { return fail("c offset") }
	return ""
}

func TestFieldOffsetPackedSmall() testing.TestResult {
	// struct { a int8; b int8; c int16; d int32 }
	//   offset 0: a (1)
	//   offset 1: b (1)
	//   offset 2: c (2)
	//   offset 4: d (4)
	//   total: 8, align 4
	var fields []@Field
	fields = append(fields, makeField("a", TypInt8()))
	fields = append(fields, makeField("b", TypInt8()))
	fields = append(fields, makeField("c", TypInt16()))
	fields = append(fields, makeField("d", TypInt32()))
	var s @Type = MakeStructType("Packed", fields)
	if FieldOffset(s, 0) != 0 { return fail("a offset") }
	if FieldOffset(s, 1) != 1 { return fail("b offset") }
	if FieldOffset(s, 2) != 2 { return fail("c offset") }
	if FieldOffset(s, 3) != 4 { return fail("d offset") }
	if SizeOf(s) != 8 { return fail("Packed size") }
	if AlignOf(s) != 4 { return fail("Packed align") }
	return ""
}

func TestSizeOfNestedStruct() testing.TestResult {
	// Inner: struct { x int; y int } — size 16, align 8
	var innerFields []@Field
	innerFields = append(innerFields, makeField("x", TypInt()))
	innerFields = append(innerFields, makeField("y", TypInt()))
	var inner @Type = MakeStructType("Inner", innerFields)
	// Outer: struct { a int8; b Inner }
	//   offset 0: a (1) + 7 padding
	//   offset 8: b (16)
	//   total: 24, align 8
	var outerFields []@Field
	outerFields = append(outerFields, makeField("a", TypInt8()))
	outerFields = append(outerFields, makeField("b", inner))
	var outer @Type = MakeStructType("Outer", outerFields)
	if SizeOf(outer) != 24 { return fail("Outer size") }
	if FieldOffset(outer, 1) != 8 { return fail("b offset") }
	return ""
}

func TestSizeOfStructWithSlice() testing.TestResult {
	// struct { tag int8; data []int }
	//   offset 0: tag (1) + 7 padding
	//   offset 8: data (16)
	//   total: 24, align 8
	var fields []@Field
	fields = append(fields, makeField("tag", TypInt8()))
	fields = append(fields, makeField("data", MakeSliceType(TypInt())))
	var s @Type = MakeStructType("Tagged", fields)
	if SizeOf(s) != 24 { return fail("Tagged size") }
	if FieldOffset(s, 1) != 8 { return fail("data offset") }
	return ""
}

func TestSizeOfEmptyStruct() testing.TestResult {
	var s @Type = MakeStructType("Empty", nil)
	if SizeOf(s) != 0 { return fail("Empty size") }
	return ""
}

// ============================================================
// Checker Integration Tests
// ============================================================

func toBytes(s []char) []uint8 {
	var b []uint8
	for i := 0; i < len(s); i++ {
		b = append(b, cast(uint8, s[i]))
	}
	return b
}

func checkSrc(src []char) @Checker {
	var p @parser.Parser = parser.New(toBytes(src), "test.bn")
	var file @ast.File = parser.ParseFile(p)
	var c @Checker = NewChecker()
	Check(c, file)
	return c
}

func expectNoErrors(c @Checker) testing.TestResult {
	var errs []CheckError = CheckerErrors(c)
	if len(errs) > 0 {
		var msg []char
		msg = appendChars(msg, "expected no errors, got ")
		msg = appendChars(msg, bootstrap.Itoa(len(errs)))
		msg = appendChars(msg, ": ")
		msg = appendChars(msg, errs[0].Msg)
		return msg
	}
	return ""
}

func expectError(c @Checker) testing.TestResult {
	var errs []CheckError = CheckerErrors(c)
	if len(errs) == 0 {
		return "expected errors but got none"
	}
	return ""
}

func TestCheckVarDecl() testing.TestResult {
	var src []char = "package \"test\"\nvar x int = 42\n"
	var c @Checker = checkSrc(src)
	return expectNoErrors(c)
}

func TestCheckVarDeclTypeMismatch() testing.TestResult {
	var src []char = "package \"test\"\nvar x bool = 42\n"
