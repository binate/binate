// ============================================================
// Additional Type Construction Tests
// ============================================================

func TestMakeManagedSliceType() testing.TestResult {
	var ms @Type = MakeManagedSliceType(TypInt())
	if ms.Kind != TYP_MANAGED_SLICE { return fail("kind should be managed_slice") }
	if ms.Elem == nil { return fail("elem should not be nil") }
	if ms.Elem.Kind != TYP_INT { return fail("elem should be int") }
	return ""
}

func TestMakeNamedType() testing.TestResult {
	var nt @Type = MakeNamedType("MyInt")
	if nt.Kind != TYP_NAMED { return fail("kind should be named") }
	if !streq(nt.Name, "MyInt") { return fail("name wrong") }
	// Underlying should be nil until set
	if nt.Underlying != nil { return fail("underlying should be nil initially") }
	// Set underlying and verify
	nt.Underlying = TypInt()
	if !Identical(nt.Underlying, TypInt()) { return fail("underlying should be int after set") }
	return ""
}

func TestIsNumeric() testing.TestResult {
	if !IsNumeric(TypInt()) { return fail("int should be numeric") }
	if !IsNumeric(TypInt32()) { return fail("int32 should be numeric") }
	if !IsNumeric(TypUint64()) { return fail("uint64 should be numeric") }
	if !IsNumeric(TypUntypedInt()) { return fail("untyped int should be numeric") }
	if IsNumeric(TypBool()) { return fail("bool should not be numeric") }
	if IsNumeric(TypString()) { return fail("string should not be numeric") }
	return ""
}
