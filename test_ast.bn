package "main"

import "pkg/ast"
import "pkg/token"

func main() {
	// Test kind name functions
	println("=== ExprKindName ===")
	println(ast.ExprKindName(ast.EXPR_IDENT))
	println(ast.ExprKindName(ast.EXPR_BINARY))
	println(ast.ExprKindName(ast.EXPR_CALL))
	println(ast.ExprKindName(99))

	println("=== StmtKindName ===")
	println(ast.StmtKindName(ast.STMT_IF))
	println(ast.StmtKindName(ast.STMT_FOR))
	println(ast.StmtKindName(ast.STMT_RETURN))

	println("=== DeclKindName ===")
	println(ast.DeclKindName(ast.DECL_FUNC))
	println(ast.DeclKindName(ast.DECL_VAR))

	println("=== TypeExprKindName ===")
	println(ast.TypeExprKindName(ast.TEXPR_NAMED))
	println(ast.TypeExprKindName(ast.TEXPR_SLICE))
	println(ast.TypeExprKindName(ast.TEXPR_POINTER))

	// Test constructing AST nodes
	println("=== Build Expr ===")
	var ident @ast.Expr = make(ast.Expr)
	ident.Kind = ast.EXPR_IDENT
	ident.Name = "x"
	println(ast.ExprKindName(ident.Kind))
	println(ident.Name)

	var lit @ast.Expr = make(ast.Expr)
	lit.Kind = ast.EXPR_INT_LIT
	lit.Name = "42"
	println(ast.ExprKindName(lit.Kind))
	println(lit.Name)

	// Build a binary expression: x + 42
	var binop @ast.Expr = make(ast.Expr)
	binop.Kind = ast.EXPR_BINARY
	binop.Op = cast(int, token.PLUS)
	binop.X = ident
	binop.Y = lit
	println(ast.ExprKindName(binop.Kind))

	// Test constructing a statement
	println("=== Build Stmt ===")
	var ret @ast.Stmt = make(ast.Stmt)
	ret.Kind = ast.STMT_RETURN
	ret.Exprs = append(ret.Exprs, binop)
	println(ast.StmtKindName(ret.Kind))
	println(len(ret.Exprs))

	// Test constructing a type expression
	println("=== Build TypeExpr ===")
	var intType @ast.TypeExpr = make(ast.TypeExpr)
	intType.Kind = ast.TEXPR_NAMED
	intType.Name = "int"
	println(ast.TypeExprKindName(intType.Kind))
	println(intType.Name)

	var sliceType @ast.TypeExpr = make(ast.TypeExpr)
	sliceType.Kind = ast.TEXPR_SLICE
	sliceType.Base = intType
	println(ast.TypeExprKindName(sliceType.Kind))
	println(sliceType.Base.Name)

	// Test constructing a function declaration
	println("=== Build Decl ===")
	var param @ast.ParamDecl = make(ast.ParamDecl)
	param.Name = "n"
	param.Type = intType

	var block @ast.Stmt = make(ast.Stmt)
	block.Kind = ast.STMT_BLOCK
	block.Stmts = append(block.Stmts, ret)

	var fn @ast.Decl = make(ast.Decl)
	fn.Kind = ast.DECL_FUNC
	fn.Name = "add"
	fn.Params = append(fn.Params, param)
	fn.Results = append(fn.Results, intType)
	fn.Body = block
	println(ast.DeclKindName(fn.Kind))
	println(fn.Name)
	println(len(fn.Params))
	println(fn.Params[0].Name)

	// Test File
	println("=== Build File ===")
	var imp @ast.ImportSpec = make(ast.ImportSpec)
	imp.Path = "pkg/token"

	var file @ast.File = make(ast.File)
	file.PkgName = "main"
	file.Imports = append(file.Imports, imp)
	file.Decls = append(file.Decls, fn)
	println(file.PkgName)
	println(len(file.Imports))
	println(file.Imports[0].Path)
	println(len(file.Decls))
	println(file.Decls[0].Name)

	println("PASS")
}
