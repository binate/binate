package "main"

import "pkg/token"

func main() {
	// Test TypeName for various token types
	println("=== TypeName ===")
	println(token.TypeName(token.ILLEGAL))
	println(token.TypeName(token.EOF))
	println(token.TypeName(token.SEMICOLON))
	println(token.TypeName(token.IDENT))
	println(token.TypeName(token.FUNC))
	println(token.TypeName(token.RETURN))
	println(token.TypeName(token.MAKE))
	println(token.TypeName(token.PLUS))
	println(token.TypeName(token.LBRACE))
	println(token.TypeName(token.ELLIPSIS))

	// Test IsKeyword
	println("=== IsKeyword ===")
	println(token.IsKeyword(token.FUNC))
	println(token.IsKeyword(token.MAKE))
	println(token.IsKeyword(token.PLUS))
	println(token.IsKeyword(token.IDENT))

	// Test IsBuiltin
	println("=== IsBuiltin ===")
	println(token.IsBuiltin(token.MAKE))
	println(token.IsBuiltin(token.LEN))
	println(token.IsBuiltin(token.FUNC))
	println(token.IsBuiltin(token.PLUS))

	// Test TriggersASI
	println("=== TriggersASI ===")
	println(token.TriggersASI(token.IDENT))
	println(token.TriggersASI(token.RBRACE))
	println(token.TriggersASI(token.RETURN))
	println(token.TriggersASI(token.PLUS))
	println(token.TriggersASI(token.LBRACE))

	// Test Lookup
	println("=== Lookup ===")
	println(token.TypeName(token.Lookup("func")))
	println(token.TypeName(token.Lookup("return")))
	println(token.TypeName(token.Lookup("make")))
	println(token.TypeName(token.Lookup("bit_cast")))
	println(token.TypeName(token.Lookup("myVar")))

	// Test PosString
	println("=== PosString ===")
	var p token.Pos
	p.File = "test.bn"
	p.Line = 42
	p.Col = 7
	println(token.PosString(p))

	var p2 token.Pos
	p2.Line = 10
	p2.Col = 3
	println(token.PosString(p2))

	println("PASS")
}
