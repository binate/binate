package "main"

import "pkg/token"

func main() {
	// Test type_name for various token types
	println("=== type_name ===")
	println(token.type_name(token.ILLEGAL))
	println(token.type_name(token.EOF))
	println(token.type_name(token.SEMICOLON))
	println(token.type_name(token.IDENT))
	println(token.type_name(token.FUNC))
	println(token.type_name(token.RETURN))
	println(token.type_name(token.MAKE))
	println(token.type_name(token.PLUS))
	println(token.type_name(token.LBRACE))
	println(token.type_name(token.ELLIPSIS))

	// Test is_keyword
	println("=== is_keyword ===")
	println(token.is_keyword(token.FUNC))
	println(token.is_keyword(token.MAKE))
	println(token.is_keyword(token.PLUS))
	println(token.is_keyword(token.IDENT))

	// Test is_builtin
	println("=== is_builtin ===")
	println(token.is_builtin(token.MAKE))
	println(token.is_builtin(token.LEN))
	println(token.is_builtin(token.FUNC))
	println(token.is_builtin(token.PLUS))

	// Test triggers_asi
	println("=== triggers_asi ===")
	println(token.triggers_asi(token.IDENT))
	println(token.triggers_asi(token.RBRACE))
	println(token.triggers_asi(token.RETURN))
	println(token.triggers_asi(token.PLUS))
	println(token.triggers_asi(token.LBRACE))

	// Test lookup
	println("=== lookup ===")
	println(token.type_name(token.lookup("func")))
	println(token.type_name(token.lookup("return")))
	println(token.type_name(token.lookup("make")))
	println(token.type_name(token.lookup("bit_cast")))
	println(token.type_name(token.lookup("myVar")))

	// Test pos_string
	println("=== pos_string ===")
	var p token.Pos
	p.file = "test.bn"
	p.line = 42
	p.col = 7
	println(token.pos_string(p))

	var p2 token.Pos
	p2.line = 10
	p2.col = 3
	println(token.pos_string(p2))

	println("PASS")
}
